// Benchmark: Stream Pipeline Processing (1M items)
// Mapanare -- uses built-in stream primitives with map/filter/fold
// Workload: stream -> map(*3) -> filter(even) -> fold(sum)

fn main() {
    let s = stream(0..1000000)
    let pipeline = s.map((x) => x * 3).filter((x) => x % 2 == 0)
    let total = sync pipeline.fold(0, (acc, x) => acc + x)
    print(total)
}
