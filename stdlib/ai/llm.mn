+fn system_msg(content: String) -> ChatMessage:
    da new ChatMessage {role: System(), content: content}

+fn user_msg(content: String) -> ChatMessage:
    da new ChatMessage {role: User(), content: content}

+fn assistant_msg(content: String) -> ChatMessage:
    da new ChatMessage {role: Assistant(), content: content}

+fn tool_msg(content: String) -> ChatMessage:
    da new ChatMessage {role: Tool(), content: content}

