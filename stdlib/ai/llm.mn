fn new_token_usage(input: Int, output: Int) -> TokenUsage:
    da new TokenUsage {input_tokens: input, output_tokens: output, total_tokens: input + output}

fn empty_usage() -> TokenUsage:
    da new TokenUsage {input_tokens: 0, output_tokens: 0, total_tokens: 0}

