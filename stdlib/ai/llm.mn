fn new_config(prov: Provider, key: String, model: String, host: String, port: Int, path: String) -> LLMConfig:
    da new LLMConfig {provider: prov, api_key: key, model: model, host: host, port: port, path: path, max_tokens: 4096, temperature: 0.7, system_prompt: "", has_system: false, timeout_ms: 120000, tools: [], has_tools: false}

