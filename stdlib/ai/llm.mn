+fn models_agree(responses: List<LLMResponse>) -> Bool:
    pon count: Int = len(responses)
    si count < 2 { da true }
    pon first: String = responses[0].content
    pon mut i: Int = 1
    mien i < count:
        si responses[i].content != first { da false }
        i = i + 1
    da true

+fn total_usage(responses: List<LLMResponse>) -> TokenUsage:
    pon count: Int = len(responses)
    pon mut in_total: Int = 0
    pon mut out_total: Int = 0
    pon mut i: Int = 0
    mien i < count:
        in_total = in_total + responses[i].usage.input_tokens
        out_total = out_total + responses[i].usage.output_tokens
        i = i + 1
    da new_token_usage(in_total, out_total)

+fn usage_summary(usage: TokenUsage) -> String:
    da "tokens: " + str(usage.input_tokens) + " in, " + str(usage.output_tokens) + " out, " + str(usage.total_tokens) + " total"

// ===========================================================================
// CONVERSATIONS — Multi-turn stateful chat sessions
//
// Ported from Prompture's Conversation pattern. Maintains message history
// across turns, enabling follow-up questions and context accumulation.
//
// Usage:
//   let mut conv = llm.new_conversation(config)
//   conv = llm.set_system_prompt(conv, "You are a helpful assistant.")
//   let r1 = llm.converse(conv, "What is Mapanare?")
//   match r1 { Ok(turn) => { conv = turn.conversation; print(turn.content) }, Err(e) => {} }
//   let r2 = llm.converse(conv, "Tell me more about its type system.")
//   match r2 { Ok(turn) => { print(turn.content) }, Err(e) => {} }
// ===========================================================================

+tipo Conversation:
    config: LLMConfig,
    history: List<ChatMessage>,
    total_usage: TokenUsage,
    turn_count: Int

+tipo TurnResult:
    content: String,
    response: LLMResponse,
    conversation: Conversation,
    turn_number: Int

+fn new_conversation(config: LLMConfig) -> Conversation:
    pon mut initial_history: List<ChatMessage> = []
    si config.has_system:
        initial_history = [system_msg(config.system_prompt)]
    da new Conversation {config: config, history: initial_history, total_usage: empty_usage(), turn_count: 0}

+fn set_system_prompt(conv: Conversation, system: String) -> Conversation:
    // Replace or prepend system message
    pon mut new_history: List<ChatMessage> = [system_msg(system)]
    pon count: Int = len(conv.history)
    pon mut i: Int = 0
    mien i < count:
        match conv.history[i].role:
            System => {},
            _ => { new_history = new_history + [conv.history[i]] }
        i = i + 1
    da new Conversation {config: conv.config, history: new_history, total_usage: conv.total_usage, turn_count: conv.turn_count}

+fn converse(conv: Conversation, prompt: String) -> Result<TurnResult, LLMError>:
    pon messages: List<ChatMessage> = conv.history + [user_msg(prompt)]
    pon result: Result<LLMResponse, LLMError> = chat(conv.config, messages)
    match result:
        Ok(resp) =>:
            pon new_history: List<ChatMessage> = messages + [assistant_msg(resp.content)]
            pon new_usage: TokenUsage = new_token_usage(conv.total_usage.input_tokens + resp.usage.input_tokens, conv.total_usage.output_tokens + resp.usage.output_tokens)
            pon new_conv: Conversation = new Conversation {config: conv.config, history: new_history, total_usage: new_usage, turn_count: conv.turn_count + 1}
            da Ok(new TurnResult {content: resp.content, response: resp, conversation: new_conv, turn_number: conv.turn_count + 1})
        Err(e) => { da Err(e) }

+fn conversation_history(conv: Conversation) -> List<ChatMessage>:
    da conv.history

+fn conversation_usage(conv: Conversation) -> TokenUsage:
    da conv.total_usage

// Trim conversation to last N user/assistant turns (keep system prompt)
+fn trim_history(conv: Conversation, max_turns: Int) -> Conversation:
    pon count: Int = len(conv.history)
    si count <= max_turns * 2 + 1 { da conv }

    pon mut trimmed: List<ChatMessage> = []
    // Keep system message if present
    si count > 0:
        match conv.history[0].role:
            System => { trimmed = [conv.history[0]] },
            _ => {}

    // Keep last max_turns * 2 messages (user + assistant pairs)
    pon start: Int = count - max_turns * 2
    pon mut i: Int = start
    si i < 0 { i = 0 }
    mien i < count:
        match conv.history[i].role:
            System => {},
            _ => { trimmed = trimmed + [conv.history[i]] }
        i = i + 1
    da new Conversation {config: conv.config, history: trimmed, total_usage: conv.total_usage, turn_count: conv.turn_count}

// ===========================================================================
// RETRY & FALLBACK — Automatic retry with model downgrade
//
// Ported from Prompture's BudgetPolicy + fallback_models pattern.
// On failure, automatically tries fallback models in order.
//
// Usage:
//   let configs = [llm.openai("sk-...", "gpt-4o"), llm.openai("sk-...", "gpt-4o-mini")]
//   let resp = llm.chat_with_fallback(configs, [llm.user_msg("Hello")])
// ===========================================================================

+tipo FallbackResult:
    response: LLMResponse,
    provider_index: Int,
    attempts: Int

+fn chat_with_fallback(configs: List<LLMConfig>, messages: List<ChatMessage>) -> Result<FallbackResult, LLMError>:
    pon count: Int = len(configs)
    pon mut last_error: LLMError = new_invalid_request("No configs provided")
    pon mut i: Int = 0
    mien i < count:
        pon result: Result<LLMResponse, LLMError> = chat(configs[i], messages)
        match result:
            Ok(resp) =>:
                da Ok(new FallbackResult {response: resp, provider_index: i, attempts: i + 1})
            Err(e) =>:
                last_error = e
        i = i + 1
    da Err(last_error)

+fn complete_with_fallback(configs: List<LLMConfig>, prompt: String) -> Result<FallbackResult, LLMError>:
    da chat_with_fallback(configs, [user_msg(prompt)])

// Retry same config N times before failing
+fn chat_with_retry(config: LLMConfig, messages: List<ChatMessage>, max_retries: Int) -> Result<LLMResponse, LLMError>:
    pon mut last_error: LLMError = new_invalid_request("No attempts")
    pon mut i: Int = 0
    mien i < max_retries:
        pon result: Result<LLMResponse, LLMError> = chat(config, messages)
        match result:
            Ok(resp) => { da Ok(resp) },
            Err(e) =>:
                // Don't retry auth errors or invalid requests
                match e:
                    AuthError(msg) => { da Err(e) },
                    InvalidRequest(msg) => { da Err(e) },
                    _ => { last_error = e }
        i = i + 1
    da Err(last_error)

// ===========================================================================
// REASONING STRATEGIES — Pure prompt augmentation
//
// Ported from Prompture's reasoning strategy system.
// Augments prompts with structured thinking frameworks.
// Zero extra LLM calls — just better prompts.
//
// Usage:
//   let resp = llm.reason(config, "plan_and_solve", "How should I design a cache?")
//   let resp = llm.reason(config, "self_discover", "Analyze this code for bugs: ...")
// ===========================================================================

fn plan_and_solve_prompt(prompt: String) -> String:
    pon mut augmented: String = "Let's approach this step by step using the Plan-and-Solve method.\n\n"
    augmented = augmented + "STEP 1 — DEVISE A PLAN: Before answering, outline a clear plan to solve this.\n"
    augmented = augmented + "STEP 2 — IDENTIFY KEY VARIABLES: What are the critical inputs, constraints, and unknowns?\n"
    augmented = augmented + "STEP 3 — LOCATE RELEVANT INFORMATION: What facts and context are needed?\n"
    augmented = augmented + "STEP 4 — VERIFY REASONING: Check each step cada logical errors.\n"
    augmented = augmented + "STEP 5 — ASSEMBLE FINAL ANSWER: Synthesize into a clear, complete response.\n\n"
    augmented = augmented + "QUESTION:\n" + prompt
    da augmented

fn self_discover_prompt(prompt: String) -> String:
    pon mut augmented: String = "Apply the following reasoning framework to answer:\n\n"
    augmented = augmented + "1. CRITICAL READING: Identify exactly what is being asked. Restate the question.\n"
    augmented = augmented + "2. DECOMPOSITION: Break the problem into sub-problems.\n"
    augmented = augmented + "3. EVIDENCE GROUNDING: For each claim, cite specific evidence or reasoning.\n"
    augmented = augmented + "4. TYPE CHECKING: Verify types and categories are consistent.\n"
    augmented = augmented + "5. SYNTHESIS: Combine sub-answers into a coherent response.\n\n"
    augmented = augmented + "QUESTION:\n" + prompt
    da augmented

fn chain_of_thought_prompt(prompt: String) -> String:
    da prompt + "\n\nLet's think through this step by step."

fn apply_reasoning(strategy: String, prompt: String) -> String:
    si strategy == "plan_and_solve" { da plan_and_solve_prompt(prompt) }
    si strategy == "self_discover" { da self_discover_prompt(prompt) }
    si strategy == "cot" { da chain_of_thought_prompt(prompt) }
    da prompt

+fn reason(config: LLMConfig, strategy: String, prompt: String) -> Result<LLMResponse, LLMError>:
    pon augmented: String = apply_reasoning(strategy, prompt)
    da complete(config, augmented)

+fn reason_chat(config: LLMConfig, strategy: String, messages: List<ChatMessage>) -> Result<LLMResponse, LLMError>:
    // Augment the last user message with reasoning strategy
    pon count: Int = len(messages)
    si count == 0 { da Err(new_invalid_request("No messages provided")) }

    pon mut augmented_msgs: List<ChatMessage> = []
    pon mut i: Int = 0
    mien i < count:
        si i == count - 1:
            match messages[i].role:
                User =>:
                    augmented_msgs = augmented_msgs + [user_msg(apply_reasoning(strategy, messages[i].content))]
                _ => { augmented_msgs = augmented_msgs + [messages[i]] }
        sino:
            augmented_msgs = augmented_msgs + [messages[i]]
        i = i + 1
    da chat(config, augmented_msgs)

// ===========================================================================
// SEQUENTIAL CHAINS — Thread output from one model to the next
//
// Ported from Prompture's SequentialGroup pattern.
// Each step's output becomes context for the next step.
//
// Usage:
//   let steps = [
//       llm.chain_step(analyst_config, "Analyze: {prompt}"),
//       llm.chain_step(writer_config, "Write a report based on: {previous}")
//   ]
//   let result = llm.run_chain(steps, "quarterly sales data")
// ===========================================================================

+tipo ChainStep:
    config: LLMConfig,
    prompt_template: String

+tipo ChainResult:
    final_content: String,
    steps: List<LLMResponse>,
    total_usage: TokenUsage

+fn chain_step(config: LLMConfig, prompt_template: String) -> ChainStep:
    da new ChainStep {config: config, prompt_template: prompt_template}

fn replace_placeholder(template: String, placeholder: String, value: String) -> String:
    // Simple template replacement: find {placeholder} and replace with value
    pon needle: String = "{" + placeholder + "}"
    pon needle_len: Int = len(needle)
    pon tlen: Int = len(template)
    pon mut result: String = ""
    pon mut i: Int = 0
    mien i < tlen:
        pon mut matched: Bool = true
        si i + needle_len <= tlen:
            pon mut j: Int = 0
            mien j < needle_len:
                si template.char_at(i + j) != needle.char_at(j):
                    matched = false
                    sal
                j = j + 1
        sino:
            matched = false

        si matched:
            result = result + value
            i = i + needle_len
        sino:
            result = result + template.char_at(i)
            i = i + 1
    da result

+fn run_chain(steps: List<ChainStep>, initial_prompt: String) -> Result<ChainResult, LLMError>:
    pon count: Int = len(steps)
    pon mut previous: String = ""
    pon mut responses: List<LLMResponse> = []
    pon mut in_total: Int = 0
    pon mut out_total: Int = 0

    pon mut i: Int = 0
    mien i < count:
        pon step: ChainStep = steps[i]
        pon mut prompt: String = step.prompt_template
        prompt = replace_placeholder(prompt, "prompt", initial_prompt)
        prompt = replace_placeholder(prompt, "previous", previous)
        prompt = replace_placeholder(prompt, "step", str(i + 1))

        pon result: Result<LLMResponse, LLMError> = complete(step.config, prompt)
        match result:
            Ok(resp) =>:
                previous = resp.content
                responses = responses + [resp]
                in_total = in_total + resp.usage.input_tokens
                out_total = out_total + resp.usage.output_tokens
            Err(e) => { da Err(e) }
        i = i + 1

    da Ok(new ChainResult {final_content: previous, steps: responses, total_usage: new_token_usage(in_total, out_total)})

// ===========================================================================
// CONSENSUS — Run same prompt across multiple models, compare results
//
// Ported from Prompture's ConsensusGroup pattern.
// Useful for high-stakes queries where you want agreement.
//
// Usage:
//   let configs = [llm.openai("sk-...", "gpt-4o"), llm.anthropic("sk-...", "claude-sonnet-4-20250514")]
//   let result = llm.consensus(configs, "What is 2+2?")
//   print("Agreed: " + str(result.all_agree))
//   print("Answer: " + result.best_answer)
// ===========================================================================

+tipo ConsensusResult:
    responses: List<LLMResponse>,
    all_agree: Bool,
    best_answer: String,
    total_usage: TokenUsage

+fn consensus(configs: List<LLMConfig>, prompt: String) -> Result<ConsensusResult, LLMError>:
    pon count: Int = len(configs)
    pon mut responses: List<LLMResponse> = []
    pon mut in_total: Int = 0
    pon mut out_total: Int = 0

    pon mut i: Int = 0
    mien i < count:
        pon result: Result<LLMResponse, LLMError> = complete(configs[i], prompt)
        match result:
            Ok(resp) =>:
                responses = responses + [resp]
                in_total = in_total + resp.usage.input_tokens
                out_total = out_total + resp.usage.output_tokens
            Err(e) => { da Err(e) }
        i = i + 1

    pon agree: Bool = models_agree(responses)
    pon mut best: String = ""
    si len(responses) > 0:
        best = responses[0].content

    // If models don't agree, pick the response from the model with most output tokens
    // (heuristic: longer = more thorough)
    si agree == false:
        pon mut best_len: Int = 0
        pon mut j: Int = 0
        mien j < len(responses):
            pon rlen: Int = len(responses[j].content)
            si rlen > best_len:
                best_len = rlen
                best = responses[j].content
            j = j + 1

    da Ok(new ConsensusResult {responses: responses, all_agree: agree, best_answer: best, total_usage: new_token_usage(in_total, out_total)})

+fn consensus_chat(configs: List<LLMConfig>, messages: List<ChatMessage>) -> Result<ConsensusResult, LLMError>:
    pon count: Int = len(configs)
    pon mut responses: List<LLMResponse> = []
    pon mut in_total: Int = 0
    pon mut out_total: Int = 0

    pon mut i: Int = 0
    mien i < count:
        pon result: Result<LLMResponse, LLMError> = chat(configs[i], messages)
        match result:
            Ok(resp) =>:
                responses = responses + [resp]
                in_total = in_total + resp.usage.input_tokens
                out_total = out_total + resp.usage.output_tokens
            Err(e) => { da Err(e) }
        i = i + 1

    pon agree: Bool = models_agree(responses)
    pon mut best: String = ""
    si len(responses) > 0 { best = responses[0].content }
    si agree == false:
        pon mut best_len: Int = 0
        pon mut j: Int = 0
        mien j < len(responses):
            si len(responses[j].content) > best_len:
                best_len = len(responses[j].content)
                best = responses[j].content
            j = j + 1

    da Ok(new ConsensusResult {responses: responses, all_agree: agree, best_answer: best, total_usage: new_token_usage(in_total, out_total)})

// ===========================================================================
// COST ESTIMATION — Per-model pricing (USD per 1M tokens)
//
// Ported from Prompture's model_rates system.
// Estimates cost without making API calls.
//
// Usage:
//   let cost = llm.estimate_cost("gpt-4o", 1000, 500)
//   print("Estimated: $" + str(cost))
// ===========================================================================

tipo ModelRate:
    input_rate: Float,
    output_rate: Float

fn new_rate(input_per_m: Float, output_per_m: Float) -> ModelRate:
    da new ModelRate {input_rate: input_per_m, output_rate: output_per_m}

fn get_model_rate(model: String) -> ModelRate:
    // Rates in USD per 1M tokens (as of 2025)
    // OpenAI
    si model == "gpt-4o" { da new_rate(2.5, 10.0) }
    si model == "gpt-4o-mini" { da new_rate(0.15, 0.6) }
    si model == "gpt-4-turbo" { da new_rate(10.0, 30.0) }
    si model == "gpt-4" { da new_rate(30.0, 60.0) }
    si model == "gpt-3.5-turbo" { da new_rate(0.5, 1.5) }
    si model == "o1" { da new_rate(15.0, 60.0) }
    si model == "o1-mini" { da new_rate(3.0, 12.0) }
    si model == "o3-mini" { da new_rate(1.1, 4.4) }
    // Anthropic
    si model == "claude-opus-4-20250514" { da new_rate(15.0, 75.0) }
    si model == "claude-sonnet-4-20250514" { da new_rate(3.0, 15.0) }
    si model == "claude-3-5-sonnet-20241022" { da new_rate(3.0, 15.0) }
    si model == "claude-3-5-haiku-20241022" { da new_rate(0.8, 4.0) }
    si model == "claude-3-opus-20240229" { da new_rate(15.0, 75.0) }
    si model == "claude-3-haiku-20240307" { da new_rate(0.25, 1.25) }
    // Google
    si model == "gemini-2.0-flash" { da new_rate(0.1, 0.4) }
    si model == "gemini-1.5-pro" { da new_rate(1.25, 5.0) }
    si model == "gemini-1.5-flash" { da new_rate(0.075, 0.3) }
    // Groq
    si model == "llama-3.1-70b-versatile" { da new_rate(0.59, 0.79) }
    si model == "llama-3.1-8b-instant" { da new_rate(0.05, 0.08) }
    si model == "mixtral-8x7b-32768" { da new_rate(0.24, 0.24) }
    // Ollama (free, local)
    da new_rate(0.0, 0.0)

+fn estimate_cost(model: String, input_tokens: Int, output_tokens: Int) -> Float:
    pon rate: ModelRate = get_model_rate(model)
    pon in_cost: Float = float(input_tokens) * rate.input_rate / 1000000.0
    pon out_cost: Float = float(output_tokens) * rate.output_rate / 1000000.0
    da in_cost + out_cost

+fn response_cost(resp: LLMResponse) -> Float:
    da estimate_cost(resp.model, resp.usage.input_tokens, resp.usage.output_tokens)

+fn cost_summary(resp: LLMResponse) -> String:
    pon cost: Float = response_cost(resp)
    da usage_summary(resp.usage) + ", cost: $" + str(cost)
