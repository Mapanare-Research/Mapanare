+fn make_chat_request(config: LLMConfig, messages: List<ChatMessage>) -> LLMRequest:
    da new LLMRequest {config: config, messages: messages}

+fn make_complete_request(config: LLMConfig, prompt: String) -> LLMRequest:
    da new LLMRequest {config: config, messages: [user_msg(prompt)]}

+fn execute_request(req: LLMRequest) -> Result<LLMResponse, LLMError>:
    da chat(req.config, req.messages)

// ---------------------------------------------------------------------------
// Multi-model helpers
