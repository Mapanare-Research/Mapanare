// ai/llm.mn — Native LLM Driver for Mapanare
//
// One import. Talk to any LLM. Built on C runtime TCP/TLS.
// Supports OpenAI, Anthropic, Groq, Ollama, and any OpenAI-compatible API.
//
// Usage:
//   import ai::llm
//
//   let config = llm.openai("sk-...", "gpt-4o")
//   let resp = llm.chat(config, [llm.user_msg("What is Mapanare?")])
//   match resp:
//       Ok(r) => { print(r.content) },
//       Err(e) => { print(llm.error_message(e)) }
//   }
//
// Multi-model composition with agents:
//   let gpt = spawn LLMAgent()
//   let claude = spawn LLMAgent()
//   gpt.request <- llm.make_chat_request(openai_config, [llm.user_msg(prompt)])
//   claude.request <- llm.make_chat_request(anthropic_config, [llm.user_msg(prompt)])
//   let r1 = sync gpt.response
//   let r2 = sync claude.response

// ---------------------------------------------------------------------------
// Extern C runtime functions (TCP + TLS from v0.8.0)
// ---------------------------------------------------------------------------

extern "C" fn __mn_net_init() -> Int
extern "C" fn __mn_tcp_connect_str(host: String, port: Int) -> Int
extern "C" fn __mn_tcp_send_str(fd: Int, data: String) -> Int
extern "C" fn __mn_tcp_recv_str(fd: Int, max_len: Int) -> String
extern "C" fn __mn_tcp_close_fd(fd: Int) -> Int
extern "C" fn __mn_tcp_set_timeout(fd: Int, ms: Int) -> Int
extern "C" fn __mn_tls_init() -> Int
extern "C" fn __mn_tls_connect_str(fd: Int, hostname: String) -> Int
extern "C" fn __mn_tls_write_str(tls_ctx: Int, data: String) -> Int
extern "C" fn __mn_tls_read_str(tls_ctx: Int, max_len: Int) -> String
extern "C" fn __mn_tls_close_fd(tls_ctx: Int, fd: Int) -> Int

usa text::string_utils

// ---------------------------------------------------------------------------
// Provider enum
// ---------------------------------------------------------------------------

+tipo Provider:
    | OpenAI
    | Anthropic
    | Groq
    | Ollama
    | Custom

fn provider_to_string(p: Provider) -> String:
    match p:
        OpenAI => { da "openai" },
        Anthropic => { da "anthropic" },
        Groq => { da "groq" },
        Ollama => { da "ollama" },
        Custom => { da "custom" }
    da "unknown"

// ---------------------------------------------------------------------------
// Message role enum
// ---------------------------------------------------------------------------

+tipo Role:
    | System
    | User
    | Assistant
    | Tool

fn role_to_string(r: Role) -> String:
    match r:
        System => { da "system" },
        User => { da "user" },
        Assistant => { da "assistant" },
        Tool => { da "tool" }
    da "user"

// ---------------------------------------------------------------------------
// Error enum
// ---------------------------------------------------------------------------

+tipo LLMError:
    | ApiError(String)
    | NetworkError(String)
    | ParseError(String)
    | AuthError(String)
    | RateLimited(String)
    | InvalidRequest(String)
    | Timeout(String)

fn new_api_error(msg: String) -> LLMError:
    da ApiError(msg)

fn new_network_error(msg: String) -> LLMError:
    da NetworkError(msg)

fn new_parse_error(msg: String) -> LLMError:
    da ParseError(msg)

fn new_auth_error(msg: String) -> LLMError:
    da AuthError(msg)

fn new_rate_limit_error(msg: String) -> LLMError:
    da RateLimited(msg)

fn new_invalid_request(msg: String) -> LLMError:
    da InvalidRequest(msg)

fn new_timeout_error(msg: String) -> LLMError:
    da Timeout(msg)

+fn error_message(e: LLMError) -> String:
    match e:
        ApiError(msg) => { da "API error: " + msg },
        NetworkError(msg) => { da "Network error: " + msg },
        ParseError(msg) => { da "Parse error: " + msg },
        AuthError(msg) => { da "Auth error: " + msg },
        RateLimited(msg) => { da "Rate limited: " + msg },
        InvalidRequest(msg) => { da "Invalid request: " + msg },
        Timeout(msg) => { da "Timeout: " + msg }
    da "Unknown error"

