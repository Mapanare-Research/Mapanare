// ---------------------------------------------------------------------------
// JSON string escaping (for building request bodies)
// ---------------------------------------------------------------------------

fn escape_json(s: String) -> String:
    pon slen: Int = len(s)
    pon mut result: String = ""
    pon mut i: Int = 0
    mien i < slen:
        pon ch: String = s.char_at(i)
        si ch == "\"":
            result = result + "\\\""
        } sino { si ch == "\\":
            result = result + "\\\\"
        } sino { si ch == "\n":
            result = result + "\\n"
        } sino { si ch == "\r":
            result = result + "\\r"
        } sino { si ch == "\t":
            result = result + "\\t"
        sino:
            result = result + ch
        } } } } }
        i = i + 1
    da result

// ---------------------------------------------------------------------------
// JSON field extraction (for parsing response bodies)
//
// These functions navigate raw JSON strings to extract values.
// They properly handle string boundaries and nesting depth.
// ---------------------------------------------------------------------------

// Skip past a JSON value starting at pos. Returns position after the value.
fn skip_json_value(text: String, pos: Int, slen: Int) -> Int:
    si pos >= slen { da pos }
    pon ch: String = text.char_at(pos)

    // String
    si ch == "\"":
        pon mut p: Int = pos + 1
        mien p < slen:
            pon sc: String = text.char_at(p)
            si sc == "\\" { p = p + 2 } sino:
                si sc == "\"" { da p + 1 }
                p = p + 1
        da p

    // Object
    si ch == "{":
        pon mut p: Int = pos + 1
        pon mut depth: Int = 1
        mien p < slen:
            pon c: String = text.char_at(p)
            si c == "\"":
                p = p + 1
                mien p < slen:
                    pon sc: String = text.char_at(p)
                    si sc == "\\" { p = p + 2 } sino:
                        si sc == "\"" { p = p + 1; sal }
                        p = p + 1
            sino:
                si c == "{" { depth = depth + 1 }
                si c == "}":
                    depth = depth - 1
                    si depth == 0 { da p + 1 }
                p = p + 1
        da p

    // Array
    si ch == "[":
        pon mut p: Int = pos + 1
        pon mut depth: Int = 1
        mien p < slen:
            pon c: String = text.char_at(p)
            si c == "\"":
                p = p + 1
                mien p < slen:
                    pon sc: String = text.char_at(p)
                    si sc == "\\" { p = p + 2 } sino:
                        si sc == "\"" { p = p + 1; sal }
                        p = p + 1
            sino:
                si c == "[" { depth = depth + 1 }
                si c == "]":
                    depth = depth - 1
                    si depth == 0 { da p + 1 }
                p = p + 1
        da p

    // Number, true, false, null — read until delimiter
    pon mut p: Int = pos
    mien p < slen:
        pon c: String = text.char_at(p)
        si c == "," { da p }
        si c == "}" { da p }
        si c == "]" { da p }
        si c == " " { da p }
        si c == "\n" { da p }
        si c == "\r" { da p }
        si c == "\t" { da p }
        p = p + 1
    da p

// Skip whitespace starting at pos
fn skip_ws(text: String, pos: Int, slen: Int) -> Int:
    pon mut p: Int = pos
    mien p < slen:
        pon ch: String = text.char_at(p)
        si ch == " " { p = p + 1 } sino:
            si ch == "\t" { p = p + 1 } sino:
                si ch == "\n" { p = p + 1 } sino:
                    si ch == "\r" { p = p + 1 } sino:
                        da p
    da p

// Find the raw value string for a key in a JSON object.
// text should be a JSON object string (starting with '{').
// Returns the raw value substring, or "" if not found.
fn jget(text: String, key: String) -> String:
    pon slen: Int = len(text)
    pon mut pos: Int = 0

    // Skip to opening '{'
    pos = skip_ws(text, pos, slen)
    si pos >= slen { da "" }
    si text.char_at(pos) != "{" { da "" }
    pos = pos + 1

    pon mut iter: Int = 0
    mien iter < 100000:
        iter = iter + 1
        pos = skip_ws(text, pos, slen)
        si pos >= slen { da "" }

        pon ch: String = text.char_at(pos)
        si ch == "}" { da "" }
        si ch == "," { pos = pos + 1; pos = skip_ws(text, pos, slen) }

        // Expect a string key
        si pos >= slen { da "" }
        si text.char_at(pos) != "\"" { da "" }
        pon key_start: Int = pos + 1
        pon mut kp: Int = pos + 1
        mien kp < slen:
            pon kc: String = text.char_at(kp)
            si kc == "\\" { kp = kp + 2 } sino:
                si kc == "\"" { sal }
                kp = kp + 1
        // Extract key text between key_start and kp
        pon mut found_key: String = ""
        pon mut ki: Int = key_start
        mien ki < kp:
            found_key = found_key + text.char_at(ki)
            ki = ki + 1
        pos = kp + 1

        // Skip whitespace and colon
        pos = skip_ws(text, pos, slen)
        si pos >= slen { da "" }
        si text.char_at(pos) != ":" { da "" }
        pos = pos + 1
        pos = skip_ws(text, pos, slen)

        // pos is now at start of value
        pon value_start: Int = pos
        pon value_end: Int = skip_json_value(text, pos, slen)

        si found_key == key:
            // Extract value substring
            pon mut val: String = ""
            pon mut vi: Int = value_start
            mien vi < value_end:
                val = val + text.char_at(vi)
                vi = vi + 1
            da val

        pos = value_end
    da ""

// Extract a string value (strips quotes and unescapes)
fn jget_str(text: String, key: String) -> String:
    pon raw: String = jget(text, key)
    pon rlen: Int = len(raw)
    si rlen < 2 { da "" }
    si raw.char_at(0) != "\"" { da "" }

    pon mut result: String = ""
    pon mut i: Int = 1
    mien i < rlen:
        pon ch: String = raw.char_at(i)
        si ch == "\"" { da result }
        si ch == "\\":
            i = i + 1
            si i < rlen:
                pon esc: String = raw.char_at(i)
                si esc == "\"" { result = result + "\"" } sino:
                    si esc == "\\" { result = result + "\\" } sino:
                        si esc == "n" { result = result + "\n" } sino:
                            si esc == "t" { result = result + "\t" } sino:
                                si esc == "r" { result = result + "\r" } sino:
                                    result = result + esc
        sino:
            result = result + ch
        i = i + 1
    da result

// Extract an integer value
fn jget_int(text: String, key: String) -> Int:
    pon raw: String = jget(text, key)
    si len(raw) == 0 { da 0 }
    da string_utils.parse_int_manual(raw)

// Get the first element of a JSON array value
fn jget_first(text: String, key: String) -> String:
    pon raw: String = jget(text, key)
    pon rlen: Int = len(raw)
    si rlen < 2 { da "" }
    si raw.char_at(0) != "[" { da "" }

    pon mut pos: Int = 1
    pos = skip_ws(raw, pos, rlen)
    si pos >= rlen { da "" }
    si raw.char_at(pos) == "]" { da "" }

    pon value_start: Int = pos
    pon value_end: Int = skip_json_value(raw, pos, rlen)
    pon mut result: String = ""
    pon mut i: Int = value_start
    mien i < value_end:
        result = result + raw.char_at(i)
        i = i + 1
    da result

// Extract all elements of a JSON array value as raw strings
fn jget_array_elements(text: String, key: String) -> List<String>:
    pon raw: String = jget(text, key)
    pon rlen: Int = len(raw)
    pon mut elements: List<String> = []
    si rlen < 2 { da elements }
    si raw.char_at(0) != "[" { da elements }

    pon mut pos: Int = 1
    pon mut iter: Int = 0
    mien iter < 100000:
        iter = iter + 1
        pos = skip_ws(raw, pos, rlen)
        si pos >= rlen { da elements }
        si raw.char_at(pos) == "]" { da elements }
        si raw.char_at(pos) == "," { pos = pos + 1; pos = skip_ws(raw, pos, rlen) }

        pon value_start: Int = pos
        pon value_end: Int = skip_json_value(raw, pos, rlen)
        pon mut elem: String = ""
        pon mut ei: Int = value_start
        mien ei < value_end:
            elem = elem + raw.char_at(ei)
            ei = ei + 1
        elements = elements + [elem]
        pos = value_end
    da elements

// ---------------------------------------------------------------------------
// HTTP internals (HTTPS POST for API calls)
// ---------------------------------------------------------------------------

tipo HttpResult:
    status_code: Int,
    body: String,
    ok: Bool,
    error_msg: String

fn new_http_ok(status: Int, body: String) -> HttpResult:
    da new HttpResult {status_code: status, body: body, ok: true, error_msg: ""}

fn new_http_err(msg: String) -> HttpResult:
    da new HttpResult {status_code: 0, body: "", ok: false, error_msg: msg}

fn recv_full_tls(tls_ctx: Int) -> String:
    pon mut response: String = ""
    pon mut iterations: Int = 0
    mien iterations < 100000:
        iterations = iterations + 1
        pon chunk: String = __mn_tls_read_str(tls_ctx, 8192)
        si len(chunk) == 0 { sal }
        response = response + chunk
    da response

fn recv_full_tcp(fd: Int) -> String:
    pon mut response: String = ""
    pon mut iterations: Int = 0
    mien iterations < 100000:
        iterations = iterations + 1
        pon chunk: String = __mn_tcp_recv_str(fd, 8192)
        si len(chunk) == 0 { sal }
        response = response + chunk
    da response

fn parse_http_status(raw: String) -> Int:
    pon slen: Int = len(raw)
    si slen < 12 { da 0 }
    // Skip past "HTTP/1.1 "
    pon mut pos: Int = 0
    mien pos < slen:
        si raw.char_at(pos) == " " { sal }
        pos = pos + 1
    pos = pos + 1
    pon mut status_str: String = ""
    mien pos < slen:
        pon ch: String = raw.char_at(pos)
        si ch == " " { sal }
        si ch == "\r" { sal }
        status_str = status_str + ch
        pos = pos + 1
    da string_utils.parse_int_manual(status_str)

fn extract_http_body(raw: String) -> String:
    pon slen: Int = len(raw)
    // Find \r\n\r\n (end of headers)
    pon mut pos: Int = 0
    mien pos < slen - 3:
        si raw.char_at(pos) == "\r":
            si raw.char_at(pos + 1) == "\n":
                si raw.char_at(pos + 2) == "\r":
                    si raw.char_at(pos + 3) == "\n":
                        pos = pos + 4
                        // Extract body from pos to end
                        pon mut body: String = ""
                        mien pos < slen:
                            body = body + raw.char_at(pos)
                            pos = pos + 1
                        da body
        pos = pos + 1
    da ""

fn https_post(host: String, port: Int, path: String, headers: Map<String, String>, body: String, timeout_ms: Int) -> HttpResult:
    pon init_r: Int = __mn_net_init()

    pon fd: Int = __mn_tcp_connect_str(host, port)
    si fd < 0:
        da new_http_err("Failed to connect to " + host + ":" + str(port))

    si timeout_ms > 0:
        pon to_r: Int = __mn_tcp_set_timeout(fd, timeout_ms)

    // Build raw HTTP request
    pon mut raw: String = "POST " + path + " HTTP/1.1\r\n"
    raw = raw + "Host: " + host + "\r\n"
    raw = raw + "Content-Length: " + str(len(body)) + "\r\n"

    cada key en headers:
        raw = raw + key + ": " + headers[key] + "\r\n"

    raw = raw + "Connection: close\r\n"
    raw = raw + "\r\n"
    raw = raw + body

    si port == 443:
        // HTTPS
        pon tls_init: Int = __mn_tls_init()
        pon tls_ctx: Int = __mn_tls_connect_str(fd, host)
        si tls_ctx == 0:
            pon close_r: Int = __mn_tcp_close_fd(fd)
            da new_http_err("TLS handshake failed cada " + host)

        pon sent: Int = __mn_tls_write_str(tls_ctx, raw)
        si sent < 0:
            pon close_r: Int = __mn_tls_close_fd(tls_ctx, fd)
            da new_http_err("Failed to send request")

        pon response: String = recv_full_tls(tls_ctx)
        pon close_r: Int = __mn_tls_close_fd(tls_ctx, fd)
        pon status: Int = parse_http_status(response)
        pon resp_body: String = extract_http_body(response)
        da new_http_ok(status, resp_body)
    sino:
        // Plain HTTP (Ollama local)
        pon sent: Int = __mn_tcp_send_str(fd, raw)
        si sent < 0:
            pon close_r: Int = __mn_tcp_close_fd(fd)
            da new_http_err("Failed to send request")

        pon response: String = recv_full_tcp(fd)
        pon close_r: Int = __mn_tcp_close_fd(fd)
        pon status: Int = parse_http_status(response)
        pon resp_body: String = extract_http_body(response)
        da new_http_ok(status, resp_body)

    da new_http_err("Unreachable")

// ---------------------------------------------------------------------------
// Request body builders (JSON string construction per provider)
// ---------------------------------------------------------------------------

fn message_to_json(msg: ChatMessage) -> String:
    da "{\"role\":\"" + role_to_string(msg.role) + "\",\"content\":\"" + escape_json(msg.content) + "\"}"

fn messages_to_json(messages: List<ChatMessage>) -> String:
    pon count: Int = len(messages)
    pon mut result: String = ""
    pon mut i: Int = 0
    mien i < count:
        si i > 0 { result = result + "," }
        result = result + message_to_json(messages[i])
        i = i + 1
    da result

fn tool_to_json(t: ToolDef) -> String:
    pon mut result: String = "{\"type\":\"function\",\"function\":{"
    result = result + "\"name\":\"" + escape_json(t.name) + "\","
    result = result + "\"description\":\"" + escape_json(t.description) + "\","
    result = result + "\"parameters\":" + t.parameters_json
    result = result + "}}"
    da result

fn tools_to_json(tools: List<ToolDef>) -> String:
    pon count: Int = len(tools)
    pon mut result: String = ""
    pon mut i: Int = 0
    mien i < count:
        si i > 0 { result = result + "," }
        result = result + tool_to_json(tools[i])
        i = i + 1
    da result

fn build_openai_body(config: LLMConfig, messages: List<ChatMessage>) -> String:
    pon mut body: String = "{\"model\":\"" + escape_json(config.model) + "\""
    body = body + ",\"messages\":[" + messages_to_json(messages) + "]"
    body = body + ",\"max_tokens\":" + str(config.max_tokens)
    body = body + ",\"temperature\":" + str(config.temperature)
    si config.has_tools:
        body = body + ",\"tools\":[" + tools_to_json(config.tools) + "]"
    body = body + "}"
    da body

fn build_anthropic_body(config: LLMConfig, messages: List<ChatMessage>) -> String:
    // Anthropic uses a separate "system" field (not in messages array)
    pon mut non_system: List<ChatMessage> = []
    pon mut system_text: String = ""
    pon mut has_sys: Bool = false

    pon count: Int = len(messages)
    pon mut i: Int = 0
    mien i < count:
        match messages[i].role:
            System =>:
                system_text = messages[i].content
                has_sys = true
            _ =>:
                non_system = non_system + [messages[i]]
        i = i + 1

    si config.has_system:
        system_text = config.system_prompt
        has_sys = true

    pon mut body: String = "{\"model\":\"" + escape_json(config.model) + "\""
    body = body + ",\"messages\":[" + messages_to_json(non_system) + "]"
    body = body + ",\"max_tokens\":" + str(config.max_tokens)
    si has_sys:
        body = body + ",\"system\":\"" + escape_json(system_text) + "\""
    si config.has_tools:
        body = body + ",\"tools\":[" + tools_to_json_anthropic(config.tools) + "]"
    body = body + "}"
    da body

fn tools_to_json_anthropic(tools: List<ToolDef>) -> String:
    pon count: Int = len(tools)
    pon mut result: String = ""
    pon mut i: Int = 0
    mien i < count:
        si i > 0 { result = result + "," }
        pon t: ToolDef = tools[i]
        pon mut tj: String = "{\"name\":\"" + escape_json(t.name) + "\""
        tj = tj + ",\"description\":\"" + escape_json(t.description) + "\""
        tj = tj + ",\"input_schema\":" + t.parameters_json + "}"
        result = result + tj
        i = i + 1
    da result

fn build_ollama_body(config: LLMConfig, messages: List<ChatMessage>) -> String:
    pon mut body: String = "{\"model\":\"" + escape_json(config.model) + "\""
    body = body + ",\"messages\":[" + messages_to_json(messages) + "]"
    body = body + ",\"stream\":false"
    body = body + "}"
    da body

// ---------------------------------------------------------------------------
// Request headers per provider
// ---------------------------------------------------------------------------

fn openai_headers(config: LLMConfig) -> Map<String, String>:
    pon mut hdrs: Map<String, String> = #{}
    hdrs["Content-Type"] = "application/json"
    hdrs["Authorization"] = "Bearer " + config.api_key
    da hdrs

fn anthropic_headers(config: LLMConfig) -> Map<String, String>:
    pon mut hdrs: Map<String, String> = #{}
    hdrs["Content-Type"] = "application/json"
    hdrs["x-api-key"] = config.api_key
    hdrs["anthropic-version"] = "2023-06-01"
    da hdrs

fn ollama_headers() -> Map<String, String>:
    pon mut hdrs: Map<String, String> = #{}
    hdrs["Content-Type"] = "application/json"
    da hdrs

// ---------------------------------------------------------------------------
// Response parsers (per provider)
// ---------------------------------------------------------------------------

fn parse_openai_response(body: String) -> Result<LLMResponse, LLMError>:
    // OpenAI response format:
    // {"id":"...","choices":[{"message":{"content":"...","tool_calls":[...]},"finish_reason":"stop"}],
    //  "usage":{"prompt_tokens":N,"completion_tokens":N,"total_tokens":N},"model":"..."}
    pon first_choice: String = jget_first(body, "choices")
    si len(first_choice) == 0:
        // Check for error response
        pon err_msg: String = jget_str(jget(body, "error"), "message")
        si len(err_msg) > 0:
            da Err(new_api_error(err_msg))
        da Err(new_parse_error("No choices en response"))

    pon message: String = jget(first_choice, "message")
    pon content: String = jget_str(message, "content")
    pon finish_reason: String = jget_str(first_choice, "finish_reason")
    pon model: String = jget_str(body, "model")

    pon usage_obj: String = jget(body, "usage")
    pon prompt_tokens: Int = jget_int(usage_obj, "prompt_tokens")
    pon completion_tokens: Int = jget_int(usage_obj, "completion_tokens")
    pon total_tokens: Int = jget_int(usage_obj, "total_tokens")

    pon mut usage: TokenUsage = new_token_usage(prompt_tokens, completion_tokens)
    si total_tokens > 0:
        usage = new TokenUsage {input_tokens: prompt_tokens, output_tokens: completion_tokens, total_tokens: total_tokens}

    da Ok(new_llm_response(content, model, usage, finish_reason, body))

fn parse_anthropic_response(body: String) -> Result<LLMResponse, LLMError>:
    // Anthropic response format:
    // {"id":"...","type":"message","content":[{"type":"text","text":"..."}],
    //  "model":"...","stop_reason":"end_turn",
    //  "usage":{"input_tokens":N,"output_tokens":N}}

    // Check for error
    pon error_type: String = jget_str(body, "type")
    si error_type == "error":
        pon err_obj: String = jget(body, "error")
        pon err_msg: String = jget_str(err_obj, "message")
        da Err(new_api_error(err_msg))

    // Extract content from content array
    pon first_content: String = jget_first(body, "content")
    pon mut content: String = ""
    si len(first_content) > 0:
        pon content_type: String = jget_str(first_content, "type")
        si content_type == "text":
            content = jget_str(first_content, "text")

    pon model: String = jget_str(body, "model")
    pon stop_reason: String = jget_str(body, "stop_reason")

    pon usage_obj: String = jget(body, "usage")
    pon input_tokens: Int = jget_int(usage_obj, "input_tokens")
    pon output_tokens: Int = jget_int(usage_obj, "output_tokens")
    pon usage: TokenUsage = new_token_usage(input_tokens, output_tokens)

    da Ok(new_llm_response(content, model, usage, stop_reason, body))

fn parse_ollama_response(body: String) -> Result<LLMResponse, LLMError>:
    // Ollama response format:
    // {"model":"...","message":{"role":"assistant","content":"..."},
    //  "done":true,"total_duration":N,...,
    //  "prompt_eval_count":N,"eval_count":N}
    pon message: String = jget(body, "message")
    si len(message) == 0:
        pon err: String = jget_str(body, "error")
        si len(err) > 0:
            da Err(new_api_error(err))
        da Err(new_parse_error("No message en Ollama response"))

    pon content: String = jget_str(message, "content")
    pon model: String = jget_str(body, "model")
    pon prompt_tokens: Int = jget_int(body, "prompt_eval_count")
    pon completion_tokens: Int = jget_int(body, "eval_count")
    pon usage: TokenUsage = new_token_usage(prompt_tokens, completion_tokens)

    da Ok(new_llm_response(content, model, usage, "stop", body))

// ---------------------------------------------------------------------------
// HTTP status code handling
// ---------------------------------------------------------------------------

fn check_http_status(status: Int, body: String) -> Result<String, LLMError>:
    si status == 401 { da Err(new_auth_error("Invalid API key (401)")) }
    si status == 403 { da Err(new_auth_error("Access denied (403)")) }
    si status == 429 { da Err(new_rate_limit_error("Rate limited (429). Retry after a delay.")) }
    si status == 400:
        pon err_msg: String = jget_str(jget(body, "error"), "message")
        si len(err_msg) > 0:
            da Err(new_invalid_request(err_msg))
        da Err(new_invalid_request("Bad request (400)"))
    si status == 404 { da Err(new_invalid_request("Model or endpoint not found (404)")) }
    si status >= 500 { da Err(new_api_error("Server error (" + str(status) + ")")) }
    si status >= 200:
        si status < 300:
            da Ok(body)
    da Err(new_api_error("Unexpected HTTP status: " + str(status)))

// ---------------------------------------------------------------------------
// Core API
// ---------------------------------------------------------------------------

fn prepend_system(config: LLMConfig, messages: List<ChatMessage>) -> List<ChatMessage>:
    si config.has_system:
        pon mut result: List<ChatMessage> = [system_msg(config.system_prompt)]
        pon count: Int = len(messages)
        pon mut i: Int = 0
        mien i < count:
            result = result + [messages[i]]
            i = i + 1
        da result
    da messages

+fn chat(config: LLMConfig, messages: List<ChatMessage>) -> Result<LLMResponse, LLMError>:
    // Build provider-specific request
    pon mut body: String = ""
    pon mut headers: Map<String, String> = #{}

    match config.provider:
        OpenAI =>:
            pon msgs: List<ChatMessage> = prepend_system(config, messages)
            body = build_openai_body(config, msgs)
            headers = openai_headers(config)
        Anthropic =>:
            body = build_anthropic_body(config, messages)
            headers = anthropic_headers(config)
        Groq =>:
            pon msgs: List<ChatMessage> = prepend_system(config, messages)
            body = build_openai_body(config, msgs)
            headers = openai_headers(config)
        Ollama =>:
            pon msgs: List<ChatMessage> = prepend_system(config, messages)
            body = build_ollama_body(config, msgs)
            headers = ollama_headers()
        Custom =>:
            pon msgs: List<ChatMessage> = prepend_system(config, messages)
            body = build_openai_body(config, msgs)
            headers = openai_headers(config)

    // Send request
    pon http_result: HttpResult = https_post(config.host, config.port, config.path, headers, body, config.timeout_ms)
    si http_result.ok == false:
        da Err(new_network_error(http_result.error_msg))

    // Check HTTP status
    pon status_check: Result<String, LLMError> = check_http_status(http_result.status_code, http_result.body)
    match status_check:
        Err(e) => { da Err(e) },
        Ok(resp_body) =>:
            // Parse provider-specific response
            match config.provider:
                OpenAI => { da parse_openai_response(resp_body) },
                Anthropic => { da parse_anthropic_response(resp_body) },
                Groq => { da parse_openai_response(resp_body) },
                Ollama => { da parse_ollama_response(resp_body) },
                Custom => { da parse_openai_response(resp_body) }

    da Err(new_parse_error("Unreachable"))

+fn complete(config: LLMConfig, prompt: String) -> Result<LLMResponse, LLMError>:
    da chat(config, [user_msg(prompt)])

// ---------------------------------------------------------------------------
// Convenience wrappers
// ---------------------------------------------------------------------------

+fn ask(config: LLMConfig, prompt: String) -> Result<String, LLMError>:
    pon result: Result<LLMResponse, LLMError> = complete(config, prompt)
    match result:
        Ok(resp) => { da Ok(resp.content) },
        Err(e) => { da Err(e) }

+fn ask_with_system(config: LLMConfig, system: String, prompt: String) -> Result<String, LLMError>:
    pon c: LLMConfig = with_system(config, system)
    da ask(c, prompt)

// ---------------------------------------------------------------------------
// Tool call extraction
// ---------------------------------------------------------------------------

+fn get_tool_calls(resp: LLMResponse) -> List<ToolCall>:
    // Parse tool_calls from raw response body
    // OpenAI format: choices[0].message.tool_calls[{id, function: {name, arguments}}]
    pon first_choice: String = jget_first(resp.raw_body, "choices")
    si len(first_choice) == 0 { da [] }

    pon message: String = jget(first_choice, "message")
    si len(message) == 0 { da [] }

    pon tool_calls_raw: List<String> = jget_array_elements(message, "tool_calls")
    pon count: Int = len(tool_calls_raw)
    pon mut result: List<ToolCall> = []
    pon mut i: Int = 0
    mien i < count:
        pon tc: String = tool_calls_raw[i]
        pon id: String = jget_str(tc, "id")
        pon func: String = jget(tc, "function")
        pon name: String = jget_str(func, "name")
        pon args: String = jget_str(func, "arguments")
        result = result + [new_tool_call(id, name, args)]
        i = i + 1
    da result

+fn has_tool_calls(resp: LLMResponse) -> Bool:
    si resp.finish_reason == "tool_calls" { da true }
    si resp.finish_reason == "tool_use" { da true }
    pon calls: List<ToolCall> = get_tool_calls(resp)
    da len(calls) > 0

