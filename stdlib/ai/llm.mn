    da new_config(Groq(), api_key, model, "api.groq.com", 443, "/openai/v1/chat/completions")

+fn ollama(model: String) -> LLMConfig:
    da new_config(Ollama(), "", model, "localhost", 11434, "/api/chat")

+fn ollama_at(host: String, port: Int, model: String) -> LLMConfig:
