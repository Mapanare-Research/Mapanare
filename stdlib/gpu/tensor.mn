// gpu/tensor.mn — GPU-Accelerated Tensor Operations for Mapanare
//
// Provides multi-dimensional tensor creation, element-wise arithmetic,
// matrix multiplication, reductions, reshaping, and device transfer.
// Operations dispatch to the appropriate GPU backend (CUDA/Metal/Vulkan)
// or fall back to CPU when no GPU is available.
//
// All heavy-lifting delegates to C runtime kernels (mapanare_tensor).
//
// Usage:
//   let a = tensor.zeros([3, 3])
//   let b = tensor.ones([3, 3])
//   let c = tensor.add(a, b)
//   let d = tensor.matmul(a, b)
//   let s = tensor.sum(c)

import gpu::device

// ---------------------------------------------------------------------------
// Extern C runtime functions
// ---------------------------------------------------------------------------

extern "C" fn __mn_tensor_alloc(size: Int, device_kind: Int) -> Int
extern "C" fn __mn_tensor_free(ptr: Int, device_kind: Int) -> Int
extern "C" fn __mn_tensor_zeros(ptr: Int, size: Int, device_kind: Int) -> Int
extern "C" fn __mn_tensor_ones(ptr: Int, size: Int, device_kind: Int) -> Int
extern "C" fn __mn_tensor_fill(ptr: Int, size: Int, value: Float, device_kind: Int) -> Int
extern "C" fn __mn_tensor_set(ptr: Int, index: Int, value: Float) -> Int
extern "C" fn __mn_tensor_get(ptr: Int, index: Int) -> Float
extern "C" fn __mn_tensor_add(dst: Int, a: Int, b: Int, size: Int, device_kind: Int) -> Int
extern "C" fn __mn_tensor_sub(dst: Int, a: Int, b: Int, size: Int, device_kind: Int) -> Int
extern "C" fn __mn_tensor_mul(dst: Int, a: Int, b: Int, size: Int, device_kind: Int) -> Int
extern "C" fn __mn_tensor_div(dst: Int, a: Int, b: Int, size: Int, device_kind: Int) -> Int
extern "C" fn __mn_tensor_matmul(dst: Int, a: Int, b: Int, m: Int, k: Int, n: Int, device_kind: Int) -> Int
extern "C" fn __mn_tensor_sum(ptr: Int, size: Int, device_kind: Int) -> Float
extern "C" fn __mn_tensor_max(ptr: Int, size: Int, device_kind: Int) -> Float
extern "C" fn __mn_tensor_min(ptr: Int, size: Int, device_kind: Int) -> Float
extern "C" fn __mn_tensor_copy(dst: Int, src: Int, size: Int) -> Int
extern "C" fn __mn_tensor_copy_to_device(dst_ptr: Int, src_ptr: Int, size: Int, dst_kind: Int, src_kind: Int) -> Int
extern "C" fn __mn_tensor_scale(ptr: Int, size: Int, scalar: Float, device_kind: Int) -> Int
extern "C" fn __mn_tensor_negate(dst: Int, src: Int, size: Int, device_kind: Int) -> Int
extern "C" fn __mn_tensor_abs(dst: Int, src: Int, size: Int, device_kind: Int) -> Int
extern "C" fn __mn_tensor_sqrt(dst: Int, src: Int, size: Int, device_kind: Int) -> Int
extern "C" fn __mn_tensor_exp(dst: Int, src: Int, size: Int, device_kind: Int) -> Int
extern "C" fn __mn_tensor_log(dst: Int, src: Int, size: Int, device_kind: Int) -> Int
extern "C" fn __mn_tensor_dot(a: Int, b: Int, size: Int, device_kind: Int) -> Float
extern "C" fn __mn_tensor_eq(a: Int, b: Int, size: Int) -> Int

// ---------------------------------------------------------------------------
// TensorError enum
// ---------------------------------------------------------------------------

pub enum TensorError {
    ShapeMismatch(String),
    InvalidShape(String),
    DeviceError(String),
    IndexOutOfBounds(String),
    AllocationFailed(String)
}

fn new_shape_mismatch(msg: String) -> TensorError {
    return ShapeMismatch(msg)
}

fn new_invalid_shape(msg: String) -> TensorError {
    return InvalidShape(msg)
}

fn new_device_error(msg: String) -> TensorError {
    return DeviceError(msg)
}

fn new_index_oob(msg: String) -> TensorError {
    return IndexOutOfBounds(msg)
}

fn new_alloc_failed(msg: String) -> TensorError {
    return AllocationFailed(msg)
}

// ---------------------------------------------------------------------------
// Tensor struct
// ---------------------------------------------------------------------------

pub struct Tensor {
    data: Int,
    shape: List<Int>,
    ndim: Int,
    size: Int,
    device: device.DeviceKind
}

// ---------------------------------------------------------------------------
// Internal helpers
// ---------------------------------------------------------------------------

/// Compute the total number of elements from a shape list.
fn compute_size(shape: List<Int>) -> Int {
    let mut total: Int = 1
    let mut i: Int = 0
    while i < len(shape) {
        total = total * shape[i]
        i = i + 1
    }
    return total
}

/// Validate that a shape has no zero or negative dimensions.
fn validate_shape(shape: List<Int>) -> Bool {
    if len(shape) == 0 {
        return false
    }
    let mut i: Int = 0
    while i < len(shape) {
        if shape[i] <= 0 {
            return false
        }
        i = i + 1
    }
    return true
}

/// Check whether two shapes are identical.
fn shapes_equal(a: List<Int>, b: List<Int>) -> Bool {
    if len(a) != len(b) {
        return false
    }
    let mut i: Int = 0
    while i < len(a) {
        if a[i] != b[i] {
            return false
        }
        i = i + 1
    }
    return true
}

/// Format a shape as a string for error messages.
fn shape_to_string(shape: List<Int>) -> String {
    let mut result: String = "["
    let mut i: Int = 0
    while i < len(shape) {
        if i > 0 {
            result = result + ", "
        }
        result = result + str(shape[i])
        i = i + 1
    }
    result = result + "]"
    return result
}

fn device_int(d: device.DeviceKind) -> Int {
    return device.device_kind_to_int(d)
}

/// Allocate a tensor with the given shape on the specified device.
fn alloc_tensor(shape: List<Int>, dev: device.DeviceKind) -> Result<Tensor, TensorError> {
    if validate_shape(shape) == false {
        return Err(new_invalid_shape("invalid shape: " + shape_to_string(shape)))
    }
    let total: Int = compute_size(shape)
    let ptr: Int = __mn_tensor_alloc(total, device_int(dev))
    if ptr == 0 {
        return Err(new_alloc_failed("failed to allocate tensor of size " + str(total)))
    }
    let t: Tensor = new Tensor { data: ptr, shape: shape, ndim: len(shape), size: total, device: dev }
    return Ok(t)
}

// ---------------------------------------------------------------------------
// Creation functions
// ---------------------------------------------------------------------------

/// Create a tensor filled with zeros.
@gpu
pub fn zeros(shape: List<Int>) -> Result<Tensor, TensorError> {
    let result: Result<Tensor, TensorError> = alloc_tensor(shape, device.CPU)
    match result {
        Ok(t) => {
            let rc: Int = __mn_tensor_zeros(t.data, t.size, device_int(t.device))
            if rc < 0 {
                return Err(new_device_error("zeros fill failed"))
            }
            return Ok(t)
        },
        Err(e) => { return Err(e) }
    }
    return Err(new_alloc_failed("unreachable"))
}

/// Create a tensor filled with ones.
@gpu
pub fn ones(shape: List<Int>) -> Result<Tensor, TensorError> {
    let result: Result<Tensor, TensorError> = alloc_tensor(shape, device.CPU)
    match result {
        Ok(t) => {
            let rc: Int = __mn_tensor_ones(t.data, t.size, device_int(t.device))
            if rc < 0 {
                return Err(new_device_error("ones fill failed"))
            }
            return Ok(t)
        },
        Err(e) => { return Err(e) }
    }
    return Err(new_alloc_failed("unreachable"))
}

/// Create a tensor filled with a constant value.
@gpu
pub fn full(shape: List<Int>, value: Float) -> Result<Tensor, TensorError> {
    let result: Result<Tensor, TensorError> = alloc_tensor(shape, device.CPU)
    match result {
        Ok(t) => {
            let rc: Int = __mn_tensor_fill(t.data, t.size, value, device_int(t.device))
            if rc < 0 {
                return Err(new_device_error("fill failed"))
            }
            return Ok(t)
        },
        Err(e) => { return Err(e) }
    }
    return Err(new_alloc_failed("unreachable"))
}

/// Create a tensor from a flat list of floats and a shape.
pub fn from_list(data: List<Float>, shape: List<Int>) -> Result<Tensor, TensorError> {
    if validate_shape(shape) == false {
        return Err(new_invalid_shape("invalid shape: " + shape_to_string(shape)))
    }
    let total: Int = compute_size(shape)
    if len(data) != total {
        return Err(new_shape_mismatch("data length " + str(len(data)) + " does not match shape " + shape_to_string(shape)))
    }
    let alloc_result: Result<Tensor, TensorError> = alloc_tensor(shape, device.CPU)
    match alloc_result {
        Ok(t) => {
            let mut i: Int = 0
            while i < total {
                __mn_tensor_set(t.data, i, data[i])
                i = i + 1
            }
            return Ok(t)
        },
        Err(e) => { return Err(e) }
    }
    return Err(new_alloc_failed("unreachable"))
}

/// Create an n x n identity matrix.
pub fn identity(n: Int) -> Result<Tensor, TensorError> {
    if n <= 0 {
        return Err(new_invalid_shape("identity matrix size must be positive"))
    }
    let shape: List<Int> = [n, n]
    let alloc_result: Result<Tensor, TensorError> = alloc_tensor(shape, device.CPU)
    match alloc_result {
        Ok(t) => {
            let rc: Int = __mn_tensor_zeros(t.data, t.size, device_int(t.device))
            if rc < 0 {
                return Err(new_device_error("zeros fill failed for identity"))
            }
            let mut i: Int = 0
            while i < n {
                let idx: Int = i * n + i
                __mn_tensor_set(t.data, idx, 1.0)
                i = i + 1
            }
            return Ok(t)
        },
        Err(e) => { return Err(e) }
    }
    return Err(new_alloc_failed("unreachable"))
}

/// Create a tensor of a given shape on a specific device.
@gpu
pub fn zeros_on(shape: List<Int>, dev: device.DeviceKind) -> Result<Tensor, TensorError> {
    let result: Result<Tensor, TensorError> = alloc_tensor(shape, dev)
    match result {
        Ok(t) => {
            let rc: Int = __mn_tensor_zeros(t.data, t.size, device_int(t.device))
            if rc < 0 {
                return Err(new_device_error("zeros fill failed on device"))
            }
            return Ok(t)
        },
        Err(e) => { return Err(e) }
    }
    return Err(new_alloc_failed("unreachable"))
}

// ---------------------------------------------------------------------------
// Element-wise arithmetic
// ---------------------------------------------------------------------------

/// Element-wise addition of two tensors.
@gpu
pub fn add(a: Tensor, b: Tensor) -> Result<Tensor, TensorError> {
    if shapes_equal(a.shape, b.shape) == false {
        return Err(new_shape_mismatch("add: shape " + shape_to_string(a.shape) + " vs " + shape_to_string(b.shape)))
    }
    let alloc_result: Result<Tensor, TensorError> = alloc_tensor(a.shape, a.device)
    match alloc_result {
        Ok(out) => {
            let rc: Int = __mn_tensor_add(out.data, a.data, b.data, a.size, device_int(a.device))
            if rc < 0 {
                return Err(new_device_error("add kernel failed"))
            }
            return Ok(out)
        },
        Err(e) => { return Err(e) }
    }
    return Err(new_alloc_failed("unreachable"))
}

/// Element-wise subtraction of two tensors.
@gpu
pub fn sub(a: Tensor, b: Tensor) -> Result<Tensor, TensorError> {
    if shapes_equal(a.shape, b.shape) == false {
        return Err(new_shape_mismatch("sub: shape " + shape_to_string(a.shape) + " vs " + shape_to_string(b.shape)))
    }
    let alloc_result: Result<Tensor, TensorError> = alloc_tensor(a.shape, a.device)
    match alloc_result {
        Ok(out) => {
            let rc: Int = __mn_tensor_sub(out.data, a.data, b.data, a.size, device_int(a.device))
            if rc < 0 {
                return Err(new_device_error("sub kernel failed"))
            }
            return Ok(out)
        },
        Err(e) => { return Err(e) }
    }
    return Err(new_alloc_failed("unreachable"))
}

/// Element-wise multiplication of two tensors.
@gpu
pub fn mul(a: Tensor, b: Tensor) -> Result<Tensor, TensorError> {
    if shapes_equal(a.shape, b.shape) == false {
        return Err(new_shape_mismatch("mul: shape " + shape_to_string(a.shape) + " vs " + shape_to_string(b.shape)))
    }
    let alloc_result: Result<Tensor, TensorError> = alloc_tensor(a.shape, a.device)
    match alloc_result {
        Ok(out) => {
            let rc: Int = __mn_tensor_mul(out.data, a.data, b.data, a.size, device_int(a.device))
            if rc < 0 {
                return Err(new_device_error("mul kernel failed"))
            }
            return Ok(out)
        },
        Err(e) => { return Err(e) }
    }
    return Err(new_alloc_failed("unreachable"))
}

/// Element-wise division of two tensors.
@gpu
pub fn div(a: Tensor, b: Tensor) -> Result<Tensor, TensorError> {
    if shapes_equal(a.shape, b.shape) == false {
        return Err(new_shape_mismatch("div: shape " + shape_to_string(a.shape) + " vs " + shape_to_string(b.shape)))
    }
    let alloc_result: Result<Tensor, TensorError> = alloc_tensor(a.shape, a.device)
    match alloc_result {
        Ok(out) => {
            let rc: Int = __mn_tensor_div(out.data, a.data, b.data, a.size, device_int(a.device))
            if rc < 0 {
                return Err(new_device_error("div kernel failed"))
            }
            return Ok(out)
        },
        Err(e) => { return Err(e) }
    }
    return Err(new_alloc_failed("unreachable"))
}

/// Scalar multiplication: multiply every element by a constant.
@gpu
pub fn scale(t: Tensor, scalar: Float) -> Result<Tensor, TensorError> {
    let alloc_result: Result<Tensor, TensorError> = alloc_tensor(t.shape, t.device)
    match alloc_result {
        Ok(out) => {
            let rc: Int = __mn_tensor_copy(out.data, t.data, t.size)
            if rc < 0 {
                return Err(new_device_error("copy failed in scale"))
            }
            let rc2: Int = __mn_tensor_scale(out.data, out.size, scalar, device_int(out.device))
            if rc2 < 0 {
                return Err(new_device_error("scale kernel failed"))
            }
            return Ok(out)
        },
        Err(e) => { return Err(e) }
    }
    return Err(new_alloc_failed("unreachable"))
}

/// Element-wise negation.
@gpu
pub fn negate(t: Tensor) -> Result<Tensor, TensorError> {
    let alloc_result: Result<Tensor, TensorError> = alloc_tensor(t.shape, t.device)
    match alloc_result {
        Ok(out) => {
            let rc: Int = __mn_tensor_negate(out.data, t.data, t.size, device_int(t.device))
            if rc < 0 {
                return Err(new_device_error("negate kernel failed"))
            }
            return Ok(out)
        },
        Err(e) => { return Err(e) }
    }
    return Err(new_alloc_failed("unreachable"))
}

