// ---------------------------------------------------------------------------
// Matrix operations
// ---------------------------------------------------------------------------

/// Matrix multiplication of two 2D tensors.
/// For a [M, K] * [K, N] operation, returns a [M, N] tensor.
@gpu
pub fn matmul(a: Tensor, b: Tensor) -> Result<Tensor, TensorError> {
    if a.ndim != 2 {
        return Err(new_shape_mismatch("matmul: first operand must be 2D, got " + shape_to_string(a.shape)))
    }
    if b.ndim != 2 {
        return Err(new_shape_mismatch("matmul: second operand must be 2D, got " + shape_to_string(b.shape)))
    }
    let m: Int = a.shape[0]
    let k1: Int = a.shape[1]
    let k2: Int = b.shape[0]
    let n: Int = b.shape[1]
    if k1 != k2 {
        return Err(new_shape_mismatch("matmul: inner dimensions mismatch: " + str(k1) + " vs " + str(k2)))
    }
    let out_shape: List<Int> = [m, n]
    let alloc_result: Result<Tensor, TensorError> = alloc_tensor(out_shape, a.device)
    match alloc_result {
        Ok(out) => {
            let rc: Int = __mn_tensor_matmul(out.data, a.data, b.data, m, k1, n, device_int(a.device))
            if rc < 0 {
                return Err(new_device_error("matmul kernel failed"))
            }
            return Ok(out)
        },
        Err(e) => { return Err(e) }
    }
    return Err(new_alloc_failed("unreachable"))
}

/// Dot product of two 1D tensors (vectors).
@gpu
pub fn dot(a: Tensor, b: Tensor) -> Result<Float, TensorError> {
    if a.ndim != 1 {
        return Err(new_shape_mismatch("dot: first operand must be 1D"))
    }
    if b.ndim != 1 {
        return Err(new_shape_mismatch("dot: second operand must be 1D"))
    }
    if a.size != b.size {
        return Err(new_shape_mismatch("dot: lengths must match: " + str(a.size) + " vs " + str(b.size)))
    }
    let result: Float = __mn_tensor_dot(a.data, b.data, a.size, device_int(a.device))
    return Ok(result)
}

// ---------------------------------------------------------------------------
// Reshaping and layout
// ---------------------------------------------------------------------------

/// Reshape a tensor to a new shape (same total number of elements).
pub fn reshape(t: Tensor, shape: List<Int>) -> Result<Tensor, TensorError> {
    if validate_shape(shape) == false {
        return Err(new_invalid_shape("invalid target shape: " + shape_to_string(shape)))
    }
    let new_size: Int = compute_size(shape)
    if new_size != t.size {
        return Err(new_shape_mismatch("reshape: size " + str(t.size) + " cannot reshape to " + shape_to_string(shape)))
    }
    // Reshape is a view operation — share data pointer, new shape metadata
    let reshaped: Tensor = new Tensor { data: t.data, shape: shape, ndim: len(shape), size: t.size, device: t.device }
    return Ok(reshaped)
}

/// Transpose a 2D matrix (swap rows and columns).
@gpu
pub fn transpose(t: Tensor) -> Result<Tensor, TensorError> {
    if t.ndim != 2 {
        return Err(new_shape_mismatch("transpose: requires 2D tensor, got " + shape_to_string(t.shape)))
    }
    let rows: Int = t.shape[0]
    let cols: Int = t.shape[1]
    let out_shape: List<Int> = [cols, rows]
    let alloc_result: Result<Tensor, TensorError> = alloc_tensor(out_shape, t.device)
    match alloc_result {
        Ok(out) => {
            // Manual transpose: out[j][i] = t[i][j]
            let mut i: Int = 0
            while i < rows {
                let mut j: Int = 0
                while j < cols {
                    let src_idx: Int = i * cols + j
                    let dst_idx: Int = j * rows + i
                    let val: Float = __mn_tensor_get(t.data, src_idx)
                    __mn_tensor_set(out.data, dst_idx, val)
                    j = j + 1
                }
                i = i + 1
            }
            return Ok(out)
        },
        Err(e) => { return Err(e) }
    }
    return Err(new_alloc_failed("unreachable"))
}

// ---------------------------------------------------------------------------
// Reductions
// ---------------------------------------------------------------------------

/// Sum of all elements in the tensor.
@gpu
pub fn sum(t: Tensor) -> Float {
    return __mn_tensor_sum(t.data, t.size, device_int(t.device))
}

/// Mean of all elements in the tensor.
@gpu
pub fn mean(t: Tensor) -> Float {
    let s: Float = __mn_tensor_sum(t.data, t.size, device_int(t.device))
    return s / float(t.size)
}

/// Maximum element in the tensor.
@gpu
pub fn max(t: Tensor) -> Float {
    return __mn_tensor_max(t.data, t.size, device_int(t.device))
}

/// Minimum element in the tensor.
@gpu
pub fn min(t: Tensor) -> Float {
    return __mn_tensor_min(t.data, t.size, device_int(t.device))
}

// ---------------------------------------------------------------------------
// Device transfer
// ---------------------------------------------------------------------------

/// Move a tensor to a different device (e.g., CPU -> CUDA).
@gpu
pub fn to_device(t: Tensor, dev: device.DeviceKind) -> Result<Tensor, TensorError> {
    let alloc_result: Result<Tensor, TensorError> = alloc_tensor(t.shape, dev)
    match alloc_result {
        Ok(out) => {
            let rc: Int = __mn_tensor_copy_to_device(out.data, t.data, t.size, device_int(dev), device_int(t.device))
            if rc < 0 {
                return Err(new_device_error("device transfer failed"))
            }
            return Ok(out)
        },
        Err(e) => { return Err(e) }
    }
    return Err(new_alloc_failed("unreachable"))
}

// ---------------------------------------------------------------------------
// Element access
// ---------------------------------------------------------------------------

/// Get the value at a flat index.
pub fn get(t: Tensor, index: Int) -> Result<Float, TensorError> {
    if index < 0 {
        return Err(new_index_oob("negative index: " + str(index)))
    }
    if index >= t.size {
        return Err(new_index_oob("index " + str(index) + " out of bounds for size " + str(t.size)))
    }
    let val: Float = __mn_tensor_get(t.data, index)
    return Ok(val)
}

/// Set the value at a flat index (mutates in-place).
pub fn set(t: Tensor, index: Int, value: Float) -> Result<Int, TensorError> {
    if index < 0 {
        return Err(new_index_oob("negative index: " + str(index)))
    }
    if index >= t.size {
        return Err(new_index_oob("index " + str(index) + " out of bounds for size " + str(t.size)))
    }
    __mn_tensor_set(t.data, index, value)
    return Ok(0)
}

/// Check element-wise equality of two tensors.
pub fn equal(a: Tensor, b: Tensor) -> Bool {
    if shapes_equal(a.shape, b.shape) == false {
        return false
    }
    let rc: Int = __mn_tensor_eq(a.data, b.data, a.size)
    return rc == 1
}

/// Free the memory backing a tensor.
pub fn free(t: Tensor) -> Result<Int, TensorError> {
    let rc: Int = __mn_tensor_free(t.data, device_int(t.device))
    if rc < 0 {
        return Err(new_device_error("failed to free tensor memory"))
    }
    return Ok(0)
}

/// Clone a tensor (deep copy to a new allocation).
pub fn clone(t: Tensor) -> Result<Tensor, TensorError> {
    let alloc_result: Result<Tensor, TensorError> = alloc_tensor(t.shape, t.device)
    match alloc_result {
        Ok(out) => {
            let rc: Int = __mn_tensor_copy(out.data, t.data, t.size)
            if rc < 0 {
                return Err(new_device_error("copy failed in clone"))
            }
            return Ok(out)
        },
        Err(e) => { return Err(e) }
    }
    return Err(new_alloc_failed("unreachable"))
}
