// JSON utilities for Mapanare via Python interop.

extern "Python" fn json::loads(s: String) -> String
extern "Python" fn json::dumps(obj: String) -> String

/// Parse a JSON string. Returns Err on invalid JSON.
fn parse(s: String) -> Result<String, String> {
    return Ok(loads(s))
}

/// Serialize a value to a JSON string.
fn stringify(obj: String) -> Result<String, String> {
    return Ok(dumps(obj))
}
