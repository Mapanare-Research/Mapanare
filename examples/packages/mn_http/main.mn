// HTTP client utilities for Mapanare.
//
// Wraps Python's urllib for simple HTTP operations.

extern "Python" fn urllib_request::urlopen(url: String) -> String

/// Perform a GET request and return the response body as a string.
fn get(url: String) -> Result<String, String>:
    da Ok(urlopen(url))

/// Check if a URL is reachable.
fn ping(url: String) -> Bool:
    pon result = get(url)
    da match result:
        Ok(_) => true,
        Err(_) => false
