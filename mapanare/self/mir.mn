// AgentSpawn
pub fn instr_agent_type(i: Instruction) -> MIRType {
    match i { AgentSpawn(_, t, _) => { return t }, _ => { return mir_void() } }
}
pub fn instr_agent_args(i: Instruction) -> List<Value> {
    match i { AgentSpawn(_, _, a) => { return a }, _ => { let empty: List<Value> = []; return empty } }
}

// AgentSend
pub fn instr_agentsend_agent(i: Instruction) -> Value {
    match i { AgentSend(a, _, _) => { return a }, _ => { return void_value() } }
}
pub fn instr_agentsend_channel(i: Instruction) -> String {
    match i { AgentSend(_, c, _) => { return c }, _ => { return "" } }
}
pub fn instr_agentsend_val(i: Instruction) -> Value {
    match i { AgentSend(_, _, v) => { return v }, _ => { return void_value() } }
}

// AgentSync
pub fn instr_agentsync_agent(i: Instruction) -> Value {
    match i { AgentSync(_, a, _) => { return a }, _ => { return void_value() } }
}
pub fn instr_agentsync_channel(i: Instruction) -> String {
    match i { AgentSync(_, _, c) => { return c }, _ => { return "" } }
}

// SignalInit
pub fn instr_signal_type(i: Instruction) -> MIRType {
    match i { SignalInit(_, t, _) => { return t }, _ => { return mir_void() } }
}
pub fn instr_signal_val(i: Instruction) -> Value {
    match i { SignalInit(_, _, v) => { return v }, _ => { return void_value() } }
}

// SignalGet
pub fn instr_signalget_sig(i: Instruction) -> Value {
    match i { SignalGet(_, s) => { return s }, _ => { return void_value() } }
}

// SignalSet
pub fn instr_signalset_sig(i: Instruction) -> Value {
    match i { SignalSet(s, _) => { return s }, _ => { return void_value() } }
}
pub fn instr_signalset_val(i: Instruction) -> Value {
    match i { SignalSet(_, v) => { return v }, _ => { return void_value() } }
}

// StreamOp
pub fn instr_streamop_kind(i: Instruction) -> StreamOpKind {
    match i { StreamOp(_, k, _, _) => { return k }, _ => { return StreamOpKind::Map } }
}
pub fn instr_streamop_source(i: Instruction) -> Value {
    match i { StreamOp(_, _, s, _) => { return s }, _ => { return void_value() } }
}
pub fn instr_streamop_args(i: Instruction) -> List<Value> {
    match i { StreamOp(_, _, _, a) => { return a }, _ => { let empty: List<Value> = []; return empty } }
}

// InterpConcat
pub fn instr_concat_parts(i: Instruction) -> List<Value> {
    match i { InterpConcat(_, p) => { return p }, _ => { let empty: List<Value> = []; return empty } }
}

// Phi
pub fn instr_phi_entries(i: Instruction) -> List<PhiEntry> {
    match i { Phi(_, e) => { return e }, _ => { let empty: List<PhiEntry> = []; return empty } }
}
