// WrapSome / WrapOk / WrapErr / Unwrap — all have (dest, val)
pub fn instr_wrap_val(i: Instruction) -> Value {
    match i {
        WrapSome(_, v) => { return v },
        WrapOk(_, v) => { return v },
        WrapErr(_, v) => { return v },
        Unwrap(_, v) => { return v },
        _ => { return void_value() }
    }
}

// WrapNone
pub fn instr_wrapnone_type(i: Instruction) -> MIRType {
    match i { WrapNone(_, t) => { return t }, _ => { return mir_void() } }
