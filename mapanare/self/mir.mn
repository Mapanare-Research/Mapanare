}
pub fn instr_fieldset_val(i: Instruction) -> Value {
    match i { FieldSet(_, _, v) => { return v }, _ => { return void_value() } }
}

// ListInit
pub fn instr_list_type(i: Instruction) -> MIRType {
    match i { ListInit(_, t, _) => { return t }, _ => { return mir_void() } }
}
pub fn instr_list_elements(i: Instruction) -> List<Value> {
    match i { ListInit(_, _, e) => { return e }, _ => { let empty: List<Value> = []; return empty } }
