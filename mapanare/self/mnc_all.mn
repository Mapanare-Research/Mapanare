// ===== lexer.mn =====
// lexer.mn — Mapanare lexer, self-hosted.
// Tokenizes .mn source files into a token stream.
// Character-by-character scanner replacing the Lark-based Python lexer.


// ---------------------------------------------------------------------------
// Token
// ---------------------------------------------------------------------------

struct Token {
    tok_type: String,
    value: String,
    line: Int,
    column: Int,
    end_line: Int,
    end_column: Int
}

// ---------------------------------------------------------------------------
// LexError
// ---------------------------------------------------------------------------

struct LexError {
    message: String,
    line: Int,
    column: Int,
    filename: String
}

// ---------------------------------------------------------------------------
// Lexer state
// ---------------------------------------------------------------------------

struct Lexer {
    source: String,
    pos: Int,
    line: Int,
    column: Int,
    filename: String
}

// ---------------------------------------------------------------------------
// Constructor functions
// ---------------------------------------------------------------------------

fn new_token(tok_type: String, value: String, line: Int, col: Int, end_line: Int, end_col: Int) -> Token {
    return new Token { tok_type: tok_type, value: value, line: line, column: col, end_line: end_line, end_column: end_col }
}

fn new_lexer(source: String, pos: Int, line: Int, column: Int, filename: String) -> Lexer {
    return new Lexer { source: source, pos: pos, line: line, column: column, filename: filename }
}

// ---------------------------------------------------------------------------
// Keywords (28 total)
// ---------------------------------------------------------------------------

fn is_keyword(name: String) -> Bool {
    if name == "let" { return true }
    if name == "mut" { return true }
    if name == "fn" { return true }
    if name == "return" { return true }
    if name == "pub" { return true }
    if name == "self" { return true }
    if name == "agent" { return true }
    if name == "spawn" { return true }
    if name == "sync" { return true }
    if name == "signal" { return true }
    if name == "stream" { return true }
    if name == "pipe" { return true }
    if name == "if" { return true }
    if name == "else" { return true }
    if name == "match" { return true }
    if name == "for" { return true }
    if name == "in" { return true }
    if name == "type" { return true }
    if name == "struct" { return true }
    if name == "enum" { return true }
    if name == "impl" { return true }
    if name == "import" { return true }
    if name == "export" { return true }
    if name == "true" { return true }
    if name == "false" { return true }
    if name == "none" { return true }
    if name == "new" { return true }
    if name == "input" { return true }
    if name == "output" { return true }
    return false
}

fn keyword_token_type(name: String) -> String {
    if name == "let" { return "KW_LET" }
    if name == "mut" { return "KW_MUT" }
    if name == "fn" { return "KW_FN" }
    if name == "return" { return "KW_RETURN" }
    if name == "pub" { return "KW_PUB" }
    if name == "self" { return "KW_SELF" }
    if name == "agent" { return "KW_AGENT" }
    if name == "spawn" { return "KW_SPAWN" }
    if name == "sync" { return "KW_SYNC" }
    if name == "signal" { return "KW_SIGNAL" }
    if name == "stream" { return "KW_STREAM" }
    if name == "pipe" { return "KW_PIPE" }
    if name == "if" { return "KW_IF" }
    if name == "else" { return "KW_ELSE" }
    if name == "match" { return "KW_MATCH" }
    if name == "for" { return "KW_FOR" }
    if name == "in" { return "KW_IN" }
    if name == "type" { return "KW_TYPE" }
    if name == "struct" { return "KW_STRUCT" }
    if name == "enum" { return "KW_ENUM" }
    if name == "impl" { return "KW_IMPL" }
    if name == "import" { return "KW_IMPORT" }
    if name == "export" { return "KW_EXPORT" }
    if name == "true" { return "KW_TRUE" }
    if name == "false" { return "KW_FALSE" }
    if name == "none" { return "KW_NONE" }
    if name == "new" { return "KW_NEW" }
    if name == "input" { return "KW_INPUT" }
    if name == "output" { return "KW_OUTPUT" }
    return "NAME"
}

// ---------------------------------------------------------------------------
// Character classification helpers
// ---------------------------------------------------------------------------

fn is_alpha(ch: String) -> Bool {
    if ch == "_" { return true }
    if ch >= "a" { if ch <= "z" { return true } }
    if ch >= "A" { if ch <= "Z" { return true } }
    return false
}

fn is_digit(ch: String) -> Bool {
    if ch >= "0" { if ch <= "9" { return true } }
    return false
}

fn is_alnum(ch: String) -> Bool {
    if is_alpha(ch) { return true }
    if is_digit(ch) { return true }
    return false
}

fn is_whitespace(ch: String) -> Bool {
    if ch == " " { return true }
    if ch == "\t" { return true }
    if ch == "\r" { return true }
    return false
}

fn is_hex_digit(ch: String) -> Bool {
    if is_digit(ch) { return true }
    if ch >= "a" { if ch <= "f" { return true } }
    if ch >= "A" { if ch <= "F" { return true } }
    return false
}

// ---------------------------------------------------------------------------
// Lexer helpers — use positional args, no struct literals
// ---------------------------------------------------------------------------

fn lexer_at_end(source: String, pos: Int) -> Bool {
    return pos >= len(source)
}

fn lexer_peek(source: String, pos: Int) -> String {
    if pos >= len(source) { return "" }
    return source.char_at(pos)
}

fn lexer_peek_at(source: String, pos: Int, offset: Int) -> String {
    let idx: Int = pos + offset
    if idx >= len(source) { return "" }
    return source.char_at(idx)
}

// ---------------------------------------------------------------------------
// Scan identifier / keyword
// ---------------------------------------------------------------------------

fn scan_ident(source: String, pos: Int, line: Int, col: Int) -> Token {
    let mut p: Int = pos
    let mut value: String = ""
    for _ in 0..10000 {
        if p >= len(source) { return new_token(keyword_token_type(value), value, line, col, line, col + len(value)) }
        let ch: String = source.char_at(p)
        if is_alnum(ch) {
            value = value + ch
            p = p + 1
        } else {
            return new_token(keyword_token_type(value), value, line, col, line, col + len(value))
        }
    }
    return new_token(keyword_token_type(value), value, line, col, line, col + len(value))
}

// ---------------------------------------------------------------------------
// Scan number literal
// ---------------------------------------------------------------------------

fn scan_number(source: String, pos: Int, line: Int, col: Int) -> Token {
    let mut p: Int = pos
    let mut value: String = ""
    let mut is_float: Bool = false
    let ch0: String = source.char_at(p)

    // Check 0x, 0b, 0o prefixes
    if ch0 == "0" {
        let ch1: String = lexer_peek(source, p + 1)
        if ch1 == "x" {
            value = "0x"
            p = p + 2
            for _ in 0..100 {
                if p >= len(source) { return new_token("HEX_INT", value, line, col, line, col + p - pos) }
                let hc: String = source.char_at(p)
                if is_hex_digit(hc) { value = value + hc } else { if hc != "_" { return new_token("HEX_INT", value, line, col, line, col + p - pos) } }
                p = p + 1
            }
            return new_token("HEX_INT", value, line, col, line, col + p - pos)
        }
        if ch1 == "b" {
            value = "0b"
            p = p + 2
            for _ in 0..100 {
                if p >= len(source) { return new_token("BIN_INT", value, line, col, line, col + p - pos) }
                let bc: String = source.char_at(p)
                if bc == "0" { value = value + bc } else { if bc == "1" { value = value + bc } else { if bc != "_" { return new_token("BIN_INT", value, line, col, line, col + p - pos) } } }
                p = p + 1
            }
            return new_token("BIN_INT", value, line, col, line, col + p - pos)
        }
        if ch1 == "o" {
            value = "0o"
            p = p + 2
            for _ in 0..100 {
                if p >= len(source) { return new_token("OCT_INT", value, line, col, line, col + p - pos) }
                let oc: String = source.char_at(p)
                if oc >= "0" { if oc <= "7" { value = value + oc } else { if oc != "_" { return new_token("OCT_INT", value, line, col, line, col + p - pos) } } } else { return new_token("OCT_INT", value, line, col, line, col + p - pos) }
                p = p + 1
            }
            return new_token("OCT_INT", value, line, col, line, col + p - pos)
        }
    }

    // Decimal / float
    for _ in 0..100 {
        if p >= len(source) {
            if is_float { return new_token("FLOAT_LIT", value, line, col, line, col + p - pos) }
            return new_token("DEC_INT", value, line, col, line, col + p - pos)
        }
        let dc: String = source.char_at(p)
        if is_digit(dc) {
            value = value + dc
            p = p + 1
        } else {
            if dc == "_" {
                p = p + 1
            } else {
                if dc == "." {
                    if lexer_peek(source, p + 1) == "." {
                        if is_float { return new_token("FLOAT_LIT", value, line, col, line, col + p - pos) }
                        return new_token("DEC_INT", value, line, col, line, col + p - pos)
                    }
                    is_float = true
                    value = value + "."
                    p = p + 1
                } else {
                    if is_float { return new_token("FLOAT_LIT", value, line, col, line, col + p - pos) }
                    return new_token("DEC_INT", value, line, col, line, col + p - pos)
                }
            }
        }
    }
    if is_float { return new_token("FLOAT_LIT", value, line, col, line, col + p - pos) }
    return new_token("DEC_INT", value, line, col, line, col + p - pos)
}

// ---------------------------------------------------------------------------
// Scan string literal
// ---------------------------------------------------------------------------

fn scan_string(source: String, pos: Int, line: Int, col: Int) -> Token {
    let mut p: Int = pos + 1
    let mut value: String = ""
    let mut cur_line: Int = line
    for _ in 0..100000 {
        if p >= len(source) { return new_token("STRING_LIT", value, line, col, cur_line, col + p - pos) }
        let ch: String = source.char_at(p)
        if ch == "\"" {
            p = p + 1
            return new_token("STRING_LIT", value, line, col, cur_line, col + p - pos)
        }
        if ch == "\\" {
            p = p + 1
            if p >= len(source) { return new_token("STRING_LIT", value, line, col, cur_line, col + p - pos) }
            let esc: String = source.char_at(p)
            if esc == "n" { value = value + "\n" }
            if esc == "t" { value = value + "\t" }
            if esc == "r" { value = value + "\r" }
            if esc == "\\" { value = value + "\\" }
            if esc == "\"" { value = value + "\"" }
            if esc == "0" { value = value + "\0" }
            if esc == "$" { value = value + "$" }
            p = p + 1
        } else {
            if ch == "\n" { cur_line = cur_line + 1 }
            value = value + ch
            p = p + 1
        }
    }
    return new_token("STRING_LIT", value, line, col, cur_line, col + p - pos)
}

// ---------------------------------------------------------------------------
// Scan char literal
// ---------------------------------------------------------------------------

fn scan_char(source: String, pos: Int, line: Int, col: Int) -> Token {
    let mut p: Int = pos + 1
    let mut value: String = ""
    if p >= len(source) { return new_token("CHAR_LIT", "", line, col, line, col + 2) }
    let ch: String = source.char_at(p)
    if ch == "\\" {
        p = p + 1
        let esc: String = source.char_at(p)
        if esc == "n" { value = "\n" }
        if esc == "t" { value = "\t" }
        if esc == "\\" { value = "\\" }
        if esc == "'" { value = "'" }
        p = p + 1
    } else {
        value = ch
        p = p + 1
    }
    if p < len(source) { if source.char_at(p) == "'" { p = p + 1 } }
    return new_token("CHAR_LIT", value, line, col, line, col + p - pos)
}

// ---------------------------------------------------------------------------
// Scan operator / punctuation — returns token + its width
// ---------------------------------------------------------------------------

fn scan_op(source: String, pos: Int, line: Int, col: Int) -> Token {
    let ch: String = source.char_at(pos)
    let ch1: String = lexer_peek(source, pos + 1)

    if ch == "|" {
        if ch1 == ">" { return new_token("PIPE_OP", "|>", line, col, line, col + 2) }
        if ch1 == "|" { return new_token("OR", "||", line, col, line, col + 2) }
    }
    if ch == "&" { if ch1 == "&" { return new_token("AND", "&&", line, col, line, col + 2) } }
    if ch == "=" {
        if ch1 == "=" { return new_token("EQEQ", "==", line, col, line, col + 2) }
        if ch1 == ">" { return new_token("FAT_ARROW", "=>", line, col, line, col + 2) }
        return new_token("ASSIGN", "=", line, col, line, col + 1)
    }
    if ch == "!" {
        if ch1 == "=" { return new_token("NEQ", "!=", line, col, line, col + 2) }
        return new_token("BANG", "!", line, col, line, col + 1)
    }
    if ch == "<" {
        if ch1 == "=" { return new_token("LTE", "<=", line, col, line, col + 2) }
        if ch1 == "-" { return new_token("SEND", "<-", line, col, line, col + 2) }
        return new_token("LT", "<", line, col, line, col + 1)
    }
    if ch == ">" {
        if ch1 == "=" { return new_token("GTE", ">=", line, col, line, col + 2) }
        return new_token("GT", ">", line, col, line, col + 1)
    }
    if ch == "-" {
        if ch1 == ">" { return new_token("ARROW", "->", line, col, line, col + 2) }
        if ch1 == "=" { return new_token("MINUS_EQ", "-=", line, col, line, col + 2) }
        return new_token("MINUS", "-", line, col, line, col + 1)
    }
    if ch == "+" {
        if ch1 == "=" { return new_token("PLUS_EQ", "+=", line, col, line, col + 2) }
        return new_token("PLUS", "+", line, col, line, col + 1)
    }
    if ch == "*" {
        if ch1 == "=" { return new_token("STAR_EQ", "*=", line, col, line, col + 2) }
        return new_token("STAR", "*", line, col, line, col + 1)
    }
    if ch == "/" {
        if ch1 == "=" { return new_token("SLASH_EQ", "/=", line, col, line, col + 2) }
        return new_token("SLASH", "/", line, col, line, col + 1)
    }
    if ch == ":" {
        if ch1 == ":" { return new_token("DOUBLE_COLON", "::", line, col, line, col + 2) }
        return new_token("COLON", ":", line, col, line, col + 1)
    }
    if ch == "." {
        if ch1 == "." {
            if lexer_peek(source, pos + 2) == "=" { return new_token("RANGE_INCL", "..=", line, col, line, col + 3) }
            return new_token("RANGE", "..", line, col, line, col + 2)
        }
        return new_token("DOT", ".", line, col, line, col + 1)
    }
    if ch == "(" { return new_token("LPAREN", "(", line, col, line, col + 1) }
    if ch == ")" { return new_token("RPAREN", ")", line, col, line, col + 1) }
    if ch == "{" { return new_token("LBRACE", "{", line, col, line, col + 1) }
    if ch == "}" { return new_token("RBRACE", "}", line, col, line, col + 1) }
    if ch == "[" { return new_token("LBRACKET", "[", line, col, line, col + 1) }
    if ch == "]" { return new_token("RBRACKET", "]", line, col, line, col + 1) }
    if ch == "," { return new_token("COMMA", ",", line, col, line, col + 1) }
    if ch == ";" { return new_token("SEMICOLON", ";", line, col, line, col + 1) }
    if ch == "?" { return new_token("QUESTION", "?", line, col, line, col + 1) }
    if ch == "@" { return new_token("AT", "@", line, col, line, col + 1) }
    if ch == "%" { return new_token("PERCENT", "%", line, col, line, col + 1) }

    return new_token("UNKNOWN", ch, line, col, line, col + 1)
}

// ---------------------------------------------------------------------------
// Public API
// ---------------------------------------------------------------------------

fn tokenize(source: String, filename: String) -> List<Token> {
    let mut tokens: List<Token> = []
    let mut pos: Int = 0
    let mut line: Int = 1
    let mut col: Int = 1
    let slen: Int = len(source)

    for _ in 0..1000000 {
        if pos >= slen { return tokens }

        // Skip whitespace and comments
        let mut skipped: Bool = true
        for _ in 0..1000000 {
            if pos >= slen { return tokens }
            if !skipped { break }
            skipped = false
            let ws: String = source.char_at(pos)
            if ws == " " { pos = pos + 1; col = col + 1; skipped = true }
            if ws == "\t" { pos = pos + 1; col = col + 1; skipped = true }
            if ws == "\r" { pos = pos + 1; skipped = true }
            if ws == "\n" { pos = pos + 1; line = line + 1; col = 1; skipped = true }
            // Skip line comments
            if ws == "/" {
                if lexer_peek(source, pos + 1) == "/" {
                    pos = pos + 2
                    skipped = true
                    for _ in 0..100000 {
                        if pos >= slen { return tokens }
                        if source.char_at(pos) == "\n" {
                            pos = pos + 1
                            line = line + 1
                            col = 1
                            break
                        }
                        pos = pos + 1
                    }
                }
            }
        }

        if pos >= slen { return tokens }

        let c: String = source.char_at(pos)

        if is_alpha(c) {
            let tok: Token = scan_ident(source, pos, line, col)
            pos = pos + len(tok.value)
            col = col + len(tok.value)
            tokens.push(tok)
        } else {
            if is_digit(c) {
                let tok: Token = scan_number(source, pos, line, col)
                let width: Int = tok.end_column - tok.column
                pos = pos + width
                col = col + width
                tokens.push(tok)
            } else {
                if c == "\"" {
                    let tok: Token = scan_string(source, pos, line, col)
                    let width: Int = tok.end_column - tok.column
                    pos = pos + width
                    col = col + width
                    line = tok.end_line
                    tokens.push(tok)
                } else {
                    if c == "'" {
                        let tok: Token = scan_char(source, pos, line, col)
                        let width: Int = tok.end_column - tok.column
                        pos = pos + width
                        col = col + width
                        tokens.push(tok)
                    } else {
                        let tok: Token = scan_op(source, pos, line, col)
                        let width: Int = len(tok.value)
                        pos = pos + width
                        col = col + width
                        tokens.push(tok)
                    }
                }
            }
        }
    }

    return tokens
}

fn tokenize_with_newlines(source: String, filename: String) -> List<Token> {
    return tokenize(source, filename)
}

// ===== parser.mn =====
// parser.mn — Mapanare parser, self-hosted.
// Recursive descent with precedence climbing.
// Builds AST from token stream produced by lexer.mn.
//
// NOTE: Struct construction syntax (Name { field: val }) is not yet in the
// Lark grammar, so all struct creation uses constructor functions.


// ---------------------------------------------------------------------------
// ParseError
// ---------------------------------------------------------------------------

struct ParseError {
    message: String,
    line: Int,
    column: Int,
    filename: String
}

// ---------------------------------------------------------------------------
// Parser state
// ---------------------------------------------------------------------------

struct Parser {
    tokens: List<Token>,
    pos: Int,
    filename: String
}

// ---------------------------------------------------------------------------
// Token classification helpers
// ---------------------------------------------------------------------------

fn is_skip_token(tok_type: String) -> Bool {
    if tok_type == "KW_FN" { return true }
    if tok_type == "KW_LET" { return true }
    if tok_type == "KW_AGENT" { return true }
    if tok_type == "KW_PIPE" { return true }
    if tok_type == "KW_STRUCT" { return true }
    if tok_type == "KW_ENUM" { return true }
    if tok_type == "KW_TYPE" { return true }
    if tok_type == "KW_IMPL" { return true }
    if tok_type == "KW_IF" { return true }
    if tok_type == "KW_ELSE" { return true }
    if tok_type == "KW_MATCH" { return true }
    if tok_type == "KW_FOR" { return true }
    if tok_type == "KW_IN" { return true }
    if tok_type == "KW_RETURN" { return true }
    if tok_type == "KW_IMPORT" { return true }
    if tok_type == "KW_EXPORT" { return true }
    if tok_type == "KW_SPAWN" { return true }
    if tok_type == "KW_SYNC" { return true }
    if tok_type == "KW_SIGNAL" { return true }
    if tok_type == "KW_STREAM" { return true }
    if tok_type == "KW_INPUT" { return true }
    if tok_type == "KW_OUTPUT" { return true }
    if tok_type == "KW_TENSOR" { return true }
    if tok_type == "KW_WILDCARD" { return true }
    if tok_type == "KW_TRUE" { return true }
    if tok_type == "KW_FALSE" { return true }
    if tok_type == "KW_NONE" { return true }
    if tok_type == "LPAREN" { return true }
    if tok_type == "RPAREN" { return true }
    if tok_type == "LBRACE" { return true }
    if tok_type == "RBRACE" { return true }
    if tok_type == "LBRACKET" { return true }
    if tok_type == "RBRACKET" { return true }
    if tok_type == "COMMA" { return true }
    if tok_type == "COLON" { return true }
    if tok_type == "SEMICOLON" { return true }
    if tok_type == "ASSIGN" { return true }
    if tok_type == "ARROW" { return true }
    if tok_type == "FAT_ARROW" { return true }
    if tok_type == "PIPE_OP" { return true }
    if tok_type == "DOUBLE_COLON" { return true }
    if tok_type == "DOT" { return true }
    if tok_type == "QUESTION" { return true }
    if tok_type == "SEND" { return true }
    return false
}

fn is_keep_token(tok_type: String) -> Bool {
    if tok_type == "KW_PUB" { return true }
    if tok_type == "KW_MUT" { return true }
    if tok_type == "KW_SELF" { return true }
    if tok_type == "NAME" { return true }
    if tok_type == "DEC_INT" { return true }
    if tok_type == "HEX_INT" { return true }
    if tok_type == "BIN_INT" { return true }
    if tok_type == "OCT_INT" { return true }
    if tok_type == "FLOAT_LIT" { return true }
    if tok_type == "STRING_LIT" { return true }
    if tok_type == "CHAR_LIT" { return true }
    return false
}

// ---------------------------------------------------------------------------
// Integer parsing helpers
// ---------------------------------------------------------------------------

fn parse_int_token(tok_type: String, value: String) -> Int {
    return 0
}

// ---------------------------------------------------------------------------
// Binary operator helpers
// ---------------------------------------------------------------------------

fn is_arithmetic_op(op: String) -> Bool {
    if op == "+" { return true }
    if op == "-" { return true }
    if op == "*" { return true }
    if op == "/" { return true }
    if op == "%" { return true }
    if op == "@" { return true }
    return false
}

fn is_comparison_op(op: String) -> Bool {
    if op == "<" { return true }
    if op == ">" { return true }
    if op == "<=" { return true }
    if op == ">=" { return true }
    if op == "==" { return true }
    if op == "!=" { return true }
    return false
}

fn is_logical_op(op: String) -> Bool {
    if op == "&&" { return true }
    if op == "||" { return true }
    return false
}

fn is_assign_op(op: String) -> Bool {
    if op == "=" { return true }
    if op == "+=" { return true }
    if op == "-=" { return true }
    if op == "*=" { return true }
    if op == "/=" { return true }
    return false
}

// ---------------------------------------------------------------------------
// Result structs — each parse function returns (value, new position)
// ---------------------------------------------------------------------------

struct ExprResult {
    expr: Expr,
    pos: Int
}

struct StmtResult {
    stmt: Stmt,
    pos: Int
}

struct BlockResult {
    block: Block,
    pos: Int
}

struct TypeResult {
    type_expr: TypeExpr,
    pos: Int
}

struct PatternResult {
    pattern: Pattern,
    pos: Int
}

struct DefResult {
    def_node: Definition,
    pos: Int
}

struct ParamResult {
    param: Param,
    pos: Int
}

struct MatchArmResult {
    arm: MatchArm,
    pos: Int
}

// ---------------------------------------------------------------------------
// Constructor functions — populate result structs positionally
// ---------------------------------------------------------------------------

fn new_expr_result(expr: Expr, pos: Int) -> ExprResult {
    return new ExprResult { expr: expr, pos: pos }
}

fn new_stmt_result(stmt: Stmt, pos: Int) -> StmtResult {
    return new StmtResult { stmt: stmt, pos: pos }
}

fn new_block_result(block: Block, pos: Int) -> BlockResult {
    return new BlockResult { block: block, pos: pos }
}

fn new_type_result(type_expr: TypeExpr, pos: Int) -> TypeResult {
    return new TypeResult { type_expr: type_expr, pos: pos }
}

fn new_pattern_result(pattern: Pattern, pos: Int) -> PatternResult {
    return new PatternResult { pattern: pattern, pos: pos }
}

fn new_def_result(def_node: Definition, pos: Int) -> DefResult {
    return new DefResult { def_node: def_node, pos: pos }
}

fn new_param_result(param: Param, pos: Int) -> ParamResult {
    return new ParamResult { param: param, pos: pos }
}

fn new_match_arm_result(arm: MatchArm, pos: Int) -> MatchArmResult {
    return new MatchArmResult { arm: arm, pos: pos }
}

// AST node constructors (new_span, new_block, new_fn_def_data are in ast.mn)

fn new_param(name: String, type_ann: Option<TypeExpr>) -> Param {
    return new Param { span: new_span(0, 0, 0, 0), name: name, type_annotation: type_ann }
}

fn new_struct_field(name: String, type_ann: TypeExpr) -> StructField {
    return new StructField { span: new_span(0, 0, 0, 0), name: name, type_annotation: type_ann }
}

fn new_enum_variant(name: String, fields: List<TypeExpr>) -> EnumVariant {
    return new EnumVariant { span: new_span(0, 0, 0, 0), name: name, fields: fields }
}

fn new_match_arm(pattern: Pattern, body: MatchArmBody) -> MatchArm {
    return new MatchArm { span: new_span(0, 0, 0, 0), pattern: pattern, body: body }
}

fn new_struct_def_data(name: String, public: Bool, type_params: List<String>, fields: List<StructField>) -> StructDefData {
    return new StructDefData { span: new_span(0, 0, 0, 0), name: name, public: public, type_params: type_params, fields: fields }
}

fn new_enum_def_data(name: String, public: Bool, type_params: List<String>, variants: List<EnumVariant>) -> EnumDefData {
    return new EnumDefData { span: new_span(0, 0, 0, 0), name: name, public: public, type_params: type_params, variants: variants }
}

fn new_agent_def_data(name: String, public: Bool, inputs: List<AgentInput>, outputs: List<AgentOutput>, state: List<Stmt>, methods: List<FnDefData>, decorators: List<Decorator>) -> AgentDefData {
    return new AgentDefData { span: new_span(0, 0, 0, 0), name: name, public: public, inputs: inputs, outputs: outputs, state: state, methods: methods, decorators: decorators }
}

fn new_pipe_def_data(name: String, public: Bool, stages: List<Expr>) -> PipeDefData {
    return new PipeDefData { span: new_span(0, 0, 0, 0), name: name, public: public, stages: stages }
}

fn new_decorator(name: String, args: List<Expr>) -> Decorator {
    return new Decorator { span: new_span(0, 0, 0, 0), name: name, args: args }
}

// ---------------------------------------------------------------------------
// Token access helpers
// ---------------------------------------------------------------------------

fn peek_type(tokens: List<Token>, pos: Int) -> String {
    if pos >= len(tokens) { return "EOF" }
    let tok: Token = tokens[pos]
    return tok.tok_type
}

fn peek_value(tokens: List<Token>, pos: Int) -> String {
    if pos >= len(tokens) { return "" }
    let tok: Token = tokens[pos]
    return tok.value
}

fn at_end(tokens: List<Token>, pos: Int) -> Bool {
    return pos >= len(tokens)
}

fn expect(tokens: List<Token>, pos: Int, expected: String) -> Int {
    let tt: String = peek_type(tokens, pos)
    if tt != expected {
        let msg: String = "Expected " + expected + " but got " + tt
        print(msg)
    }
    return pos + 1
}

fn skip_semis(tokens: List<Token>, pos: Int) -> Int {
    let mut p: Int = pos
    for _ in 0..100000 {
        if p >= len(tokens) { return p }
        if peek_type(tokens, p) == "SEMICOLON" {
            p = p + 1
        } else {
            return p
        }
    }
    return p
}

// ---------------------------------------------------------------------------
// Operator helpers
// ---------------------------------------------------------------------------

fn tok_to_binop(tt: String) -> String {
    if tt == "PLUS" { return "+" }
    if tt == "MINUS" { return "-" }
    if tt == "STAR" { return "*" }
    if tt == "SLASH" { return "/" }
    if tt == "PERCENT" { return "%" }
    if tt == "AT" { return "@" }
    if tt == "EQEQ" { return "==" }
    if tt == "NEQ" { return "!=" }
    if tt == "LT" { return "<" }
    if tt == "GT" { return ">" }
    if tt == "LTE" { return "<=" }
    if tt == "GTE" { return ">=" }
    if tt == "AND" { return "&&" }
    if tt == "OR" { return "||" }
    if tt == "PIPE_OP" { return "|>" }
    if tt == "RANGE" { return ".." }
    if tt == "RANGE_INCL" { return "..=" }
    return ""
}

fn op_precedence(op: String) -> Int {
    if op == "||" { return 1 }
    if op == "&&" { return 2 }
    if op == "==" { return 3 }
    if op == "!=" { return 3 }
    if op == "<" { return 4 }
    if op == ">" { return 4 }
    if op == "<=" { return 4 }
    if op == ">=" { return 4 }
    if op == "|>" { return 5 }
    if op == ".." { return 6 }
    if op == "..=" { return 6 }
    if op == "+" { return 7 }
    if op == "-" { return 7 }
    if op == "*" { return 8 }
    if op == "/" { return 8 }
    if op == "%" { return 8 }
    if op == "@" { return 8 }
    return 0
}

fn is_right_assoc(op: String) -> Bool {
    if op == ".." { return true }
    if op == "..=" { return true }
    return false
}

// ---------------------------------------------------------------------------
// Public API
// ---------------------------------------------------------------------------

fn is_definition_start(tt: String) -> Bool {
    if tt == "KW_IMPORT" { return true }
    if tt == "KW_EXPORT" { return true }
    if tt == "KW_PUB" { return true }
    if tt == "KW_FN" { return true }
    if tt == "KW_STRUCT" { return true }
    if tt == "KW_ENUM" { return true }
    if tt == "KW_AGENT" { return true }
    if tt == "KW_PIPE" { return true }
    if tt == "KW_TYPE" { return true }
    if tt == "KW_IMPL" { return true }
    if tt == "AT" { return true }
    return false
}

fn has_explicit_main(defs: List<Definition>) -> Bool {
    for i in 0..len(defs) {
        let d: Definition = defs[i]
        match d {
            FnDef(fd) => {
                if fd.name == "main" {
                    return true
                }
            },
            _ => {}
        }
    }
    return false
}

pub fn parse(source: String, filename: String) -> Program {
    let tokens: List<Token> = tokenize(source, filename)
    let mut pos: Int = 0
    let mut defs: List<Definition> = []
    let mut top_stmts: List<Stmt> = []

    for _ in 0..100000 {
        pos = skip_semis(tokens, pos)
        if pos >= len(tokens) {
            if len(top_stmts) > 0 {
                if !has_explicit_main(defs) {
                    let body: Block = new_block(new_span(0, 0, 0, 0), top_stmts)
                    let empty_tp: List<String> = []
                    let empty_params: List<Param> = []
                    let empty_decs: List<Decorator> = []
                    let main_fn: FnDefData = new_fn_def_data(new_span(0, 0, 0, 0), "main", false, empty_tp, empty_params, none, body, empty_decs)
                    defs.push(Definition::FnDef(main_fn))
                }
            }
            return Program::start(defs)
        }

        let tt: String = peek_type(tokens, pos)
        if is_definition_start(tt) {
            let r: DefResult = parse_definition(tokens, pos, filename)
            defs.push(r.def_node)
            pos = r.pos
        } else {
            let sr: StmtResult = parse_stmt(tokens, pos, filename)
            top_stmts.push(sr.stmt)
            pos = sr.pos
        }
    }

    if len(top_stmts) > 0 {
        if !has_explicit_main(defs) {
            let body: Block = new_block(new_span(0, 0, 0, 0), top_stmts)
            let empty_tp2: List<String> = []
            let empty_params2: List<Param> = []
            let empty_decs2: List<Decorator> = []
            let main_fn: FnDefData = new_fn_def_data(new_span(0, 0, 0, 0), "main", false, empty_tp2, empty_params2, none, body, empty_decs2)
            defs.push(Definition::FnDef(main_fn))
        }
    }

    return Program::start(defs)
}

// ---------------------------------------------------------------------------
// Definition dispatch
// ---------------------------------------------------------------------------

fn parse_definition(tokens: List<Token>, pos: Int, filename: String) -> DefResult {
    let tt: String = peek_type(tokens, pos)

    if tt == "KW_IMPORT" {
        return parse_import_def(tokens, pos, filename)
    }
    if tt == "KW_EXPORT" {
        return parse_export_def(tokens, pos, filename)
    }
    if tt == "KW_PUB" {
        let next_tt: String = peek_type(tokens, pos + 1)
        if next_tt == "KW_FN" { return parse_fn_def(tokens, pos, filename) }
        if next_tt == "KW_STRUCT" { return parse_struct_def(tokens, pos, filename) }
        if next_tt == "KW_ENUM" { return parse_enum_def(tokens, pos, filename) }
        if next_tt == "KW_AGENT" { return parse_agent_def(tokens, pos, filename) }
        if next_tt == "KW_PIPE" { return parse_pipe_def(tokens, pos, filename) }
    }
    if tt == "KW_FN" { return parse_fn_def(tokens, pos, filename) }
    if tt == "KW_STRUCT" { return parse_struct_def(tokens, pos, filename) }
    if tt == "KW_ENUM" { return parse_enum_def(tokens, pos, filename) }
    if tt == "KW_AGENT" { return parse_agent_def(tokens, pos, filename) }
    if tt == "KW_PIPE" { return parse_pipe_def(tokens, pos, filename) }
    if tt == "KW_TYPE" { return parse_type_alias_def(tokens, pos, filename) }
    if tt == "KW_IMPL" { return parse_impl_def(tokens, pos, filename) }
    if tt == "AT" { return parse_decorated_def(tokens, pos, filename) }

    // Fallback: skip unknown token
    let empty_path: List<String> = []
    let empty_items: List<String> = []
    let d: Definition = Definition::ImportDef(empty_path, empty_items)
    return new_def_result(d, pos + 1)
}

// ---------------------------------------------------------------------------
// Import definition
// ---------------------------------------------------------------------------

fn parse_import_def(tokens: List<Token>, pos: Int, filename: String) -> DefResult {
    let mut p: Int = pos + 1
    let mut path: List<String> = []

    let name0: String = peek_value(tokens, p)
    path.push(name0)
    p = p + 1

    for _ in 0..100 {
        if peek_type(tokens, p) != "DOUBLE_COLON" {
            let imp_items: List<String> = []
            return new_def_result(Definition::ImportDef(path, imp_items), p)
        }
        p = p + 1
        let seg: String = peek_value(tokens, p)
        path.push(seg)
        p = p + 1
    }

    let trail_items: List<String> = []
    return new_def_result(Definition::ImportDef(path, trail_items), p)
}

// ---------------------------------------------------------------------------
// Export definition
// ---------------------------------------------------------------------------

fn parse_export_def(tokens: List<Token>, pos: Int, filename: String) -> DefResult {
    let mut p: Int = pos + 1
    let tt: String = peek_type(tokens, p)

    if tt == "KW_FN" {
        let r: DefResult = parse_fn_def(tokens, p, filename)
        let exp_items: List<String> = []
        return new_def_result(Definition::ExportDef(none, exp_items), r.pos)
    }
    if tt == "KW_STRUCT" {
        let r: DefResult = parse_struct_def(tokens, p, filename)
        let exp_items: List<String> = []
        return new_def_result(Definition::ExportDef(none, exp_items), r.pos)
    }

    let mut names: List<String> = []
    names.push(peek_value(tokens, p))
    p = p + 1
    for _ in 0..100 {
        if peek_type(tokens, p) != "COMMA" {
            return new_def_result(Definition::ExportDef(none, names), p)
        }
        p = p + 1
        names.push(peek_value(tokens, p))
        p = p + 1
    }
    return new_def_result(Definition::ExportDef(none, names), p)
}

// ---------------------------------------------------------------------------
// Function definition
// ---------------------------------------------------------------------------

fn parse_fn_def(tokens: List<Token>, pos: Int, filename: String) -> DefResult {
    let mut p: Int = pos
    let mut is_pub: Bool = false

    if peek_type(tokens, p) == "KW_PUB" {
        is_pub = true
        p = p + 1
    }
    p = expect(tokens, p, "KW_FN")

    let name: String = peek_value(tokens, p)
    p = p + 1

    // Optional type params <T, U>
    let mut type_params: List<String> = []
    if peek_type(tokens, p) == "LT" {
        p = p + 1
        type_params.push(peek_value(tokens, p))
        p = p + 1
        for _ in 0..20 {
            if peek_type(tokens, p) != "COMMA" {
                p = expect(tokens, p, "GT")
                return parse_fn_params(tokens, p, filename, name, is_pub, type_params)
            }
            p = p + 1
            type_params.push(peek_value(tokens, p))
            p = p + 1
        }
        p = expect(tokens, p, "GT")
    }

    return parse_fn_params(tokens, p, filename, name, is_pub, type_params)
}

fn parse_fn_params(tokens: List<Token>, pos: Int, filename: String, name: String, is_pub: Bool, type_params: List<String>) -> DefResult {
    let mut p: Int = pos
    p = expect(tokens, p, "LPAREN")
    let mut params: List<Param> = []

    if peek_type(tokens, p) != "RPAREN" {
        let pr: ParamResult = parse_param(tokens, p, filename)
        params.push(pr.param)
        p = pr.pos

        for _ in 0..50 {
            if peek_type(tokens, p) != "COMMA" {
                p = expect(tokens, p, "RPAREN")
                return parse_fn_body(tokens, p, filename, name, is_pub, type_params, params)
            }
            p = p + 1
            if peek_type(tokens, p) == "RPAREN" {
                p = p + 1
                return parse_fn_body(tokens, p, filename, name, is_pub, type_params, params)
            }
            let pr2: ParamResult = parse_param(tokens, p, filename)
            params.push(pr2.param)
            p = pr2.pos
        }
    }
    p = expect(tokens, p, "RPAREN")

    return parse_fn_body(tokens, p, filename, name, is_pub, type_params, params)
}

fn parse_fn_body(tokens: List<Token>, pos: Int, filename: String, name: String, is_pub: Bool, type_params: List<String>, params: List<Param>) -> DefResult {
    let mut p: Int = pos

    let mut ret_type: Option<TypeExpr> = none
    if peek_type(tokens, p) == "ARROW" {
        p = p + 1
        let tr: TypeResult = parse_type_expr(tokens, p, filename)
        ret_type = Some(tr.type_expr)
        p = tr.pos
    }

    let br: BlockResult = parse_block(tokens, p, filename)
    p = br.pos

    let decorators: List<Decorator> = []
    let fd: FnDefData = new_fn_def_data(new_span(0, 0, 0, 0), name, is_pub, type_params, params, ret_type, br.block, decorators)
    return new_def_result(Definition::FnDef(fd), p)
}

fn parse_param(tokens: List<Token>, pos: Int, filename: String) -> ParamResult {
    let name: String = peek_value(tokens, pos)
    let mut p: Int = pos + 1
    p = expect(tokens, p, "COLON")
    let tr: TypeResult = parse_type_expr(tokens, p, filename)
    let param: Param = new_param(name, Some(tr.type_expr))
    return new_param_result(param, tr.pos)
}

// ---------------------------------------------------------------------------
// Struct definition
// ---------------------------------------------------------------------------

fn parse_struct_def(tokens: List<Token>, pos: Int, filename: String) -> DefResult {
    let mut p: Int = pos
    let mut is_pub: Bool = false

    if peek_type(tokens, p) == "KW_PUB" {
        is_pub = true
        p = p + 1
    }
    p = expect(tokens, p, "KW_STRUCT")

    let name: String = peek_value(tokens, p)
    p = p + 1

    let mut type_params: List<String> = []
    if peek_type(tokens, p) == "LT" {
        p = p + 1
        type_params.push(peek_value(tokens, p))
        p = p + 1
        for _ in 0..20 {
            if peek_type(tokens, p) != "COMMA" {
                p = expect(tokens, p, "GT")
                return parse_struct_fields(tokens, p, filename, name, is_pub, type_params)
            }
            p = p + 1
            type_params.push(peek_value(tokens, p))
            p = p + 1
        }
        p = expect(tokens, p, "GT")
    }

    return parse_struct_fields(tokens, p, filename, name, is_pub, type_params)
}

fn parse_struct_fields(tokens: List<Token>, pos: Int, filename: String, name: String, is_pub: Bool, type_params: List<String>) -> DefResult {
    let mut p: Int = pos
    p = expect(tokens, p, "LBRACE")

    let mut fields: List<StructField> = []
    for _ in 0..100 {
        p = skip_semis(tokens, p)
        if peek_type(tokens, p) == "RBRACE" {
            p = p + 1
            let sd: StructDefData = new_struct_def_data(name, is_pub, type_params, fields)
            return new_def_result(Definition::StructDef(sd), p)
        }

        let fname: String = peek_value(tokens, p)
        p = p + 1
        p = expect(tokens, p, "COLON")
        let tr: TypeResult = parse_type_expr(tokens, p, filename)
        p = tr.pos

        let field: StructField = new_struct_field(fname, tr.type_expr)
        fields.push(field)

        if peek_type(tokens, p) == "COMMA" { p = p + 1 }
    }

    let sd: StructDefData = new_struct_def_data(name, is_pub, type_params, fields)
    return new_def_result(Definition::StructDef(sd), p)
}

// ---------------------------------------------------------------------------
// Enum definition
// ---------------------------------------------------------------------------

fn parse_enum_def(tokens: List<Token>, pos: Int, filename: String) -> DefResult {
    let mut p: Int = pos
    let mut is_pub: Bool = false

    if peek_type(tokens, p) == "KW_PUB" {
        is_pub = true
        p = p + 1
    }
    p = expect(tokens, p, "KW_ENUM")

    let name: String = peek_value(tokens, p)
    p = p + 1

    let mut type_params: List<String> = []
    if peek_type(tokens, p) == "LT" {
        p = p + 1
        type_params.push(peek_value(tokens, p))
        p = p + 1
        for _ in 0..20 {
            if peek_type(tokens, p) != "COMMA" {
                p = expect(tokens, p, "GT")
                return parse_enum_body(tokens, p, filename, name, is_pub, type_params)
            }
            p = p + 1
            type_params.push(peek_value(tokens, p))
            p = p + 1
        }
        p = expect(tokens, p, "GT")
    }

    return parse_enum_body(tokens, p, filename, name, is_pub, type_params)
}

fn parse_enum_body(tokens: List<Token>, pos: Int, filename: String, name: String, is_pub: Bool, type_params: List<String>) -> DefResult {
    let mut p: Int = pos
    p = expect(tokens, p, "LBRACE")

    let mut variants: List<EnumVariant> = []
    for _ in 0..100 {
        p = skip_semis(tokens, p)
        if peek_type(tokens, p) == "RBRACE" {
            p = p + 1
            let ed: EnumDefData = new_enum_def_data(name, is_pub, type_params, variants)
            return new_def_result(Definition::EnumDef(ed), p)
        }

        let vname: String = peek_value(tokens, p)
        p = p + 1
        let mut vtypes: List<TypeExpr> = []

        if peek_type(tokens, p) == "LPAREN" {
            p = p + 1
            if peek_type(tokens, p) != "RPAREN" {
                let tr: TypeResult = parse_type_expr(tokens, p, filename)
                vtypes.push(tr.type_expr)
                p = tr.pos
                for _ in 0..20 {
                    if peek_type(tokens, p) != "COMMA" {
                        p = expect(tokens, p, "RPAREN")
                        let v: EnumVariant = new_enum_variant(vname, vtypes)
                        variants.push(v)
                        if peek_type(tokens, p) == "COMMA" { p = p + 1 }
                        // Continue loop
                        return parse_enum_body_continue(tokens, p, filename, name, is_pub, type_params, variants)
                    }
                    p = p + 1
                    let tr2: TypeResult = parse_type_expr(tokens, p, filename)
                    vtypes.push(tr2.type_expr)
                    p = tr2.pos
                }
            }
            p = expect(tokens, p, "RPAREN")
        }

        let v: EnumVariant = new_enum_variant(vname, vtypes)
        variants.push(v)

        if peek_type(tokens, p) == "COMMA" { p = p + 1 }
    }

    let ed: EnumDefData = new_enum_def_data(name, is_pub, type_params, variants)
    return new_def_result(Definition::EnumDef(ed), p)
}

fn parse_enum_body_continue(tokens: List<Token>, pos: Int, filename: String, name: String, is_pub: Bool, type_params: List<String>, variants: List<EnumVariant>) -> DefResult {
    let mut p: Int = pos
    let mut vars: List<EnumVariant> = variants

    for _ in 0..100 {
        p = skip_semis(tokens, p)
        if peek_type(tokens, p) == "RBRACE" {
            p = p + 1
            let ed: EnumDefData = new_enum_def_data(name, is_pub, type_params, vars)
            return new_def_result(Definition::EnumDef(ed), p)
        }

        let vn: String = peek_value(tokens, p)
        p = p + 1
        let mut vt: List<TypeExpr> = []

        if peek_type(tokens, p) == "LPAREN" {
            p = p + 1
            if peek_type(tokens, p) != "RPAREN" {
                let tr: TypeResult = parse_type_expr(tokens, p, filename)
                vt.push(tr.type_expr)
                p = tr.pos
                for _ in 0..20 {
                    if peek_type(tokens, p) != "COMMA" {
                        p = expect(tokens, p, "RPAREN")
                        let v2: EnumVariant = new_enum_variant(vn, vt)
                        vars.push(v2)
                        if peek_type(tokens, p) == "COMMA" { p = p + 1 }
                        return parse_enum_body_continue(tokens, p, filename, name, is_pub, type_params, vars)
                    }
                    p = p + 1
                    let tr2: TypeResult = parse_type_expr(tokens, p, filename)
                    vt.push(tr2.type_expr)
                    p = tr2.pos
                }
            }
            p = expect(tokens, p, "RPAREN")
        }

        let v: EnumVariant = new_enum_variant(vn, vt)
        vars.push(v)

        if peek_type(tokens, p) == "COMMA" { p = p + 1 }
    }

    let ed: EnumDefData = new_enum_def_data(name, is_pub, type_params, vars)
    return new_def_result(Definition::EnumDef(ed), p)
}

// ---------------------------------------------------------------------------
// Type alias
// ---------------------------------------------------------------------------

fn parse_type_alias_def(tokens: List<Token>, pos: Int, filename: String) -> DefResult {
    let mut p: Int = pos + 1
    let name: String = peek_value(tokens, p)
    p = p + 1
    p = expect(tokens, p, "ASSIGN")
    let tr: TypeResult = parse_type_expr(tokens, p, filename)
    return new_def_result(Definition::TypeAlias(name, tr.type_expr), tr.pos)
}

// ---------------------------------------------------------------------------
// Impl definition
// ---------------------------------------------------------------------------

fn parse_impl_def(tokens: List<Token>, pos: Int, filename: String) -> DefResult {
    let mut p: Int = pos + 1
    let name: String = peek_value(tokens, p)
    p = p + 1
    p = expect(tokens, p, "LBRACE")

    let mut methods: List<FnDefData> = []
    for _ in 0..100 {
        p = skip_semis(tokens, p)
        if peek_type(tokens, p) == "RBRACE" {
            p = p + 1
            return new_def_result(Definition::ImplDef(name, methods), p)
        }
        let r: DefResult = parse_fn_def(tokens, p, filename)
        p = r.pos
    }

    return new_def_result(Definition::ImplDef(name, methods), p)
}

// ---------------------------------------------------------------------------
// Agent definition (brace-skip for bootstrap)
// ---------------------------------------------------------------------------

fn parse_agent_def(tokens: List<Token>, pos: Int, filename: String) -> DefResult {
    // Pre-create typed empty lists for AgentDefData constructor
    let no_inputs: List<AgentInput> = []
    let no_outputs: List<AgentOutput> = []
    let no_state: List<Stmt> = []
    let no_methods: List<FnDefData> = []
    let no_adecs: List<Decorator> = []
    let mut p: Int = pos
    let mut is_pub: Bool = false
    if peek_type(tokens, p) == "KW_PUB" {
        is_pub = true
        p = p + 1
    }
    p = expect(tokens, p, "KW_AGENT")
    let name: String = peek_value(tokens, p)
    p = p + 1
    p = expect(tokens, p, "LBRACE")
    let mut depth: Int = 1
    for _ in 0..100000 {
        if p >= len(tokens) {
            let ad: AgentDefData = new_agent_def_data(name, is_pub, no_inputs, no_outputs, no_state, no_methods, no_adecs)
            return new_def_result(Definition::AgentDef(ad), p)
        }
        let tt: String = peek_type(tokens, p)
        if tt == "LBRACE" { depth = depth + 1 }
        if tt == "RBRACE" {
            depth = depth - 1
            if depth == 0 {
                p = p + 1
                let ad: AgentDefData = new_agent_def_data(name, is_pub, no_inputs, no_outputs, no_state, no_methods, no_adecs)
                return new_def_result(Definition::AgentDef(ad), p)
            }
        }
        p = p + 1
    }
    let ad: AgentDefData = new_agent_def_data(name, is_pub, no_inputs, no_outputs, no_state, no_methods, no_adecs)
    return new_def_result(Definition::AgentDef(ad), p)
}

// ---------------------------------------------------------------------------
// Pipe definition (brace-skip for bootstrap)
// ---------------------------------------------------------------------------

fn parse_pipe_def(tokens: List<Token>, pos: Int, filename: String) -> DefResult {
    let no_stages: List<Expr> = []
    let mut p: Int = pos
    let mut is_pub: Bool = false
    if peek_type(tokens, p) == "KW_PUB" {
        is_pub = true
        p = p + 1
    }
    p = expect(tokens, p, "KW_PIPE")
    let name: String = peek_value(tokens, p)
    p = p + 1
    p = expect(tokens, p, "LBRACE")
    let mut depth: Int = 1
    for _ in 0..100000 {
        if p >= len(tokens) {
            let pd: PipeDefData = new_pipe_def_data(name, is_pub, no_stages)
            return new_def_result(Definition::PipeDef(pd), p)
        }
        let tt: String = peek_type(tokens, p)
        if tt == "LBRACE" { depth = depth + 1 }
        if tt == "RBRACE" {
            depth = depth - 1
            if depth == 0 {
                p = p + 1
                let pd: PipeDefData = new_pipe_def_data(name, is_pub, no_stages)
                return new_def_result(Definition::PipeDef(pd), p)
            }
        }
        p = p + 1
    }
    let pd: PipeDefData = new_pipe_def_data(name, is_pub, no_stages)
    return new_def_result(Definition::PipeDef(pd), p)
}

// ---------------------------------------------------------------------------
// Decorated definition
// ---------------------------------------------------------------------------

fn parse_decorated_def(tokens: List<Token>, pos: Int, filename: String) -> DefResult {
    let mut p: Int = pos
    for _ in 0..10 {
        if peek_type(tokens, p) != "AT" { return parse_definition(tokens, p, filename) }
        p = p + 1
        p = p + 1
        if peek_type(tokens, p) == "LPAREN" {
            p = p + 1
            let mut depth: Int = 1
            for _ in 0..1000 {
                if p >= len(tokens) { return parse_definition(tokens, p, filename) }
                if peek_type(tokens, p) == "LPAREN" { depth = depth + 1 }
                if peek_type(tokens, p) == "RPAREN" {
                    depth = depth - 1
                    if depth == 0 {
                        p = p + 1
                        return parse_definition(tokens, p, filename)
                    }
                }
                p = p + 1
            }
        }
    }
    return parse_definition(tokens, p, filename)
}

// ---------------------------------------------------------------------------
// Block
// ---------------------------------------------------------------------------

fn parse_block(tokens: List<Token>, pos: Int, filename: String) -> BlockResult {
    let mut p: Int = pos
    p = expect(tokens, p, "LBRACE")

    let mut stmts: List<Stmt> = []
    for _ in 0..100000 {
        p = skip_semis(tokens, p)
        if at_end(tokens, p) {
            let blk: Block = new_block(new_span(0, 0, 0, 0), stmts)
            return new_block_result(blk, p)
        }
        if peek_type(tokens, p) == "RBRACE" {
            p = p + 1
            let blk: Block = new_block(new_span(0, 0, 0, 0), stmts)
            return new_block_result(blk, p)
        }

        let sr: StmtResult = parse_stmt(tokens, p, filename)
        stmts.push(sr.stmt)
        p = sr.pos
    }

    let blk: Block = new_block(new_span(0, 0, 0, 0), stmts)
    return new_block_result(blk, p)
}

// ---------------------------------------------------------------------------
// Statement dispatch
// ---------------------------------------------------------------------------

fn parse_stmt(tokens: List<Token>, pos: Int, filename: String) -> StmtResult {
    let tt: String = peek_type(tokens, pos)

    if tt == "KW_LET" { return parse_let_stmt(tokens, pos, filename) }
    if tt == "KW_RETURN" { return parse_return_stmt(tokens, pos, filename) }
    if tt == "KW_FOR" { return parse_for_stmt(tokens, pos, filename) }

    let er: ExprResult = parse_expr(tokens, pos, filename, 0)
    return new_stmt_result(Stmt::ExprStmt(er.expr), er.pos)
}

// ---------------------------------------------------------------------------
// Let statement
// ---------------------------------------------------------------------------

fn parse_let_stmt(tokens: List<Token>, pos: Int, filename: String) -> StmtResult {
    let mut p: Int = pos + 1
    let mut is_mut: Bool = false

    if peek_type(tokens, p) == "KW_MUT" {
        is_mut = true
        p = p + 1
    }

    let name: String = peek_value(tokens, p)
    p = p + 1

    let mut type_ann: Option<TypeExpr> = none
    if peek_type(tokens, p) == "COLON" {
        p = p + 1
        let tr: TypeResult = parse_type_expr(tokens, p, filename)
        type_ann = Some(tr.type_expr)
        p = tr.pos
    }

    p = expect(tokens, p, "ASSIGN")

    let er: ExprResult = parse_expr(tokens, p, filename, 0)
    return new_stmt_result(Stmt::Let(name, is_mut, type_ann, er.expr), er.pos)
}

// ---------------------------------------------------------------------------
// Return statement
// ---------------------------------------------------------------------------

fn parse_return_stmt(tokens: List<Token>, pos: Int, filename: String) -> StmtResult {
    let mut p: Int = pos + 1

    let tt: String = peek_type(tokens, p)
    if tt == "RBRACE" { return new_stmt_result(Stmt::Return(none), p) }
    if tt == "SEMICOLON" { return new_stmt_result(Stmt::Return(none), p) }
    if at_end(tokens, p) { return new_stmt_result(Stmt::Return(none), p) }

    let er: ExprResult = parse_expr(tokens, p, filename, 0)
    return new_stmt_result(Stmt::Return(Some(er.expr)), er.pos)
}

// ---------------------------------------------------------------------------
// For statement
// ---------------------------------------------------------------------------

fn parse_for_stmt(tokens: List<Token>, pos: Int, filename: String) -> StmtResult {
    let mut p: Int = pos + 1
    let var_name: String = peek_value(tokens, p)
    p = p + 1
    p = expect(tokens, p, "KW_IN")

    let er: ExprResult = parse_expr(tokens, p, filename, 0)
    p = er.pos

    let br: BlockResult = parse_block(tokens, p, filename)
    return new_stmt_result(Stmt::For(var_name, er.expr, br.block), br.pos)
}

// ---------------------------------------------------------------------------
// Expression parser — precedence climbing
// ---------------------------------------------------------------------------

fn parse_expr(tokens: List<Token>, pos: Int, filename: String, min_prec: Int) -> ExprResult {
    let mut left_r: ExprResult = parse_unary(tokens, pos, filename)
    let mut left: Expr = left_r.expr
    let mut p: Int = left_r.pos

    // Assignment operators (right-associative, lowest precedence)
    if min_prec == 0 {
        let att: String = peek_type(tokens, p)
        if att == "ASSIGN" {
            p = p + 1
            let rhs: ExprResult = parse_expr(tokens, p, filename, 0)
            return new_expr_result(Expr::Assign(left, "=", rhs.expr), rhs.pos)
        }
        if att == "PLUS_EQ" {
            p = p + 1
            let rhs: ExprResult = parse_expr(tokens, p, filename, 0)
            return new_expr_result(Expr::Assign(left, "+=", rhs.expr), rhs.pos)
        }
        if att == "MINUS_EQ" {
            p = p + 1
            let rhs: ExprResult = parse_expr(tokens, p, filename, 0)
            return new_expr_result(Expr::Assign(left, "-=", rhs.expr), rhs.pos)
        }
        if att == "STAR_EQ" {
            p = p + 1
            let rhs: ExprResult = parse_expr(tokens, p, filename, 0)
            return new_expr_result(Expr::Assign(left, "*=", rhs.expr), rhs.pos)
        }
        if att == "SLASH_EQ" {
            p = p + 1
            let rhs: ExprResult = parse_expr(tokens, p, filename, 0)
            return new_expr_result(Expr::Assign(left, "/=", rhs.expr), rhs.pos)
        }
        if att == "SEND" {
            p = p + 1
            let rhs: ExprResult = parse_expr(tokens, p, filename, 0)
            return new_expr_result(Expr::Send(left, rhs.expr), rhs.pos)
        }
        if att == "FAT_ARROW" {
            p = p + 1
            let body: ExprResult = parse_expr(tokens, p, filename, 0)
            // Extract lambda params from the left-hand side expression.
            // (n) => ... parses as Ident("n") on the left of =>
            let mut params: List<Param> = []
            match left {
                Ident(name) => {
                    params.push(new_param(name, none))
                },
                _ => {}
            }
            return new_expr_result(Expr::Lambda(params, LambdaBody::ExprBody(body.expr)), body.pos)
        }
    }

    // Binary operator loop
    for _ in 0..10000 {
        if at_end(tokens, p) { return new_expr_result(left, p) }

        let op_tt: String = peek_type(tokens, p)
        let op: String = tok_to_binop(op_tt)
        if op == "" { return new_expr_result(left, p) }

        let prec: Int = op_precedence(op)
        if prec < min_prec { return new_expr_result(left, p) }

        p = p + 1

        let mut next_prec: Int = prec + 1
        if is_right_assoc(op) { next_prec = prec }

        let right_r: ExprResult = parse_expr(tokens, p, filename, next_prec)
        p = right_r.pos

        if op == "|>" {
            left = Expr::Pipe(left, right_r.expr)
        } else {
            if op == ".." {
                left = Expr::Range(left, right_r.expr, false)
            } else {
                if op == "..=" {
                    left = Expr::Range(left, right_r.expr, true)
                } else {
                    left = Expr::Binary(left, op, right_r.expr)
                }
            }
        }
    }

    return new_expr_result(left, p)
}

// ---------------------------------------------------------------------------
// Unary expressions
// ---------------------------------------------------------------------------

fn parse_unary(tokens: List<Token>, pos: Int, filename: String) -> ExprResult {
    let tt: String = peek_type(tokens, pos)

    if tt == "MINUS" {
        let r: ExprResult = parse_unary(tokens, pos + 1, filename)
        return new_expr_result(Expr::Unary("-", r.expr), r.pos)
    }
    if tt == "BANG" {
        let r: ExprResult = parse_unary(tokens, pos + 1, filename)
        return new_expr_result(Expr::Unary("!", r.expr), r.pos)
    }

    return parse_postfix(tokens, pos, filename)
}

// ---------------------------------------------------------------------------
// Postfix expressions
// ---------------------------------------------------------------------------

fn parse_postfix(tokens: List<Token>, pos: Int, filename: String) -> ExprResult {
    let mut ar: ExprResult = parse_atom(tokens, pos, filename)
    let mut left: Expr = ar.expr
    let mut p: Int = ar.pos

    for _ in 0..10000 {
        if at_end(tokens, p) { return new_expr_result(left, p) }

        let tt: String = peek_type(tokens, p)

        if tt == "LPAREN" {
            let cr: ExprResult = parse_call_args(tokens, p, filename, left)
            left = cr.expr
            p = cr.pos
        } else {
            if tt == "DOT" {
                p = p + 1
                let field_name: String = peek_value(tokens, p)
                p = p + 1

                if peek_type(tokens, p) == "LPAREN" {
                    let mr: ExprResult = parse_method_args(tokens, p, filename, left, field_name)
                    left = mr.expr
                    p = mr.pos
                } else {
                    left = Expr::FieldAccess(left, field_name)
                }
            } else {
                if tt == "LBRACKET" {
                    p = p + 1
                    let idx_r: ExprResult = parse_expr(tokens, p, filename, 0)
                    p = idx_r.pos
                    p = expect(tokens, p, "RBRACKET")
                    left = Expr::Index(left, idx_r.expr)
                } else {
                    if tt == "QUESTION" {
                        p = p + 1
                        left = Expr::ErrorProp(left)
                    } else {
                        return new_expr_result(left, p)
                    }
                }
            }
        }
    }

    return new_expr_result(left, p)
}

fn parse_call_args(tokens: List<Token>, pos: Int, filename: String, callee: Expr) -> ExprResult {
    let mut p: Int = pos + 1
    let mut args: List<Expr> = []

    if peek_type(tokens, p) == "RPAREN" {
        p = p + 1
        return new_expr_result(Expr::Call(callee, args), p)
    }

    let a0: ExprResult = parse_expr(tokens, p, filename, 0)
    args.push(a0.expr)
    p = a0.pos

    for _ in 0..100 {
        if peek_type(tokens, p) != "COMMA" {
            p = expect(tokens, p, "RPAREN")
            return new_expr_result(Expr::Call(callee, args), p)
        }
        p = p + 1
        if peek_type(tokens, p) == "RPAREN" {
            p = p + 1
            return new_expr_result(Expr::Call(callee, args), p)
        }
        let an: ExprResult = parse_expr(tokens, p, filename, 0)
        args.push(an.expr)
        p = an.pos
    }

    p = expect(tokens, p, "RPAREN")
    return new_expr_result(Expr::Call(callee, args), p)
}

fn parse_method_args(tokens: List<Token>, pos: Int, filename: String, obj: Expr, method: String) -> ExprResult {
    let mut p: Int = pos + 1
    let mut args: List<Expr> = []

    if peek_type(tokens, p) == "RPAREN" {
        p = p + 1
        return new_expr_result(Expr::MethodCall(obj, method, args), p)
    }

    let a0: ExprResult = parse_expr(tokens, p, filename, 0)
    args.push(a0.expr)
    p = a0.pos

    for _ in 0..100 {
        if peek_type(tokens, p) != "COMMA" {
            p = expect(tokens, p, "RPAREN")
            return new_expr_result(Expr::MethodCall(obj, method, args), p)
        }
        p = p + 1
        if peek_type(tokens, p) == "RPAREN" {
            p = p + 1
            return new_expr_result(Expr::MethodCall(obj, method, args), p)
        }
        let an: ExprResult = parse_expr(tokens, p, filename, 0)
        args.push(an.expr)
        p = an.pos
    }

    p = expect(tokens, p, "RPAREN")
    return new_expr_result(Expr::MethodCall(obj, method, args), p)
}

// ---------------------------------------------------------------------------
// String interpolation helpers
// ---------------------------------------------------------------------------

fn has_interpolation(s: String) -> Bool {
    for i in 0..len(s) {
        if s.char_at(i) == "$" {
            if i + 1 < len(s) {
                if s.char_at(i + 1) == "{" {
                    // Check not escaped
                    if i == 0 { return true }
                    if s.char_at(i - 1) != "\\" { return true }
                }
            }
        }
    }
    return false
}

fn split_interp_parts(s: String) -> List<Expr> {
    let mut parts: List<Expr> = []
    let mut lit: String = ""
    let mut i: Int = 0
    for _ in 0..100000 {
        if i >= len(s) {
            if len(lit) > 0 { parts.push(Expr::StringLit(lit)) }
            return parts
        }
        let ch: String = s.char_at(i)
        if ch == "\\" {
            if i + 1 < len(s) {
                if s.char_at(i + 1) == "$" {
                    lit = lit + "$"
                    i = i + 2
                } else {
                    lit = lit + ch
                    i = i + 1
                }
            } else {
                lit = lit + ch
                i = i + 1
            }
        } else {
            if ch == "$" {
                if i + 1 < len(s) {
                    if s.char_at(i + 1) == "{" {
                        // Flush literal
                        if len(lit) > 0 {
                            parts.push(Expr::StringLit(lit))
                            lit = ""
                        }
                        // Find matching }
                        let mut depth: Int = 1
                        let mut j: Int = i + 2
                        for _ in 0..10000 {
                            if j >= len(s) { return parts }
                            if depth == 0 { return parts }
                            if s.char_at(j) == "{" { depth = depth + 1 }
                            if s.char_at(j) == "}" {
                                depth = depth - 1
                                if depth == 0 {
                                    // Extract expression text between ${ and }
                                    let expr_text: String = s.substr(i + 2, j)
                                    // For now, treat as Ident (simple variable reference)
                                    parts.push(Expr::Ident(expr_text))
                                    i = j + 1
                                    return parts
                                }
                            }
                            j = j + 1
                        }
                        i = j
                    } else {
                        lit = lit + ch
                        i = i + 1
                    }
                } else {
                    lit = lit + ch
                    i = i + 1
                }
            } else {
                lit = lit + ch
                i = i + 1
            }
        }
    }
    if len(lit) > 0 { parts.push(Expr::StringLit(lit)) }
    return parts
}

// ---------------------------------------------------------------------------
// Atom expressions
// ---------------------------------------------------------------------------

fn parse_struct_fields_to_list(tokens: List<Token>, pos: Int, filename: String) -> ExprResult {
    // Parse field values: name: expr, name: expr, ...
    // Returns a ListLit of the field values (ignoring field names)
    let mut p: Int = pos
    let mut vals: List<Expr> = []
    for _ in 0..100 {
        if peek_type(tokens, p) == "RBRACE" {
            return new_expr_result(Expr::ListLit(vals), p + 1)
        }
        p = p + 1  // skip field name
        p = expect(tokens, p, "COLON")
        let er: ExprResult = parse_expr(tokens, p, filename, 0)
        p = er.pos
        vals.push(er.expr)
        if peek_type(tokens, p) == "COMMA" { p = p + 1 }
    }
    return new_expr_result(Expr::ListLit(vals), p)
}

fn parse_struct_construct(tokens: List<Token>, pos: Int, filename: String) -> ExprResult {
    // Parse: new Name { field1: val1, field2: val2 }
    // Returns Call(Ident("__new_Name"), [val1, val2])
    let struct_name: String = peek_value(tokens, pos + 1)
    let mut p: Int = pos + 2
    p = expect(tokens, p, "LBRACE")

    // Parse field values (returns ListLit wrapping the values)
    let fields_r: ExprResult = parse_struct_fields_to_list(tokens, p, filename)
    p = fields_r.pos

    // Extract the values from ListLit
    // The lowerer will handle Call("__new_Name", args) as struct construction
    let callee: Expr = Expr::Ident("__new_" + struct_name)
    match fields_r.expr {
        ListLit(vals) => {
            return new_expr_result(Expr::Call(callee, vals), p)
        },
        _ => {
            let empty: List<Expr> = []
            return new_expr_result(Expr::Call(callee, empty), p)
        }
    }
}

fn parse_atom(tokens: List<Token>, pos: Int, filename: String) -> ExprResult {
    let tt: String = peek_type(tokens, pos)
    let val: String = peek_value(tokens, pos)

    // Integer literals
    if tt == "DEC_INT" { return new_expr_result(Expr::IntLit(int(val)), pos + 1) }
    if tt == "HEX_INT" { return new_expr_result(Expr::IntLit(int(val)), pos + 1) }
    if tt == "BIN_INT" { return new_expr_result(Expr::IntLit(int(val)), pos + 1) }
    if tt == "OCT_INT" { return new_expr_result(Expr::IntLit(int(val)), pos + 1) }

    // Float literal
    if tt == "FLOAT_LIT" { return new_expr_result(Expr::FloatLit(float(val)), pos + 1) }

    // String literal — check for interpolation ${...}
    if tt == "STRING_LIT" {
        if has_interpolation(val) {
            let parts: List<Expr> = split_interp_parts(val)
            if len(parts) > 1 {
                // Multiple parts: return as a binary concat chain
                let mut result: Expr = parts[0]
                for i in 1..len(parts) {
                    result = Expr::Binary(result, "+", parts[i])
                }
                return new_expr_result(result, pos + 1)
            }
        }
        return new_expr_result(Expr::StringLit(val), pos + 1)
    }

    // Char literal
    if tt == "CHAR_LIT" { return new_expr_result(Expr::CharLit(val), pos + 1) }

    // Bool literals
    if tt == "KW_TRUE" { return new_expr_result(Expr::BoolLit(true), pos + 1) }
    if tt == "KW_FALSE" { return new_expr_result(Expr::BoolLit(false), pos + 1) }

    // None literal
    if tt == "KW_NONE" { return new_expr_result(Expr::NoneLit, pos + 1) }

    // Self
    if tt == "KW_SELF" { return new_expr_result(Expr::Ident("self"), pos + 1) }

    // If expression
    if tt == "KW_IF" { return parse_if_expr(tokens, pos, filename) }

    // Match expression
    if tt == "KW_MATCH" { return parse_match_expr(tokens, pos, filename) }

    // Spawn expression
    if tt == "KW_SPAWN" { return parse_spawn_expr(tokens, pos, filename) }

    // Sync expression
    if tt == "KW_SYNC" {
        let sr: ExprResult = parse_postfix(tokens, pos + 1, filename)
        return new_expr_result(Expr::Sync(sr.expr), sr.pos)
    }

    // Signal expression
    if tt == "KW_SIGNAL" { return parse_signal_expr(tokens, pos, filename) }

    // List literal
    if tt == "LBRACKET" { return parse_list_lit(tokens, pos, filename) }

    // Parenthesized expression
    if tt == "LPAREN" { return parse_paren_expr(tokens, pos, filename) }

    // Struct constructor: new Name { field: val, ... }
    // Emits as Call(Ident("__new_Name"), [val1, val2, ...]).
    // The emitter handles __new_ calls as struct construction.
    if tt == "KW_NEW" {
        return parse_struct_construct(tokens, pos, filename)
    }

    // Identifier or namespace access
    if tt == "NAME" {
        let name: String = val
        if peek_type(tokens, pos + 1) == "DOUBLE_COLON" {
            let ns_member: String = peek_value(tokens, pos + 2)
            return new_expr_result(Expr::NamespaceAccess(name, ns_member), pos + 3)
        }
        return new_expr_result(Expr::Ident(name), pos + 1)
    }

    // Fallback
    return new_expr_result(Expr::NoneLit, pos + 1)
}

// ---------------------------------------------------------------------------
// If expression
// ---------------------------------------------------------------------------

fn parse_if_expr(tokens: List<Token>, pos: Int, filename: String) -> ExprResult {
    let mut p: Int = pos + 1

    let cond_r: ExprResult = parse_expr(tokens, p, filename, 0)
    p = cond_r.pos

    let then_r: BlockResult = parse_block(tokens, p, filename)
    p = then_r.pos

    if peek_type(tokens, p) != "KW_ELSE" {
        return new_expr_result(Expr::If(cond_r.expr, then_r.block, none), p)
    }

    p = p + 1

    if peek_type(tokens, p) == "KW_IF" {
        let elif_r: ExprResult = parse_if_expr(tokens, p, filename)
        let else_stmts: List<Stmt> = [Stmt::ExprStmt(elif_r.expr)]
        let else_block: Block = new_block(new_span(0, 0, 0, 0), else_stmts)
        let else_clause: ElseClause = ElseClause::ElseBlock(else_block)
        return new_expr_result(Expr::If(cond_r.expr, then_r.block, else_clause), elif_r.pos)
    }

    let else_r: BlockResult = parse_block(tokens, p, filename)
    let else_clause: ElseClause = ElseClause::ElseBlock(else_r.block)
    return new_expr_result(Expr::If(cond_r.expr, then_r.block, else_clause), else_r.pos)
}

// ---------------------------------------------------------------------------
// Match expression
// ---------------------------------------------------------------------------

fn parse_match_expr(tokens: List<Token>, pos: Int, filename: String) -> ExprResult {
    let mut p: Int = pos + 1

    let subj_r: ExprResult = parse_expr(tokens, p, filename, 0)
    p = subj_r.pos

    p = expect(tokens, p, "LBRACE")

    let mut arms: List<MatchArm> = []
    for _ in 0..100 {
        p = skip_semis(tokens, p)
        if peek_type(tokens, p) == "RBRACE" {
            p = p + 1
            return new_expr_result(Expr::Match(subj_r.expr, arms), p)
        }

        let mar: MatchArmResult = parse_match_arm_item(tokens, p, filename)
        arms.push(mar.arm)
        p = mar.pos

        if peek_type(tokens, p) == "COMMA" { p = p + 1 }
    }

    return new_expr_result(Expr::Match(subj_r.expr, arms), p)
}

fn parse_match_arm_item(tokens: List<Token>, pos: Int, filename: String) -> MatchArmResult {
    let pr: PatternResult = parse_pattern(tokens, pos, filename)
    let mut p: Int = pr.pos
    p = expect(tokens, p, "FAT_ARROW")

    if peek_type(tokens, p) == "LBRACE" {
        let br: BlockResult = parse_block(tokens, p, filename)
        let arm: MatchArm = new_match_arm(pr.pattern, MatchArmBody::BlockBody(br.block))
        return new_match_arm_result(arm, br.pos)
    }

    let er: ExprResult = parse_expr(tokens, p, filename, 0)
    let arm: MatchArm = new_match_arm(pr.pattern, MatchArmBody::ExprBody(er.expr))
    return new_match_arm_result(arm, er.pos)
}

// ---------------------------------------------------------------------------
// Pattern
// ---------------------------------------------------------------------------

fn parse_pattern(tokens: List<Token>, pos: Int, filename: String) -> PatternResult {
    let tt: String = peek_type(tokens, pos)
    let val: String = peek_value(tokens, pos)

    if val == "_" {
        return new_pattern_result(Pattern::Wildcard, pos + 1)
    }

    if tt == "DEC_INT" { return new_pattern_result(Pattern::LiteralPat(Expr::IntLit(int(val))), pos + 1) }
    if tt == "FLOAT_LIT" { return new_pattern_result(Pattern::LiteralPat(Expr::FloatLit(float(val))), pos + 1) }
    if tt == "STRING_LIT" { return new_pattern_result(Pattern::LiteralPat(Expr::StringLit(val)), pos + 1) }
    if tt == "KW_TRUE" { return new_pattern_result(Pattern::LiteralPat(Expr::BoolLit(true)), pos + 1) }
    if tt == "KW_FALSE" { return new_pattern_result(Pattern::LiteralPat(Expr::BoolLit(false)), pos + 1) }

    if tt == "NAME" {
        if peek_type(tokens, pos + 1) == "LPAREN" {
            let name: String = val
            let mut p: Int = pos + 2
            let mut pats: List<Pattern> = []

            if peek_type(tokens, p) != "RPAREN" {
                let p0: PatternResult = parse_pattern(tokens, p, filename)
                pats.push(p0.pattern)
                p = p0.pos
                for _ in 0..20 {
                    if peek_type(tokens, p) != "COMMA" {
                        p = expect(tokens, p, "RPAREN")
                        return new_pattern_result(Pattern::ConstructorPat(name, pats), p)
                    }
                    p = p + 1
                    let pn: PatternResult = parse_pattern(tokens, p, filename)
                    pats.push(pn.pattern)
                    p = pn.pos
                }
            }
            p = expect(tokens, p, "RPAREN")
            return new_pattern_result(Pattern::ConstructorPat(name, pats), p)
        }

        return new_pattern_result(Pattern::IdentPat(val), pos + 1)
    }

    return new_pattern_result(Pattern::Wildcard, pos + 1)
}

// ---------------------------------------------------------------------------
// Spawn expression
// ---------------------------------------------------------------------------

fn parse_spawn_expr(tokens: List<Token>, pos: Int, filename: String) -> ExprResult {
    let mut p: Int = pos + 1
    let name: String = peek_value(tokens, p)
    p = p + 1

    p = expect(tokens, p, "LPAREN")
    let mut args: List<Expr> = []
    if peek_type(tokens, p) != "RPAREN" {
        let a0: ExprResult = parse_expr(tokens, p, filename, 0)
        args.push(a0.expr)
        p = a0.pos
        for _ in 0..50 {
            if peek_type(tokens, p) != "COMMA" {
                p = expect(tokens, p, "RPAREN")
                let callee: Expr = Expr::Ident(name)
                return new_expr_result(Expr::Spawn(callee, args), p)
            }
            p = p + 1
            let an: ExprResult = parse_expr(tokens, p, filename, 0)
            args.push(an.expr)
            p = an.pos
        }
    }
    p = expect(tokens, p, "RPAREN")
    let callee: Expr = Expr::Ident(name)
    return new_expr_result(Expr::Spawn(callee, args), p)
}

// ---------------------------------------------------------------------------
// Signal expression
// ---------------------------------------------------------------------------

fn parse_signal_expr(tokens: List<Token>, pos: Int, filename: String) -> ExprResult {
    let mut p: Int = pos + 1

    if peek_type(tokens, p) == "LPAREN" {
        p = p + 1
        let er: ExprResult = parse_expr(tokens, p, filename, 0)
        p = er.pos
        p = expect(tokens, p, "RPAREN")
        return new_expr_result(Expr::SignalVal(er.expr, false), p)
    }

    if peek_type(tokens, p) == "LBRACE" {
        let br: BlockResult = parse_block(tokens, p, filename)
        return new_expr_result(Expr::SignalVal(Expr::NoneLit, true), br.pos)
    }

    return new_expr_result(Expr::NoneLit, p)
}

// ---------------------------------------------------------------------------
// List literal
// ---------------------------------------------------------------------------

fn parse_list_lit(tokens: List<Token>, pos: Int, filename: String) -> ExprResult {
    let mut p: Int = pos + 1
    let mut elems: List<Expr> = []

    if peek_type(tokens, p) == "RBRACKET" {
        p = p + 1
        return new_expr_result(Expr::ListLit(elems), p)
    }

    let e0: ExprResult = parse_expr(tokens, p, filename, 0)
    elems.push(e0.expr)
    p = e0.pos

    for _ in 0..10000 {
        if peek_type(tokens, p) != "COMMA" {
            p = expect(tokens, p, "RBRACKET")
            return new_expr_result(Expr::ListLit(elems), p)
        }
        p = p + 1
        if peek_type(tokens, p) == "RBRACKET" {
            p = p + 1
            return new_expr_result(Expr::ListLit(elems), p)
        }
        let en: ExprResult = parse_expr(tokens, p, filename, 0)
        elems.push(en.expr)
        p = en.pos
    }

    p = expect(tokens, p, "RBRACKET")
    return new_expr_result(Expr::ListLit(elems), p)
}

// ---------------------------------------------------------------------------
// Parenthesized expression
// ---------------------------------------------------------------------------

fn parse_paren_expr(tokens: List<Token>, pos: Int, filename: String) -> ExprResult {
    let mut p: Int = pos + 1

    let er: ExprResult = parse_expr(tokens, p, filename, 0)
    p = er.pos

    if peek_type(tokens, p) == "RPAREN" {
        p = p + 1
        return new_expr_result(er.expr, p)
    }

    // Tuple: (expr, expr, ...)
    let mut elems: List<Expr> = [er.expr]
    for _ in 0..100 {
        if peek_type(tokens, p) != "COMMA" {
            p = expect(tokens, p, "RPAREN")
            return new_expr_result(Expr::ListLit(elems), p)
        }
        p = p + 1
        let en: ExprResult = parse_expr(tokens, p, filename, 0)
        elems.push(en.expr)
        p = en.pos
    }
    p = expect(tokens, p, "RPAREN")
    return new_expr_result(Expr::ListLit(elems), p)
}

// ---------------------------------------------------------------------------
// Type expression parser
// ---------------------------------------------------------------------------

fn parse_type_expr(tokens: List<Token>, pos: Int, filename: String) -> TypeResult {
    let tt: String = peek_type(tokens, pos)

    if tt == "KW_FN" { return parse_fn_type(tokens, pos, filename) }

    if tt == "NAME" {
        let name: String = peek_value(tokens, pos)
        if peek_type(tokens, pos + 1) == "LT" {
            return parse_generic_type(tokens, pos, filename)
        }
        return new_type_result(TypeExpr::Named(name), pos + 1)
    }

    return new_type_result(TypeExpr::Named("Void"), pos + 1)
}

fn parse_generic_type(tokens: List<Token>, pos: Int, filename: String) -> TypeResult {
    let name: String = peek_value(tokens, pos)
    let mut p: Int = pos + 1
    p = expect(tokens, p, "LT")

    let mut args: List<TypeExpr> = []
    let t0: TypeResult = parse_type_expr(tokens, p, filename)
    args.push(t0.type_expr)
    p = t0.pos

    for _ in 0..20 {
        if peek_type(tokens, p) != "COMMA" {
            p = expect(tokens, p, "GT")
            return new_type_result(TypeExpr::Generic(name, args), p)
        }
        p = p + 1
        let tn: TypeResult = parse_type_expr(tokens, p, filename)
        args.push(tn.type_expr)
        p = tn.pos
    }

    p = expect(tokens, p, "GT")
    return new_type_result(TypeExpr::Generic(name, args), p)
}

fn parse_fn_type(tokens: List<Token>, pos: Int, filename: String) -> TypeResult {
    let mut p: Int = pos + 1
    p = expect(tokens, p, "LPAREN")

    let mut param_types: List<TypeExpr> = []
    if peek_type(tokens, p) != "RPAREN" {
        let t0: TypeResult = parse_type_expr(tokens, p, filename)
        param_types.push(t0.type_expr)
        p = t0.pos
        for _ in 0..20 {
            if peek_type(tokens, p) != "COMMA" {
                p = expect(tokens, p, "RPAREN")
                p = expect(tokens, p, "ARROW")
                let ret: TypeResult = parse_type_expr(tokens, p, filename)
                return new_type_result(TypeExpr::FnTy(param_types, ret.type_expr), ret.pos)
            }
            p = p + 1
            let tn: TypeResult = parse_type_expr(tokens, p, filename)
            param_types.push(tn.type_expr)
            p = tn.pos
        }
    }
    p = expect(tokens, p, "RPAREN")
    p = expect(tokens, p, "ARROW")
    let ret: TypeResult = parse_type_expr(tokens, p, filename)
    return new_type_result(TypeExpr::FnTy(param_types, ret.type_expr), ret.pos)
}

// ===== semantic.mn =====
// semantic.mn — Semantic analysis for the Mapanare self-hosted compiler.
// Port of mapa/semantic.py to native Mapanare.
// Performs type checking and scope resolution via two-pass analysis:
//   Pass 1: register all top-level definitions (names & signatures)
//   Pass 2: check function bodies, expressions, and statements


// ---------------------------------------------------------------------------
// SemanticError
// ---------------------------------------------------------------------------

struct SemanticError {
    message: String,
    line: Int,
    column: Int,
    filename: String
}

fn new_semantic_error(msg: String, line: Int, col: Int, fname: String) -> SemanticError {
    return new SemanticError { message: msg, line: line, column: col, filename: fname }
}

// ---------------------------------------------------------------------------
// Type representation
// ---------------------------------------------------------------------------

struct TypeInfo {
    name: String,
    args: List<TypeInfo>,
    is_function: Bool,
    param_types: List<TypeInfo>,
    return_type: Option<TypeInfo>,
    tensor_shape: Option<List<Int>>
}

fn new_type_info(name: String, args: List<TypeInfo>, is_fn: Bool, params: List<TypeInfo>, ret: Option<TypeInfo>, shape: Option<List<Int>>) -> TypeInfo {
    return new TypeInfo { name: name, args: args, is_function: is_fn, param_types: params, return_type: ret, tensor_shape: shape }
}

// Singleton type constructors
fn unknown_type() -> TypeInfo {
    return make_type("<unknown>")
}

fn int_type() -> TypeInfo {
    return make_type("Int")
}

fn float_type() -> TypeInfo {
    return make_type("Float")
}

fn bool_type() -> TypeInfo {
    return make_type("Bool")
}

fn string_type() -> TypeInfo {
    return make_type("String")
}

fn char_type() -> TypeInfo {
    return make_type("Char")
}

fn void_type() -> TypeInfo {
    return make_type("Void")
}

fn make_type(name: String) -> TypeInfo {
    let args: List<TypeInfo> = []
    let params: List<TypeInfo> = []
    return new_type_info(name, args, false, params, none, none)
}

fn make_generic_type(name: String, args: List<TypeInfo>) -> TypeInfo {
    let params: List<TypeInfo> = []
    return new_type_info(name, args, false, params, none, none)
}

fn make_fn_type(params: List<TypeInfo>, ret: TypeInfo) -> TypeInfo {
    let args: List<TypeInfo> = []
    return new_type_info("<fn>", args, true, params, Some(ret), none)
}

fn make_builtin_fn_type(ret: TypeInfo) -> TypeInfo {
    let args: List<TypeInfo> = []
    let params: List<TypeInfo> = []
    return new_type_info("<builtin>", args, true, params, Some(ret), none)
}

// ---------------------------------------------------------------------------
// Primitive and builtin type sets
// ---------------------------------------------------------------------------

fn is_primitive_type(name: String) -> Bool {
    if name == "Int" { return true }
    if name == "Float" { return true }
    if name == "Bool" { return true }
    if name == "String" { return true }
    if name == "Char" { return true }
    if name == "Void" { return true }
    return false
}

fn is_builtin_generic(name: String) -> Bool {
    if name == "Option" { return true }
    if name == "Result" { return true }
    if name == "List" { return true }
    if name == "Map" { return true }
    if name == "Signal" { return true }
    if name == "Stream" { return true }
    if name == "Channel" { return true }
    if name == "Tensor" { return true }
    return false
}

fn is_builtin_function(name: String) -> Bool {
    if name == "print" { return true }
    if name == "println" { return true }
    if name == "len" { return true }
    if name == "toString" { return true }
    if name == "str" { return true }
    if name == "int" { return true }
    if name == "float" { return true }
    if name == "Some" { return true }
    if name == "Ok" { return true }
    if name == "Err" { return true }
    if name == "signal" { return true }
    if name == "stream" { return true }
    if name == "ord" { return true }
    if name == "chr" { return true }
    if name == "join" { return true }
    return false
}

fn builtin_return_type(name: String) -> String {
    if name == "print" { return "Void" }
    if name == "println" { return "Void" }
    if name == "len" { return "Int" }
    if name == "toString" { return "String" }
    if name == "str" { return "String" }
    if name == "int" { return "Int" }
    if name == "float" { return "Float" }
    if name == "Some" { return "Option" }
    if name == "Ok" { return "Result" }
    if name == "Err" { return "Result" }
    if name == "signal" { return "Signal" }
    if name == "stream" { return "Stream" }
    if name == "ord" { return "Int" }
    if name == "chr" { return "String" }
    if name == "join" { return "String" }
    return "Void"
}

// ---------------------------------------------------------------------------
// Symbol table
// ---------------------------------------------------------------------------

struct Symbol {
    name: String,
    kind: String,
    type_info: TypeInfo,
    mutable: Bool
}

fn new_symbol(name: String, kind: String, ti: TypeInfo, mutable: Bool) -> Symbol {
    return new Symbol { name: name, kind: kind, type_info: ti, mutable: mutable }
}

struct Scope {
    parent: Option<Scope>,
    symbols: List<Symbol>
}

fn new_scope(parent: Option<Scope>) -> Scope {
    let syms: List<Symbol> = []
    return new Scope { parent: parent, symbols: syms }
}

fn scope_define(scope: Scope, name: String, sym: Symbol) -> Scope {
    // Append symbol to scope's symbol list.
    // Later entries shadow earlier ones (last-match-wins in lookup).
    let mut syms: List<Symbol> = scope.symbols
    // syms.push(sym) — append to list
    return new_scope(scope.parent)
}

fn scope_lookup(scope: Scope, name: String) -> Option<Symbol> {
    // Linear search through symbols (last to first for shadowing).
    let mut i: Int = len(scope.symbols) - 1
    for _ in 0..1000000 {
        if i < 0 {
            // Not found locally; walk to parent scope.
            match scope.parent {
                Some(parent) => { return scope_lookup(parent, name) },
                _ => { return none }
            }
        }
        let sym: Symbol = scope.symbols[i]
        if sym.name == name { return Some(sym) }
        i = i - 1
    }
    return none
}

fn scope_lookup_local(scope: Scope, name: String) -> Option<Symbol> {
    // Only search the current scope (no parent walk).
    let mut i: Int = len(scope.symbols) - 1
    for _ in 0..1000000 {
        if i < 0 { return none }
        let sym: Symbol = scope.symbols[i]
        if sym.name == name { return Some(sym) }
        i = i - 1
    }
    return none
}

// ---------------------------------------------------------------------------
// Semantic checker state
// ---------------------------------------------------------------------------

struct SemanticChecker {
    filename: String,
    errors: List<SemanticError>,
    global_scope: Scope,
    current_scope: Scope
}

fn new_checker(filename: String) -> SemanticChecker {
    let scope: Scope = new_scope(none)
    let errs: List<SemanticError> = []
    return new SemanticChecker { filename: filename, errors: errs, global_scope: scope, current_scope: scope }
}

// ---------------------------------------------------------------------------
// State threading — result structs for functions that return a value + state
// ---------------------------------------------------------------------------

struct SemState {
    errors: List<SemanticError>,
    scope: Scope,
    filename: String
}

struct InferResult {
    type_info: TypeInfo,
    st: SemState
}

struct CheckResult {
    st: SemState
}

fn new_sem_state(filename: String) -> SemState {
    let scope: Scope = new_scope(none)
    let sem_errs: List<SemanticError> = []
    return new SemState { errors: sem_errs, scope: scope, filename: filename }
}

fn new_infer_result(ti: TypeInfo, st: SemState) -> InferResult {
    return new InferResult { type_info: ti, st: st }
}

fn new_check_result(st: SemState) -> CheckResult {
    return new CheckResult { st: st }
}

// ---------------------------------------------------------------------------
// Error helpers
// ---------------------------------------------------------------------------

fn add_error(st: SemState, msg: String, line: Int, col: Int) -> SemState {
    let err: SemanticError = new_semantic_error(msg, line, col, st.filename)
    // st.errors.push(err)
    return st
}

fn add_error_msg(st: SemState, msg: String) -> SemState {
    return add_error(st, msg, 0, 0)
}

// ---------------------------------------------------------------------------
// Scope helpers
// ---------------------------------------------------------------------------

fn push_scope(st: SemState) -> SemState {
    let child: Scope = new_scope(Some(st.scope))
    let new_st: SemState = new SemState { errors: st.errors, scope: child, filename: st.filename }
    return new_st
}

fn pop_scope(st: SemState) -> SemState {
    match st.scope.parent {
        Some(parent) => {
            let new_st: SemState = new SemState { errors: st.errors, scope: parent, filename: st.filename }
            return new_st
        },
        _ => { return st }
    }
}

fn define_in_scope(st: SemState, name: String, sym: Symbol) -> SemState {
    let new_scope_val: Scope = scope_define(st.scope, name, sym)
    let new_st: SemState = new SemState { errors: st.errors, scope: new_scope_val, filename: st.filename }
    return new_st
}

// ---------------------------------------------------------------------------
// Type compatibility checking
// ---------------------------------------------------------------------------

fn types_compatible(a: TypeInfo, b: TypeInfo) -> Bool {
    if a.name == "<unknown>" { return true }
    if b.name == "<unknown>" { return true }
    if a.is_function {
        if b.is_function {
            // Compare param counts and return types
            if len(a.param_types) != len(b.param_types) { return false }
            return true
        }
        return false
    }
    if a.name != b.name { return false }
    return true
}

fn is_numeric_type(name: String) -> Bool {
    if name == "Int" { return true }
    if name == "Float" { return true }
    if name == "<unknown>" { return true }
    return false
}

fn is_arithmetic_operand(name: String) -> Bool {
    if name == "Int" { return true }
    if name == "Float" { return true }
    if name == "String" { return true }
    if name == "Tensor" { return true }
    if name == "<unknown>" { return true }
    return false
}

fn type_exists(st: SemState, t: TypeInfo) -> Bool {
    if is_primitive_type(t.name) { return true }
    if is_builtin_generic(t.name) { return true }
    let sym: Option<Symbol> = scope_lookup(st.scope, t.name)
    match sym {
        Some(s) => {
            if s.kind == "struct" { return true }
            if s.kind == "enum" { return true }
            if s.kind == "agent" { return true }
            if s.kind == "type_alias" { return true }
            return false
        },
        _ => { return false }
    }
}

// ---------------------------------------------------------------------------
// Binary operator type rules
// ---------------------------------------------------------------------------

fn check_arithmetic_result(left: String, right: String, op: String) -> String {
    if left == "Tensor" { return "Tensor" }
    if right == "Tensor" { return "Tensor" }
    if op == "+" {
        if left == "String" { return "String" }
        if right == "String" { return "String" }
    }
    if left == "Float" { return "Float" }
    if right == "Float" { return "Float" }
    if left == "Int" {
        if right == "Int" { return "Int" }
    }
    return "<unknown>"
}

fn check_comparison_result(left: String, right: String) -> String {
    return "Bool"
}

fn check_logical_result(left: String, right: String) -> String {
    return "Bool"
}

// ---------------------------------------------------------------------------
// Type resolution — convert TypeExpr AST nodes to TypeInfo
// ---------------------------------------------------------------------------

fn resolve_type_expr(te: TypeExpr) -> TypeInfo {
    match te {
        Named(name) => { return make_type(name) },
        Generic(name, args) => {
            let mut resolved: List<TypeInfo> = []
            let mut i: Int = 0
            for _ in 0..1000 {
                if i >= len(args) { return make_generic_type(name, resolved) }
                let arg: TypeExpr = args[i]
                let rt: TypeInfo = resolve_type_expr(arg)
                resolved.push(rt)
                i = i + 1
            }
            return make_generic_type(name, resolved)
        },
        FnTy(param_types, return_type) => {
            let mut params: List<TypeInfo> = []
            let mut i: Int = 0
            for _ in 0..1000 {
                if i >= len(param_types) {
                    let ret: TypeInfo = resolve_type_expr(return_type)
                    return make_fn_type(params, ret)
                }
                let pt: TypeExpr = param_types[i]
                let rp: TypeInfo = resolve_type_expr(pt)
                params.push(rp)
                i = i + 1
            }
            let ret2: TypeInfo = resolve_type_expr(return_type)
            return make_fn_type(params, ret2)
        },
        _ => { return unknown_type() }
    }
}

fn resolve_type_opt(te: Option<TypeExpr>) -> TypeInfo {
    match te {
        Some(t) => { return resolve_type_expr(t) },
        _ => { return unknown_type() }
    }
}

// ---------------------------------------------------------------------------
// Expression type inference
// ---------------------------------------------------------------------------

fn infer_expr(st: SemState, expr: Expr) -> InferResult {
    match expr {
        IntLit(_) => { return new_infer_result(int_type(), st) },
        FloatLit(_) => { return new_infer_result(float_type(), st) },
        BoolLit(_) => { return new_infer_result(bool_type(), st) },
        StringLit(_) => { return new_infer_result(string_type(), st) },
        CharLit(_) => { return new_infer_result(char_type(), st) },
        NoneLit => { return new_infer_result(make_type("Option"), st) },

        Ident(name) => {
            let result: Option<Symbol> = scope_lookup(st.scope, name)
            match result {
                Some(sym) => { return new_infer_result(sym.type_info, st) },
                _ => {
                    let st2: SemState = add_error(st, "Undefined variable '" + name + "'", 0, 0)
                    return new_infer_result(unknown_type(), st2)
                }
            }
        },

        Binary(left, op, right) => { return check_binary_expr(st, left, op, right) },
        Unary(op, operand) => { return check_unary_expr(st, op, operand) },
        Call(callee, args) => { return check_call_expr(st, callee, args) },

        MethodCall(obj, method_name, args) => {
            let obj_r: InferResult = infer_expr(st, obj)
            let mut st2: SemState = obj_r.st
            let mut i: Int = 0
            for _ in 0..1000 {
                if i >= len(args) { return new_infer_result(unknown_type(), st2) }
                let arg: Expr = args[i]
                let ar: InferResult = infer_expr(st2, arg)
                st2 = ar.st
                i = i + 1
            }
            return new_infer_result(unknown_type(), st2)
        },

        FieldAccess(obj, field_name) => {
            let obj_r: InferResult = infer_expr(st, obj)
            return new_infer_result(unknown_type(), obj_r.st)
        },

        NamespaceAccess(ns, name) => {
            return new_infer_result(unknown_type(), st)
        },

        Index(obj, idx) => {
            let obj_r: InferResult = infer_expr(st, obj)
            let idx_r: InferResult = infer_expr(obj_r.st, idx)
            // List<T>[i] -> T
            if obj_r.type_info.name == "List" {
                if len(obj_r.type_info.args) > 0 {
                    let elem: TypeInfo = obj_r.type_info.args[0]
                    return new_infer_result(elem, idx_r.st)
                }
            }
            return new_infer_result(unknown_type(), idx_r.st)
        },

        Pipe(left, right) => { return check_pipe_expr(st, left, right) },

        Range(start, end, inclusive) => {
            let sr: InferResult = infer_expr(st, start)
            let er: InferResult = infer_expr(sr.st, end)
            return new_infer_result(make_type("Range"), er.st)
        },

        Lambda(params, body) => { return check_lambda_expr(st, params, body) },
        Spawn(callee, args) => { return check_spawn_expr(st, callee, args) },

        Sync(inner) => {
            let ir: InferResult = infer_expr(st, inner)
            return new_infer_result(unknown_type(), ir.st)
        },

        Send(value, target) => {
            let st2: SemState = check_send_expr(st, value, target)
            return new_infer_result(void_type(), st2)
        },

        ErrorProp(inner) => {
            let ir: InferResult = infer_expr(st, inner)
            return new_infer_result(unknown_type(), ir.st)
        },

        ListLit(elements) => {
            if len(elements) > 0 {
                let first: Expr = elements[0]
                let fr: InferResult = infer_expr(st, first)
                let mut st2: SemState = fr.st
                let mut i: Int = 1
                for _ in 0..100000 {
                    if i >= len(elements) {
                        let args: List<TypeInfo> = []
                        // args.push(fr.type_info)
                        return new_infer_result(make_generic_type("List", args), st2)
                    }
                    let elem: Expr = elements[i]
                    let er: InferResult = infer_expr(st2, elem)
                    st2 = er.st
                    i = i + 1
                }
                let args2: List<TypeInfo> = []
                return new_infer_result(make_generic_type("List", args2), st2)
            }
            let empty_args: List<TypeInfo> = []
            return new_infer_result(make_generic_type("List", empty_args), st)
        },

        Construct(name, fields) => {
            let mut st2: SemState = st
            let mut i: Int = 0
            for _ in 0..1000 {
                if i >= len(fields) { return new_infer_result(make_type(name), st2) }
                let fi: FieldInit = fields[i]
                let fr: InferResult = infer_expr(st2, fi.value)
                st2 = fr.st
                i = i + 1
            }
            return new_infer_result(make_type(name), st2)
        },

        SomeWrap(value) => {
            let vr: InferResult = infer_expr(st, value)
            let args: List<TypeInfo> = []
            // args.push(vr.type_info)
            return new_infer_result(make_generic_type("Option", args), vr.st)
        },

        OkWrap(value) => {
            let vr: InferResult = infer_expr(st, value)
            let args: List<TypeInfo> = []
            // args.push(vr.type_info)
            return new_infer_result(make_generic_type("Result", args), vr.st)
        },

        ErrWrap(value) => {
            let vr: InferResult = infer_expr(st, value)
            let args: List<TypeInfo> = []
            return new_infer_result(make_generic_type("Result", args), vr.st)
        },

        SignalVal(value, _) => {
            let vr: InferResult = infer_expr(st, value)
            let args: List<TypeInfo> = []
            // args.push(vr.type_info)
            return new_infer_result(make_generic_type("Signal", args), vr.st)
        },

        Assign(target, op, value) => { return check_assign_expr(st, target, op, value) },
        If(cond, then_block, else_clause) => { return check_if_expr(st, cond, then_block, else_clause) },
        Match(subject, arms) => { return check_match_expr(st, subject, arms) },

        _ => { return new_infer_result(unknown_type(), st) }
    }
}

// ---------------------------------------------------------------------------
// Binary operators
// ---------------------------------------------------------------------------

fn check_binary_expr(st: SemState, left: Expr, op: String, right: Expr) -> InferResult {
    let lr: InferResult = infer_expr(st, left)
    let rr: InferResult = infer_expr(lr.st, right)
    let lt: String = lr.type_info.name
    let rt: String = rr.type_info.name
    let st2: SemState = rr.st

    // Arithmetic operators
    if op == "+" { return check_arithmetic_binary(st2, lt, rt, op, lr.type_info, rr.type_info) }
    if op == "-" { return check_arithmetic_binary(st2, lt, rt, op, lr.type_info, rr.type_info) }
    if op == "*" { return check_arithmetic_binary(st2, lt, rt, op, lr.type_info, rr.type_info) }
    if op == "/" { return check_arithmetic_binary(st2, lt, rt, op, lr.type_info, rr.type_info) }
    if op == "%" { return check_arithmetic_binary(st2, lt, rt, op, lr.type_info, rr.type_info) }

    // Comparison and equality operators
    if op == "<" { return new_infer_result(bool_type(), st2) }
    if op == ">" { return new_infer_result(bool_type(), st2) }
    if op == "<=" { return new_infer_result(bool_type(), st2) }
    if op == ">=" { return new_infer_result(bool_type(), st2) }
    if op == "==" { return new_infer_result(bool_type(), st2) }
    if op == "!=" { return new_infer_result(bool_type(), st2) }

    // Logical operators
    if op == "&&" { return check_logical_binary(st2, lt, rt, op) }
    if op == "||" { return check_logical_binary(st2, lt, rt, op) }

    // Matrix multiply
    if op == "@" { return check_matmul_binary(st2, lt, rt, lr.type_info, rr.type_info) }

    return new_infer_result(unknown_type(), st2)
}

fn check_arithmetic_binary(st: SemState, lt: String, rt: String, op: String, left_ti: TypeInfo, right_ti: TypeInfo) -> InferResult {
    // Tensor element-wise operations
    if lt == "Tensor" {
        if rt != "<unknown>" {
            if rt != "Tensor" {
                if rt != "Int" {
                    if rt != "Float" {
                        let st2: SemState = add_error(st, "Operator '" + op + "' not supported for Tensor and " + rt, 0, 0)
                        return new_infer_result(make_type("Tensor"), st2)
                    }
                }
            }
        }
        return new_infer_result(make_type("Tensor"), st)
    }
    if rt == "Tensor" {
        if lt != "<unknown>" {
            if lt != "Int" {
                if lt != "Float" {
                    let st2: SemState = add_error(st, "Operator '" + op + "' not supported for " + lt + " and Tensor", 0, 0)
                    return new_infer_result(make_type("Tensor"), st2)
                }
            }
        }
        return new_infer_result(make_type("Tensor"), st)
    }

    // Non-tensor arithmetic
    if lt != "<unknown>" {
        if lt != "Int" {
            if lt != "Float" {
                if lt != "String" {
                    let st2: SemState = add_error(st, "Operator '" + op + "' not supported for types " + lt + " and " + rt, 0, 0)
                    return new_infer_result(unknown_type(), st2)
                }
            }
        }
    }
    if rt != "<unknown>" {
        if rt != "Int" {
            if rt != "Float" {
                if rt != "String" {
                    let st2: SemState = add_error(st, "Operator '" + op + "' not supported for types " + lt + " and " + rt, 0, 0)
                    return new_infer_result(unknown_type(), st2)
                }
            }
        }
    }

    let result_name: String = check_arithmetic_result(lt, rt, op)
    return new_infer_result(make_type(result_name), st)
}

fn check_logical_binary(st: SemState, lt: String, rt: String, op: String) -> InferResult {
    let mut st2: SemState = st
    if lt != "<unknown>" {
        if lt != "Bool" {
            st2 = add_error(st2, "Operator '" + op + "' requires Bool, got " + lt, 0, 0)
        }
    }
    if rt != "<unknown>" {
        if rt != "Bool" {
            st2 = add_error(st2, "Operator '" + op + "' requires Bool, got " + rt, 0, 0)
        }
    }
    return new_infer_result(bool_type(), st2)
}

fn check_matmul_binary(st: SemState, lt: String, rt: String, left_ti: TypeInfo, right_ti: TypeInfo) -> InferResult {
    let mut st2: SemState = st
    if lt != "<unknown>" {
        if lt != "Tensor" {
            st2 = add_error(st2, "Operator '@' requires Tensor, got " + lt, 0, 0)
        }
    }
    if rt != "<unknown>" {
        if rt != "Tensor" {
            st2 = add_error(st2, "Operator '@' requires Tensor, got " + rt, 0, 0)
        }
    }
    let elem: TypeInfo = unknown_type()
    if len(left_ti.args) > 0 {
        let elem2: TypeInfo = left_ti.args[0]
        let args: List<TypeInfo> = []
        // args.push(elem2)
        return new_infer_result(make_generic_type("Tensor", args), st2)
    }
    let args3: List<TypeInfo> = []
    return new_infer_result(make_generic_type("Tensor", args3), st2)
}

// ---------------------------------------------------------------------------
// Unary operators
// ---------------------------------------------------------------------------

fn check_unary_expr(st: SemState, op: String, operand: Expr) -> InferResult {
    let or: InferResult = infer_expr(st, operand)
    let ot: String = or.type_info.name

    if op == "-" {
        if ot != "<unknown>" {
            if ot != "Int" {
                if ot != "Float" {
                    let st2: SemState = add_error(or.st, "Unary '-' not supported for type " + ot, 0, 0)
                    return new_infer_result(or.type_info, st2)
                }
            }
        }
        return new_infer_result(or.type_info, or.st)
    }

    if op == "!" {
        if ot != "<unknown>" {
            if ot != "Bool" {
                let st2: SemState = add_error(or.st, "Unary '!' requires Bool, got " + ot, 0, 0)
                return new_infer_result(bool_type(), st2)
            }
        }
        return new_infer_result(bool_type(), or.st)
    }

    return new_infer_result(unknown_type(), or.st)
}

// ---------------------------------------------------------------------------
// Call expression
// ---------------------------------------------------------------------------

fn check_call_expr(st: SemState, callee: Expr, args: List<Expr>) -> InferResult {
    // Infer argument types
    let mut st2: SemState = st
    let mut arg_types: List<TypeInfo> = []
    let mut i: Int = 0
    for _ in 0..1000 {
        if i >= len(args) {
            return check_call_resolved(st2, callee, arg_types)
        }
        let arg: Expr = args[i]
        let ar: InferResult = infer_expr(st2, arg)
        st2 = ar.st
        // arg_types.push(ar.type_info)
        i = i + 1
    }
    return check_call_resolved(st2, callee, arg_types)
}

fn check_call_resolved(st: SemState, callee: Expr, arg_types: List<TypeInfo>) -> InferResult {
    match callee {
        Ident(name) => {
            let sym_opt: Option<Symbol> = scope_lookup(st.scope, name)
            match sym_opt {
                Some(sym) => {
                    if sym.kind == "function" {
                        if sym.type_info.is_function {
                            match sym.type_info.return_type {
                                Some(ret) => {
                                    // Check argument count
                                    if len(sym.type_info.param_types) > 0 {
                                        if len(arg_types) != len(sym.type_info.param_types) {
                                            let st2: SemState = add_error(st, "Function '" + name + "' argument count mismatch", 0, 0)
                                            return new_infer_result(ret, st2)
                                        }
                                    }
                                    return new_infer_result(ret, st)
                                },
                                _ => { return new_infer_result(unknown_type(), st) }
                            }
                        }
                        return new_infer_result(unknown_type(), st)
                    }
                    if sym.kind == "agent" {
                        return new_infer_result(make_type(sym.name), st)
                    }
                    if sym.kind == "struct" {
                        return new_infer_result(make_type(sym.name), st)
                    }
                    return new_infer_result(unknown_type(), st)
                },
                _ => {
                    let st2: SemState = add_error(st, "Undefined function '" + name + "'", 0, 0)
                    return new_infer_result(unknown_type(), st2)
                }
            }
        },
        _ => {
            let cr: InferResult = infer_expr(st, callee)
            return new_infer_result(unknown_type(), cr.st)
        }
    }
}

// ---------------------------------------------------------------------------
// Assignment
// ---------------------------------------------------------------------------

fn check_assign_expr(st: SemState, target: Expr, op: String, value: Expr) -> InferResult {
    let vr: InferResult = infer_expr(st, value)

    match target {
        Ident(name) => {
            let sym_opt: Option<Symbol> = scope_lookup(vr.st.scope, name)
            match sym_opt {
                Some(sym) => {
                    let mut st2: SemState = vr.st
                    if sym.mutable == false {
                        st2 = add_error(st2, "Cannot assign to immutable variable '" + name + "'", 0, 0)
                    }
                    if sym.type_info.name != "<unknown>" {
                        if vr.type_info.name != "<unknown>" {
                            if types_compatible(sym.type_info, vr.type_info) == false {
                                st2 = add_error(st2, "Type mismatch in assignment to '" + name + "'", 0, 0)
                            }
                        }
                    }
                    return new_infer_result(void_type(), st2)
                },
                _ => {
                    let st2: SemState = add_error(vr.st, "Undefined variable '" + name + "'", 0, 0)
                    return new_infer_result(void_type(), st2)
                }
            }
        },
        _ => {
            // Field or index target — infer both sides
            let tr: InferResult = infer_expr(vr.st, target)
            return new_infer_result(void_type(), tr.st)
        }
    }
}

// ---------------------------------------------------------------------------
// If expression
// ---------------------------------------------------------------------------

fn check_if_expr(st: SemState, cond: Expr, then_block: Block, else_clause: Option<ElseClause>) -> InferResult {
    let cr: InferResult = infer_expr(st, cond)
    let mut st2: SemState = cr.st

    if cr.type_info.name != "<unknown>" {
        if cr.type_info.name != "Bool" {
            st2 = add_error(st2, "If condition must be Bool, got " + cr.type_info.name, 0, 0)
        }
    }

    // Check then block
    let then_st: SemState = push_scope(st2)
    let after_then: SemState = check_block(then_st, then_block)
    st2 = pop_scope(after_then)

    // Check else clause
    match else_clause {
        Some(ec) => {
            st2 = check_else_clause(st2, ec)
        },
        _ => {}
    }

    return new_infer_result(unknown_type(), st2)
}

fn check_else_clause(st: SemState, ec: ElseClause) -> SemState {
    match ec {
        ElseBlock(block) => {
            let inner: SemState = push_scope(st)
            let after: SemState = check_block(inner, block)
            return pop_scope(after)
        },
        ElseIf(cond, block, next_else) => {
            let r: InferResult = check_if_expr(st, cond, block, next_else)
            return r.st
        }
    }
}

// ---------------------------------------------------------------------------
// Match expression
// ---------------------------------------------------------------------------

fn check_match_expr(st: SemState, subject: Expr, arms: List<MatchArm>) -> InferResult {
    let sr: InferResult = infer_expr(st, subject)
    let mut st2: SemState = sr.st
    let mut i: Int = 0
    for _ in 0..1000 {
        if i >= len(arms) { return new_infer_result(unknown_type(), st2) }
        let arm: MatchArm = arms[i]
        let arm_st: SemState = push_scope(st2)
        let bound_st: SemState = bind_pattern(arm_st, arm.pattern)
        let after_arm: SemState = check_match_arm_body(bound_st, arm.body)
        st2 = pop_scope(after_arm)
        i = i + 1
    }
    return new_infer_result(unknown_type(), st2)
}

fn check_match_arm_body(st: SemState, body: MatchArmBody) -> SemState {
    match body {
        ExprBody(expr) => {
            let r: InferResult = infer_expr(st, expr)
            return r.st
        },
        BlockBody(block) => {
            return check_block(st, block)
        }
    }
}

fn bind_pattern(st: SemState, pat: Pattern) -> SemState {
    match pat {
        Wildcard => { return st },
        IdentPat(name) => {
            let sym: Symbol = new_symbol(name, "variable", unknown_type(), false)
            return define_in_scope(st, name, sym)
        },
        LiteralPat(_) => { return st },
        ConstructorPat(name, args) => {
            let mut st2: SemState = st
            let mut i: Int = 0
            for _ in 0..1000 {
                if i >= len(args) { return st2 }
                let arg: Pattern = args[i]
                st2 = bind_pattern(st2, arg)
                i = i + 1
            }
            return st2
        }
    }
}

// ---------------------------------------------------------------------------
// Lambda
// ---------------------------------------------------------------------------

fn check_lambda_expr(st: SemState, params: List<Param>, body: LambdaBody) -> InferResult {
    let inner: SemState = push_scope(st)
    let mut st2: SemState = inner
    let mut param_types: List<TypeInfo> = []
    let mut i: Int = 0

    // Register parameters
    for _ in 0..1000 {
        if i >= len(params) {
            // Check body
            let body_result: InferResult = check_lambda_body(st2, body)
            let st3: SemState = pop_scope(body_result.st)
            let fn_ti: TypeInfo = make_fn_type(param_types, body_result.type_info)
            return new_infer_result(fn_ti, st3)
        }
        let p: Param = params[i]
        let pt: TypeInfo = resolve_type_opt(p.type_annotation)
        // param_types.push(pt)
        let sym: Symbol = new_symbol(p.name, "param", pt, false)
        st2 = define_in_scope(st2, p.name, sym)
        i = i + 1
    }

    let st4: SemState = pop_scope(st2)
    return new_infer_result(unknown_type(), st4)
}

fn check_lambda_body(st: SemState, body: LambdaBody) -> InferResult {
    match body {
        ExprBody(expr) => { return infer_expr(st, expr) },
        BlockBody(block) => {
            let st2: SemState = check_block(st, block)
            return new_infer_result(unknown_type(), st2)
        }
    }
}

// ---------------------------------------------------------------------------
// Spawn / Send
// ---------------------------------------------------------------------------

fn check_spawn_expr(st: SemState, callee: Expr, args: List<Expr>) -> InferResult {
    // Infer arguments
    let mut st2: SemState = st
    let mut i: Int = 0
    for _ in 0..1000 {
        if i >= len(args) {
            // Check callee
            match callee {
                Ident(name) => {
                    let sym_opt: Option<Symbol> = scope_lookup(st2.scope, name)
                    match sym_opt {
                        Some(sym) => {
                            if sym.kind != "agent" {
                                if sym.kind != "variable" {
                                    st2 = add_error(st2, "'spawn' requires an agent, but '" + name + "' is a " + sym.kind, 0, 0)
                                }
                            }
                            return new_infer_result(make_type(sym.name), st2)
                        },
                        _ => {
                            st2 = add_error(st2, "Undefined agent '" + name + "'", 0, 0)
                            return new_infer_result(unknown_type(), st2)
                        }
                    }
                },
                _ => {
                    return new_infer_result(unknown_type(), st2)
                }
            }
        }
        let arg: Expr = args[i]
        let ar: InferResult = infer_expr(st2, arg)
        st2 = ar.st
        i = i + 1
    }
    return new_infer_result(unknown_type(), st2)
}

fn check_send_expr(st: SemState, value: Expr, target: Expr) -> SemState {
    let vr: InferResult = infer_expr(st, value)
    let tr: InferResult = infer_expr(vr.st, target)
    return tr.st
}

// ---------------------------------------------------------------------------
// Pipe expression
// ---------------------------------------------------------------------------

fn check_pipe_expr(st: SemState, left: Expr, right: Expr) -> InferResult {
    let lr: InferResult = infer_expr(st, left)
    let st2: SemState = lr.st

    match right {
        Ident(name) => {
            let sym_opt: Option<Symbol> = scope_lookup(st2.scope, name)
            match sym_opt {
                Some(sym) => {
                    if sym.kind == "function" {
                        if sym.type_info.is_function {
                            // Check piped value type matches first param
                            if len(sym.type_info.param_types) > 0 {
                                let expected: TypeInfo = sym.type_info.param_types[0]
                                if expected.name != "<unknown>" {
                                    if lr.type_info.name != "<unknown>" {
                                        if types_compatible(expected, lr.type_info) == false {
                                            let st3: SemState = add_error(st2, "Pipe type mismatch: piped to '" + name + "'", 0, 0)
                                            match sym.type_info.return_type {
                                                Some(ret) => { return new_infer_result(ret, st3) },
                                                _ => { return new_infer_result(unknown_type(), st3) }
                                            }
                                        }
                                    }
                                }
                            }
                            match sym.type_info.return_type {
                                Some(ret) => { return new_infer_result(ret, st2) },
                                _ => { return new_infer_result(unknown_type(), st2) }
                            }
                        }
                    }
                    if sym.kind == "agent" {
                        return new_infer_result(make_type(sym.name), st2)
                    }
                    return new_infer_result(unknown_type(), st2)
                },
                _ => {
                    let st3: SemState = add_error(st2, "Undefined function '" + name + "'", 0, 0)
                    return new_infer_result(unknown_type(), st3)
                }
            }
        },
        Call(callee, args) => {
            return check_call_expr(st2, callee, args)
        },
        _ => {
            let rr: InferResult = infer_expr(st2, right)
            return new_infer_result(unknown_type(), rr.st)
        }
    }
}

// ---------------------------------------------------------------------------
// Block and statement checking
// ---------------------------------------------------------------------------

fn check_block(st: SemState, block: Block) -> SemState {
    let mut st2: SemState = st
    let mut i: Int = 0
    for _ in 0..100000 {
        if i >= len(block.stmts) { return st2 }
        let stmt: Stmt = block.stmts[i]
        st2 = check_stmt(st2, stmt)
        i = i + 1
    }
    return st2
}

fn check_stmt(st: SemState, stmt: Stmt) -> SemState {
    match stmt {
        Let(name, mutable, type_ann, value) => {
            return check_let_stmt(st, name, mutable, type_ann, value)
        },
        ExprStmt(expr) => {
            let r: InferResult = infer_expr(st, expr)
            return r.st
        },
        Return(value_opt) => {
            match value_opt {
                Some(value) => {
                    let r: InferResult = infer_expr(st, value)
                    return r.st
                },
                _ => { return st }
            }
        },
        For(var_name, iterable, body) => {
            return check_for_stmt(st, var_name, iterable, body)
        },
        SignalDecl(name, mutable, type_ann, value, _) => {
            return check_signal_decl(st, name, mutable, type_ann, value)
        },
        StreamDecl(name, type_ann, value) => {
            return check_stream_decl(st, name, type_ann, value)
        }
    }
}

// ---------------------------------------------------------------------------
// Let binding
// ---------------------------------------------------------------------------

fn check_let_stmt(st: SemState, name: String, mutable: Bool, type_ann: Option<TypeExpr>, value: Expr) -> SemState {
    let vr: InferResult = infer_expr(st, value)
    let ann_type: TypeInfo = resolve_type_opt(type_ann)
    let mut st2: SemState = vr.st

    // Check annotation matches value type
    if ann_type.name != "<unknown>" {
        if vr.type_info.name != "<unknown>" {
            if types_compatible(ann_type, vr.type_info) == false {
                st2 = add_error(st2, "Type mismatch: declared type " + ann_type.name + " but initial value is " + vr.type_info.name, 0, 0)
            }
        }
    }

    // Use annotation if available, otherwise inferred
    let resolved: TypeInfo = ann_type
    if ann_type.name == "<unknown>" {
        let resolved2: TypeInfo = vr.type_info
        let sym: Symbol = new_symbol(name, "variable", resolved2, mutable)
        return define_in_scope(st2, name, sym)
    }
    let sym2: Symbol = new_symbol(name, "variable", resolved, mutable)
    return define_in_scope(st2, name, sym2)
}

// ---------------------------------------------------------------------------
// For loop
// ---------------------------------------------------------------------------

fn check_for_stmt(st: SemState, var_name: String, iterable: Expr, body: Block) -> SemState {
    let ir: InferResult = infer_expr(st, iterable)
    let inner: SemState = push_scope(ir.st)
    let sym: Symbol = new_symbol(var_name, "variable", unknown_type(), false)
    let bound: SemState = define_in_scope(inner, var_name, sym)
    let after: SemState = check_block(bound, body)
    return pop_scope(after)
}

// ---------------------------------------------------------------------------
// Signal / Stream declarations
// ---------------------------------------------------------------------------

fn check_signal_decl(st: SemState, name: String, mutable: Bool, type_ann: Option<TypeExpr>, value: Expr) -> SemState {
    let vr: InferResult = infer_expr(st, value)
    let ann_type: TypeInfo = resolve_type_opt(type_ann)
    let resolved: TypeInfo = ann_type
    if ann_type.name == "<unknown>" {
        let resolved2: TypeInfo = vr.type_info
        let args: List<TypeInfo> = []
        // args.push(resolved2)
        let sig_type: TypeInfo = make_generic_type("Signal", args)
        let sym: Symbol = new_symbol(name, "variable", sig_type, mutable)
        return define_in_scope(vr.st, name, sym)
    }
    let args2: List<TypeInfo> = []
    // args2.push(resolved)
    let sig_type2: TypeInfo = make_generic_type("Signal", args2)
    let sym2: Symbol = new_symbol(name, "variable", sig_type2, mutable)
    return define_in_scope(vr.st, name, sym2)
}

fn check_stream_decl(st: SemState, name: String, type_ann: Option<TypeExpr>, value: Expr) -> SemState {
    let vr: InferResult = infer_expr(st, value)
    let ann_type: TypeInfo = resolve_type_opt(type_ann)
    let resolved: TypeInfo = ann_type
    if ann_type.name == "<unknown>" {
        let resolved2: TypeInfo = vr.type_info
        let args: List<TypeInfo> = []
        let stream_type: TypeInfo = make_generic_type("Stream", args)
        let sym: Symbol = new_symbol(name, "variable", stream_type, false)
        return define_in_scope(vr.st, name, sym)
    }
    let args2: List<TypeInfo> = []
    let stream_type2: TypeInfo = make_generic_type("Stream", args2)
    let sym2: Symbol = new_symbol(name, "variable", stream_type2, false)
    return define_in_scope(vr.st, name, sym2)
}

// ---------------------------------------------------------------------------
// Definition registration (first pass)
// ---------------------------------------------------------------------------

fn register_definitions(st: SemState, program: Program) -> SemState {
    let mut st2: SemState = st
    let mut i: Int = 0
    for _ in 0..100000 {
        if i >= len(program.definitions) { return st2 }
        let def: Definition = program.definitions[i]
        st2 = register_def(st2, def)
        i = i + 1
    }
    return st2
}

fn register_def(st: SemState, def: Definition) -> SemState {
    match def {
        FnDef(data) => {
            let mut params: List<TypeInfo> = []
            let mut pi: Int = 0
            for _ in 0..1000 {
                if pi >= len(data.params) {
                    let ret: TypeInfo = resolve_type_opt(data.return_type)
                    let fn_type: TypeInfo = make_fn_type(params, ret)
                    let sym: Symbol = new_symbol(data.name, "function", fn_type, false)
                    return define_in_scope(st, data.name, sym)
                }
                let p: Param = data.params[pi]
                let pt: TypeInfo = resolve_type_opt(p.type_annotation)
                // params.push(pt)
                pi = pi + 1
            }
            return st
        },

        AgentDef(data) => {
            let sym: Symbol = new_symbol(data.name, "agent", make_type(data.name), false)
            return define_in_scope(st, data.name, sym)
        },

        PipeDef(data) => {
            let sym: Symbol = new_symbol(data.name, "pipe", unknown_type(), false)
            return define_in_scope(st, data.name, sym)
        },

        StructDef(data) => {
            let sym: Symbol = new_symbol(data.name, "struct", make_type(data.name), false)
            return define_in_scope(st, data.name, sym)
        },

        EnumDef(data) => {
            let sym: Symbol = new_symbol(data.name, "enum", make_type(data.name), false)
            let mut st2: SemState = define_in_scope(st, data.name, sym)
            // Register variants as constructors
            let mut vi: Int = 0
            for _ in 0..1000 {
                if vi >= len(data.variants) { return st2 }
                let v: EnumVariant = data.variants[vi]
                let variant_type: TypeInfo = make_builtin_fn_type(make_type(data.name))
                let vsym: Symbol = new_symbol(v.name, "function", variant_type, false)
                st2 = define_in_scope(st2, v.name, vsym)
                vi = vi + 1
            }
            return st2
        },

        TypeAlias(name, type_expr) => {
            let resolved: TypeInfo = resolve_type_expr(type_expr)
            let sym: Symbol = new_symbol(name, "type_alias", resolved, false)
            return define_in_scope(st, name, sym)
        },

        ImportDef(path, items) => {
            let mut st2: SemState = st
            if len(items) > 0 {
                let mut ii: Int = 0
                for _ in 0..1000 {
                    if ii >= len(items) { return st2 }
                    let item: String = items[ii]
                    let sym: Symbol = new_symbol(item, "variable", unknown_type(), false)
                    st2 = define_in_scope(st2, item, sym)
                    ii = ii + 1
                }
            } else {
                if len(path) > 0 {
                    let mod_name: String = path[len(path) - 1]
                    let sym: Symbol = new_symbol(mod_name, "variable", unknown_type(), false)
                    st2 = define_in_scope(st2, mod_name, sym)
                }
            }
            return st2
        },

        ExportDef(inner_def, names) => {
            match inner_def {
                Some(d) => { return register_def(st, d) },
                _ => { return st }
            }
        },

        ImplDef(target, methods) => {
            // Methods handled in second pass
            return st
        }
    }
}

// ---------------------------------------------------------------------------
// Definition checking (second pass)
// ---------------------------------------------------------------------------

fn check_definitions(st: SemState, program: Program) -> SemState {
    let mut st2: SemState = st
    let mut i: Int = 0
    for _ in 0..100000 {
        if i >= len(program.definitions) { return st2 }
        let def: Definition = program.definitions[i]
        st2 = check_def(st2, def)
        i = i + 1
    }
    return st2
}

fn check_def(st: SemState, def: Definition) -> SemState {
    match def {
        FnDef(data) => { return check_fn_body(st, data) },
        AgentDef(data) => { return check_agent_body(st, data) },
        PipeDef(data) => { return check_pipe_stages(st, data) },
        ImplDef(target, methods) => { return check_impl_body(st, target, methods) },
        ExportDef(inner_def, _) => {
            match inner_def {
                Some(d) => { return check_def(st, d) },
                _ => { return st }
            }
        },
        _ => { return st }
    }
}

// ---------------------------------------------------------------------------
// Function body checking
// ---------------------------------------------------------------------------

fn check_fn_body(st: SemState, data: FnDefData) -> SemState {
    let inner: SemState = push_scope(st)
    let mut st2: SemState = inner

    // Register parameters
    let mut pi: Int = 0
    for _ in 0..1000 {
        if pi >= len(data.params) {
            // Check body
            let after: SemState = check_block(st2, data.body)
            return pop_scope(after)
        }
        let p: Param = data.params[pi]
        let pt: TypeInfo = resolve_type_opt(p.type_annotation)
        let sym: Symbol = new_symbol(p.name, "param", pt, false)
        st2 = define_in_scope(st2, p.name, sym)
        pi = pi + 1
    }

    return pop_scope(st2)
}

// ---------------------------------------------------------------------------
// Agent body checking
// ---------------------------------------------------------------------------

fn check_agent_body(st: SemState, data: AgentDefData) -> SemState {
    let inner: SemState = push_scope(st)
    let mut st2: SemState = inner

    // Register self
    let self_sym: Symbol = new_symbol("self", "variable", make_type(data.name), false)
    st2 = define_in_scope(st2, "self", self_sym)

    // Register inputs
    let mut ii: Int = 0
    for _ in 0..1000 {
        if ii >= len(data.inputs) {
            // Register outputs
            let mut oi: Int = 0
            for _ in 0..1000 {
                if oi >= len(data.outputs) {
                    // Check state bindings
                    let mut si: Int = 0
                    for _ in 0..1000 {
                        if si >= len(data.state) {
                            // Check methods
                            let mut mi: Int = 0
                            for _ in 0..1000 {
                                if mi >= len(data.methods) {
                                    return pop_scope(st2)
                                }
                                let method: FnDefData = data.methods[mi]
                                st2 = check_fn_body(st2, method)
                                mi = mi + 1
                            }
                            return pop_scope(st2)
                        }
                        let state_stmt: Stmt = data.state[si]
                        st2 = check_stmt(st2, state_stmt)
                        si = si + 1
                    }
                    return pop_scope(st2)
                }
                let out: AgentOutput = data.outputs[oi]
                let out_type: TypeInfo = resolve_type_expr(out.type_annotation)
                let out_sym: Symbol = new_symbol(out.name, "variable", out_type, false)
                st2 = define_in_scope(st2, out.name, out_sym)
                oi = oi + 1
            }
            return pop_scope(st2)
        }
        let inp: AgentInput = data.inputs[ii]
        let inp_type: TypeInfo = resolve_type_expr(inp.type_annotation)
        let inp_sym: Symbol = new_symbol(inp.name, "variable", inp_type, false)
        st2 = define_in_scope(st2, inp.name, inp_sym)
        ii = ii + 1
    }

    return pop_scope(st2)
}

// ---------------------------------------------------------------------------
// Impl block checking
// ---------------------------------------------------------------------------

fn check_impl_body(st: SemState, target: String, methods: List<FnDefData>) -> SemState {
    let sym_opt: Option<Symbol> = scope_lookup(st.scope, target)
    let mut st2: SemState = st
    match sym_opt {
        Some(_) => {},
        _ => {
            st2 = add_error(st2, "Undefined type '" + target + "' in impl block", 0, 0)
        }
    }

    let mut mi: Int = 0
    for _ in 0..1000 {
        if mi >= len(methods) { return st2 }
        let method: FnDefData = methods[mi]
        st2 = check_fn_body(st2, method)
        mi = mi + 1
    }
    return st2
}

// ---------------------------------------------------------------------------
// Pipe definition checking
// ---------------------------------------------------------------------------

fn check_pipe_stage_type(st: SemState, stage: Expr, pipe_name: String) -> TypeInfo {
    match stage {
        Ident(name) => {
            return resolve_pipe_ident_type(st, name)
        },
        _ => { return unknown_type() }
    }
}

fn resolve_pipe_ident_type(st: SemState, name: String) -> TypeInfo {
    let sym_opt: Option<Symbol> = scope_lookup(st.scope, name)
    match sym_opt {
        Some(sym) => {
            return resolve_sym_output_type(sym)
        },
        _ => { return unknown_type() }
    }
}

fn resolve_sym_output_type(sym: Symbol) -> TypeInfo {
    if sym.kind != "function" { return unknown_type() }
    if !sym.type_info.is_function { return unknown_type() }
    match sym.type_info.return_type {
        Some(ret) => { return ret },
        _ => { return unknown_type() }
    }
}

fn check_pipe_stage_err(st: SemState, stage: Expr, pipe_name: String) -> SemState {
    match stage {
        Ident(name) => {
            let sym_opt: Option<Symbol> = scope_lookup(st.scope, name)
            match sym_opt {
                Some(sym) => { return st },
                _ => { return add_error(st, "Undefined stage '" + name + "' in pipe '" + pipe_name + "'", 0, 0) }
            }
        },
        _ => {
            let sr: InferResult = infer_expr(st, stage)
            return sr.st
        }
    }
}

fn check_pipe_stages(st: SemState, data: PipeDefData) -> SemState {
    if len(data.stages) < 2 { return st }

    let mut st2: SemState = st
    let mut prev_output: TypeInfo = unknown_type()
    let mut si: Int = 0

    for _ in 0..1000 {
        if si >= len(data.stages) { return st2 }
        let stage: Expr = data.stages[si]
        prev_output = check_pipe_stage_type(st2, stage, data.name)
        let stage_err: SemState = check_pipe_stage_err(st2, stage, data.name)
        st2 = stage_err
        si = si + 1
    }
    return st2
}

// ---------------------------------------------------------------------------
// Builtin registration
// ---------------------------------------------------------------------------

fn register_builtins(st: SemState) -> SemState {
    let mut st2: SemState = st

    // print, println -> Void
    let print_sym: Symbol = new_symbol("print", "function", make_builtin_fn_type(void_type()), false)
    st2 = define_in_scope(st2, "print", print_sym)
    let println_sym: Symbol = new_symbol("println", "function", make_builtin_fn_type(void_type()), false)
    st2 = define_in_scope(st2, "println", println_sym)

    // len -> Int
    let len_sym: Symbol = new_symbol("len", "function", make_builtin_fn_type(int_type()), false)
    st2 = define_in_scope(st2, "len", len_sym)

    // toString -> String
    let tostr_sym: Symbol = new_symbol("toString", "function", make_builtin_fn_type(string_type()), false)
    st2 = define_in_scope(st2, "toString", tostr_sym)

    // str -> String (alias for toString)
    let str_sym: Symbol = new_symbol("str", "function", make_builtin_fn_type(string_type()), false)
    st2 = define_in_scope(st2, "str", str_sym)

    // int -> Int, float -> Float (type conversions)
    let int_sym: Symbol = new_symbol("int", "function", make_builtin_fn_type(int_type()), false)
    st2 = define_in_scope(st2, "int", int_sym)
    let float_sym: Symbol = new_symbol("float", "function", make_builtin_fn_type(make_type("Float")), false)
    st2 = define_in_scope(st2, "float", float_sym)

    // Some -> Option
    let some_sym: Symbol = new_symbol("Some", "function", make_builtin_fn_type(make_type("Option")), false)
    st2 = define_in_scope(st2, "Some", some_sym)

    // Ok, Err -> Result
    let ok_sym: Symbol = new_symbol("Ok", "function", make_builtin_fn_type(make_type("Result")), false)
    st2 = define_in_scope(st2, "Ok", ok_sym)
    let err_sym: Symbol = new_symbol("Err", "function", make_builtin_fn_type(make_type("Result")), false)
    st2 = define_in_scope(st2, "Err", err_sym)

    // signal -> Signal
    let sig_sym: Symbol = new_symbol("signal", "function", make_builtin_fn_type(make_type("Signal")), false)
    st2 = define_in_scope(st2, "signal", sig_sym)

    // stream -> Stream
    let stream_sym: Symbol = new_symbol("stream", "function", make_builtin_fn_type(make_type("Stream")), false)
    st2 = define_in_scope(st2, "stream", stream_sym)

    // ord -> Int
    let ord_sym: Symbol = new_symbol("ord", "function", make_builtin_fn_type(int_type()), false)
    st2 = define_in_scope(st2, "ord", ord_sym)

    // chr -> String
    let chr_sym: Symbol = new_symbol("chr", "function", make_builtin_fn_type(string_type()), false)
    st2 = define_in_scope(st2, "chr", chr_sym)

    // join -> String
    let join_sym: Symbol = new_symbol("join", "function", make_builtin_fn_type(string_type()), false)
    st2 = define_in_scope(st2, "join", join_sym)

    return st2
}

// ---------------------------------------------------------------------------
// Public API
// ---------------------------------------------------------------------------

pub fn check(program: Program, filename: String) -> List<SemanticError> {
    // Create initial state with builtins
    let mut st: SemState = new_sem_state(filename)
    st = register_builtins(st)

    // Pass 1: register all top-level definitions
    st = register_definitions(st, program)

    // Pass 2: check all definition bodies
    st = check_definitions(st, program)

    return st.errors
}

fn check_or_raise(program: Program, filename: String) -> List<SemanticError> {
    let errors: List<SemanticError> = check(program, filename)
    return errors
}

// ===== mir.mn =====
// mir.mn — MIR (Mid-level Intermediate Representation) data structures.
// Shared by lower.mn, lower_state.mn, and emit_llvm.mn.
//
// Defines all MIR types, values, instructions, basic blocks, functions,
// modules, and associated helper structs/constructors.

// ---------------------------------------------------------------------------
// MIR type representation
// ---------------------------------------------------------------------------

struct MIRType {
    name: String,
    kind: String,
    args: List<MIRType>
}

fn new_mir_type(name: String, kind: String) -> MIRType {
    let args: List<MIRType> = []
    return new MIRType { name: name, kind: kind, args: args }
}

fn new_mir_type_with_args(name: String, kind: String, args: List<MIRType>) -> MIRType {
    return new MIRType { name: name, kind: kind, args: args }
}

fn mir_int() -> MIRType { return new_mir_type("Int", "int") }
fn mir_float() -> MIRType { return new_mir_type("Float", "float") }
fn mir_bool() -> MIRType { return new_mir_type("Bool", "bool") }
fn mir_string() -> MIRType { return new_mir_type("String", "string") }
fn mir_void() -> MIRType { return new_mir_type("Void", "void") }
fn mir_unknown() -> MIRType { return new_mir_type("<unknown>", "unknown") }
fn mir_option() -> MIRType { return new_mir_type("Option", "option") }
fn mir_option_of(inner: MIRType) -> MIRType {
    let mut t: MIRType = new_mir_type("Option", "option")
    t.args.push(inner)
    return t
}
fn mir_result() -> MIRType { return new_mir_type("Result", "result") }
fn mir_list() -> MIRType { return new_mir_type("List", "list") }
fn mir_map() -> MIRType { return new_mir_type("Map", "map") }
fn mir_signal() -> MIRType { return new_mir_type("Signal", "signal") }
fn mir_range() -> MIRType { return new_mir_type("Range", "range") }
fn mir_fn_type() -> MIRType { return new_mir_type("<fn>", "fn") }

fn mir_struct(name: String) -> MIRType {
    return new_mir_type(name, "struct")
}

fn mir_enum(name: String) -> MIRType {
    return new_mir_type(name, "enum")
}

fn mir_agent(name: String) -> MIRType {
    return new_mir_type(name, "agent")
}

// ---------------------------------------------------------------------------
// MIR values — SSA virtual registers
// ---------------------------------------------------------------------------

struct Value {
    name: String,
    ty: MIRType
}

fn new_value(name: String, ty: MIRType) -> Value {
    return new Value { name: name, ty: ty }
}

fn void_value() -> Value {
    return new_value("%void", mir_void())
}

// ---------------------------------------------------------------------------
// MIR instructions — encoded as tagged enum
// ---------------------------------------------------------------------------

enum BinOpKind {
    Add, Sub, Mul, Div, Mod,
    Eq, Ne, Lt, Gt, Le, Ge,
    And, Or
}

enum UnaryOpKind {
    Neg, Not
}

enum StreamOpKind {
    Map, Filter, Fold, Take, Skip, Collect
}

// Field pair for struct init
struct FieldPair {
    name: String,
    val: Value
}

fn new_field_pair(name: String, val: Value) -> FieldPair {
    return new FieldPair { name: name, val: val }
}

// Key-value pair for map init
struct KVPair {
    key: Value,
    val: Value
}

fn new_kv_pair(key: Value, val: Value) -> KVPair {
    return new KVPair { key: key, val: val }
}

// Phi incoming entry
struct PhiEntry {
    block_label: String,
    val: Value
}

fn new_phi_entry(label: String, val: Value) -> PhiEntry {
    return new PhiEntry { block_label: label, val: val }
}

// Switch case entry
struct SwitchCase {
    tag_value: String,
    block_label: String
}

fn new_switch_case(tag: String, label: String) -> SwitchCase {
    return new SwitchCase { tag_value: tag, block_label: label }
}

enum Instruction {
    // Values
    Const(Value, MIRType, String),
    Copy(Value, Value),
    Cast(Value, Value, MIRType),
    // Arithmetic
    BinOp(Value, BinOpKind, Value, Value),
    UnaryOp(Value, UnaryOpKind, Value),
    // Aggregates
    StructInit(Value, MIRType, List<FieldPair>),
    FieldGet(Value, Value, String),
    FieldSet(Value, String, Value),
    ListInit(Value, MIRType, List<Value>),
    IndexGet(Value, Value, Value),
    IndexSet(Value, Value, Value),
    Alloca(Value, MIRType),
    Load(Value, Value),
    Store(Value, Value),
    MapInit(Value, MIRType, MIRType, List<KVPair>),
    // Enum
    EnumInit(Value, MIRType, String, List<Value>),
    EnumTag(Value, Value),
    EnumPayload(Value, Value, String),
    // Option/Result
    WrapSome(Value, Value),
    WrapNone(Value, MIRType),
    WrapOk(Value, Value),
    WrapErr(Value, Value),
    Unwrap(Value, Value),
    // Functions
    Call(Value, String, List<Value>),
    Return(Option<Value>),
    // Control flow
    Jump(String),
    Branch(Value, String, String),
    Switch(Value, List<SwitchCase>, String),
    // Agents
    AgentSpawn(Value, MIRType, List<Value>),
    AgentSend(Value, String, Value),
    AgentSync(Value, Value, String),
    // Signals
    SignalInit(Value, MIRType, Value),
    SignalGet(Value, Value),
    SignalSet(Value, Value),
    // Streams
    StreamOp(Value, StreamOpKind, Value, List<Value>),
    // Strings
    InterpConcat(Value, List<Value>),
    // SSA
    Phi(Value, List<PhiEntry>)
}

// ---------------------------------------------------------------------------
// Basic block
// ---------------------------------------------------------------------------

struct BasicBlock {
    label: String,
    instructions: List<Instruction>
}

fn new_basic_block(label: String) -> BasicBlock {
    let instrs: List<Instruction> = []
    return new BasicBlock { label: label, instructions: instrs }
}

fn is_terminator(inst: Instruction) -> Bool {
    match inst {
        Jump(_) => { return true },
        Branch(_, _, _) => { return true },
        Switch(_, _, _) => { return true },
        Return(_) => { return true },
        _ => { return false }
    }
}

fn block_terminated(bb: BasicBlock) -> Bool {
    if len(bb.instructions) == 0 { return false }
    let last: Instruction = bb.instructions[len(bb.instructions) - 1]
    return is_terminator(last)
}

// ---------------------------------------------------------------------------
// MIR function
// ---------------------------------------------------------------------------

struct MIRParam {
    name: String,
    ty: MIRType
}

fn new_mir_param(name: String, ty: MIRType) -> MIRParam {
    return new MIRParam { name: name, ty: ty }
}

struct MIRFunction {
    name: String,
    params: List<MIRParam>,
    return_type: MIRType,
    blocks: List<BasicBlock>,
    decorators: List<String>,
    is_public: Bool
}

fn new_mir_function(name: String, params: List<MIRParam>, ret: MIRType, decorators: List<String>, is_public: Bool) -> MIRFunction {
    let blocks: List<BasicBlock> = []
    return new MIRFunction { name: name, params: params, return_type: ret, blocks: blocks, decorators: decorators, is_public: is_public }
}

// ---------------------------------------------------------------------------
// MIR module
// ---------------------------------------------------------------------------

struct StructInfo {
    name: String,
    fields: List<FieldPair>
}

fn new_struct_info(name: String, fields: List<FieldPair>) -> StructInfo {
    return new StructInfo { name: name, fields: fields }
}

struct EnumVariantInfo {
    name: String,
    payload_types: List<MIRType>
}

fn new_enum_variant_info(name: String, types: List<MIRType>) -> EnumVariantInfo {
    return new EnumVariantInfo { name: name, payload_types: types }
}

struct EnumInfo {
    name: String,
    variants: List<EnumVariantInfo>
}

fn new_enum_info(name: String, variants: List<EnumVariantInfo>) -> EnumInfo {
    return new EnumInfo { name: name, variants: variants }
}

struct ExternFnInfo {
    abi: String,
    module_name: String,
    fn_name: String,
    param_types: List<MIRType>,
    return_type: MIRType
}

fn new_extern_fn_info(abi: String, module_name: String, fn_name: String, params: List<MIRType>, ret: MIRType) -> ExternFnInfo {
    return new ExternFnInfo { abi: abi, module_name: module_name, fn_name: fn_name, param_types: params, return_type: ret }
}

struct AgentInfo {
    name: String,
    inputs: List<String>,
    outputs: List<String>,
    method_names: List<String>
}

fn new_agent_info(name: String, inputs: List<String>, outputs: List<String>, methods: List<String>) -> AgentInfo {
    return new AgentInfo { name: name, inputs: inputs, outputs: outputs, method_names: methods }
}

struct PipeInfo {
    name: String,
    stages: List<String>
}

fn new_pipe_info(name: String, stages: List<String>) -> PipeInfo {
    return new PipeInfo { name: name, stages: stages }
}

struct ImportInfo {
    path: List<String>,
    items: List<String>
}

fn new_import_info(path: List<String>, items: List<String>) -> ImportInfo {
    return new ImportInfo { path: path, items: items }
}

struct MIRModule {
    name: String,
    functions: List<MIRFunction>,
    structs: List<StructInfo>,
    enums: List<EnumInfo>,
    extern_fns: List<ExternFnInfo>,
    agents: List<AgentInfo>,
    pipes: List<PipeInfo>,
    imports: List<ImportInfo>,
    trait_names: List<String>
}

fn new_mir_module(name: String) -> MIRModule {
    let functions: List<MIRFunction> = []
    let structs: List<StructInfo> = []
    let enums: List<EnumInfo> = []
    let extern_fns: List<ExternFnInfo> = []
    let agents: List<AgentInfo> = []
    let pipes: List<PipeInfo> = []
    let imports: List<ImportInfo> = []
    let trait_names: List<String> = []
    return new MIRModule { name: name, functions: functions, structs: structs, enums: enums, extern_fns: extern_fns, agents: agents, pipes: pipes, imports: imports, trait_names: trait_names }
}

// ---------------------------------------------------------------------------
// Variable tracking
// ---------------------------------------------------------------------------

struct VarInfo {
    name: String,
    current: Value,
    mutable: Bool
}

fn new_var_info(name: String, val: Value, mutable: Bool) -> VarInfo {
    return new VarInfo { name: name, current: val, mutable: mutable }
}

// Impl method mapping: "Type.method" -> "Type_method"
struct ImplEntry {
    key: String,
    mir_name: String
}

fn new_impl_entry(key: String, mir_name: String) -> ImplEntry {
    return new ImplEntry { key: key, mir_name: mir_name }
}

// Struct field names and types mapping
struct StructFieldInfo {
    name: String,
    field_names: List<String>,
    field_types: List<MIRType>
}

fn new_struct_field_info(name: String, fields: List<String>, types: List<MIRType>) -> StructFieldInfo {
    return new StructFieldInfo { name: name, field_names: fields, field_types: types }
}

// Enum variant names mapping
struct EnumVariantNames {
    enum_name: String,
    variant_names: List<String>
}

fn new_enum_variant_names(name: String, variants: List<String>) -> EnumVariantNames {
    return new EnumVariantNames { enum_name: name, variant_names: variants }
}

// Lambda variable mapping
struct LambdaEntry {
    var_name: String,
    fn_name: String
}

fn new_lambda_entry(var_name: String, fn_name: String) -> LambdaEntry {
    return new LambdaEntry { var_name: var_name, fn_name: fn_name }
}

// ---------------------------------------------------------------------------
// Enum-to-string conversion (used by emit_llvm.mn and pretty-printer)
// ---------------------------------------------------------------------------

pub fn binop_kind_to_str(op: BinOpKind) -> String {
    match op {
        Add => { return "add" },
        Sub => { return "sub" },
        Mul => { return "mul" },
        Div => { return "div" },
        Mod => { return "mod" },
        Eq => { return "eq" },
        Ne => { return "ne" },
        Lt => { return "lt" },
        Gt => { return "gt" },
        Le => { return "le" },
        Ge => { return "ge" },
        And => { return "and" },
        Or => { return "or" }
    }
}

pub fn unaryop_kind_to_str(op: UnaryOpKind) -> String {
    match op {
        Neg => { return "neg" },
        Not => { return "not" }
    }
}

// ===== lower_state.mn =====
// lower_state.mn — Lowerer state, scope management, lookups, and type resolution.
// Extracted from lower.mn to reduce file size and share lookup utilities.


// ---------------------------------------------------------------------------
// Lowerer state — threaded through all lowering functions
// ---------------------------------------------------------------------------

struct LowerState {
    module: MIRModule,
    current_fn: Option<MIRFunction>,
    current_block_idx: Int,
    tmp_counter: Int,
    block_counter: Int,
    vars: List<VarInfo>,
    scope_stack: List<Int>,
    impl_methods: List<ImplEntry>,
    struct_fields: List<StructFieldInfo>,
    enum_variants: List<EnumVariantNames>,
    lambda_vars: List<LambdaEntry>,
}

fn new_lower_state(module_name: String) -> LowerState {
    let module: MIRModule = new_mir_module(module_name)
    let vars: List<VarInfo> = []
    let scope_stack: List<Int> = []
    let impl_methods: List<ImplEntry> = []
    let struct_fields: List<StructFieldInfo> = []
    let enum_variants: List<EnumVariantNames> = []
    let lambda_vars: List<LambdaEntry> = []
    return new LowerState { module: module, current_fn: none, current_block_idx: 0, tmp_counter: 0, block_counter: 0, vars: vars, scope_stack: scope_stack, impl_methods: impl_methods, struct_fields: struct_fields, enum_variants: enum_variants, lambda_vars: lambda_vars }
}

// Lower result: value + updated state
struct LowerResult {
    value: Value,
    state: LowerState
}

fn new_lower_result(val: Value, st: LowerState) -> LowerResult {
    return new LowerResult { value: val, state: st }
}

// ---------------------------------------------------------------------------
// Name generation
// ---------------------------------------------------------------------------

fn fresh_tmp(st: LowerState, prefix: String) -> LowerResult {
    let name: String = "%" + prefix + toString(st.tmp_counter)
    let mut new_st: LowerState = st
    new_st.tmp_counter = st.tmp_counter + 1
    let val: Value = new_value(name, mir_unknown())
    return new_lower_result(val, new_st)
}

fn fresh_block_label(st: LowerState, prefix: String) -> LowerResult {
    let name: String = prefix + toString(st.block_counter)
    let mut new_st: LowerState = st
    new_st.block_counter = st.block_counter + 1
    let val: Value = new_value(name, mir_unknown())
    return new_lower_result(val, new_st)
}

fn make_value(st: LowerState, ty: MIRType, prefix: String) -> LowerResult {
    let r: LowerResult = fresh_tmp(st, prefix)
    let val: Value = new_value(r.value.name, ty)
    return new_lower_result(val, r.state)
}

// ---------------------------------------------------------------------------
// Block management
// ---------------------------------------------------------------------------

fn add_block(st: LowerState, label: String) -> LowerState {
    let bb: BasicBlock = new_basic_block(label)
    let mut new_st: LowerState = st
    match st.current_fn {
        Some(f) => {
            let mut new_fn: MIRFunction = f
            let mut blk_list: List<BasicBlock> = new_fn.blocks
            blk_list.push(bb)
            new_fn.blocks = blk_list
            new_st.current_fn = Some(new_fn)
            new_st.current_block_idx = len(f.blocks)
        },
        _ => {}
    }
    return new_st
}

fn set_block(st: LowerState, idx: Int) -> LowerState {
    let mut new_st: LowerState = st
    new_st.current_block_idx = idx
    return new_st
}

fn emit_instr(st: LowerState, instr: Instruction) -> LowerState {
    // Append instruction to current block in current function.
    let mut new_st: LowerState = st
    match st.current_fn {
        Some(f) => {
            if st.current_block_idx >= 0 {
                if st.current_block_idx < len(f.blocks) {
                    let bb: BasicBlock = f.blocks[st.current_block_idx]
                    let mut instrs: List<Instruction> = bb.instructions
                    instrs.push(instr)
                    let new_bb: BasicBlock = new BasicBlock { label: bb.label, instructions: instrs }
                    let mut blks: List<BasicBlock> = f.blocks
                    blks[st.current_block_idx] = new_bb
                    // Update the function in new_st with the modified blocks
                    let mut new_fn: MIRFunction = f
                    new_fn.blocks = blks
                    new_st.current_fn = Some(new_fn)
                }
            }
        },
        _ => {}
    }
    return new_st
}

fn current_block_terminated(st: LowerState) -> Bool {
    match st.current_fn {
        Some(f) => {
            if st.current_block_idx >= 0 {
                if st.current_block_idx < len(f.blocks) {
                    let bb: BasicBlock = f.blocks[st.current_block_idx]
                    return block_terminated(bb)
                }
            }
            return true
        },
        _ => { return true }
    }
}

// ---------------------------------------------------------------------------
// Scope management
// ---------------------------------------------------------------------------

fn lower_push_scope(st: LowerState) -> LowerState {
    // Save the current variable count. On pop, truncate vars back to this length.
    // This avoids nested list aliasing (no List<List<VarInfo>> needed).
    let mut new_st: LowerState = st
    let var_count: Int = len(st.vars)
    new_st.scope_stack.push(var_count)
    return new_st
}

fn lower_pop_scope(st: LowerState) -> LowerState {
    let mut new_st: LowerState = st
    if len(st.scope_stack) > 0 {
        let saved_len: Int = st.scope_stack[len(st.scope_stack) - 1]
        // Truncate vars back to the saved length
        // (removes variables defined in the inner scope)
        let mut restored: List<VarInfo> = []
        let mut i: Int = 0
        for _ in 0..100000 {
            if i >= saved_len { break }
            if i >= len(st.vars) { break }
            restored.push(st.vars[i])
            i = i + 1
        }
        new_st.vars = restored
    }
    return new_st
}

fn define_var(st: LowerState, name: String, val: Value, mutable: Bool) -> LowerState {
    let mut new_st: LowerState = st
    let vi: VarInfo = new_var_info(name, val, mutable)
    new_st.vars.push(vi)
    return new_st
}

fn lookup_var(st: LowerState, name: String) -> Option<Value> {
    let mut i: Int = len(st.vars) - 1
    for _ in 0..100000 {
        if i < 0 { return none }
        let v: VarInfo = st.vars[i]
        if v.name == name { return Some(v.current) }
        i = i - 1
    }
    return none
}

fn update_var(st: LowerState, name: String, val: Value) -> LowerState {
    let mut new_st: LowerState = st
    let mut i: Int = len(st.vars) - 1
    for _ in 0..100000 {
        if i < 0 { return new_st }
        let v: VarInfo = st.vars[i]
        if v.name == name {
            let updated: VarInfo = new_var_info(name, val, v.mutable)
            st.vars[i] = updated
            return new_st
        }
        i = i - 1
    }
    return new_st
}

// ---------------------------------------------------------------------------
// Lookup helpers
// ---------------------------------------------------------------------------

fn find_struct_fields(st: LowerState, name: String) -> Option<List<String>> {
    let mut i: Int = 0
    for _ in 0..100000 {
        if i >= len(st.struct_fields) { return none }
        let sf: StructFieldInfo = st.struct_fields[i]
        if sf.name == name { return Some(sf.field_names) }
        i = i + 1
    }
    return none
}

fn is_struct_name(st: LowerState, name: String) -> Bool {
    let mut i: Int = 0
    for _ in 0..100000 {
        if i >= len(st.struct_fields) { return false }
        let sf: StructFieldInfo = st.struct_fields[i]
        if sf.name == name { return true }
        i = i + 1
    }
    return false
}

fn get_struct_field_names(st: LowerState, name: String) -> List<String> {
    let mut i: Int = 0
    for _ in 0..100000 {
        if i >= len(st.struct_fields) { break }
        let sf: StructFieldInfo = st.struct_fields[i]
        if sf.name == name { return sf.field_names }
        i = i + 1
    }
    let empty: List<String> = []
    return empty
}

fn find_enum_variants(st: LowerState, name: String) -> Option<List<String>> {
    let mut i: Int = 0
    for _ in 0..100000 {
        if i >= len(st.enum_variants) { return none }
        let ev: EnumVariantNames = st.enum_variants[i]
        if ev.enum_name == name { return Some(ev.variant_names) }
        i = i + 1
    }
    return none
}

fn is_enum_variant(st: LowerState, name: String) -> Bool {
    let mut i: Int = 0
    for _ in 0..100000 {
        if i >= len(st.enum_variants) { return false }
        let ev: EnumVariantNames = st.enum_variants[i]
        let mut j: Int = 0
        for _ in 0..100000 {
            if j >= len(ev.variant_names) { break }
            let vn: String = ev.variant_names[j]
            if vn == name { return true }
            j = j + 1
        }
        i = i + 1
    }
    return false
}

fn variant_index(st: LowerState, variant: String) -> Int {
    let mut i: Int = 0
    for _ in 0..100000 {
        if i >= len(st.enum_variants) { return 0 }
        let ev: EnumVariantNames = st.enum_variants[i]
        let mut j: Int = 0
        for _ in 0..100000 {
            if j >= len(ev.variant_names) { break }
            if ev.variant_names[j] == variant { return j }
            j = j + 1
        }
        i = i + 1
    }
    return 0
}

fn enum_name_for_variant(st: LowerState, variant: String) -> String {
    let mut i: Int = 0
    for _ in 0..100000 {
        if i >= len(st.enum_variants) { return "" }
        let ev: EnumVariantNames = st.enum_variants[i]
        let mut j: Int = 0
        for _ in 0..100000 {
            if j >= len(ev.variant_names) { break }
            let vn: String = ev.variant_names[j]
            if vn == variant { return ev.enum_name }
            j = j + 1
        }
        i = i + 1
    }
    return ""
}

fn find_impl_method(st: LowerState, type_name: String, method: String) -> Option<String> {
    let key: String = type_name + "." + method
    let mut i: Int = 0
    for _ in 0..100000 {
        if i >= len(st.impl_methods) { return none }
        let e: ImplEntry = st.impl_methods[i]
        if e.key == key { return Some(e.mir_name) }
        i = i + 1
    }
    return none
}

fn find_lambda(st: LowerState, name: String) -> Option<String> {
    let mut i: Int = 0
    for _ in 0..100000 {
        if i >= len(st.lambda_vars) { return none }
        let e: LambdaEntry = st.lambda_vars[i]
        if e.var_name == name { return Some(e.fn_name) }
        i = i + 1
    }
    return none
}

// ---------------------------------------------------------------------------
// Type resolution: AST TypeExpr -> MIRType
// ---------------------------------------------------------------------------

fn lower_resolve_type_expr(te: TypeExpr) -> MIRType {
    match te {
        Named(name) => {
            return resolve_type_name(name)
        },
        Generic(name, args) => {
            let mut resolved_args: List<MIRType> = []
            let mut i: Int = 0
            for _ in 0..100 {
                if i >= len(args) {
                    let kind: String = kind_from_name(name)
                    if kind != "unknown" {
                        return new_mir_type_with_args(name, kind, resolved_args)
                    }
                    return new_mir_type_with_args(name, "struct", resolved_args)
                }
                let arg: TypeExpr = args[i]
                let resolved: MIRType = lower_resolve_type_expr(arg)
                resolved_args.push(resolved)
                i = i + 1
            }
            return mir_unknown()
        },
        FnTy(param_types, return_type) => {
            return mir_fn_type()
        },
        _ => { return mir_unknown() }
    }
}

fn resolve_type_name(name: String) -> MIRType {
    if name == "Int" { return mir_int() }
    if name == "Float" { return mir_float() }
    if name == "Bool" { return mir_bool() }
    if name == "String" { return mir_string() }
    if name == "Char" { return mir_string() }
    if name == "Void" { return mir_void() }
    if name == "Option" { return mir_option() }
    if name == "Result" { return mir_result() }
    if name == "List" { return mir_list() }
    if name == "Map" { return mir_map() }
    if name == "Signal" { return mir_signal() }
    return mir_struct(name)
}

// State-aware type resolution: distinguishes structs from enums
fn resolve_type_name_checked(st: LowerState, name: String) -> MIRType {
    if name == "Int" { return mir_int() }
    if name == "Float" { return mir_float() }
    if name == "Bool" { return mir_bool() }
    if name == "String" { return mir_string() }
    if name == "Char" { return mir_string() }
    if name == "Void" { return mir_void() }
    if name == "Option" { return mir_option() }
    if name == "Result" { return mir_result() }
    if name == "List" { return mir_list() }
    if name == "Map" { return mir_map() }
    if name == "Signal" { return mir_signal() }
    // Check if this is a registered enum
    let mut i: Int = 0
    for _ in 0..10000 {
        if i >= len(st.enum_variants) { break }
        if st.enum_variants[i].enum_name == name {
            return mir_enum(name)
        }
        i = i + 1
    }
    return mir_struct(name)
}

fn kind_from_name(name: String) -> String {
    if name == "Int" { return "int" }
    if name == "Float" { return "float" }
    if name == "Bool" { return "bool" }
    if name == "String" { return "string" }
    if name == "Char" { return "string" }
    if name == "Void" { return "void" }
    if name == "Option" { return "option" }
    if name == "Result" { return "result" }
    if name == "List" { return "list" }
    if name == "Map" { return "map" }
    if name == "Signal" { return "signal" }
    if name == "Stream" { return "stream" }
    if name == "Agent" { return "agent" }
    if name == "Tensor" { return "tensor" }
    if name == "Range" { return "range" }
    return "unknown"
}

fn lower_resolve_type_opt(te: Option<TypeExpr>) -> MIRType {
    match te {
        Some(t) => { return lower_resolve_type_expr(t) },
        _ => { return mir_unknown() }
    }
}

fn lower_resolve_type_opt_checked(st: LowerState, te: Option<TypeExpr>) -> MIRType {
    match te {
        Some(t) => { return lower_resolve_type_checked(st, t) },
        _ => { return mir_unknown() }
    }
}

fn resolve_return_type(te: Option<TypeExpr>) -> MIRType {
    match te {
        Some(t) => { return lower_resolve_type_expr(t) },
        _ => { return mir_void() }
    }
}

// State-aware type expression resolver (distinguishes enums from structs)
fn resolve_generic_args_rec(st: LowerState, args: List<TypeExpr>, idx: Int, acc: List<MIRType>) -> List<MIRType> {
    if idx >= len(args) { return acc }
    let arg: TypeExpr = args[idx]
    let resolved: MIRType = lower_resolve_type_checked(st, arg)
    acc.push(resolved)
    return resolve_generic_args_rec(st, args, idx + 1, acc)
}

fn lower_resolve_type_checked(st: LowerState, te: TypeExpr) -> MIRType {
    match te {
        Named(name) => {
            return resolve_type_name_checked(st, name)
        },
        Generic(name, args) => {
            // Use recursion instead of for-loop to avoid the alloca aliasing bug
            let init_args: List<MIRType> = []
            let resolved_args: List<MIRType> = resolve_generic_args_rec(st, args, 0, init_args)
            let kind: String = kind_from_name(name)
            if kind != "unknown" {
                return new_mir_type_with_args(name, kind, resolved_args)
            }
            let checked: MIRType = resolve_type_name_checked(st, name)
            return new_mir_type_with_args(name, checked.kind, resolved_args)
        },
        FnTy(param_types, return_type) => {
            return mir_fn_type()
        },
        _ => { return mir_unknown() }
    }
}

fn resolve_return_type_checked(st: LowerState, te: Option<TypeExpr>) -> MIRType {
    match te {
        Some(t) => { return lower_resolve_type_checked(st, t) },
        _ => { return mir_void() }
    }
}

// ---------------------------------------------------------------------------
// Operator mapping
// ---------------------------------------------------------------------------

fn binop_from_str(op: String) -> Option<BinOpKind> {
    if op == "+" { return Some(BinOpKind::Add) }
    if op == "-" { return Some(BinOpKind::Sub) }
    if op == "*" { return Some(BinOpKind::Mul) }
    if op == "/" { return Some(BinOpKind::Div) }
    if op == "%" { return Some(BinOpKind::Mod) }
    if op == "==" { return Some(BinOpKind::Eq) }
    if op == "!=" { return Some(BinOpKind::Ne) }
    if op == "<" { return Some(BinOpKind::Lt) }
    if op == ">" { return Some(BinOpKind::Gt) }
    if op == "<=" { return Some(BinOpKind::Le) }
    if op == ">=" { return Some(BinOpKind::Ge) }
    if op == "&&" { return Some(BinOpKind::And) }
    if op == "||" { return Some(BinOpKind::Or) }
    return none
}

fn unaryop_from_str(op: String) -> Option<UnaryOpKind> {
    if op == "-" { return Some(UnaryOpKind::Neg) }
    if op == "!" { return Some(UnaryOpKind::Not) }
    return none
}

fn stream_op_from_str(name: String) -> Option<StreamOpKind> {
    if name == "map" { return Some(StreamOpKind::Map) }
    if name == "filter" { return Some(StreamOpKind::Filter) }
    if name == "fold" { return Some(StreamOpKind::Fold) }
    if name == "take" { return Some(StreamOpKind::Take) }
    if name == "skip" { return Some(StreamOpKind::Skip) }
    if name == "collect" { return Some(StreamOpKind::Collect) }
    return none
}

fn is_comparison_binop(op: BinOpKind) -> Bool {
    match op {
        Eq => { return true },
        Ne => { return true },
        Lt => { return true },
        Gt => { return true },
        Le => { return true },
        Ge => { return true },
        And => { return true },
        Or => { return true },
        _ => { return false }
    }
}

// binop_kind_to_str and unaryop_kind_to_str live in mir.mn (near the enums they convert)

// ===== lower.mn =====
// lower.mn — AST → MIR lowering pass for the Mapanare self-hosted compiler.
// Core lowering logic: declaration registration, definition lowering,
// expression/statement lowering, control flow, pretty-printer, verifier.
//
// Data structures (MIRType, Value, Instruction, etc.) are in mir.mn.
// State management (LowerState, lookups, type resolution) is in lower_state.mn.


// ---------------------------------------------------------------------------
// Declaration registration (Pass 1)
// ---------------------------------------------------------------------------

fn register_declarations(st: LowerState, program: Program) -> LowerState {
    let mut s: LowerState = st
    // Pass 1: register enums first so struct field types can distinguish enum vs struct
    let mut i: Int = 0
    for _ in 0..100000 {
        if i >= len(program.definitions) { break }
        let defn: Definition = program.definitions[i]
        match defn {
            EnumDef(data) => { s = register_enum(s, data) },
            _ => {}
        }
        i = i + 1
    }
    // Pass 2: register structs, impls, functions, imports
    i = 0
    for _ in 0..100000 {
        if i >= len(program.definitions) { return s }
        let defn: Definition = program.definitions[i]
        match defn {
            EnumDef(_) => {},
            _ => { s = register_definition(s, defn) }
        }
        i = i + 1
    }
    return s
}

fn register_definition(st: LowerState, defn: Definition) -> LowerState {
    match defn {
        StructDef(data) => {
            return register_struct(st, data)
        },
        EnumDef(data) => {
            return register_enum(st, data)
        },
        ImplDef(target, methods) => {
            return register_impl(st, target, methods)
        },
        ImportDef(path, items) => {
            let info: ImportInfo = new_import_info(path, items)
            let mut new_st: LowerState = st
            let mut mod_tmp: MIRModule = new_st.module
            let mut imp_list: List<ImportInfo> = mod_tmp.imports
            imp_list.push(info)
            mod_tmp.imports = imp_list
            new_st.module = mod_tmp
            return new_st
        },
        ExportDef(inner_opt, _) => {
            match inner_opt {
                Some(inner) => { return register_definition(st, inner) },
                _ => { return st }
            }
        },
        FnDef(fd) => {
            // Register function return type via lambda_vars (top-level list,
            // properly COW-cloned). Using "__ret__fn_name" as the key.
            // This avoids the nested MIRModule.functions COW corruption issue.
            let ret_ty: MIRType = resolve_return_type_checked(st, fd.return_type)
            let ret_key: String = "__ret__" + fd.name
            let ret_val: String = ret_ty.kind + ":" + ret_ty.name
            let entry: LambdaEntry = new_lambda_entry(ret_key, ret_val)
            let mut new_st: LowerState = st
            new_st.lambda_vars.push(entry)
            return new_st
        },
        _ => { return st }
    }
}

fn register_struct(st: LowerState, data: StructDefData) -> LowerState {
    let mut fields: List<FieldPair> = []
    let mut field_names: List<String> = []
    let mut field_types: List<MIRType> = []
    let mut i: Int = 0
    let mut s: LowerState = st

    for _ in 0..1000 {
        if i >= len(data.fields) {
            let info: StructInfo = new_struct_info(data.name, fields)
            s.module = module_push_struct(s.module, info)
            let sfi: StructFieldInfo = new_struct_field_info(data.name, field_names, field_types)
            s.struct_fields.push(sfi)
            return s
        }
        let field: StructField = data.fields[i]
        let fty: MIRType = lower_resolve_type_checked(s, field.type_annotation)
        let fp: FieldPair = new_field_pair(field.name, new_value("", fty))
        fields.push(fp)
        field_names.push(field.name)
        field_types.push(fty)
        i = i + 1
    }
    return s
}

fn register_enum(st: LowerState, data: EnumDefData) -> LowerState {
    let mut variants: List<EnumVariantInfo> = []
    let mut variant_names: List<String> = []
    let mut i: Int = 0
    let mut s: LowerState = st

    for _ in 0..1000 {
        if i >= len(data.variants) {
            let info: EnumInfo = new_enum_info(data.name, variants)
            s.module = module_push_enum(s.module, info)
            let evn: EnumVariantNames = new_enum_variant_names(data.name, variant_names)
            s.enum_variants.push(evn)
            return s
        }
        let variant: EnumVariant = data.variants[i]
        let mut payload_types: List<MIRType> = []
        let mut j: Int = 0
        for _ in 0..100 {
            if j >= len(variant.fields) { break }
            let fty: MIRType = lower_resolve_type_expr(variant.fields[j])
            payload_types.push(fty)
            j = j + 1
        }
        let vi: EnumVariantInfo = new_enum_variant_info(variant.name, payload_types)
        variants.push(vi)
        variant_names.push(variant.name)
        i = i + 1
    }
    return s
}

fn register_impl(st: LowerState, target: String, methods: List<FnDefData>) -> LowerState {
    let mut s: LowerState = st
    let mut i: Int = 0
    for _ in 0..1000 {
        if i >= len(methods) { return s }
        let method: FnDefData = methods[i]
        let key: String = target + "." + method.name
        let mir_name: String = target + "_" + method.name
        let entry: ImplEntry = new_impl_entry(key, mir_name)
        s.impl_methods.push(entry)
        i = i + 1
    }
    return s
}

// ---------------------------------------------------------------------------
// Definition lowering (Pass 2)
// ---------------------------------------------------------------------------

fn lower_definitions(st: LowerState, program: Program) -> LowerState {
    let mut s: LowerState = st
    let mut i: Int = 0
    for _ in 0..100000 {
        if i >= len(program.definitions) {
            return s
        }
        let defn: Definition = program.definitions[i]
        let new_s: LowerState = lower_definition(s, defn)
        s = new_s
        i = i + 1
    }
    return s
}

fn lower_definition(st: LowerState, defn: Definition) -> LowerState {
    match defn {
        FnDef(data) => {
            return lower_fn(st, data, "")
        },
        AgentDef(data) => {
            return lower_agent(st, data)
        },
        ImplDef(target, methods) => {
            return lower_impl(st, target, methods)
        },
        ExportDef(inner_opt, _) => {
            match inner_opt {
                Some(inner) => {
                    let s: LowerState = lower_definition(st, inner)
                    return s
                },
                _ => { return st }
            }
        },
        _ => {
            return st
        }
    }
}

// ---------------------------------------------------------------------------
// Function lowering
// ---------------------------------------------------------------------------

fn lower_fn(st: LowerState, fn_def: FnDefData, name_prefix: String) -> LowerState {
    let fn_name: String = name_prefix + fn_def.name

    // Build params
    let mut params: List<MIRParam> = []
    let mut pi: Int = 0
    for _ in 0..1000 {
        if pi >= len(fn_def.params) { break }
        let p: Param = fn_def.params[pi]
        let pty: MIRType = lower_resolve_type_opt_checked(st, p.type_annotation)
        let mp: MIRParam = new_mir_param(p.name, pty)
        params.push(mp)
        pi = pi + 1
    }

    let ret_type: MIRType = resolve_return_type_checked(st, fn_def.return_type)

    // Collect decorator names
    let mut decorators: List<String> = []
    let mut di: Int = 0
    for _ in 0..100 {
        if di >= len(fn_def.decorators) { break }
        let dec: Decorator = fn_def.decorators[di]
        decorators.push(dec.name)
        di = di + 1
    }

    let mir_fn: MIRFunction = new_mir_function(fn_name, params, ret_type, decorators, fn_def.public)

    // Save state
    let prev_fn: Option<MIRFunction> = st.current_fn
    let prev_block_idx: Int = st.current_block_idx
    let prev_tmp: Int = st.tmp_counter
    let prev_blk_cnt: Int = st.block_counter
    let prev_vars: List<VarInfo> = st.vars

    let mut s: LowerState = st
    s.current_fn = Some(mir_fn)
    s.tmp_counter = 0
    s.block_counter = 0
    let fresh_vars: List<VarInfo> = []
    s.vars = fresh_vars

    // Create entry block
    s = add_block(s, "entry")
    s = set_block(s, 0)

    // Bind params as variables
    let mut bi: Int = 0
    for _ in 0..1000 {
        if bi >= len(fn_def.params) { break }
        let p: Param = fn_def.params[bi]
        let pty: MIRType = lower_resolve_type_opt_checked(s, p.type_annotation)

        let addr_name: String = "%" + p.name + ".addr"
        let addr: Value = new_value(addr_name, pty)
        let param_val: Value = new_value("%" + p.name, pty)
        
        s = emit_instr(s, Instruction::Alloca(addr, pty))
        s = emit_instr(s, Instruction::Store(addr, param_val))
        s = define_var(s, p.name, addr, false)
        bi = bi + 1
    }

    // Lower body
    let body_r: LowerResult = lower_block(s, fn_def.body)
    s = body_r.state

    // Add implicit return if block isn't terminated
    if !current_block_terminated(s) {
        if ret_type.kind == "void" {
            s = emit_instr(s, Instruction::Return(none))
        } else {
            s = emit_instr(s, Instruction::Return(Some(body_r.value)))
        }
    }

    // Add function to module
    match s.current_fn {
        Some(f) => {
            s.module = module_push_function(s.module, f)
        },
        _ => {}
    }

    // Restore state
    s.current_fn = prev_fn
    s.current_block_idx = prev_block_idx
    s.tmp_counter = prev_tmp
    s.block_counter = prev_blk_cnt
    s.vars = prev_vars

    return s
}

fn lower_agent(st: LowerState, data: AgentDefData) -> LowerState {
    let mut s: LowerState = st
    let mut method_names: List<String> = []

    // Lower each method
    let mut i: Int = 0
    for _ in 0..1000 {
        if i >= len(data.methods) {
            let inputs: List<String> = extract_agent_input_names(data)
            let outputs: List<String> = extract_agent_output_names(data)
            let info: AgentInfo = new_agent_info(data.name, inputs, outputs, method_names)
            s.module = module_push_agent(s.module, info)
            return s
        }
        let method: FnDefData = data.methods[i]
        s = lower_fn(s, method, data.name + "_")
        let method_mir_name: String = data.name + "_" + method.name
        method_names.push(method_mir_name)
        i = i + 1
    }
    return s
}

fn extract_agent_input_names(data: AgentDefData) -> List<String> {
    let mut names: List<String> = []
    let mut i: Int = 0
    for _ in 0..100 {
        if i >= len(data.inputs) { return names }
        let inp: AgentInput = data.inputs[i]
        names.push(inp.name)
        i = i + 1
    }
    return names
}

fn extract_agent_output_names(data: AgentDefData) -> List<String> {
    let mut names: List<String> = []
    let mut i: Int = 0
    for _ in 0..100 {
        if i >= len(data.outputs) { return names }
        let out: AgentOutput = data.outputs[i]
        names.push(out.name)
        i = i + 1
    }
    return names
}

fn lower_impl(st: LowerState, target: String, methods: List<FnDefData>) -> LowerState {
    let mut s: LowerState = st
    let mut i: Int = 0
    for _ in 0..1000 {
        if i >= len(methods) { return s }
        let method: FnDefData = methods[i]
        s = lower_fn(s, method, target + "_")
        i = i + 1
    }
    return s
}

// ---------------------------------------------------------------------------
// Block / statement lowering
// ---------------------------------------------------------------------------

fn lower_block(st: LowerState, block: Block) -> LowerResult {
    let mut s: LowerState = lower_push_scope(st)
    let mut last_val: Value = void_value()
    let mut i: Int = 0
    for _ in 0..100000 {
        if i >= len(block.stmts) {
            s = lower_pop_scope(s)
            return new_lower_result(last_val, s)
        }
        if current_block_terminated(s) {
            s = lower_pop_scope(s)
            return new_lower_result(last_val, s)
        }
        let stmt: Stmt = block.stmts[i]
        let r: LowerResult = lower_stmt(s, stmt)
        s = r.state
        last_val = r.value
        i = i + 1
    }
    s = lower_pop_scope(s)
    return new_lower_result(last_val, s)
}

fn lower_stmt(st: LowerState, stmt: Stmt) -> LowerResult {
    match stmt {
        Let(name, mutable, type_ann, value) => {
            let s: LowerState = lower_let(st, name, mutable, type_ann, value)
            return new_lower_result(void_value(), s)
        },
        ExprStmt(expr) => {
            return lower_expr(st, expr)
        },
        Return(value_opt) => {
            let s: LowerState = lower_return(st, value_opt)
            return new_lower_result(void_value(), s)
        },
        For(var_name, iterable, body) => {
            let s: LowerState = lower_for(st, var_name, iterable, body)
            return new_lower_result(void_value(), s)
        },
        SignalDecl(name, mutable, type_ann, value, _) => {
            let s: LowerState = lower_signal_decl(st, name, mutable, type_ann, value)
            return new_lower_result(void_value(), s)
        },
        StreamDecl(name, type_ann, value) => {
            let s: LowerState = lower_stream_decl(st, name, value)
            return new_lower_result(void_value(), s)
        }
    }
}

// ---------------------------------------------------------------------------
// Let binding
// ---------------------------------------------------------------------------

fn lower_let(st: LowerState, name: String, mutable: Bool, type_ann: Option<TypeExpr>, value: Expr) -> LowerState {
    let r: LowerResult = lower_expr(st, value)
    let mut s: LowerState = r.state

    // Update lambda registration: lower_lambda left var_name empty
    let num_lv: Int = len(s.lambda_vars)
    if num_lv > 0 {
        let last_e: LambdaEntry = s.lambda_vars[num_lv - 1]
        if last_e.var_name == "" {
            let updated: LambdaEntry = new_lambda_entry(name, last_e.fn_name)
            s.lambda_vars[num_lv - 1] = updated
        }
    }

    // Prefer the declared type annotation over the expression's inferred type.
    // This is critical: function calls return mir_unknown(), but the declared
    // type (e.g., `let ch: String = lexer_peek(source)`) carries the real type.
    let mut val_ty: MIRType = r.value.ty
    let mut val: Value = r.value
    match type_ann {
        Some(te) => {
            let declared: MIRType = lower_resolve_type_checked(s, te)
            if declared.kind != "unknown" {
                val_ty = declared
                // Patch the value to carry the declared type (same SSA name, correct type)
                val = new_value(r.value.name, declared)
            }
        },
        _ => {}
    }

    // Find or create alloca for this variable (use counter for uniqueness
    // when the same variable name appears in different branches)
    let addr_name: String = "%" + name + toString(s.tmp_counter) + ".addr"
    s.tmp_counter = s.tmp_counter + 1

    let addr: Value = new_value(addr_name, val_ty)

    // Emit Alloca with the resolved type
    s = emit_instr(s, Instruction::Alloca(addr, val_ty))

    // For None stored to a typed Option alloca: re-emit WrapNone with the
    // declared type so the value and alloca types match.
    if val_ty.kind == "option" && r.value.ty.kind == "option" && len(val_ty.args) > 0 && len(r.value.ty.args) == 0 {
        let typed_none_r: LowerResult = make_value(s, val_ty, "tnone")
        s = emit_instr(typed_none_r.state, Instruction::WrapNone(typed_none_r.value, val_ty))
        val = typed_none_r.value
    }

    // Store value to alloca
    s = emit_instr(s, Instruction::Store(addr, val))

    // Track the alloca address in our variable map
    s = define_var(s, name, addr, mutable)
    return s
}

// ---------------------------------------------------------------------------
// Return
// ---------------------------------------------------------------------------

fn lower_return(st: LowerState, value_opt: Option<Expr>) -> LowerState {
    match value_opt {
        Some(expr) => {
            let r: LowerResult = lower_expr(st, expr)
            // Return the value directly — no Copy needed.
            // (Avoids `add i64 0, %struct_val` type mismatch for struct returns.)
            return emit_instr(r.state, Instruction::Return(Some(r.value)))
        },
        _ => {
            return emit_instr(st, Instruction::Return(none))
        }
    }
}

// ---------------------------------------------------------------------------
// For loop
// ---------------------------------------------------------------------------

fn lower_for(st: LowerState, var_name: String, iterable: Expr, body: Block) -> LowerState {
    // Lower the iterable (Range expression: start..end)
    let iter_r: LowerResult = lower_expr(st, iterable)
    let mut s: LowerState = iter_r.state

    // Counter-based loop: use __mn_range_start/end to extract bounds.
    // SSA-based iterator can't mutate, so we use alloca counter.
    let counter_addr: Value = new_value("%for_counter" + toString(s.tmp_counter) + ".addr", mir_int())
    s.tmp_counter = s.tmp_counter + 1
    s = emit_instr(s, Instruction::Alloca(counter_addr, mir_int()))

    // Extract start/end from range via runtime calls
    let start_r: LowerResult = make_value(s, mir_int(), "for_start")
    s = start_r.state
    let mut start_args: List<Value> = []
    start_args.push(iter_r.value)
    s = emit_instr(s, Instruction::Call(start_r.value, "__mn_range_start", start_args))
    let end_r: LowerResult = make_value(s, mir_int(), "for_end")
    s = end_r.state
    let mut end_args: List<Value> = []
    end_args.push(iter_r.value)
    s = emit_instr(s, Instruction::Call(end_r.value, "__mn_range_end", end_args))

    // Store start value to counter
    s = emit_instr(s, Instruction::Store(counter_addr, start_r.value))

    // Save current (entry) block index
    let entry_idx: Int = s.current_block_idx

    // Create blocks
    let header_r2: LowerResult = fresh_block_label(s, "for_header")
    s = header_r2.state
    let header_label: String = header_r2.value.name
    s = add_block(s, header_label)
    let header_idx: Int = s.current_block_idx

    let body_r2: LowerResult = fresh_block_label(s, "for_body")
    s = body_r2.state
    let body_label: String = body_r2.value.name
    s = add_block(s, body_label)
    let body_idx: Int = s.current_block_idx

    let exit_r2: LowerResult = fresh_block_label(s, "for_exit")
    s = exit_r2.state
    let exit_label: String = exit_r2.value.name
    s = add_block(s, exit_label)
    let exit_idx: Int = s.current_block_idx

    // Jump from entry block to header
    s = set_block(s, entry_idx)
    if !current_block_terminated(s) {
        s = emit_instr(s, Instruction::Jump(header_label))
    }

    // Header block: load counter, compare < end, branch
    s = set_block(s, header_idx)
    let counter_val: LowerResult = make_value(s, mir_int(), "for_i")
    s = counter_val.state
    s = emit_instr(s, Instruction::Load(counter_val.value, counter_addr))
    let cmp_r: LowerResult = make_value(s, mir_bool(), "for_cmp")
    s = cmp_r.state
    s = emit_instr(s, Instruction::BinOp(cmp_r.value, BinOpKind::Lt, counter_val.value, end_r.value))
    s = emit_instr(s, Instruction::Branch(cmp_r.value, body_label, exit_label))

    // Body block: define loop variable, execute body, increment counter
    s = set_block(s, body_idx)
    let loop_addr_r: LowerResult = make_value(s, mir_int(), var_name + "_addr")
    s = loop_addr_r.state
    s = emit_instr(s, Instruction::Alloca(loop_addr_r.value, mir_int()))
    // Load current counter value for the loop variable
    let cur_i: LowerResult = make_value(s, mir_int(), "cur_i")
    s = cur_i.state
    s = emit_instr(s, Instruction::Load(cur_i.value, counter_addr))
    s = emit_instr(s, Instruction::Store(loop_addr_r.value, cur_i.value))
    s = define_var(s, var_name, loop_addr_r.value, false)

    s = lower_push_scope(s)
    let body_result: LowerResult = lower_block(s, body)
    s = body_result.state
    s = lower_pop_scope(s)

    // Increment counter and jump back to header
    if !current_block_terminated(s) {
        let inc_val: LowerResult = make_value(s, mir_int(), "for_inc")
        s = inc_val.state
        let inc_i: LowerResult = make_value(s, mir_int(), "for_ci")
        s = inc_i.state
        s = emit_instr(s, Instruction::Load(inc_i.value, counter_addr))
        let one_r: LowerResult = make_value(s, mir_int(), "one")
        s = one_r.state
        s = emit_instr(s, Instruction::Const(one_r.value, mir_int(), "1"))
        s = emit_instr(s, Instruction::BinOp(inc_val.value, BinOpKind::Add, inc_i.value, one_r.value))
        s = emit_instr(s, Instruction::Store(counter_addr, inc_val.value))
        s = emit_instr(s, Instruction::Jump(header_label))
    }

    // Exit block
    s = set_block(s, exit_idx)
    return s
}

// ---------------------------------------------------------------------------
// Signal / stream declarations
// ---------------------------------------------------------------------------

fn lower_signal_decl(st: LowerState, name: String, mutable: Bool, type_ann: Option<TypeExpr>, value: Expr) -> LowerState {
    let init_r: LowerResult = lower_expr(st, value)
    let sig_type: MIRType = lower_resolve_type_opt(type_ann)
    let dest_r: LowerResult = make_value(init_r.state, mir_signal(), "sig")
    let mut s: LowerState = emit_instr(dest_r.state, Instruction::SignalInit(dest_r.value, sig_type, init_r.value))
    s = define_var(s, name, dest_r.value, mutable)
    return s
}

fn lower_stream_decl(st: LowerState, name: String, value: Expr) -> LowerState {
    let r: LowerResult = lower_expr(st, value)
    return define_var(r.state, name, r.value, false)
}

// ---------------------------------------------------------------------------
// Expression lowering
// ---------------------------------------------------------------------------

fn lower_expr(st: LowerState, expr: Expr) -> LowerResult {
    match expr {
        IntLit(n) => {
            let r: LowerResult = make_value(st, mir_int(), "t")
            let s: LowerState = emit_instr(r.state, Instruction::Const(r.value, mir_int(), toString(n)))
            return new_lower_result(r.value, s)
        },
        FloatLit(f) => {
            let r: LowerResult = make_value(st, mir_float(), "t")
            let s: LowerState = emit_instr(r.state, Instruction::Const(r.value, mir_float(), toString(f)))
            return new_lower_result(r.value, s)
        },
        BoolLit(b) => {
            let r: LowerResult = make_value(st, mir_bool(), "t")
            let val_str: String = if b { "true" } else { "false" }
            let s: LowerState = emit_instr(r.state, Instruction::Const(r.value, mir_bool(), val_str))
            return new_lower_result(r.value, s)
        },
        StringLit(text) => {
            let r: LowerResult = make_value(st, mir_string(), "t")
            let s: LowerState = emit_instr(r.state, Instruction::Const(r.value, mir_string(), text))
            return new_lower_result(r.value, s)
        },
        CharLit(ch) => {
            let r: LowerResult = make_value(st, mir_string(), "t")
            let s: LowerState = emit_instr(r.state, Instruction::Const(r.value, mir_string(), ch))
            return new_lower_result(r.value, s)
        },
        NoneLit => {
            let r: LowerResult = make_value(st, mir_option(), "t")
            let s: LowerState = emit_instr(r.state, Instruction::WrapNone(r.value, mir_option()))
            return new_lower_result(r.value, s)
        },
        Ident(name) => {
            return lower_identifier(st, name)
        },
        Binary(left, op, right) => {
            return lower_binary(st, left, op, right)
        },
        Unary(op, operand) => {
            return lower_unary(st, op, operand)
        },
        Call(callee, args) => {
            return lower_call(st, callee, args)
        },
        MethodCall(obj, method, args) => {
            return lower_method_call(st, obj, method, args)
        },
        FieldAccess(obj, field_name) => {
            return lower_field_access(st, obj, field_name)
        },
        NamespaceAccess(ns, member) => {
            return lower_namespace_access(st, ns, member)
        },
        Index(obj, idx) => {
            return lower_index(st, obj, idx)
        },
        Pipe(left, right) => {
            return lower_pipe(st, left, right)
        },
        Range(start, end, inclusive) => {
            return lower_range(st, start, end, inclusive)
        },
        Lambda(params, body) => {
            return lower_lambda(st, params, body)
        },
        Spawn(callee, args) => {
            return lower_spawn(st, callee, args)
        },
        Sync(inner) => {
            return lower_sync(st, inner)
        },
        Send(target, value) => {
            return lower_send(st, target, value)
        },
        ErrorProp(inner) => {
            return lower_error_prop(st, inner)
        },
        ListLit(elements) => {
            return lower_list(st, elements)
        },
        Construct(name, fields) => {
            return lower_construct(st, name, fields)
        },
        SomeWrap(inner) => {
            let r: LowerResult = lower_expr(st, inner)
            let dest_r: LowerResult = make_value(r.state, mir_option(), "t")
            let s: LowerState = emit_instr(dest_r.state, Instruction::WrapSome(dest_r.value, r.value))
            return new_lower_result(dest_r.value, s)
        },
        OkWrap(inner) => {
            let r: LowerResult = lower_expr(st, inner)
            let dest_r: LowerResult = make_value(r.state, mir_result(), "t")
            let s: LowerState = emit_instr(dest_r.state, Instruction::WrapOk(dest_r.value, r.value))
            return new_lower_result(dest_r.value, s)
        },
        ErrWrap(inner) => {
            let r: LowerResult = lower_expr(st, inner)
            let dest_r: LowerResult = make_value(r.state, mir_result(), "t")
            let s: LowerState = emit_instr(dest_r.state, Instruction::WrapErr(dest_r.value, r.value))
            return new_lower_result(dest_r.value, s)
        },
        SignalVal(inner, _) => {
            return lower_signal_expr(st, inner)
        },
        Assign(target, op, value) => {
            return lower_assign(st, target, op, value)
        },
        If(cond, then_block, else_clause) => {
            return lower_if(st, cond, then_block, else_clause)
        },
        Match(subject, arms) => {
            return lower_match(st, subject, arms)
        }
    }
}

// ---------------------------------------------------------------------------
// Identifier lowering
// ---------------------------------------------------------------------------

fn lower_identifier(st: LowerState, name: String) -> LowerResult {
    // Check variable scope
    let var_opt: Option<Value> = lookup_var(st, name)
    match var_opt {
        Some(addr) => {
            // var_opt now returns the alloca address. Emit a Load to get the value.
            let r: LowerResult = make_value(st, addr.ty, name + "_val")
            let s: LowerState = emit_instr(r.state, Instruction::Load(r.value, addr))
            return new_lower_result(r.value, s)
        },
        _ => {}
    }

    // Check if it's a bare enum variant (no payload)
    if is_enum_variant(st, name) {
        let enum_name: String = enum_name_for_variant(st, name)
        let enum_ty: MIRType = mir_enum(enum_name)
        let r: LowerResult = make_value(st, enum_ty, "t")
        let empty_payload: List<Value> = []
        let s: LowerState = emit_instr(r.state, Instruction::EnumInit(r.value, enum_ty, name, empty_payload))
        return new_lower_result(r.value, s)
    }

    // Unknown — emit placeholder
    let r: LowerResult = make_value(st, mir_unknown(), name)
    let s: LowerState = emit_instr(r.state, Instruction::Const(r.value, mir_unknown(), ""))
    return new_lower_result(r.value, s)
}

// ---------------------------------------------------------------------------
// Binary expression lowering
// ---------------------------------------------------------------------------

fn lower_binary(st: LowerState, left: Expr, op: String, right: Expr) -> LowerResult {
    // Handle pipe operator
    if op == "|>" {
        return lower_pipe(st, left, right)
    }

    let lhs_r: LowerResult = lower_expr(st, left)
    let rhs_r: LowerResult = lower_expr(lhs_r.state, right)

    // Type coercion: if one operand is unknown and the other is typed,
    // propagate the known type to the unknown operand.
    let mut lhs_val: Value = lhs_r.value
    let mut rhs_val: Value = rhs_r.value
    if lhs_val.ty.kind == "unknown" && rhs_val.ty.kind != "unknown" {
        lhs_val = new_value(lhs_val.name, rhs_val.ty)
    }
    if rhs_val.ty.kind == "unknown" && lhs_val.ty.kind != "unknown" {
        rhs_val = new_value(rhs_val.name, lhs_val.ty)
    }

    let binop_opt: Option<BinOpKind> = binop_from_str(op)
    match binop_opt {
        Some(binop) => {
            // Use string comparison on the operator (not enum match on BinOpKind)
            // because enum match falls through in the compiled binary
            let is_cmp: Bool = op == "==" || op == "!=" || op == "<" || op == ">" || op == "<=" || op == ">=" || op == "and" || op == "or"
            let result_ty: MIRType = if is_cmp { mir_bool() } else { lhs_val.ty }
            let dest_r: LowerResult = make_value(rhs_r.state, result_ty, "t")
            let s: LowerState = emit_instr(dest_r.state, Instruction::BinOp(dest_r.value, binop, lhs_val, rhs_val))
            return new_lower_result(dest_r.value, s)
        },
        _ => {
            // Unknown operator — emit as call
            let dest_r: LowerResult = make_value(rhs_r.state, mir_unknown(), "t")
            let mut args: List<Value> = []
            args.push(lhs_r.value)
            args.push(rhs_r.value)
            let s: LowerState = emit_instr(dest_r.state, Instruction::Call(dest_r.value, "__op_" + op, args))
            return new_lower_result(dest_r.value, s)
        }
    }
}

// ---------------------------------------------------------------------------
// Unary expression lowering
// ---------------------------------------------------------------------------

fn resolve_unary_result_type(uop: UnaryOpKind, operand_ty: MIRType) -> MIRType {
    match uop {
        Not => { return mir_bool() },
        _ => { return operand_ty }
    }
}

fn lower_unary(st: LowerState, op: String, operand: Expr) -> LowerResult {
    let op_r: LowerResult = lower_expr(st, operand)
    let uop_opt: Option<UnaryOpKind> = unaryop_from_str(op)
    match uop_opt {
        Some(uop) => {
            let result_ty: MIRType = resolve_unary_result_type(uop, op_r.value.ty)
            let dest_r: LowerResult = make_value(op_r.state, result_ty, "t")
            let s: LowerState = emit_instr(dest_r.state, Instruction::UnaryOp(dest_r.value, uop, op_r.value))
            return new_lower_result(dest_r.value, s)
        },
        _ => {
            let dest_r: LowerResult = make_value(op_r.state, mir_unknown(), "t")
            let mut args: List<Value> = []
            args.push(op_r.value)
            let s: LowerState = emit_instr(dest_r.state, Instruction::Call(dest_r.value, "__unary_" + op, args))
            return new_lower_result(dest_r.value, s)
        }
    }
}

// ---------------------------------------------------------------------------
// Call lowering
// ---------------------------------------------------------------------------

fn lower_call(st: LowerState, callee: Expr, arg_exprs: List<Expr>) -> LowerResult {
    // Lower all arguments first
    let mut s: LowerState = st
    let mut args: List<Value> = []
    let mut i: Int = 0
    for _ in 0..1000 {
        if i >= len(arg_exprs) { break }
        let arg_r: LowerResult = lower_expr(s, arg_exprs[i])
        s = arg_r.state
        args.push(arg_r.value)
        i = i + 1
    }

    // Dispatch on callee type
    match callee {
        Ident(fn_name) => {
            return lower_call_by_name(s, fn_name, args)
        },
        FieldAccess(obj, method) => {
            // obj.method(args) that parsed as Call(FieldAccess, args)
            let obj_r: LowerResult = lower_expr(s, obj)
            let dest_r: LowerResult = make_value(obj_r.state, mir_unknown(), "t")
            let mut all_args: List<Value> = []
            all_args.push(obj_r.value)
            let mut j: Int = 0
            for _ in 0..1000 {
                if j >= len(args) { break }
                all_args.push(args[j])
                j = j + 1
            }
            let new_s: LowerState = emit_instr(dest_r.state, Instruction::Call(dest_r.value, method, all_args))
            return new_lower_result(dest_r.value, new_s)
        },
        NamespaceAccess(ns, member) => {
            // Check if this is an enum variant constructor: Enum::Variant(...)
            // Verify the variant belongs specifically to the namespace enum
            let found_enum: String = enum_name_for_variant(s, member)
            if found_enum == ns {
                let enum_ty: MIRType = mir_enum(ns)
                let dest_r: LowerResult = make_value(s, enum_ty, "t")
                let new_s: LowerState = emit_instr(dest_r.state, Instruction::EnumInit(dest_r.value, enum_ty, member, args))
                return new_lower_result(dest_r.value, new_s)
            }
            // For struct statics like Program::start(defs), try bare function
            // name first (the function is `start`, not `Program_start`).
            return lower_call_by_name(s, member, args)
        },
        _ => {
            let callee_r: LowerResult = lower_expr(s, callee)
            let dest_r: LowerResult = make_value(callee_r.state, mir_unknown(), "t")
            let new_s: LowerState = emit_instr(dest_r.state, Instruction::Call(dest_r.value, callee_r.value.name, args))
            return new_lower_result(dest_r.value, new_s)
        }
    }
}

fn lower_call_by_name(st: LowerState, fn_name: String, args: List<Value>) -> LowerResult {
    // Builtin void functions
    if fn_name == "print" {
        let dest_r: LowerResult = make_value(st, mir_void(), "t")
        let s: LowerState = emit_instr(dest_r.state, Instruction::Call(dest_r.value, fn_name, args))
        return new_lower_result(dest_r.value, s)
    }
    if fn_name == "println" {
        let dest_r: LowerResult = make_value(st, mir_void(), "t")
        let s: LowerState = emit_instr(dest_r.state, Instruction::Call(dest_r.value, fn_name, args))
        return new_lower_result(dest_r.value, s)
    }
    // Builtin conversion functions — set correct MIR return types
    if fn_name == "int" {
        let dest_r: LowerResult = make_value(st, mir_int(), "t")
        let s: LowerState = emit_instr(dest_r.state, Instruction::Call(dest_r.value, fn_name, args))
        return new_lower_result(dest_r.value, s)
    }
    if fn_name == "float" {
        let dest_r: LowerResult = make_value(st, mir_float(), "t")
        let s: LowerState = emit_instr(dest_r.state, Instruction::Call(dest_r.value, fn_name, args))
        return new_lower_result(dest_r.value, s)
    }
    if fn_name == "str" || fn_name == "toString" {
        let dest_r: LowerResult = make_value(st, mir_string(), "t")
        let s: LowerState = emit_instr(dest_r.state, Instruction::Call(dest_r.value, fn_name, args))
        return new_lower_result(dest_r.value, s)
    }
    if fn_name == "len" {
        let dest_r: LowerResult = make_value(st, mir_int(), "t")
        let s: LowerState = emit_instr(dest_r.state, Instruction::Call(dest_r.value, fn_name, args))
        return new_lower_result(dest_r.value, s)
    }

    // Handle Option/Result builtins
    if fn_name == "Some" {
        if len(args) == 1 {
            let dest_r: LowerResult = make_value(st, mir_option(), "t")
            let s: LowerState = emit_instr(dest_r.state, Instruction::WrapSome(dest_r.value, args[0]))
            return new_lower_result(dest_r.value, s)
        }
    }
    if fn_name == "Ok" {
        if len(args) == 1 {
            // Use the function's return type (with generic args) if available
            let mut res_ty: MIRType = mir_result()
            match st.current_fn {
                Some(cf) => {
                    if cf.return_type.kind == "result" {
                        res_ty = cf.return_type
                    }
                },
                _ => {}
            }
            let dest_r: LowerResult = make_value(st, res_ty, "t")
            let s: LowerState = emit_instr(dest_r.state, Instruction::WrapOk(dest_r.value, args[0]))
            return new_lower_result(dest_r.value, s)
        }
    }
    if fn_name == "Err" {
        if len(args) == 1 {
            let mut res_ty: MIRType = mir_result()
            match st.current_fn {
                Some(cf) => {
                    if cf.return_type.kind == "result" {
                        res_ty = cf.return_type
                    }
                },
                _ => {}
            }
            let dest_r: LowerResult = make_value(st, res_ty, "t")
            let s: LowerState = emit_instr(dest_r.state, Instruction::WrapErr(dest_r.value, args[0]))
            return new_lower_result(dest_r.value, s)
        }
    }

    // Check if it's an enum variant constructor
    if is_enum_variant(st, fn_name) {
        let enum_name: String = enum_name_for_variant(st, fn_name)
        let enum_ty: MIRType = mir_enum(enum_name)
        let dest_r: LowerResult = make_value(st, enum_ty, "t")
        let s: LowerState = emit_instr(dest_r.state, Instruction::EnumInit(dest_r.value, enum_ty, fn_name, args))
        return new_lower_result(dest_r.value, s)
    }

    // Check if it's a struct constructor (use if instead of match to avoid
    // control flow issues with return-inside-match)
    if is_struct_name(st, fn_name) {
        let field_names: List<String> = get_struct_field_names(st, fn_name)
        let struct_ty: MIRType = mir_struct(fn_name)
        let mut field_pairs: List<FieldPair> = []
        let mut fi: Int = 0
        for _ in 0..1000 {
            if fi >= len(field_names) { break }
            if fi >= len(args) { break }
            let fp: FieldPair = new_field_pair(field_names[fi], args[fi])
            field_pairs.push(fp)
            fi = fi + 1
        }
        let dest_r: LowerResult = make_value(st, struct_ty, "t")
        let s: LowerState = emit_instr(dest_r.state, Instruction::StructInit(dest_r.value, struct_ty, field_pairs))
        return new_lower_result(dest_r.value, s)
    }

    // Resolve lambda variable names to actual function names
    let resolved: String = unwrap_or_default(find_lambda(st, fn_name), fn_name)

    // For non-lambda calls, emit directly (no state copy needed).
    // Look up function return type from lambda_vars registry (__ret__fn_name).
    if resolved.find(":") < 0 {
        let mut call_ret: MIRType = mir_unknown()
        let ret_key: String = "__ret__" + resolved
        let ret_opt: Option<String> = find_lambda(st, ret_key)
        match ret_opt {
            Some(ret_encoded) => {
                // Decode "kind:name" → MIRType
                let colon: Int = ret_encoded.find(":")
                if colon >= 0 {
                    let kind: String = ret_encoded.substr(0, colon)
                    // substr(start, END) not substr(start, LENGTH)
                    let name: String = ret_encoded.substr(colon + 1, len(ret_encoded))
                    if kind == "struct" { call_ret = mir_struct(name) }
                    if kind == "enum" { call_ret = mir_enum(name) }
                    if kind == "int" { call_ret = mir_int() }
                    if kind == "float" { call_ret = mir_float() }
                    if kind == "string" { call_ret = mir_string() }
                    if kind == "bool" { call_ret = mir_bool() }
                    if kind == "void" { call_ret = mir_void() }
                    if kind == "option" { call_ret = mir_option() }
                    if kind == "result" { call_ret = mir_result() }
                    if kind == "list" { call_ret = mir_list() }
                }
            },
            _ => {}
        }
        let dest_r: LowerResult = make_value(st, call_ret, "t")
        let s: LowerState = emit_instr(dest_r.state, Instruction::Call(dest_r.value, resolved, args))
        return new_lower_result(dest_r.value, s)
    }

    // Lambda call with captures — decode "lambda1:x,y" and load captured vars.
    // Chain state through make_value/emit_instr (byref, no LowerState copy).
    let actual_fn: String = resolved.substr(0, resolved.find(":"))
    let cp: Int = resolved.find(":")
    let caps_str: String = resolved.substr(cp + 1, len(resolved))
    let cap_parts: List<String> = caps_str.split(",")
    return lower_call_with_captures(st, actual_fn, args, cap_parts, 0)
}

fn lower_call_with_captures(st: LowerState, fn_name: String, args: List<Value>, captures: List<String>, idx: Int) -> LowerResult {
    // Base case: all captures loaded — emit the call
    if idx >= len(captures) {
        let dest_r: LowerResult = make_value(st, mir_unknown(), "t")
        let s: LowerState = emit_instr(dest_r.state, Instruction::Call(dest_r.value, fn_name, args))
        return new_lower_result(dest_r.value, s)
    }

    // Load one captured variable and recurse
    let cap_name: String = captures[idx]
    let var_opt: Option<Value> = lookup_var(st, cap_name)
    match var_opt {
        Some(addr) => {
            let lr: LowerResult = make_value(st, addr.ty, "cap")
            let ns: LowerState = emit_instr(lr.state, Instruction::Load(lr.value, addr))
            args.push(lr.value)
            return lower_call_with_captures(ns, fn_name, args, captures, idx + 1)
        },
        _ => {
            return lower_call_with_captures(st, fn_name, args, captures, idx + 1)
        }
    }
}

// ---------------------------------------------------------------------------
// Method call lowering
// ---------------------------------------------------------------------------

fn str_method_return_type(method: String) -> MIRType {
    if method == "char_at" { return mir_string() }
    if method == "substr" { return mir_string() }
    if method == "to_upper" { return mir_string() }
    if method == "to_lower" { return mir_string() }
    if method == "replace" { return mir_string() }
    if method == "trim" { return mir_string() }
    if method == "trim_start" { return mir_string() }
    if method == "trim_end" { return mir_string() }
    if method == "concat" { return mir_string() }
    if method == "byte_at" { return mir_int() }
    if method == "find" { return mir_int() }
    if method == "starts_with" { return mir_bool() }
    if method == "ends_with" { return mir_bool() }
    if method == "contains" { return mir_bool() }
    if method == "split" { return mir_list() }
    return mir_unknown()
}

fn lower_method_call(st: LowerState, obj: Expr, method: String, arg_exprs: List<Expr>) -> LowerResult {
    let obj_r: LowerResult = lower_expr(st, obj)
    let mut s: LowerState = obj_r.state

    // Special handling for push: pass the list ALLOCA address (not the loaded value)
    // so the emitter can push directly to the alloca, avoiding copy semantics.
    if method == "push" {
        return lower_push_method(s, obj, obj_r, arg_exprs)
    }

    // Build arg list: [obj_value, arg_values...]
    let mut all_args: List<Value> = []
    all_args.push(obj_r.value)
    let nae: Int = len(arg_exprs)
    let mut i: Int = 0
    for _ in 0..1000 {
        if i >= nae { break }
        let arg_r: LowerResult = lower_expr(s, arg_exprs[i])
        s = arg_r.state
        all_args.push(arg_r.value)
        i = i + 1
    }

    let mut ret_ty: MIRType = mir_unknown()
    if obj_r.value.ty.kind == "string" {
        ret_ty = str_method_return_type(method)
    }

    let dest_r: LowerResult = make_value(s, ret_ty, "t")
    let new_s: LowerState = emit_instr(dest_r.state, Instruction::Call(dest_r.value, method, all_args))
    return new_lower_result(dest_r.value, new_s)
}

fn lower_push_method(st: LowerState, obj: Expr, obj_r: LowerResult, arg_exprs: List<Expr>) -> LowerResult {
    let mut s: LowerState = st
    // Lower the element
    let arg_r: LowerResult = lower_expr(s, arg_exprs[0])
    s = arg_r.state
    // Find the alloca for the list.
    // For simple Ident: use lookup_var → alloca address
    // For FieldAccess: use the struct alloca + field name
    //   The emitter handles this via the @field: prefix
    let list_ref: Value = find_list_alloca(s, obj, obj_r)
    let mut all_args: List<Value> = []
    all_args.push(list_ref)
    all_args.push(arg_r.value)
    let dest_r: LowerResult = make_value(s, mir_void(), "t")
    let new_s: LowerState = emit_instr(dest_r.state, Instruction::Call(dest_r.value, "push", all_args))
    return new_lower_result(dest_r.value, new_s)
}

fn find_list_alloca(st: LowerState, obj: Expr, obj_r: LowerResult) -> Value {
    match obj {
        Ident(name) => {
            // Simple variable push: use the variable's alloca directly
            let var_opt: Option<Value> = lookup_var(st, name)
            match var_opt {
                Some(addr) => { return addr },
                _ => { return obj_r.value }
            }
        },
        FieldAccess(inner, field_name) => {
            // struct.field.push(): GEP into the struct alloca
            // to get a pointer to the list field
            return find_field_alloca(st, inner, field_name, obj_r)
        },
        _ => { return obj_r.value }
    }
}

fn find_field_alloca(st: LowerState, inner: Expr, field_name: String, obj_r: LowerResult) -> Value {
    match inner {
        Ident(name) => {
            let var_opt: Option<Value> = lookup_var(st, name)
            match var_opt {
                Some(addr) => {
                    // Encode the field name in the Value's type name
                    // so the emitter can find the correct field index.
                    // Convention: ty.name = "StructName:field_name"
                    // Encode struct_name:field_name in ty.name
                    let combined: MIRType = new_mir_type(addr.ty.name + ":" + field_name, addr.ty.kind)
                    return new_value(addr.name, combined)
                },
                _ => { return obj_r.value }
            }
        },
        _ => { return obj_r.value }
    }
}

// ---------------------------------------------------------------------------
// Field access lowering
// ---------------------------------------------------------------------------

fn lookup_struct_field_type(st: LowerState, struct_name: String, field_name: String) -> MIRType {
    let mut i: Int = 0
    for _ in 0..10000 {
        if i >= len(st.struct_fields) { return mir_unknown() }
        let info: StructFieldInfo = st.struct_fields[i]
        if info.name == struct_name {
            let mut j: Int = 0
            for _ in 0..1000 {
                if j >= len(info.field_names) { return mir_unknown() }
                if info.field_names[j] == field_name {
                    if j < len(info.field_types) {
                        return info.field_types[j]
                    }
                    return mir_unknown()
                }
                j = j + 1
            }
        }
        i = i + 1
    }
    return mir_unknown()
}

fn lower_field_access(st: LowerState, obj: Expr, field_name: String) -> LowerResult {
    let obj_r: LowerResult = lower_expr(st, obj)

    // Only emit SignalGet for actual signal types, not for struct .value fields
    if field_name == "value" && obj_r.value.ty.kind == "signal" {
        let dest_r: LowerResult = make_value(obj_r.state, mir_unknown(), "t")
        let s: LowerState = emit_instr(dest_r.state, Instruction::SignalGet(dest_r.value, obj_r.value))
        return new_lower_result(dest_r.value, s)
    }

    // Resolve field type from struct registry
    let field_ty: MIRType = lookup_struct_field_type(obj_r.state, obj_r.value.ty.name, field_name)

    let dest_r: LowerResult = make_value(obj_r.state, field_ty, "t")
    let s: LowerState = emit_instr(dest_r.state, Instruction::FieldGet(dest_r.value, obj_r.value, field_name))
    return new_lower_result(dest_r.value, s)
}

// ---------------------------------------------------------------------------
// Namespace access lowering
// ---------------------------------------------------------------------------

fn is_enum_name(st: LowerState, name: String) -> Bool {
    let mut i: Int = 0
    for _ in 0..100000 {
        if i >= len(st.enum_variants) { return false }
        if st.enum_variants[i].enum_name == name { return true }
        i = i + 1
    }
    return false
}

fn lower_namespace_access(st: LowerState, ns: String, member: String) -> LowerResult {
    // Check if namespace is a registered enum → emit EnumInit
    if is_enum_name(st, ns) {
        let enum_ty: MIRType = mir_enum(ns)
        let dest_r: LowerResult = make_value(st, enum_ty, "t")
        let empty_args: List<Value> = []
        let s: LowerState = emit_instr(dest_r.state, Instruction::EnumInit(dest_r.value, enum_ty, member, empty_args))
        return new_lower_result(dest_r.value, s)
    }
    // Otherwise: module function call
    let dest_r: LowerResult = make_value(st, mir_unknown(), "t")
    let fn_name: String = ns + "_" + member
    let empty_args: List<Value> = []
    let s: LowerState = emit_instr(dest_r.state, Instruction::Call(dest_r.value, fn_name, empty_args))
    return new_lower_result(dest_r.value, s)
}

// ---------------------------------------------------------------------------
// Index lowering
// ---------------------------------------------------------------------------

fn lower_index(st: LowerState, obj: Expr, idx: Expr) -> LowerResult {
    let obj_r: LowerResult = lower_expr(st, obj)
    let idx_r: LowerResult = lower_expr(obj_r.state, idx)

    // For string indexing, result is a string (char_at)
    // For list indexing, result is the element type from List<T>.args[0]
    let mut elem_ty: MIRType = mir_unknown()
    if obj_r.value.ty.kind == "string" {
        elem_ty = mir_string()
    } else if obj_r.value.ty.kind == "list" {
        if len(obj_r.value.ty.args) > 0 {
            elem_ty = obj_r.value.ty.args[0]
        }
    }

    let dest_r: LowerResult = make_value(idx_r.state, elem_ty, "t")
    let s: LowerState = emit_instr(dest_r.state, Instruction::IndexGet(dest_r.value, obj_r.value, idx_r.value))
    return new_lower_result(dest_r.value, s)
}

// ---------------------------------------------------------------------------
// Pipe lowering
// ---------------------------------------------------------------------------

fn lower_pipe_call(arg_r: LowerResult, fn_name: String, extra_exprs: List<Expr>) -> LowerResult {
    let mut s: LowerState = arg_r.state
    let mut args: List<Value> = []
    args.push(arg_r.value)
    let mut i: Int = 0
    for _ in 0..1000 {
        if i >= len(extra_exprs) { break }
        let extra_r: LowerResult = lower_expr(s, extra_exprs[i])
        s = extra_r.state
        args.push(extra_r.value)
        i = i + 1
    }
    let dest_r: LowerResult = make_value(s, mir_unknown(), "t")
    let new_s: LowerState = emit_instr(dest_r.state, Instruction::Call(dest_r.value, fn_name, args))
    return new_lower_result(dest_r.value, new_s)
}

fn lower_pipe_with_call(arg_r: LowerResult, callee: Expr, extra_arg_exprs: List<Expr>) -> LowerResult {
    match callee {
        Ident(fn_name) => {
            return lower_pipe_call(arg_r, fn_name, extra_arg_exprs)
        },
        _ => {
            return new_lower_result(arg_r.value, arg_r.state)
        }
    }
}

fn lower_pipe(st: LowerState, left: Expr, right: Expr) -> LowerResult {
    let arg_r: LowerResult = lower_expr(st, left)

    match right {
        Ident(fn_name) => {
            return lower_pipe_call(arg_r, fn_name, [])
        },
        Call(callee, extra_arg_exprs) => {
            return lower_pipe_with_call(arg_r, callee, extra_arg_exprs)
        },
        _ => {}
    }

    // General case
    let fn_r: LowerResult = lower_expr(arg_r.state, right)
    let dest_r: LowerResult = make_value(fn_r.state, mir_unknown(), "t")
    let mut args: List<Value> = []
    args.push(arg_r.value)
    let s: LowerState = emit_instr(dest_r.state, Instruction::Call(dest_r.value, fn_r.value.name, args))
    return new_lower_result(dest_r.value, s)
}

// ---------------------------------------------------------------------------
// Range lowering
// ---------------------------------------------------------------------------

fn lower_range(st: LowerState, start: Expr, end: Expr, inclusive: Bool) -> LowerResult {
    let start_r: LowerResult = lower_expr(st, start)
    let end_r: LowerResult = lower_expr(start_r.state, end)
    let dest_r: LowerResult = make_value(end_r.state, mir_range(), "t")
    let fn_name: String = if inclusive { "__mn_range_inclusive" } else { "__mn_range" }
    let mut args: List<Value> = []
    args.push(start_r.value)
    args.push(end_r.value)
    let s: LowerState = emit_instr(dest_r.state, Instruction::Call(dest_r.value, fn_name, args))
    return new_lower_result(dest_r.value, s)
}

// ---------------------------------------------------------------------------
// Lambda lowering
// ---------------------------------------------------------------------------

fn find_expr_alloca(st: LowerState, expr: Expr, obj_r: LowerResult) -> Value {
    // For Ident(name), return the variable's alloca address
    match expr {
        Ident(name) => {
            let var_opt: Option<Value> = lookup_var(st, name)
            match var_opt {
                Some(addr) => { return addr },
                _ => { return obj_r.value }
            }
        },
        _ => { return obj_r.value }
    }
}

// Module mutation: extract list to local variable, push, reconstruct.
// This avoids struct field push (GEP index issues) by using the
// 9-field struct init which the parser now supports.
fn module_push_struct(m: MIRModule, info: StructInfo) -> MIRModule {
    let mut lst: List<StructInfo> = m.structs
    lst.push(info)
    return new MIRModule { name: m.name, functions: m.functions, structs: lst, enums: m.enums, extern_fns: m.extern_fns, agents: m.agents, pipes: m.pipes, imports: m.imports, trait_names: m.trait_names }
}

fn module_push_enum(m: MIRModule, info: EnumInfo) -> MIRModule {
    let mut lst: List<EnumInfo> = m.enums
    lst.push(info)
    return new MIRModule { name: m.name, functions: m.functions, structs: m.structs, enums: lst, extern_fns: m.extern_fns, agents: m.agents, pipes: m.pipes, imports: m.imports, trait_names: m.trait_names }
}

fn module_push_function(m: MIRModule, f: MIRFunction) -> MIRModule {
    let mut lst: List<MIRFunction> = m.functions
    lst.push(f)
    return new MIRModule { name: m.name, functions: lst, structs: m.structs, enums: m.enums, extern_fns: m.extern_fns, agents: m.agents, pipes: m.pipes, imports: m.imports, trait_names: m.trait_names }
}

fn module_push_agent(m: MIRModule, info: AgentInfo) -> MIRModule {
    let mut lst: List<AgentInfo> = m.agents
    lst.push(info)
    return new MIRModule { name: m.name, functions: m.functions, structs: m.structs, enums: m.enums, extern_fns: m.extern_fns, agents: lst, pipes: m.pipes, imports: m.imports, trait_names: m.trait_names }
}

fn lower_arm_body(st: LowerState, body: MatchArmBody) -> LowerResult {
    match body {
        BlockBody(block) => { return lower_block(st, block) },
        ExprBody(expr) => { return lower_expr(st, expr) }
    }
}

fn extract_ident_name(expr: Expr) -> String {
    match expr {
        Ident(name) => { return name },
        _ => { return "" }
    }
}

fn unwrap_or_default(opt: Option<String>, default: String) -> String {
    match opt {
        Some(val) => { return val },
        _ => { return default }
    }
}

fn lambda_body_to_block(body: LambdaBody) -> Block {
    match body {
        BlockBody(block) => { return block },
        ExprBody(expr) => {
            let ret_stmt: Stmt = Stmt::Return(Some(expr))
            let stmts: List<Stmt> = []
            stmts.push(ret_stmt)
            let span: Span = new_span(0, 0, 0, 0)
            return new_block(span, stmts)
        }
    }
}

fn lower_lambda(st: LowerState, params: List<Param>, body: LambdaBody) -> LowerResult {
    let name_r: LowerResult = fresh_tmp(st, "lambda")
    let lambda_name: String = "lambda" + toString(st.tmp_counter)

    let body_block: Block = lambda_body_to_block(body)

    // Build extended params: explicit params + captured parent vars
    let parent_vars: List<VarInfo> = name_r.state.vars
    let mut all_params: List<Param> = []
    let mut capture_suffix: String = ""
    let mut pi: Int = 0
    for _ in 0..100 {
        if pi >= len(params) { break }
        all_params.push(params[pi])
        pi = pi + 1
    }
    let mut ci: Int = 0
    for _ in 0..1000 {
        if ci >= len(parent_vars) { break }
        let pv: VarInfo = parent_vars[ci]
        let cap_param: Param = new Param { span: new_span(0, 0, 0, 0), name: pv.name, type_annotation: none }
        all_params.push(cap_param)
        if ci == 0 {
            capture_suffix = ":" + pv.name
        } else {
            capture_suffix = capture_suffix + "," + pv.name
        }
        ci = ci + 1
    }

    // Create FnDefData with Int return type
    let span: Span = new_span(0, 0, 0, 0)
    let empty_type_params: List<String> = []
    let empty_decorators: List<Decorator> = []
    let int_ret: TypeExpr = make_int_type()
    let fn_def: FnDefData = new_fn_def_data(span, lambda_name, false, empty_type_params, all_params, Some(int_ret), body_block, empty_decorators)

    // Lower as a nested function (lower_fn saves/restores function scope)
    let mut s: LowerState = lower_fn(name_r.state, fn_def, "")

    // Register lambda with capture info
    let encoded_name: String = lambda_name + capture_suffix
    let entry: LambdaEntry = new_lambda_entry("", encoded_name)
    s.lambda_vars.push(entry)

    // Return a reference to the lambda function
    let dest_r: LowerResult = make_value(s, mir_fn_type(), "t")
    s = emit_instr(dest_r.state, Instruction::Const(dest_r.value, mir_fn_type(), lambda_name))
    return new_lower_result(dest_r.value, s)
}

// ---------------------------------------------------------------------------
// Spawn / Sync / Send lowering
// ---------------------------------------------------------------------------

fn lower_spawn(st: LowerState, callee: Expr, arg_exprs: List<Expr>) -> LowerResult {
    let mut s: LowerState = st
    let mut args: List<Value> = []
    let mut i: Int = 0
    for _ in 0..1000 {
        if i >= len(arg_exprs) { break }
        let arg_r: LowerResult = lower_expr(s, arg_exprs[i])
        s = arg_r.state
        args.push(arg_r.value)
        i = i + 1
    }

    let agent_name: String = extract_ident_name(callee)

    let agent_ty: MIRType = mir_agent(agent_name)
    let dest_r: LowerResult = make_value(s, agent_ty, "t")
    let new_s: LowerState = emit_instr(dest_r.state, Instruction::AgentSpawn(dest_r.value, agent_ty, args))
    return new_lower_result(dest_r.value, new_s)
}

fn lower_sync(st: LowerState, inner: Expr) -> LowerResult {
    match inner {
        FieldAccess(obj, field_name) => {
            let obj_r: LowerResult = lower_expr(st, obj)
            let dest_r: LowerResult = make_value(obj_r.state, mir_unknown(), "t")
            let s: LowerState = emit_instr(dest_r.state, Instruction::AgentSync(dest_r.value, obj_r.value, field_name))
            return new_lower_result(dest_r.value, s)
        },
        _ => {
            let val_r: LowerResult = lower_expr(st, inner)
            let dest_r: LowerResult = make_value(val_r.state, mir_unknown(), "t")
            let s: LowerState = emit_instr(dest_r.state, Instruction::AgentSync(dest_r.value, val_r.value, ""))
            return new_lower_result(dest_r.value, s)
        }
    }
}

fn lower_send(st: LowerState, target: Expr, value: Expr) -> LowerResult {
    let val_r: LowerResult = lower_expr(st, value)

    match target {
        FieldAccess(obj, field_name) => {
            let obj_r: LowerResult = lower_expr(val_r.state, obj)
            let s: LowerState = emit_instr(obj_r.state, Instruction::AgentSend(obj_r.value, field_name, val_r.value))
            let dest_r: LowerResult = make_value(s, mir_void(), "t")
            let s2: LowerState = emit_instr(dest_r.state, Instruction::Const(dest_r.value, mir_void(), ""))
            return new_lower_result(dest_r.value, s2)
        },
        _ => {
            let target_r: LowerResult = lower_expr(val_r.state, target)
            let s: LowerState = emit_instr(target_r.state, Instruction::AgentSend(target_r.value, "", val_r.value))
            let dest_r: LowerResult = make_value(s, mir_void(), "t")
            let s2: LowerState = emit_instr(dest_r.state, Instruction::Const(dest_r.value, mir_void(), ""))
            return new_lower_result(dest_r.value, s2)
        }
    }
}

// ---------------------------------------------------------------------------
// Error propagation lowering
// ---------------------------------------------------------------------------

fn lower_error_prop(st: LowerState, inner: Expr) -> LowerResult {
    let val_r: LowerResult = lower_expr(st, inner)
    let mut s: LowerState = val_r.state

    // Extract tag
    let tag_r: LowerResult = make_value(s, mir_bool(), "tag")
    s = emit_instr(tag_r.state, Instruction::EnumTag(tag_r.value, val_r.value))

    // Create blocks
    let ok_label_r: LowerResult = fresh_block_label(s, "prop_ok")
    s = ok_label_r.state
    let ok_label: String = ok_label_r.value.name

    let err_label_r: LowerResult = fresh_block_label(s, "prop_err")
    s = err_label_r.state
    let err_label: String = err_label_r.value.name

    s = add_block(s, ok_label)
    let ok_idx: Int = s.current_block_idx
    s = add_block(s, err_label)
    let err_idx: Int = s.current_block_idx

    // Branch on tag
    s = emit_instr(s, Instruction::Branch(tag_r.value, ok_label, err_label))

    // Error path: return the error
    s = set_block(s, err_idx)
    s = emit_instr(s, Instruction::Return(Some(val_r.value)))

    // Ok path: unwrap
    s = set_block(s, ok_idx)
    let dest_r: LowerResult = make_value(s, mir_unknown(), "t")
    s = emit_instr(dest_r.state, Instruction::Unwrap(dest_r.value, val_r.value))
    return new_lower_result(dest_r.value, s)
}

// ---------------------------------------------------------------------------
// List lowering
// ---------------------------------------------------------------------------

fn lower_list(st: LowerState, elements: List<Expr>) -> LowerResult {
    // Touch st to force materialization before any list operations.
    // Without this, clang -O0 may leave the LowerState in stale registers
    // from the caller's sret return, causing corruption in subsequent ops.
    let mut s: LowerState = st
    let mut vals: List<Value> = []
    let mut i: Int = 0
    for _ in 0..100000 {
        if i >= len(elements) { break }
        let el_r: LowerResult = lower_expr(s, elements[i])
        s = el_r.state
        vals.push(el_r.value)
        i = i + 1
    }

    let elem_type: MIRType = if len(vals) > 0 { vals[0].ty } else { mir_unknown() }
    let dest_r: LowerResult = make_value(s, mir_list(), "t")
    let new_s: LowerState = emit_instr(dest_r.state, Instruction::ListInit(dest_r.value, elem_type, vals))
    return new_lower_result(dest_r.value, new_s)
}

// ---------------------------------------------------------------------------
// Construct (struct literal) lowering
// ---------------------------------------------------------------------------

fn lower_construct(st: LowerState, name: String, field_inits: List<FieldInit>) -> LowerResult {
    let mut s: LowerState = st

    // Debug: emit the number of field_inits as a constant to verify the list works
    let nfields: Int = len(field_inits)

    // Lower each field value
    let mut vals: List<Value> = []
    let mut i: Int = 0
    for _ in 0..1000 {
        if i >= nfields { break }
        let fi: FieldInit = field_inits[i]
        let val_r: LowerResult = lower_expr(s, fi.value)
        s = val_r.state
        vals.push(val_r.value)
        i = i + 1
    }

    // Emit as Call to "__new_<StructName>" (emitter handles this specially)
    let struct_ty: MIRType = mir_struct(name)
    let dest_r: LowerResult = make_value(s, struct_ty, "t")
    // Debug: emit nfields as a const to see if the field_inits list is intact
    let dbg_r: LowerResult = make_value(dest_r.state, mir_int(), "dbg_nfields")
    s = emit_instr(dbg_r.state, Instruction::Const(dbg_r.value, mir_int(), toString(nfields)))
    s = emit_instr(s, Instruction::Call(dest_r.value, "__new_" + name, vals))
    return new_lower_result(dest_r.value, s)
}

// ---------------------------------------------------------------------------
// Signal expression lowering
// ---------------------------------------------------------------------------

fn lower_signal_expr(st: LowerState, inner: Expr) -> LowerResult {
    let init_r: LowerResult = lower_expr(st, inner)
    let dest_r: LowerResult = make_value(init_r.state, mir_signal(), "t")
    let s: LowerState = emit_instr(dest_r.state, Instruction::SignalInit(dest_r.value, mir_signal(), init_r.value))
    return new_lower_result(dest_r.value, s)
}

// ---------------------------------------------------------------------------
// Assignment lowering
// ---------------------------------------------------------------------------

fn lower_assign(st: LowerState, target: Expr, op: String, value: Expr) -> LowerResult {
    let val_r: LowerResult = lower_expr(st, value)
    let mut s: LowerState = val_r.state

    match target {
        Ident(name) => {
            if op != "=" {
                // Compound assignment: x += 1 → x = x + 1
                let old_r: LowerResult = lower_identifier(s, name)
                s = old_r.state
                let op_str: String = strip_assign_op(op)
                let binop_opt: Option<BinOpKind> = binop_from_str(op_str)
                match binop_opt {
                    Some(binop) => {
                        let result_r: LowerResult = make_value(s, old_r.value.ty, "t")
                        s = emit_instr(result_r.state, Instruction::BinOp(result_r.value, binop, old_r.value, val_r.value))
                        
                        let var_opt: Option<Value> = lookup_var(s, name)
                        match var_opt {
                            Some(addr) => {
                                s = emit_instr(s, Instruction::Store(addr, result_r.value))
                                return new_lower_result(result_r.value, s)
                            },
                            _ => {}
                        }
                    },
                    _ => {}
                }
            }

            let var_opt: Option<Value> = lookup_var(s, name)
            match var_opt {
                Some(addr) => {
                    // Update var type if the new value is more specific
                    // (e.g. from unknown/i64 to a concrete struct type)
                    let mut store_addr: Value = addr
                    if addr.ty.kind == "unknown" && val_r.value.ty.kind != "unknown" {
                        store_addr = new_value(addr.name, val_r.value.ty)
                        s = define_var(s, name, store_addr, true)
                    }
                    s = emit_instr(s, Instruction::Store(store_addr, val_r.value))
                    return new_lower_result(val_r.value, s)
                },
                _ => {}
            }
            return new_lower_result(val_r.value, s)
        },
        FieldAccess(obj, field_name) => {
            // Pass the ALLOCA address (not loaded value) so the emitter
            // can GEP+store directly to the struct field.
            let obj_r: LowerResult = lower_expr(s, obj)
            let obj_alloca: Value = find_expr_alloca(obj_r.state, obj, obj_r)
            s = emit_instr(obj_r.state, Instruction::FieldSet(obj_alloca, field_name, val_r.value))
            return new_lower_result(val_r.value, s)
        },
        Index(obj, idx) => {
            let obj_r: LowerResult = lower_expr(s, obj)
            let idx_r: LowerResult = lower_expr(obj_r.state, idx)
            s = emit_instr(idx_r.state, Instruction::IndexSet(obj_r.value, idx_r.value, val_r.value))
            return new_lower_result(val_r.value, s)
        },
        _ => {
            return new_lower_result(val_r.value, s)
        }
    }
}

// Strip the '=' suffix from compound assignment operators: "+=" → "+"
fn strip_assign_op(op: String) -> String {
    if op == "+=" { return "+" }
    if op == "-=" { return "-" }
    if op == "*=" { return "*" }
    if op == "/=" { return "/" }
    if op == "%=" { return "%" }
    return op
}

// ---------------------------------------------------------------------------
// If/else lowering
// ---------------------------------------------------------------------------

fn build_if_phi_entries(then_term: Bool, else_term: Bool, then_val: Value, else_val: Value, then_lbl: String, else_lbl: String) -> List<PhiEntry> {
    let mut result: List<PhiEntry> = []
    // Add then arm if it has a usable value (not terminated, not void)
    let then_ok: Bool = !then_term
    let then_non_void: Bool = then_val.ty.kind != "void"
    if then_ok {
        if then_non_void {
            result.push(new_phi_entry(then_lbl, then_val))
        }
    }
    // Add else arm if it has a usable value
    let else_ok: Bool = !else_term
    let else_non_void: Bool = else_val.ty.kind != "void"
    if else_ok {
        if else_non_void {
            result.push(new_phi_entry(else_lbl, else_val))
        }
    }
    // If one arm has value but other is void, add zeroinitializer for the void arm
    if len(result) == 1 {
        if then_ok {
            if !then_non_void {
                let zero_v: Value = new_value("zeroinitializer", result[0].val.ty)
                result.push(new_phi_entry(then_lbl, zero_v))
            }
        }
        if else_ok {
            if !else_non_void {
                let zero_v: Value = new_value("zeroinitializer", result[0].val.ty)
                result.push(new_phi_entry(else_lbl, zero_v))
            }
        }
    }
    return result
}

fn infer_variant_payload_type(st: LowerState, subject: Value, variant_name: String, field_idx: Int) -> MIRType {
    // Result types
    if subject.ty.kind == "result" {
        if len(subject.ty.args) >= 2 {
            if variant_name == "Ok" { return subject.ty.args[0] }
            if variant_name == "Err" { return subject.ty.args[1] }
        }
    }
    // Option types
    if subject.ty.kind == "option" {
        if len(subject.ty.args) >= 1 {
            return subject.ty.args[0]
        }
    }
    // Regular enums — look up from module registry
    if subject.ty.kind == "enum" {
        let enum_name: String = subject.ty.name
        let mut ei: Int = 0
        for _ in 0..1000 {
            if ei >= len(st.module.enums) { break }
            let einfo: EnumInfo = st.module.enums[ei]
            if einfo.name == enum_name {
                let mut vi: Int = 0
                for _ in 0..1000 {
                    if vi >= len(einfo.variants) { break }
                    let vinfo: EnumVariantInfo = einfo.variants[vi]
                    if vinfo.name == variant_name {
                        if field_idx < len(vinfo.payload_types) {
                            return vinfo.payload_types[field_idx]
                        }
                    }
                    vi = vi + 1
                }
            }
            ei = ei + 1
        }
    }
    return mir_unknown()
}

fn is_some_else_clause(clause: Option<ElseClause>) -> Bool {
    match clause {
        Some(c) => { return true },
        _ => { return false }
    }
}

fn lower_else_clause(st: LowerState, clause_opt: Option<ElseClause>) -> LowerResult {
    match clause_opt {
        Some(clause) => {
            return lower_else_clause_inner(st, clause)
        },
        _ => { return new_lower_result(void_value(), st) }
    }
}

fn lower_else_clause_inner(st: LowerState, clause: ElseClause) -> LowerResult {
    match clause {
        ElseBlock(block) => {
            return lower_block(st, block)
        },
        ElseIf(next_cond, next_then, next_else) => {
            return lower_if(st, next_cond, next_then, next_else)
        }
    }
}

fn lower_if(st: LowerState, cond: Expr, then_block: Block, else_clause: Option<ElseClause>) -> LowerResult {
    let cond_r: LowerResult = lower_expr(st, cond)
    let mut s: LowerState = cond_r.state

    // Save the current (entry) block index for the branch
    let entry_idx: Int = s.current_block_idx

    // Create blocks
    let then_label_r: LowerResult = fresh_block_label(s, "if_then")
    s = then_label_r.state
    let then_label: String = then_label_r.value.name
    s = add_block(s, then_label)
    let then_idx: Int = s.current_block_idx

    let else_label_r: LowerResult = fresh_block_label(s, "if_else")
    s = else_label_r.state
    let else_label: String = else_label_r.value.name
    s = add_block(s, else_label)
    let else_idx: Int = s.current_block_idx

    let merge_label_r: LowerResult = fresh_block_label(s, "if_merge")
    s = merge_label_r.state
    let merge_label: String = merge_label_r.value.name
    s = add_block(s, merge_label)
    let merge_idx: Int = s.current_block_idx

    // Branch (emitted in the entry block, not the merge block)
    s = set_block(s, entry_idx)
    s = emit_instr(s, Instruction::Branch(cond_r.value, then_label, else_label))

    // Then block
    s = set_block(s, then_idx)
    let then_r: LowerResult = lower_block(s, then_block)
    s = then_r.state
    let then_val: Value = then_r.value
    let then_exit_idx: Int = s.current_block_idx
    let then_terminated: Bool = current_block_terminated(s)
    if !then_terminated {
        s = emit_instr(s, Instruction::Jump(merge_label))
    }

    // Else block
    s = set_block(s, else_idx)
    let mut else_val: Value = void_value()
    let has_else: Bool = is_some_else_clause(else_clause)
    if has_else {
        let else_r: LowerResult = lower_else_clause(s, else_clause)
        s = else_r.state
        else_val = else_r.value
    }
    let else_exit_idx: Int = s.current_block_idx
    let else_terminated: Bool = current_block_terminated(s)
    if !else_terminated {
        s = emit_instr(s, Instruction::Jump(merge_label))
    }

    // Merge block with phi — only include arms that reach the merge block
    s = set_block(s, merge_idx)

    let then_exit_label: String = get_block_label(s, then_exit_idx)
    let else_exit_label: String = get_block_label(s, else_exit_idx)

    // Build Phi directly — no list intermediary to avoid return-by-value bugs.
    // Determine what kind of Phi we need:
    // - Both arms have values → 2-entry Phi
    // - One arm has value, other void → 2-entry Phi with zeroinitializer
    // - Neither has value → void fallback
    let then_ok: Bool = !then_terminated
    let mut then_non_void: Bool = true
    if then_val.ty.kind == "void" { then_non_void = false }
    if then_val.ty.kind == "unknown" { then_non_void = false }
    if then_val.name == "%void" { then_non_void = false }
    let else_ok: Bool = !else_terminated
    let mut else_non_void: Bool = true
    if else_val.ty.kind == "void" { else_non_void = false }
    if else_val.ty.kind == "unknown" { else_non_void = false }
    if else_val.name == "%void" { else_non_void = false }

    // Determine case using simple flags
    let mut both: Bool = false
    let mut only_then: Bool = false
    let mut only_else: Bool = false
    if then_ok {
        if then_non_void {
            if else_ok {
                if else_non_void {
                    both = true
                }
                if !else_non_void {
                    only_then = true
                }
            }
        }
        if !then_non_void {
            if else_ok {
                if else_non_void {
                    only_else = true
                }
            }
        }
    }
    if !then_ok {
        if else_ok {
            if else_non_void {
                only_else = true
            }
        }
    }

    let mut final_val: Value = void_value()
    if both {
        let mut entries: List<PhiEntry> = []
        entries.push(new_phi_entry(then_exit_label, then_val))
        entries.push(new_phi_entry(else_exit_label, else_val))
        let result_r: LowerResult = make_value(s, then_val.ty, "if_result")
        s = result_r.state
        s = emit_instr(s, Instruction::Phi(result_r.value, entries))
        final_val = result_r.value
    }
    if only_then {
        let mut entries: List<PhiEntry> = []
        entries.push(new_phi_entry(then_exit_label, then_val))
        let zero_v: Value = new_value("zeroinitializer", then_val.ty)
        entries.push(new_phi_entry(else_exit_label, zero_v))
        let result_r: LowerResult = make_value(s, then_val.ty, "if_result")
        s = result_r.state
        s = emit_instr(s, Instruction::Phi(result_r.value, entries))
        final_val = result_r.value
    }
    if only_else {
        let mut entries: List<PhiEntry> = []
        let zero_v: Value = new_value("zeroinitializer", else_val.ty)
        entries.push(new_phi_entry(then_exit_label, zero_v))
        entries.push(new_phi_entry(else_exit_label, else_val))
        let result_r: LowerResult = make_value(s, else_val.ty, "if_result")
        s = result_r.state
        s = emit_instr(s, Instruction::Phi(result_r.value, entries))
        final_val = result_r.value
    }
    let is_void: Bool = !both && !only_then && !only_else
    if is_void {
        let result_r: LowerResult = make_value(s, mir_void(), "t")
        s = emit_instr(result_r.state, Instruction::Const(result_r.value, mir_void(), ""))
        final_val = result_r.value
    }
    return new_lower_result(final_val, s)
}

fn get_block_label(st: LowerState, idx: Int) -> String {
    match st.current_fn {
        Some(f) => {
            if idx >= 0 {
                if idx < len(f.blocks) {
                    let bb: BasicBlock = f.blocks[idx]
                    return bb.label
                }
            }
            return "unknown"
        },
        _ => { return "unknown" }
    }
}

// ---------------------------------------------------------------------------
// Match lowering
// ---------------------------------------------------------------------------

struct MatchBuildResult {
    state: LowerState,
    arm_labels: List<String>,
    arm_indices: List<Int>,
    cases: List<SwitchCase>,
    default_label: String
}

fn build_match_arms(st: LowerState, arms: List<MatchArm>, merge_label: String) -> MatchBuildResult {
    let labels: List<String> = []
    let indices: List<Int> = []
    let cases: List<SwitchCase> = []
    let init: MatchBuildResult = new MatchBuildResult { state: st, arm_labels: labels, arm_indices: indices, cases: cases, default_label: merge_label }
    let mut s: LowerState = st
    let mut i: Int = 0
    let n: Int = len(arms)
    for _ in 0..1000 {
        if i >= n { break }
        let label_r: LowerResult = fresh_block_label(s, "match_arm")
        s = label_r.state
        let label: String = label_r.value.name
        s = add_block(s, label)
        init.arm_labels.push(label)
        init.arm_indices.push(s.current_block_idx)
        let arm: MatchArm = arms[i]
        match arm.pattern {
            ConstructorPat(name, _) => { init.cases.push(new_switch_case(name, label)) },
            LiteralPat(expr) => { init.cases.push(new_switch_case(get_literal_value(expr), label)) },
            IdentPat(name) => {
                if is_enum_variant(s, name) {
                    init.cases.push(new_switch_case(name, label))
                } else {
                    init.default_label = label
                }
            },
            Wildcard => { init.default_label = label }
        }
        i = i + 1
    }
    init.state = s
    return init
}

fn lower_match(st: LowerState, subject: Expr, arms: List<MatchArm>) -> LowerResult {
    let subject_r: LowerResult = lower_expr(st, subject)
    let mut s: LowerState = subject_r.state

    // Save entry block for switch/branch emission
    let match_entry_idx: Int = s.current_block_idx

    // Create merge block
    let merge_label_r: LowerResult = fresh_block_label(s, "match_merge")
    s = merge_label_r.state
    let merge_label: String = merge_label_r.value.name
    s = add_block(s, merge_label)
    let merge_idx: Int = s.current_block_idx

    // Create arm blocks AND build switch cases.
    // Note: we use build_match_arms which returns accumulated results,
    // avoiding the for-loop local variable aliasing bug in the compiled binary.
    let build_r: MatchBuildResult = build_match_arms(s, arms, merge_label)
    s = build_r.state
    let arm_labels: List<String> = build_r.arm_labels
    let arm_indices: List<Int> = build_r.arm_indices
    let cases: List<SwitchCase> = build_r.cases
    let default_label: String = build_r.default_label

    // Emit switch or branch (in the entry block)
    s = set_block(s, match_entry_idx)
    if len(cases) > 0 {
        let tag_r: LowerResult = make_value(s, subject_r.value.ty, "tag")
        s = tag_r.state
        s = emit_instr(s, Instruction::EnumTag(tag_r.value, subject_r.value))
        s = emit_instr(s, Instruction::Switch(tag_r.value, cases, default_label))
    } else {
        if len(arm_labels) > 0 {
            s = emit_instr(s, Instruction::Jump(arm_labels[0]))
        }
    }

    // Lower each arm
    let mut arm_results: List<PhiEntry> = []
    let mut ai: Int = 0
    for _ in 0..1000 {
        if ai >= len(arms) { break }
        let arm: MatchArm = arms[ai]
        let arm_idx: Int = arm_indices[ai]

        s = set_block(s, arm_idx)
        s = lower_push_scope(s)

        // Bind pattern variables
        match arm.pattern {
            ConstructorPat(name, sub_patterns) => {
                let mut pi: Int = 0
                for _ in 0..100 {
                    if pi >= len(sub_patterns) { break }
                    let sub_pat: Pattern = sub_patterns[pi]
                    match sub_pat {
                        IdentPat(var_name) => {
                            let pay_ty: MIRType = infer_variant_payload_type(s, subject_r.value, name, pi)
                            let payload_r: LowerResult = make_value(s, pay_ty, var_name)
                            s = payload_r.state
                            s = emit_instr(s, Instruction::EnumPayload(payload_r.value, subject_r.value, name))
                            let payload_addr: Value = new_value("%" + var_name + toString(s.tmp_counter) + ".addr", pay_ty)
                            s.tmp_counter = s.tmp_counter + 1
                            s = emit_instr(s, Instruction::Alloca(payload_addr, pay_ty))
                            s = emit_instr(s, Instruction::Store(payload_addr, payload_r.value))
                            s = define_var(s, var_name, payload_addr, false)
                        },
                        _ => {}
                    }
                    pi = pi + 1
                }
            },
            IdentPat(name) => {
                if !is_enum_variant(s, name) {
                    // Store subject to alloca so lower_identifier can load from it
                    let ident_addr: Value = new_value("%" + name + ".addr", subject_r.value.ty)
                    s = emit_instr(s, Instruction::Alloca(ident_addr, subject_r.value.ty))
                    s = emit_instr(s, Instruction::Store(ident_addr, subject_r.value))
                    s = define_var(s, name, ident_addr, false)
                }
            },
            _ => {}
        }

        // Lower arm body
        let arm_val_r: LowerResult = lower_arm_body(s, arm.body)
        s = arm_val_r.state

        let exit_label: String = get_block_label(s, s.current_block_idx)
        let arm_terminated: Bool = current_block_terminated(s)

        // Track arm results for phi
        let arm_kind: String = arm_val_r.value.ty.kind
        if !arm_terminated && arm_kind != "void" && arm_kind != "unknown" && arm_val_r.value.name != "%void" {
            let pe: PhiEntry = new_phi_entry(exit_label, arm_val_r.value)
            arm_results.push(pe)
        }

        if !arm_terminated {
            s = emit_instr(s, Instruction::Jump(merge_label))
        }
        s = lower_pop_scope(s)
        ai = ai + 1
    }

    // Merge block
    s = set_block(s, merge_idx)
    if len(arm_results) > 0 {
        let result_r: LowerResult = make_value(s, arm_results[0].val.ty, "match_result")
        s = result_r.state
        s = emit_instr(s, Instruction::Phi(result_r.value, arm_results))
        return new_lower_result(result_r.value, s)
    }

    // All arms terminated. Merge block is unreachable.
    // Emit a dummy return to terminate the block. Any code the caller
    // emits after this will be in a dead block (after a terminator).
    let dummy_val: Value = new_value("zeroinitializer", mir_unknown())
    s = emit_instr(s, Instruction::Return(Some(dummy_val)))
    let void_r: LowerResult = make_value(s, mir_void(), "t")
    return new_lower_result(void_r.value, void_r.state)
}

fn get_literal_value(expr: Expr) -> String {
    match expr {
        IntLit(n) => { return toString(n) },
        FloatLit(f) => { return toString(f) },
        BoolLit(b) => { if b { return "true" } else { return "false" } },
        StringLit(s) => { return s },
        _ => { return "" }
    }
}

// ---------------------------------------------------------------------------
// Pretty-printer
// ---------------------------------------------------------------------------

fn format_value(v: Value) -> String {
    return v.name
}

fn format_type(t: MIRType) -> String {
    return t.name
}

fn format_instruction(inst: Instruction) -> String {
    match inst {
        Const(dest, ty, val) => {
            return dest.name + " = const " + format_type(ty) + " " + val
        },
        Copy(dest, src) => {
            return dest.name + " = copy " + src.name
        },
        Cast(dest, src, target) => {
            return dest.name + " = cast " + src.name + " to " + format_type(target)
        },
        BinOp(dest, op, lhs, rhs) => {
            return dest.name + " = binop " + lhs.name + ", " + rhs.name
        },
        UnaryOp(dest, op, operand) => {
            return dest.name + " = unaryop " + operand.name
        },
        StructInit(dest, ty, fields) => {
            return dest.name + " = struct_init " + format_type(ty)
        },
        FieldGet(dest, obj, field) => {
            return dest.name + " = field_get " + obj.name + "." + field
        },
        FieldSet(obj, field, val) => {
            return "field_set " + obj.name + "." + field + " = " + val.name
        },
        ListInit(dest, ty, elems) => {
            return dest.name + " = list_init " + format_type(ty)
        },
        IndexGet(dest, obj, idx) => {
            return dest.name + " = index_get " + obj.name + "[" + idx.name + "]"
        },
        IndexSet(obj, idx, val) => {
            return "index_set " + obj.name + "[" + idx.name + "] = " + val.name
        },
        Alloca(dest, ty) => {
            return dest.name + " = alloca " + format_type(ty)
        },
        Load(dest, ptr) => {
            return dest.name + " = load " + ptr.name
        },
        Store(ptr, val) => {
            return "store " + val.name + " to " + ptr.name
        },
        MapInit(dest, kt, vt, pairs) => {
            return "map_init"
        },
        EnumInit(dest, ty, variant, payload) => {
            return dest.name + " = enum_init " + format_type(ty) + "::" + variant
        },
        EnumTag(dest, val) => {
            return dest.name + " = enum_tag " + val.name
        },
        EnumPayload(dest, val, variant) => {
            return dest.name + " = enum_payload " + val.name + "::" + variant
        },
        WrapSome(dest, val) => {
            return dest.name + " = wrap_some " + val.name
        },
        WrapNone(dest, ty) => {
            return dest.name + " = wrap_none " + format_type(ty)
        },
        WrapOk(dest, val) => {
            return dest.name + " = wrap_ok " + val.name
        },
        WrapErr(dest, val) => {
            return dest.name + " = wrap_err " + val.name
        },
        Unwrap(dest, val) => {
            return dest.name + " = unwrap " + val.name
        },
        Call(dest, fn_name, args) => {
            return dest.name + " = call " + fn_name + "(...)"
        },
        Return(val_opt) => {
            match val_opt {
                Some(v) => { return "ret " + v.name },
                _ => { return "ret void" }
            }
        },
        Jump(target) => {
            return "jump " + target
        },
        Branch(cond, true_bb, false_bb) => {
            return "branch " + cond.name + ", " + true_bb + ", " + false_bb
        },
        Switch(tag, cases, default_bb) => {
            return "switch " + tag.name + " default " + default_bb
        },
        AgentSpawn(dest, ty, args) => {
            return dest.name + " = agent_spawn " + format_type(ty)
        },
        AgentSend(ag, channel, val) => {
            return "agent_send"
        },
        AgentSync(dest, ag, channel) => {
            return "agent_sync"
        },
        SignalInit(dest, ty, val) => {
            return dest.name + " = signal_init " + format_type(ty) + " " + val.name
        },
        SignalGet(dest, sig) => {
            return dest.name + " = signal_get " + sig.name
        },
        SignalSet(sig, val) => {
            return "signal_set " + sig.name + " = " + val.name
        },
        StreamOp(dest, kind, source, args) => {
            return "stream_op"
        },
        InterpConcat(dest, parts) => {
            return dest.name + " = interp_concat [...]"
        },
        Phi(dest, incoming) => {
            return dest.name + " = phi [...]"
        }
    }
}

fn pretty_print_block(bb: BasicBlock) -> String {
    let mut result: String = "  " + bb.label + ":\n"
    let mut i: Int = 0
    for _ in 0..100000 {
        if i >= len(bb.instructions) { return result }
        let inst: Instruction = bb.instructions[i]
        result = result + "    " + format_instruction(inst) + "\n"
        i = i + 1
    }
    return result
}

fn pretty_print_function(f: MIRFunction) -> String {
    let mut params_str: String = ""
    let mut i: Int = 0
    for _ in 0..1000 {
        if i >= len(f.params) { break }
        let p: MIRParam = f.params[i]
        if i > 0 { params_str = params_str + ", " }
        params_str = params_str + p.name + ": " + format_type(p.ty)
        i = i + 1
    }

    let header: String = "fn " + f.name + "(" + params_str + ") -> " + format_type(f.return_type)
    if len(f.blocks) == 0 { return header + " {}" }

    let mut result: String = header + " {\n"
    let mut bi: Int = 0
    for _ in 0..100000 {
        if bi >= len(f.blocks) { break }
        let bb: BasicBlock = f.blocks[bi]
        result = result + pretty_print_block(bb)
        bi = bi + 1
    }
    result = result + "}"
    return result
}

fn pretty_print_module(module: MIRModule) -> String {
    let mut result: String = ""
    if module.name != "" {
        result = "module " + module.name + "\n\n"
    }

    // Print structs
    let mut si: Int = 0
    for _ in 0..1000 {
        if si >= len(module.structs) { break }
        let s: StructInfo = module.structs[si]
        result = result + "struct " + s.name + " {...}\n"
        si = si + 1
    }

    // Print enums
    let mut ei: Int = 0
    for _ in 0..1000 {
        if ei >= len(module.enums) { break }
        let e: EnumInfo = module.enums[ei]
        result = result + "enum " + e.name + " {...}\n"
        ei = ei + 1
    }

    if len(module.structs) > 0 { result = result + "\n" }
    if len(module.enums) > 0 { result = result + "\n" }

    // Print functions
    let mut fi: Int = 0
    for _ in 0..100000 {
        if fi >= len(module.functions) { break }
        let f: MIRFunction = module.functions[fi]
        result = result + pretty_print_function(f) + "\n\n"
        fi = fi + 1
    }

    return result
}

// ---------------------------------------------------------------------------
// MIR verifier
// ---------------------------------------------------------------------------

struct VerifyError {
    fn_name: String,
    block_label: String,
    message: String
}

fn new_verify_error(fn_name: String, block: String, msg: String) -> VerifyError {
    return new VerifyError { fn_name: fn_name, block_label: block, message: msg }
}

fn verify_module(module: MIRModule) -> List<VerifyError> {
    let mut errors: List<VerifyError> = []
    let mut i: Int = 0
    for _ in 0..100000 {
        if i >= len(module.functions) { return errors }
        let f: MIRFunction = module.functions[i]
        let fn_errors: List<VerifyError> = verify_function(f)
        let mut j: Int = 0
        for _ in 0..100000 {
            if j >= len(fn_errors) { break }
            errors.push(fn_errors[j])
            j = j + 1
        }
        i = i + 1
    }
    return errors
}

fn verify_function(f: MIRFunction) -> List<VerifyError> {
    let mut errors: List<VerifyError> = []

    if len(f.blocks) == 0 {
        let e: VerifyError = new_verify_error(f.name, "", "function has no basic blocks")
        errors.push(e)
        return errors
    }

    let mut i: Int = 0
    for _ in 0..100000 {
        if i >= len(f.blocks) { return errors }
        let bb: BasicBlock = f.blocks[i]
        let bb_errors: List<VerifyError> = verify_block(f.name, bb, f)
        let mut j: Int = 0
        for _ in 0..100000 {
            if j >= len(bb_errors) { break }
            errors.push(bb_errors[j])
            j = j + 1
        }
        i = i + 1
    }
    return errors
}

fn verify_block(fn_name: String, bb: BasicBlock, f: MIRFunction) -> List<VerifyError> {
    let mut errors: List<VerifyError> = []

    if len(bb.instructions) == 0 {
        let e: VerifyError = new_verify_error(fn_name, bb.label, "block has no instructions")
        errors.push(e)
        return errors
    }

    // Check terminator
    let last: Instruction = bb.instructions[len(bb.instructions) - 1]
    if !is_terminator(last) {
        let e: VerifyError = new_verify_error(fn_name, bb.label, "block does not end with a terminator")
        errors.push(e)
    }

    // Check no terminators in the middle
    let mut i: Int = 0
    for _ in 0..100000 {
        if i >= len(bb.instructions) - 1 { break }
        let inst: Instruction = bb.instructions[i]
        if is_terminator(inst) {
            let e: VerifyError = new_verify_error(fn_name, bb.label, "terminator at position " + toString(i) + " (not last)")
            errors.push(e)
        }
        i = i + 1
    }

    // Check phi nodes are at the start
    let mut seen_non_phi: Bool = false
    let mut pi: Int = 0
    for _ in 0..100000 {
        if pi >= len(bb.instructions) { break }
        let inst: Instruction = bb.instructions[pi]
        match inst {
            Phi(_, _) => {
                if seen_non_phi {
                    let e: VerifyError = new_verify_error(fn_name, bb.label, "phi node after non-phi instruction")
                    errors.push(e)
                }
            },
            _ => {
                seen_non_phi = true
            }
        }
        pi = pi + 1
    }

    return errors
}

// ---------------------------------------------------------------------------
// Public API
// ---------------------------------------------------------------------------

pub fn lower(program: Program, module_name: String) -> MIRModule {
    let mut st: LowerState = new_lower_state(module_name)

    // Pass 1: register declarations
    st = register_declarations(st, program)

    // Pass 2: lower function bodies
    st = lower_definitions(st, program)

    return st.module
}

// Streaming API: lower header only (types, externs), return state for per-function lowering
pub fn lower_header(program: Program, module_name: String) -> LowerState {
    let mut st: LowerState = new_lower_state(module_name)
    st = register_declarations(st, program)
    return st
}

// Lower a single function and return the MIR function + updated state
// The function is NOT added to module.functions (caller handles emission)
pub fn lower_one_fn(st: LowerState, fn_def: FnDefData, prefix: String) -> LowerResult {
    let fn_name: String = prefix + fn_def.name

    // Build params
    let mut params: List<MIRParam> = []
    let mut pi: Int = 0
    for _ in 0..1000 {
        if pi >= len(fn_def.params) { break }
        let p: Param = fn_def.params[pi]
        let pty: MIRType = lower_resolve_type_opt_checked(st, p.type_annotation)
        let mp: MIRParam = new_mir_param(p.name, pty)
        params.push(mp)
        pi = pi + 1
    }

    let ret_type: MIRType = resolve_return_type_checked(st, fn_def.return_type)

    let mut decorators: List<String> = []
    let mut di: Int = 0
    for _ in 0..100 {
        if di >= len(fn_def.decorators) { break }
        decorators.push(fn_def.decorators[di].name)
        di = di + 1
    }

    let mir_fn: MIRFunction = new_mir_function(fn_name, params, ret_type, decorators, fn_def.public)

    // Save state
    let prev_fn: Option<MIRFunction> = st.current_fn
    let prev_block_idx: Int = st.current_block_idx
    let prev_tmp: Int = st.tmp_counter
    let prev_blk_cnt: Int = st.block_counter
    let prev_vars: List<VarInfo> = st.vars

    let mut s: LowerState = st
    s.current_fn = Some(mir_fn)
    s.tmp_counter = 0
    s.block_counter = 0
    let fresh_vars: List<VarInfo> = []
    s.vars = fresh_vars

    s = add_block(s, "entry")
    s = set_block(s, 0)

    // Bind params
    let mut bi: Int = 0
    for _ in 0..1000 {
        if bi >= len(fn_def.params) { break }
        let p: Param = fn_def.params[bi]
        let pty: MIRType = lower_resolve_type_opt_checked(s, p.type_annotation)
        let addr_name: String = "%" + p.name + ".addr"
        let addr: Value = new_value(addr_name, pty)
        let param_val: Value = new_value("%" + p.name, pty)
        s = emit_instr(s, Instruction::Alloca(addr, pty))
        s = emit_instr(s, Instruction::Store(addr, param_val))
        s = define_var(s, p.name, addr, false)
        bi = bi + 1
    }

    // Lower body
    let body_r: LowerResult = lower_block(s, fn_def.body)
    s = body_r.state

    if !current_block_terminated(s) {
        if ret_type.kind == "void" {
            s = emit_instr(s, Instruction::Return(none))
        } else {
            s = emit_instr(s, Instruction::Return(Some(body_r.value)))
        }
    }

    // Extract the completed function (DO NOT add to module — caller emits it)
    let mut result_fn: MIRFunction = mir_fn
    match s.current_fn {
        Some(f) => { result_fn = f },
        _ => {}
    }

    // Restore counters/vars but KEEP current_fn so caller can extract it
    s.current_fn = Some(result_fn)
    s.current_block_idx = prev_block_idx
    s.tmp_counter = prev_tmp
    s.block_counter = prev_blk_cnt
    s.vars = prev_vars

    let fn_val: Value = new_value(fn_name, mir_void())
    return new_lower_result(fn_val, s)
}

// Get the last-added function from a LowerState's current_fn
pub fn extract_current_fn(st: LowerState) -> MIRFunction {
    match st.current_fn {
        Some(f) => { return f },
        _ => {
            let empty_params: List<MIRParam> = []
            let empty_blocks: List<BasicBlock> = []
            let empty_decorators: List<String> = []
            return new MIRFunction { name: "unknown", params: empty_params, return_type: mir_void(), blocks: empty_blocks, decorators: empty_decorators, is_public: false }
        }
    }
}

// ===== emit_llvm_ir.mn =====
// emit_llvm_ir.mn — LLVM IR type constants and instruction string builders.
// Pure string-producing functions, shared by emit_llvm.mn.


// ---------------------------------------------------------------------------
// LLVM type constants (as string representations)
// ---------------------------------------------------------------------------

fn llvm_int() -> String {
    return "i64"
}

fn llvm_float() -> String {
    return "double"
}

fn llvm_bool() -> String {
    return "i1"
}

fn llvm_char() -> String {
    return "i8"
}

fn llvm_void() -> String {
    return "void"
}

fn llvm_string() -> String {
    return "{ ptr, i64 }"
}

// ---------------------------------------------------------------------------
// Composite type builders
// ---------------------------------------------------------------------------

fn llvm_option_type(inner: String) -> String {
    return "{ i1, " + inner + " }"
}

fn llvm_result_type(ok_ty: String, err_ty: String) -> String {
    return "{ i1, { " + ok_ty + ", " + err_ty + " } }"
}

fn llvm_tensor_type(elem_ty: String) -> String {
    return "{ ptr, i64, ptr, i64 }"
}

fn llvm_list_type(elem_ty: String) -> String {
    return "{ ptr, i64, i64 }"
}

fn llvm_map_type() -> String {
    return "{ ptr, i64 }"
}

fn llvm_ptr() -> String {
    return "ptr"
}

fn llvm_list_rt() -> String {
    return "{ ptr, i64, i64, i64 }"
}

// ---------------------------------------------------------------------------
// MIR type → LLVM type resolution
// ---------------------------------------------------------------------------

fn resolve_mir_type(t: MIRType) -> String {
    if t.kind == "int" { return llvm_int() }
    if t.kind == "float" { return llvm_float() }
    if t.kind == "bool" { return llvm_bool() }
    if t.kind == "string" { return llvm_string() }
    if t.kind == "void" { return llvm_void() }
    if t.kind == "char" { return llvm_char() }
    if t.kind == "list" { return llvm_list_rt() }
    if t.kind == "map" { return llvm_map_type() }
    if t.kind == "option" {
        // Universal type erasure: all Option types use {i1, ptr}.
        // The payload is stored via alloca and accessed through the ptr.
        // This ensures Option types are always consistent between
        // function signatures and match extraction.
        return llvm_option_type(llvm_ptr())
    }
    if t.kind == "result" {
        if len(t.args) >= 2 {
            let ok_ty: String = resolve_mir_type(t.args[0])
            let err_ty: String = resolve_mir_type(t.args[1])
            return llvm_result_type(ok_ty, err_ty)
        }
        return llvm_result_type(llvm_ptr(), llvm_ptr())
    }
    if t.kind == "signal" { return llvm_ptr() }
    if t.kind == "agent" { return llvm_ptr() }
    if t.kind == "struct" { return "%struct." + t.name }
    if t.kind == "enum" { return "%enum." + t.name }
    if t.kind == "range" { return "{ i64, i64 }" }
    if t.kind == "fn" { return llvm_ptr() }
    if t.kind == "unknown" { return llvm_int() }
    return llvm_int()
}

// ---------------------------------------------------------------------------
// LLVM IR instruction builders (string-based)
// ---------------------------------------------------------------------------

fn llvm_alloca(name: String, ty: String) -> String {
    return "  " + name + " =alloca " + ty
}

fn llvm_store(ty: String, value: String, ptr: String) -> String {
    return "  store " + ty + " " + value + ", ptr " + ptr
}

fn llvm_load(name: String, ty: String, ptr: String) -> String {
    return "  " + name + " =load " + ty + ", ptr " + ptr
}

fn emit_add(name: String, ty: String, left: String, right: String) -> String {
    return "  " + name + " =add " + ty + " " + left + ", " + right
}

fn emit_sub(name: String, ty: String, left: String, right: String) -> String {
    return "  " + name + " =sub " + ty + " " + left + ", " + right
}

fn emit_mul(name: String, ty: String, left: String, right: String) -> String {
    return "  " + name + " =mul " + ty + " " + left + ", " + right
}

fn emit_sdiv(name: String, ty: String, left: String, right: String) -> String {
    return "  " + name + " =sdiv " + ty + " " + left + ", " + right
}

fn emit_srem(name: String, ty: String, left: String, right: String) -> String {
    return "  " + name + " =srem " + ty + " " + left + ", " + right
}

fn emit_fadd(name: String, left: String, right: String) -> String {
    return "  " + name + " =fadd double " + left + ", " + right
}

fn emit_fsub(name: String, left: String, right: String) -> String {
    return "  " + name + " =fsub double " + left + ", " + right
}

fn emit_fmul(name: String, left: String, right: String) -> String {
    return "  " + name + " =fmul double " + left + ", " + right
}

fn emit_fdiv(name: String, left: String, right: String) -> String {
    return "  " + name + " =fdiv double " + left + ", " + right
}

fn emit_frem(name: String, left: String, right: String) -> String {
    return "  " + name + " =frem double " + left + ", " + right
}

fn emit_fneg(name: String, operand: String) -> String {
    return "  " + name + " =fneg double " + operand
}

fn emit_neg(name: String, ty: String, operand: String) -> String {
    return "  " + name + " =sub " + ty + " 0, " + operand
}

fn emit_not(name: String, operand: String) -> String {
    return "  " + name + " =xor i1 " + operand + ", true"
}

// ---------------------------------------------------------------------------
// Comparison instruction builders
// ---------------------------------------------------------------------------

fn emit_icmp(name: String, cmp: String, ty: String, left: String, right: String) -> String {
    return "  " + name + " =icmp " + cmp + " " + ty + " " + left + ", " + right
}

fn emit_fcmp(name: String, cmp: String, left: String, right: String) -> String {
    return "  " + name + " =fcmp o" + cmp + " double " + left + ", " + right
}

// ---------------------------------------------------------------------------
// Logical operators
// ---------------------------------------------------------------------------

fn emit_and_instr(name: String, left: String, right: String) -> String {
    return "  " + name + " =and i1 " + left + ", " + right
}

fn emit_or_instr(name: String, left: String, right: String) -> String {
    return "  " + name + " =or i1 " + left + ", " + right
}

// ---------------------------------------------------------------------------
// Control flow
// ---------------------------------------------------------------------------

fn emit_br(label: String) -> String {
    return "  br label %" + label
}

fn emit_cbranch(cond: String, true_label: String, false_label: String) -> String {
    return "  br i1 " + cond + ", label %" + true_label + ", label %" + false_label
}

fn emit_phi_instr(name: String, ty: String, val1: String, bb1: String, val2: String, bb2: String) -> String {
    return "  " + name + " =phi " + ty + " [ " + val1 + ", %" + bb1 + " ], [ " + val2 + ", %" + bb2 + " ]"
}

fn emit_switch_hdr(subject: String, default_label: String) -> String {
    return "  switch i64 " + subject + ", label %" + default_label + " ["
}

fn emit_switch_case(value: String, label: String) -> String {
    return "    i64 " + value + ", label %" + label
}

// ---------------------------------------------------------------------------
// Function / call builders
// ---------------------------------------------------------------------------

fn emit_call_ir(name: String, ret_ty: String, callee: String, args: String) -> String {
    return "  " + name + " =call " + ret_ty + " @" + callee + "(" + args + ")"
}

fn emit_call_void(callee: String, args: String) -> String {
    return "  call void @" + callee + "(" + args + ")"
}

fn emit_ret(ty: String, value: String) -> String {
    return "  ret " + ty + " " + value
}

fn emit_ret_void() -> String {
    return "  ret void"
}

// ---------------------------------------------------------------------------
// GEP / insertvalue / extractvalue builders
// ---------------------------------------------------------------------------

fn emit_gep(name: String, ty: String, ptr: String, idx: String) -> String {
    return "  " + name + " =getelementptr " + ty + ", ptr " + ptr + ", i64 0, i64 " + idx
}

fn emit_insertvalue(name: String, struct_ty: String, agg: String, val: String, val_ty: String, idx: String) -> String {
    return "  " + name + " =insertvalue " + struct_ty + " " + agg + ", " + val_ty + " " + val + ", " + idx
}

fn emit_extractvalue(name: String, struct_ty: String, agg: String, idx: String) -> String {
    return "  " + name + " =extractvalue " + struct_ty + " " + agg + ", " + idx
}

fn emit_bitcast(name: String, src_ty: String, val: String, dst_ty: String) -> String {
    return "  " + name + " =bitcast " + src_ty + " " + val + " to " + dst_ty
}

// ===== emit_llvm.mn =====
// emit_llvm.mn — LLVM IR emitter for the Mapanare self-hosted compiler.
// Consumes MIR (from lower.mn) and produces LLVM IR text (string-based).
//
// Architecture:
//   - emit_mir_module walks MIR structs, enums, extern fns, then functions
//   - emit_mir_function emits function header + basic blocks
//   - emit_mir_basic_block emits block label + instructions
//   - emit_mir_instruction maps each MIR opcode to LLVM IR instructions
//   - A local counter produces unique SSA names (%0, %1, ...)
//
// LLVM type constants and IR string builders are in emit_llvm_ir.mn.


// ---------------------------------------------------------------------------
// Emitter state
// ---------------------------------------------------------------------------

struct StructEntry {
    name: String,
    field_names: List<String>,
    field_types: List<String>,
    llvm_type: String
}

fn new_struct_entry(name: String, fields: List<String>, types: List<String>, ty: String) -> StructEntry {
    return new StructEntry { name: name, field_names: fields, field_types: types, llvm_type: ty }
}

fn lookup_struct_field_types(st: EmitState, name: String) -> List<String> {
    let mut i: Int = 0
    for _ in 0..10000 {
        if i >= len(st.structs) { break }
        let entry: StructEntry = st.structs[i]
        if entry.name == name {
            return entry.field_types
        }
        i = i + 1
    }
    let empty: List<String> = []
    return empty
}

struct FnEntry {
    name: String,
    ret_type: String,
    param_types: List<String>
}

fn new_fn_entry(name: String, ret: String, params: List<String>) -> FnEntry {
    return new FnEntry { name: name, ret_type: ret, param_types: params }
}

struct EmitState {
    lines: List<String>,
    counter: Int,
    functions: List<FnEntry>,
    structs: List<StructEntry>,
    module_name: String,
    str_counter: Int,
    str_globals: List<String>,
    current_ret_type: String,
    enum_names: List<String>,
    enum_infos: List<EnumInfo>
}

fn new_emit_state(module_name: String) -> EmitState {
    let lines: List<String> = []
    let functions: List<FnEntry> = []
    let structs: List<StructEntry> = []
    let str_globals: List<String> = []
    let enum_names: List<String> = []
    let enum_infos: List<EnumInfo> = []
    return new EmitState { lines: lines, counter: 0, functions: functions, structs: structs, module_name: module_name, str_counter: 0, str_globals: str_globals, current_ret_type: "void", enum_names: enum_names, enum_infos: enum_infos }
}

fn emit_global(st: EmitState, line: String) -> EmitState {
    st.str_globals.push(line)
    return st
}

fn emit_fresh_tmp(st: EmitState, prefix: String) -> String {
    return prefix + "." + toString(st.counter)
}

// ---------------------------------------------------------------------------
// Line emission
// ---------------------------------------------------------------------------

fn emit_line(st: EmitState, line: String) -> EmitState {
    st.lines.push(line)
    return st
}

fn emit_blank(st: EmitState) -> EmitState {
    return emit_line(st, "")
}

// ---------------------------------------------------------------------------
// Counter helpers
// ---------------------------------------------------------------------------

fn next_ssa(st: EmitState) -> EmitState {
    // Returns state with counter incremented; caller uses st.counter for name
    return st
}

fn ssa_name(st: EmitState) -> String {
    return "%" + toString(st.counter)
}

fn next_str_name(st: EmitState) -> String {
    return "@str." + toString(st.str_counter)
}

// ---------------------------------------------------------------------------
// Lookup helpers
// ---------------------------------------------------------------------------

fn find_function(st: EmitState, name: String) -> Option<FnEntry> {
    let mut i: Int = len(st.functions) - 1
    for _ in 0..100000 {
        if i < 0 { return none }
        let f: FnEntry = st.functions[i]
        if f.name == name { return Some(f) }
        i = i - 1
    }
    return none
}

fn find_struct_entry(st: EmitState, name: String) -> Option<StructEntry> {
    let mut i: Int = len(st.structs) - 1
    for _ in 0..100000 {
        if i < 0 { return none }
        let s: StructEntry = st.structs[i]
        if s.name == name { return Some(s) }
        i = i - 1
    }
    return none
}

// ---------------------------------------------------------------------------
// State-aware type resolution (corrects struct→enum misclassification)
// ---------------------------------------------------------------------------

fn resolve_type(st: EmitState, ty: MIRType) -> String {
    let resolved: String = resolve_mir_type(ty)
    if resolved.starts_with("%struct.") && is_enum_type(st, ty.name) {
        return "%enum." + ty.name
    }
    return resolved
}

// ---------------------------------------------------------------------------
// Runtime function declarations
// ---------------------------------------------------------------------------

fn declare_runtime_fn(st: EmitState, name: String, ret: String, params: String) -> EmitState {
    let line: String = "declare " + ret + " @" + name + "(" + params + ")"
    return emit_line(st, line)
}

fn declare_all_runtime(st: EmitState) -> EmitState {
    let mut s: EmitState = st

    // String runtime
    s = declare_runtime_fn(s, "__mn_str_concat", llvm_string(), llvm_string() + ", " + llvm_string())
    s = declare_runtime_fn(s, "__mn_str_eq", llvm_int(), llvm_string() + ", " + llvm_string())
    s = declare_runtime_fn(s, "__mn_str_cmp", llvm_int(), llvm_string() + ", " + llvm_string())
    s = declare_runtime_fn(s, "__mn_str_len", llvm_int(), llvm_string())
    s = declare_runtime_fn(s, "__mn_str_char_at", llvm_string(), llvm_string() + ", i64")
    s = declare_runtime_fn(s, "__mn_str_byte_at", llvm_int(), llvm_string() + ", i64")
    s = declare_runtime_fn(s, "__mn_str_substr", llvm_string(), llvm_string() + ", i64, i64")
    s = declare_runtime_fn(s, "__mn_str_from_int", llvm_string(), "i64")
    s = declare_runtime_fn(s, "__mn_str_from_bool", llvm_string(), "i1")
    s = declare_runtime_fn(s, "__mn_str_from_float", llvm_string(), "double")
    s = declare_runtime_fn(s, "__mn_str_to_int", llvm_int(), llvm_string())
    s = declare_runtime_fn(s, "__mn_str_to_float", llvm_float(), llvm_string())
    s = declare_runtime_fn(s, "__mn_str_println", "void", llvm_string())
    s = declare_runtime_fn(s, "__mn_str_print", "void", llvm_string())
    s = declare_runtime_fn(s, "__mn_str_starts_with", llvm_bool(), llvm_string() + ", " + llvm_string())
    s = declare_runtime_fn(s, "__mn_str_ends_with", llvm_bool(), llvm_string() + ", " + llvm_string())
    s = declare_runtime_fn(s, "__mn_str_find", llvm_int(), llvm_string() + ", " + llvm_string())
    s = declare_runtime_fn(s, "__mn_str_join", llvm_string(), llvm_string() + ", ptr")

    // List runtime
    s = declare_runtime_fn(s, "__mn_list_new", llvm_list_rt(), "i64")
    s = declare_runtime_fn(s, "__mn_list_push", "void", "ptr, ptr")
    s = declare_runtime_fn(s, "__mn_list_get", "ptr", "ptr, i64")
    s = declare_runtime_fn(s, "__mn_list_len", "i64", "ptr")

    // Iterator runtime
    s = declare_runtime_fn(s, "__iter_has_next", llvm_bool(), "{ i64, i64 }")
    s = declare_runtime_fn(s, "__iter_next", llvm_int(), "{ i64, i64 }")
    s = declare_runtime_fn(s, "__mn_range", "{ i64, i64 }", "i64, i64")

    // String methods
    s = declare_runtime_fn(s, "__mn_str_to_upper", llvm_string(), llvm_string())
    s = declare_runtime_fn(s, "__mn_str_to_lower", llvm_string(), llvm_string())
    s = declare_runtime_fn(s, "__mn_str_replace", llvm_string(), llvm_string() + ", " + llvm_string() + ", " + llvm_string())
    s = declare_runtime_fn(s, "__mn_str_split", llvm_list_rt(), llvm_string() + ", " + llvm_string())
    s = declare_runtime_fn(s, "__mn_str_trim", llvm_string(), llvm_string())
    s = declare_runtime_fn(s, "__mn_str_contains", llvm_bool(), llvm_string() + ", " + llvm_string())

    // Panic
    s = declare_runtime_fn(s, "__mn_panic", "void", llvm_string())

    // Printf
    s = declare_runtime_fn(s, "printf", "i32", "ptr, ...")

    // Tensor runtime
    s = declare_runtime_fn(s, "__mapanare_tensor_add", "ptr", "ptr, ptr")
    s = declare_runtime_fn(s, "__mapanare_tensor_sub", "ptr", "ptr, ptr")
    s = declare_runtime_fn(s, "__mapanare_tensor_mul", "ptr", "ptr, ptr")
    s = declare_runtime_fn(s, "__mapanare_tensor_div", "ptr", "ptr, ptr")
    s = declare_runtime_fn(s, "__mapanare_matmul", "ptr", "ptr, ptr")
    s = declare_runtime_fn(s, "__mapanare_tensor_alloc", "ptr", "i64, i64*, i64")
    s = declare_runtime_fn(s, "__mapanare_tensor_free", "void", "ptr")
    s = declare_runtime_fn(s, "__mapanare_tensor_shape_eq", "i1", "ptr, ptr")
    s = declare_runtime_fn(s, "__mapanare_detect_gpus", "ptr", "")

    // Agent runtime
    s = declare_runtime_fn(s, "__mn_agent_spawn", "ptr", "ptr, ptr")
    s = declare_runtime_fn(s, "__mn_agent_send", "void", "ptr, ptr, ptr")
    s = declare_runtime_fn(s, "__mn_agent_sync", "ptr", "ptr, ptr")

    // Signal runtime
    s = declare_runtime_fn(s, "__mn_signal_new", "ptr", "ptr")
    s = declare_runtime_fn(s, "__mn_signal_get", "ptr", "ptr")
    s = declare_runtime_fn(s, "__mn_signal_set", "void", "ptr, ptr")

    return emit_blank(s)
}

// ---------------------------------------------------------------------------
// Struct type registration from MIR
// ---------------------------------------------------------------------------

fn register_mir_struct(st: EmitState, info: StructInfo) -> EmitState {
    let mut field_names: List<String> = []
    let mut field_types: List<String> = []
    let mut llvm_fields: String = ""
    let mut fi: Int = 0

    for _ in 0..1000 {
        if fi >= len(info.fields) {
            let ty: String = "{ " + llvm_fields + " }"
            let entry: StructEntry = new_struct_entry(info.name, field_names, field_types, ty)
            st.structs.push(entry)

            // Emit named struct type definition
            let mut s: EmitState = emit_line(st, "%struct." + info.name + " = type " + ty)
            return s
        }
        let fp: FieldPair = info.fields[fi]
        let mut fty: String = resolve_mir_type(fp.val.ty)
        // Detect self-referential fields (e.g. TypeInfo has Option<TypeInfo>).
        // Replace with ptr to avoid infinite recursion in LLVM type layout.
        // Use boundary-aware match: check for exact type name followed by
        // non-alphanumeric (space, comma, }, etc.) to avoid false positives
        // like MatchArm matching MatchArmBody.
        let self_struct: String = "%struct." + info.name + " "
        let self_struct2: String = "%struct." + info.name + "}"
        let self_enum: String = "%enum." + info.name + " "
        let self_enum2: String = "%enum." + info.name + "}"
        if fty.contains(self_struct) || fty.contains(self_struct2) || fty.contains(self_enum) || fty.contains(self_enum2) {
            fty = llvm_ptr()
        }
        field_names.push(fp.name)
        field_types.push(fty)
        if fi > 0 {
            llvm_fields = llvm_fields + ", " + fty
        } else {
            llvm_fields = fty
        }
        fi = fi + 1
    }
    return st
}

// ---------------------------------------------------------------------------
// Enum type registration from MIR
// ---------------------------------------------------------------------------

fn is_enum_type(st: EmitState, name: String) -> Bool {
    let mut i: Int = 0
    for _ in 0..10000 {
        if i >= len(st.enum_names) { return false }
        if st.enum_names[i] == name { return true }
        i = i + 1
    }
    return false
}

// Compute size of an LLVM type in i64 units (8-byte slots)
fn type_size_in_slots(st: EmitState, ty: MIRType) -> Int {
    let resolved: String = resolve_mir_type(ty)
    if resolved == "i64" { return 1 }
    if resolved == "double" { return 1 }
    if resolved == "i1" { return 1 }
    if resolved == "i8" { return 1 }
    if resolved == "ptr" { return 1 }
    if resolved == "void" { return 0 }
    // String: { ptr, i64 } = 2 slots
    if resolved == "{ ptr, i64 }" { return 2 }
    // List: { ptr, i64, i64, i64 } = 4 slots
    if resolved == "{ ptr, i64, i64, i64 }" { return 4 }
    // Range: { i64, i64 } = 2 slots
    if resolved == "{ i64, i64 }" { return 2 }
    // Option: { i1, T } ≈ 2 slots minimum
    if ty.kind == "option" {
        if len(ty.args) > 0 {
            return 1 + type_size_in_slots(st, ty.args[0])
        }
        return 2
    }
    // Result: { i1, { T, E } }
    if ty.kind == "result" { return 4 }
    // Map: { ptr, i64 } = 2 slots
    if ty.kind == "map" { return 2 }
    // Enum: look up declared size from enum_infos
    if ty.kind == "enum" {
        // Search for the enum's type definition to get its actual slot count
        let mut ei: Int = 0
        for _ in 0..1000 {
            if ei >= len(st.enum_infos) { break }
            let e_info: EnumInfo = st.enum_infos[ei]
            if e_info.name == ty.name {
                // Already registered — look up its slot count from the type string
                // The type was emitted as { i64, [N x i64] } → N+1 total slots
                // For now, iterate its variants to compute max payload
                let mut mp: Int = 0
                let mut evi: Int = 0
                for _ in 0..1000 {
                    if evi >= len(e_info.variants) { break }
                    let ev: EnumVariantInfo = e_info.variants[evi]
                    let mut vsize: Int = 0
                    let mut pi: Int = 0
                    for _ in 0..100 {
                        if pi >= len(ev.payload_types) { break }
                        vsize = vsize + type_size_in_slots(st, ev.payload_types[pi])
                        pi = pi + 1
                    }
                    if vsize > mp { mp = vsize }
                    evi = evi + 1
                }
                return 1 + mp
            }
            ei = ei + 1
        }
        return 4
    }
    // Struct: look up from struct entries
    if ty.kind == "struct" {
        let struct_opt: Option<StructEntry> = find_struct_entry(st, ty.name)
        match struct_opt {
            Some(se) => { return len(se.field_types) },
            _ => { return 8 }
        }
    }
    // Default: 8 slots (conservative fallback)
    return 8
}

fn register_mir_enum(st: EmitState, info: EnumInfo) -> EmitState {
    // Tagged union: { i64 tag, payload... }
    // Each payload type gets 8 i64 slots (conservative) to handle
    // struct payloads that expand to multiple fields.
    let mut max_payload: Int = 0
    let mut vi: Int = 0
    for _ in 0..1000 {
        if vi >= len(info.variants) { break }
        let variant: EnumVariantInfo = info.variants[vi]
        let count: Int = len(variant.payload_types) * 8
        if count > max_payload {
            max_payload = count
        }
        vi = vi + 1
    }

    let mut s: EmitState = st
    s.enum_names.push(info.name)
    s.enum_infos.push(info)
    if max_payload == 0 {
        s = emit_line(s, "%enum." + info.name + " = type { i64 }")
    } else {
        s = emit_line(s, "%enum." + info.name + " = type { i64, [" + toString(max_payload) + " x i64] }")
    }
    return s
}

// ---------------------------------------------------------------------------
// Extern function declaration from MIR
// ---------------------------------------------------------------------------

fn declare_mir_extern(st: EmitState, info: ExternFnInfo) -> EmitState {
    let ret_ty: String = resolve_mir_type(info.return_type)
    let mut params_str: String = ""
    let mut i: Int = 0
    for _ in 0..1000 {
        if i >= len(info.param_types) { break }
        let pty: String = resolve_mir_type(info.param_types[i])
        if i > 0 {
            params_str = params_str + ", " + pty
        } else {
            params_str = pty
        }
        i = i + 1
    }
    return emit_line(st, "declare " + ret_ty + " @" + info.fn_name + "(" + params_str + ")")
}

// ---------------------------------------------------------------------------
// MIR instruction emission → LLVM IR
// ---------------------------------------------------------------------------

fn emit_mir_instruction(st: EmitState, inst: Instruction) -> EmitState {
    match inst {
        Const(dest, ty, val) => {
            return emit_const(st, dest, ty, val)
        },
        Copy(dest, src) => {
            return emit_copy(st, dest, src)
        },
        Cast(dest, src, target_ty) => {
            return emit_cast(st, dest, src, target_ty)
        },
        BinOp(dest, op, lhs, rhs) => {
            return emit_binop(st, dest, op, lhs, rhs)
        },
        UnaryOp(dest, op, operand) => {
            return emit_unaryop(st, dest, op, operand)
        },
        StructInit(dest, ty, fields) => {
            return emit_struct_init(st, dest, ty, fields)
        },
        FieldGet(dest, obj, field_name) => {
            return emit_field_get(st, dest, obj, field_name)
        },
        FieldSet(obj, field_name, val) => {
            return emit_field_set(st, obj, field_name, val)
        },
        ListInit(dest, elem_ty, elements) => {
            // Check if this is a struct init by looking up dest type name
            // in the struct registry. Enum payload types get corrupted, so
            // we check elem_ty.name and dest.ty.name against known structs.
            let struct_check: Option<StructEntry> = find_struct_entry(st, dest.ty.name)
            let struct_check2: Option<StructEntry> = find_struct_entry(st, elem_ty.name)
            match struct_check {
                Some(_) => {
                    return emit_struct_init_from_values(st, dest, dest.ty, elements)
                },
                _ => {}
            }
            match struct_check2 {
                Some(_) => {
                    return emit_struct_init_from_values(st, dest, elem_ty, elements)
                },
                _ => {}
            }
            return emit_list_init(st, dest, elem_ty, elements)
        },
        IndexGet(dest, obj, idx) => {
            return emit_index_get(st, dest, obj, idx)
        },
        IndexSet(obj, idx, val) => {
            return emit_index_set(st, obj, idx, val)
        },
        Alloca(dest, ty) => {
            return emit_alloca(st, dest, ty)
        },
        Load(dest, ptr) => {
            return emit_load(st, dest, ptr)
        },
        Store(ptr, val) => {
            return emit_store(st, ptr, val)
        },
        MapInit(dest, key_ty, val_ty, pairs) => {
            return emit_map_init(st, dest, key_ty, val_ty, pairs)
        },
        EnumInit(dest, ty, variant, payload) => {
            return emit_enum_init(st, dest, ty, variant, payload)
        },
        EnumTag(dest, val) => {
            return emit_enum_tag(st, dest, val)
        },
        EnumPayload(dest, val, variant) => {
            return emit_enum_payload(st, dest, val, variant)
        },
        WrapSome(dest, val) => {
            return emit_wrap_some(st, dest, val)
        },
        WrapNone(dest, ty) => {
            return emit_wrap_none(st, dest, ty)
        },
        WrapOk(dest, val) => {
            return emit_wrap_ok(st, dest, val)
        },
        WrapErr(dest, val) => {
            return emit_wrap_err(st, dest, val)
        },
        Unwrap(dest, val) => {
            return emit_unwrap(st, dest, val)
        },
        Call(dest, fn_name, args) => {
            return emit_mir_call(st, dest, fn_name, args)
        },
        Return(val_opt) => {
            return emit_mir_return(st, val_opt)
        },
        Jump(target) => {
            return emit_line(st, emit_br(target))
        },
        Branch(cond, true_bb, false_bb) => {
            return emit_line(st, emit_cbranch(cond.name, true_bb, false_bb))
        },
        Switch(tag, cases, default_bb) => {
            return emit_mir_switch(st, tag, cases, default_bb)
        },
        AgentSpawn(dest, ty, args) => {
            return emit_agent_spawn(st, dest, ty, args)
        },
        AgentSend(ag, channel, val) => {
            return emit_agent_send(st, ag, channel, val)
        },
        AgentSync(dest, ag, channel) => {
            return emit_agent_sync(st, dest, ag, channel)
        },
        SignalInit(dest, ty, val) => {
            return emit_signal_init(st, dest, ty, val)
        },
        SignalGet(dest, sig) => {
            return emit_signal_get(st, dest, sig)
        },
        SignalSet(sig, val) => {
            return emit_signal_set(st, sig, val)
        },
        StreamOp(dest, kind, source, args) => {
            return emit_stream_op(st, dest, kind, source, args)
        },
        InterpConcat(dest, parts) => {
            return emit_interp_concat(st, dest, parts)
        },
        Phi(dest, incoming) => {
            return emit_mir_phi(st, dest, incoming)
        }
    }
}

// ---------------------------------------------------------------------------
// Const instruction
// ---------------------------------------------------------------------------

fn emit_const(st: EmitState, dest: Value, ty: MIRType, val: String) -> EmitState {
    let mut s: EmitState = st
    let dn: String = dest.name
    let llvm_ty: String = resolve_mir_type(ty)

    // Void constants are no-ops
    if ty.kind == "void" {
        return s
    }

    // String constant: emit global at module level, build struct inline
    if ty.kind == "string" {
        // Escape special chars for LLVM IR string constants
        let escaped: String = val.replace("\\", "\\5C").replace("\"", "\\22").replace("\n", "\\0A")
        let slen: Int = len(val)
        let gname: String = next_str_name(s)
        s.str_counter = s.str_counter + 1
        let arr_ty: String = "[" + toString(slen) + " x i8]"
        s = emit_global(s, gname + " = private constant " + arr_ty + " c\"" + escaped + "\"")
        let ptr_name: String = dn + ".ptr"
        s = emit_line(s, "  " + ptr_name + " = getelementptr " + arr_ty + ", " + "ptr " + gname + ", i64 0, i64 0")
        let s1_name: String = dn + ".s1"
        s = emit_line(s, emit_insertvalue(s1_name, llvm_string(), "undef", ptr_name, "ptr", "0"))
        s = emit_line(s, emit_insertvalue(dn, llvm_string(), s1_name, toString(slen), "i64", "1"))
        return s
    }

    // Bool constant
    if ty.kind == "bool" {
        let bval: String = if val == "true" { "1" } else { "0" }
        s = emit_line(s, "  " + dn + " = add i1 0, " + bval)
        return s
    }

    // Int constant: emit `%dest = add i64 0, <val>` to define the SSA value
    if ty.kind == "int" {
        s = emit_line(s, "  " + dn + " = add i64 0, " + val)
        return s
    }

    // Float constant: emit `%dest = fadd double 0.0, <val>`
    if ty.kind == "float" {
        s = emit_line(s, "  " + dn + " = fadd double 0.0, " + val)
        return s
    }

    // Struct constant (undef initializer for struct construction)
    if ty.kind == "struct" {
        s = emit_line(s, "  " + dn + " = insertvalue " + llvm_ty + " undef, " + llvm_ty + " undef, 0")
        return s
    }

    // Function constant: emit function pointer reference
    if ty.kind == "fn" {
        s = emit_line(s, "  " + dn + " = bitcast void ()* @" + val + " to ptr")
        return s
    }

    // Unknown type — no-op
    return s
}

// ---------------------------------------------------------------------------
// Copy instruction
// ---------------------------------------------------------------------------

fn emit_copy(st: EmitState, dest: Value, src: Value) -> EmitState {
    let mut s: EmitState = st
    let ty: String = resolve_type(st, dest.ty)
    let src_ty: String = resolve_type(st, src.ty)
    // Use source type when dest is unknown/scalar but source is aggregate.
    // This handles match pattern bindings where the payload type is known
    // from enum info but the pattern variable type is unknown.
    let mut use_ty: String = ty
    if ty == "ptr" {
        use_ty = src_ty
    }
    if ty == "i64" && (src_ty.starts_with("%struct.") || src_ty.starts_with("%enum.") || src_ty.starts_with("{")) {
        use_ty = src_ty
    }

    // Bool: use bitwise identity (and true)
    if ty == "i1" {
        return emit_line(s, "  " + dest.name + " = and i1 " + src.name + ", true")
    }
    // Aggregate types (structs, enums, options, results, lists) cannot use `add`.
    // Use alloca/store/load to copy the value through memory.
    if use_ty.starts_with("%struct.") || use_ty.starts_with("%enum.") || use_ty.starts_with("{") {
        let tmp_a: String = dest.name + ".cpy"
        s = emit_line(s, "  " + tmp_a + " = alloca " + use_ty)
        s = emit_line(s, "  store " + use_ty + " " + src.name + ", " + "ptr " + tmp_a)
        return emit_line(s, "  " + dest.name + " = load " + use_ty + ", " + "ptr " + tmp_a)
    }
    // Scalars (i64, double, ptr, etc.): use add 0 identity
    return emit_line(s, "  " + dest.name + " = add " + use_ty + " 0, " + src.name)
}

// ---------------------------------------------------------------------------
// Cast instruction
// ---------------------------------------------------------------------------

fn emit_cast(st: EmitState, dest: Value, src: Value, target_ty: MIRType) -> EmitState {
    let mut s: EmitState = st
    let sn: String = src.name
    let dn: String = dest.name

    let src_ty: String = resolve_mir_type(src.ty)
    let dst_ty: String = resolve_mir_type(target_ty)

    // Int → Float
    if src.ty.kind == "int" {
        if target_ty.kind == "float" {
            s = emit_line(s, "  " + dn + " =sitofp i64 " + sn + " to double")
            return s
        }
    }
    // Float → Int
    if src.ty.kind == "float" {
        if target_ty.kind == "int" {
            s = emit_line(s, "  " + dn + " =fptosi double " + sn + " to i64")
            return s
        }
    }
    // Fallback: bitcast
    s = emit_line(s, emit_bitcast(dn, src_ty, sn, dst_ty))
    return s
}

// ---------------------------------------------------------------------------
// BinOp instruction
// ---------------------------------------------------------------------------

fn emit_binop(st: EmitState, dest: Value, op: BinOpKind, lhs: Value, rhs: Value) -> EmitState {
    let mut s: EmitState = st
    let ln: String = lhs.name
    let rn: String = rhs.name

    let dn: String = dest.name
    let is_float: Bool = lhs.ty.kind == "float"
    let is_string: Bool = lhs.ty.kind == "string"
    let is_bool: Bool = lhs.ty.kind == "bool"
    let cmp_ty: String = if is_bool { "i1" } else { llvm_int() }

    // Use binop_kind_to_str (defined in lower.mn where BinOpKind is local)
    // to convert the enum tag to a string, then dispatch with if/else
    let op_str: String = binop_kind_to_str(op)

    if op_str == "add" {
        if is_string {
            s = emit_line(s, emit_call_ir(dn, llvm_string(), "__mn_str_concat", llvm_string() + " " + ln + ", " + llvm_string() + " " + rn))
        } else {
            if is_float { s = emit_line(s, emit_fadd(dn, ln, rn)) } else { s = emit_line(s, emit_add(dn, llvm_int(), ln, rn)) }
        }
    } else if op_str == "sub" {
        if is_float { s = emit_line(s, emit_fsub(dn, ln, rn)) } else { s = emit_line(s, emit_sub(dn, llvm_int(), ln, rn)) }
    } else if op_str == "mul" {
        if is_float { s = emit_line(s, emit_fmul(dn, ln, rn)) } else { s = emit_line(s, emit_mul(dn, llvm_int(), ln, rn)) }
    } else if op_str == "div" {
        if is_float { s = emit_line(s, emit_fdiv(dn, ln, rn)) } else { s = emit_line(s, emit_sdiv(dn, llvm_int(), ln, rn)) }
    } else if op_str == "mod" {
        if is_float { s = emit_line(s, emit_frem(dn, ln, rn)) } else { s = emit_line(s, emit_srem(dn, llvm_int(), ln, rn)) }
    } else if op_str == "eq" {
        if is_string {
            let eq_raw: String = dn + ".sr"
            s = emit_line(s, emit_call_ir(eq_raw, llvm_int(), "__mn_str_eq", llvm_string() + " " + ln + ", " + llvm_string() + " " + rn))
            s = emit_line(s, emit_icmp(dn, "ne", llvm_int(), eq_raw, "0"))
        } else {
            if is_float { s = emit_line(s, emit_fcmp(dn, "eq", ln, rn)) } else { s = emit_line(s, emit_icmp(dn, "eq", cmp_ty, ln, rn)) }
        }
    } else if op_str == "ne" {
        if is_string {
            let eq_raw: String = dn + ".sr"
            s = emit_line(s, emit_call_ir(eq_raw, llvm_int(), "__mn_str_eq", llvm_string() + " " + ln + ", " + llvm_string() + " " + rn))
            s = emit_line(s, emit_icmp(dn, "eq", llvm_int(), eq_raw, "0"))
        } else {
            if is_float { s = emit_line(s, emit_fcmp(dn, "ne", ln, rn)) } else { s = emit_line(s, emit_icmp(dn, "ne", cmp_ty, ln, rn)) }
        }
    } else if op_str == "lt" {
        if is_string {
            let cmp_r: String = dn + ".sc"
            s = emit_line(s, emit_call_ir(cmp_r, llvm_int(), "__mn_str_cmp", llvm_string() + " " + ln + ", " + llvm_string() + " " + rn))
            s = emit_line(s, emit_icmp(dn, "slt", llvm_int(), cmp_r, "0"))
        } else {
            if is_float { s = emit_line(s, emit_fcmp(dn, "lt", ln, rn)) } else { s = emit_line(s, emit_icmp(dn, "slt", llvm_int(), ln, rn)) }
        }
    } else if op_str == "gt" {
        if is_string {
            let cmp_r: String = dn + ".sc"
            s = emit_line(s, emit_call_ir(cmp_r, llvm_int(), "__mn_str_cmp", llvm_string() + " " + ln + ", " + llvm_string() + " " + rn))
            s = emit_line(s, emit_icmp(dn, "sgt", llvm_int(), cmp_r, "0"))
        } else {
            if is_float { s = emit_line(s, emit_fcmp(dn, "gt", ln, rn)) } else { s = emit_line(s, emit_icmp(dn, "sgt", llvm_int(), ln, rn)) }
        }
    } else if op_str == "le" {
        if is_string {
            let cmp_r: String = dn + ".sc"
            s = emit_line(s, emit_call_ir(cmp_r, llvm_int(), "__mn_str_cmp", llvm_string() + " " + ln + ", " + llvm_string() + " " + rn))
            s = emit_line(s, emit_icmp(dn, "sle", llvm_int(), cmp_r, "0"))
        } else {
            if is_float { s = emit_line(s, emit_fcmp(dn, "le", ln, rn)) } else { s = emit_line(s, emit_icmp(dn, "sle", llvm_int(), ln, rn)) }
        }
    } else if op_str == "ge" {
        if is_string {
            let cmp_r: String = dn + ".sc"
            s = emit_line(s, emit_call_ir(cmp_r, llvm_int(), "__mn_str_cmp", llvm_string() + " " + ln + ", " + llvm_string() + " " + rn))
            s = emit_line(s, emit_icmp(dn, "sge", llvm_int(), cmp_r, "0"))
        } else {
            if is_float { s = emit_line(s, emit_fcmp(dn, "ge", ln, rn)) } else { s = emit_line(s, emit_icmp(dn, "sge", llvm_int(), ln, rn)) }
        }
    } else if op_str == "and" {
        s = emit_line(s, emit_and_instr(dn, ln, rn))
    } else if op_str == "or" {
        s = emit_line(s, emit_or_instr(dn, ln, rn))
    } else {
        // Fallback: add
        s = emit_line(s, emit_add(dn, llvm_int(), ln, rn))
    }

    return s
}

// ---------------------------------------------------------------------------
// UnaryOp instruction
// ---------------------------------------------------------------------------

fn emit_unaryop(st: EmitState, dest: Value, op: UnaryOpKind, operand: Value) -> EmitState {
    let mut s: EmitState = st
    let on: String = operand.name
    let dn: String = dest.name
    let op_str: String = unaryop_kind_to_str(op)

    if op_str == "neg" {
        if operand.ty.kind == "float" {
            s = emit_line(s, emit_fneg(dn, on))
        } else {
            s = emit_line(s, emit_neg(dn, llvm_int(), on))
        }
        return s
    }
    if op_str == "not" {
        s = emit_line(s, emit_not(dn, on))
        return s
    }
    return s
}

// ---------------------------------------------------------------------------
// StructInit instruction
// ---------------------------------------------------------------------------

fn emit_struct_init(st: EmitState, dest: Value, ty: MIRType, fields: List<FieldPair>) -> EmitState {
    let struct_ty: String = resolve_mir_type(ty)
    let mut s: EmitState = st
    let dn: String = dest.name
    let mut agg: String = "undef"
    let mut i: Int = 0

    // Lookup struct field types from the registry (more reliable than MIR types)
    let field_types: List<String> = lookup_struct_field_types(s, ty.name)

    let nfields: Int = len(fields)
    for _ in 0..1000 {
        if i >= nfields {
            break
        }
        let fp: FieldPair = fields[i]
        let mut fty: String = resolve_mir_type(fp.val.ty)
        let val_name: String = fp.val.name
        // If MIR type is unknown, use the registered struct field type
        if fty == "i64" && fp.val.ty.kind == "unknown" && i < len(field_types) {
            fty = field_types[i]
        }
        let tmp_name: String = dn + ".f" + toString(i)
        s = emit_line(s, emit_insertvalue(tmp_name, struct_ty, agg, val_name, fty, toString(i)))
        agg = tmp_name
        i = i + 1
    }
    // Copy the final insertvalue result to dest via alloca/store/load
    // (aggregate types cannot use `add 0` identity)
    if nfields > 0 {
        let cpy_a: String = dn + ".si"
        s = emit_line(s, "  " + cpy_a + " = alloca " + struct_ty)
        s = emit_line(s, "  store " + struct_ty + " " + agg + ", " + "ptr " + cpy_a)
        s = emit_line(s, "  " + dn + " = load " + struct_ty + ", " + "ptr " + cpy_a)
    }
    return s
}

// ---------------------------------------------------------------------------
// FieldGet instruction
// ---------------------------------------------------------------------------

fn emit_field_get(st: EmitState, dest: Value, obj: Value, field_name: String) -> EmitState {
    let mut s: EmitState = st
    let on: String = obj.name
    let dn: String = dest.name
    let obj_ty: String = resolve_type(st, obj.ty)

    // String .len → extractvalue index 1
    if obj.ty.kind == "string" {
        if field_name == "len" {
            s = emit_line(s, emit_extractvalue(dn, llvm_string(), on, "1"))
            return s
        }
        // String methods (contains, starts_with, etc.) — not struct fields.
        // The actual call is handled by the Call instruction that follows.
        // Just pass the object through as the "method reference".
        return emit_copy(s, dest, obj)
    }

    // List .len
    if obj.ty.kind == "list" {
        if field_name == "len" {
            let lt: String = llvm_list_rt()
            let tmp: String = dn + ".lp"
            s = emit_line(s, "  " + tmp + " = alloca " + lt)
            s = emit_line(s, "  store " + lt + " " + on + ", " + "ptr " + tmp)
            s = emit_line(s, emit_call_ir(dn, llvm_int(), "__mn_list_len", "ptr " + tmp))
            return s
        }
        // List methods (push, etc.) — pass object through
        return emit_copy(s, dest, obj)
    }

    // Look up field index from registered structs
    let struct_opt: Option<StructEntry> = find_struct_entry(s, obj.ty.name)
    match struct_opt {
        Some(se) => {
            let idx: Int = find_field_index(se.field_names, field_name)
            // Use the resolved type (named struct form like %struct.Point)
            // to match the value type from load instructions
            s = emit_line(s, emit_extractvalue(dn, obj_ty, on, toString(idx)))
            return s
        },
        _ => {
            // Default: extract index 0
            s = emit_line(s, emit_extractvalue(dn, obj_ty, on, "0"))
            return s
        }
    }
}

fn find_field_index(fields: List<String>, name: String) -> Int {
    let mut i: Int = 0
    for _ in 0..1000 {
        if i >= len(fields) { return 0 }
        if fields[i] == name { return i }
        i = i + 1
    }
    return 0
}

// ---------------------------------------------------------------------------
// FieldSet instruction
// ---------------------------------------------------------------------------

fn emit_field_set(st: EmitState, obj: Value, field_name: String, val: Value) -> EmitState {
    let mut s: EmitState = st

    let val_ty: String = resolve_mir_type(val.ty)

    let struct_opt: Option<StructEntry> = find_struct_entry(s, obj.ty.name)
    match struct_opt {
        Some(se) => {
            let idx: Int = find_field_index(se.field_names, field_name)
            let struct_ty: String = resolve_type(s, obj.ty)
            // If obj is an alloca address (from lowerer's find_expr_alloca),
            // use GEP+store directly — no insertvalue needed.
            if obj.name.contains(".addr") {
                let gep: String = "%" + strip_percent(obj.name) + "_fp" + toString(s.counter)
                s.counter = s.counter + 1
                s = emit_line(s, "  " + gep + " = getelementptr inbounds " + struct_ty + ", ptr " + obj.name + ", i32 0, i32 " + toString(idx))
                s = emit_line(s, "  store " + val_ty + " " + val.name + ", ptr " + gep)
            } else {
                // Fallback: insertvalue (doesn't write back to alloca)
                let tmp_name: String = "%" + strip_percent(obj.name) + "_set" + toString(s.counter)
                s.counter = s.counter + 1
                s = emit_line(s, emit_insertvalue(tmp_name, struct_ty, obj.name, val.name, val_ty, toString(idx)))
            }
            return s
        },
        _ => {
            return s
        }
    }
}

// ---------------------------------------------------------------------------
// ListInit instruction
// ---------------------------------------------------------------------------

fn strip_percent(name: String) -> String {
    // Strip leading % from name. Uses starts_with + substr.
    // NOTE: Can't use early return inside if (self-hosted control flow limitation).
    let starts: Bool = name.starts_with("%")
    let result: String = if starts { name.substr(1, len(name) - 1) } else { name }
    return result
}

fn has_struct(st: EmitState, name: String) -> Bool {
    let opt: Option<StructEntry> = find_struct_entry(st, name)
    match opt {
        Some(_) => { return true },
        _ => { return false }
    }
}

fn try_emit_struct_construct(st: EmitState, dest: Value, fn_name: String, args: List<Value>) -> EmitState {
    // Check if fn_name is "__new_<StructName>" and emit struct construction.
    // Uses ternary expressions to avoid early returns inside if/match.
    let is_new: Bool = len(fn_name) > 6
    let prefix: String = if is_new { fn_name.substr(0, 6) } else { "" }
    let struct_name: String = if prefix == "__new_" { fn_name.substr(6, len(fn_name) - 6) } else { "" }
    let found: Bool = if struct_name != "" { has_struct(st, struct_name) } else { false }
    let result: EmitState = if found { emit_struct_init_from_values(st, dest, dest.ty, args) } else { st }
    return result
}

fn emit_struct_init_from_values(st: EmitState, dest: Value, ty: MIRType, values: List<Value>) -> EmitState {
    // Build struct from a list of values (field order matches struct definition)
    let struct_ty: String = resolve_mir_type(ty)
    let mut s: EmitState = st
    let dn: String = dest.name
    let mut agg: String = "undef"
    let nfields: Int = len(values)

    // Lookup registered field types for this struct
    let field_types: List<String> = lookup_struct_field_types(s, ty.name)

    let mut i: Int = 0
    for _ in 0..1000 {
        if i >= nfields { break }
        let v: Value = values[i]
        let mut fty: String = resolve_type(st, v.ty)
        let vname: String = v.name
        // Always prefer registered field types for struct construction.
        // MIR value types are often wrong (unknown/empty name) due to
        // COW corruption in nested lists. The emitter's struct registry
        // (from type definitions) is authoritative.
        if i < len(field_types) {
            let rft: String = field_types[i]
            if len(rft) > 2 && rft != "i64" {
                fty = rft
            }
        }
        let tmp_name: String = dn + ".f" + toString(i)
        s = emit_line(s, emit_insertvalue(tmp_name, struct_ty, agg, vname, fty, toString(i)))
        agg = tmp_name
        i = i + 1
    }
    // Copy the final insertvalue result to dest
    if nfields > 0 {
        let cpy_a: String = dn + ".si"
        s = emit_line(s, "  " + cpy_a + " = alloca " + struct_ty)
        s = emit_line(s, "  store " + struct_ty + " " + agg + ", " + "ptr " + cpy_a)
        s = emit_line(s, "  " + dn + " = load " + struct_ty + ", " + "ptr " + cpy_a)
    }
    return s
}

fn find_list_field_index(st: EmitState, struct_name: String, dest: Value) -> String {
    // The struct_name may be "StructName:field_name" (encoded by lowerer)
    let colon_pos: Int = struct_name.find(":")
    if colon_pos > 0 {
        let base: String = struct_name.substr(0, colon_pos)
        let field: String = struct_name.substr(colon_pos + 1, len(struct_name) - colon_pos - 1)
        let opt: Option<StructEntry> = find_struct_entry(st, base)
        match opt {
            Some(se) => {
                let idx: Int = find_field_index(se.field_names, field)
                return toString(idx)
            },
            _ => { return "0" }
        }
    }
    return "0"
}

fn find_alloca_by_search(lines: List<String>, value_name: String) -> String {
    // Search FORWARD for "value_name =load TYPE, ptr %alloca"
    // Use the LAST match (most recent load of this value)
    let search_pat: String = value_name + " =load"
    let n: Int = len(lines)
    let mut result: String = ""
    let mut i: Int = 0
    for _ in 0..100000 {
        if i >= n { return result }
        let line: String = lines[i]
        if line.contains(search_pat) {
            let pp: Int = line.find(", ptr ")
            if pp > 0 {
                result = line.substr(pp + 6, len(line) - pp - 6)
            }
        }
        i = i + 1
    }
    return result
}

fn is_name_in_byref(byref_names: List<String>, name: String) -> Bool {
    // Check if alloca name matches a byref param EXACTLY.
    // Alloca names: "%{param_name}.addr" (params have no counter suffix).
    // Local vars: "%{name}{counter}.addr" — these should NOT match.
    let mut i: Int = 0
    for _ in 0..100 {
        if i >= len(byref_names) { return false }
        let bn: String = byref_names[i]
        // Exact match: the alloca is %{param_name}.addr
        let expected: String = "%" + bn + ".addr"
        if name == expected { return true }
        i = i + 1
    }
    return false
}

fn is_byref_type(ty: String) -> Bool {
    // Large struct types (> 64 bytes) should use byref/sret passing.
    // Named structs: check by name against known large types.
    if ty.starts_with("%struct.") {
        // Only large structs: EmitState, LowerState, MIRModule, SemState, etc.
        // Small structs (Token, Value, MIRType, CompileResult) stay by-value.
        if ty.contains("EmitState") { return true }
        if ty.contains("LowerState") { return true }
        if ty.contains("LowerResult") { return true }
        if ty.contains("MIRModule") { return true }
        if ty.contains("MIRFunction") { return true }
        if ty.contains("SemState") { return true }
        if ty.contains("InferResult") { return true }
        if ty.contains("SemanticChecker") { return true }
        if ty.contains("MatchBuildResult") { return true }
        return false
    }
    if ty.starts_with("{") {
        let sz: Int = llvm_type_size(ty)
        if sz > 64 { return true }
    }
    return false
}

fn find_alloca_for_value(st: EmitState, value_name: String) -> String {
    // Scan backward through emitted lines to find:
    //   %value_name =load TYPE, ptr %ALLOCA
    // Return %ALLOCA name so FieldSet can store back.
    let search: String = value_name + " ="
    let n: Int = len(st.lines)
    let mut i: Int = n - 1
    for _ in 0..10000 {
        if i < 0 { return "" }
        let line: String = st.lines[i]
        if line.contains(search) {
            if line.contains("load") {
                let ptr_pos: Int = line.find(", ptr ")
                if ptr_pos > 0 {
                    let after: String = line.substr(ptr_pos + 6, len(line) - ptr_pos - 6)
                    return after
                }
            }
            return ""
        }
        i = i - 1
    }
    return ""
}

fn llvm_type_size(ty: String) -> Int {
    if ty == "i1" { return 1 }
    if ty == "i8" { return 1 }
    if ty == "i32" { return 4 }
    if ty == "i64" { return 8 }
    if ty == "double" { return 8 }
    if ty == "ptr" { return 8 }
    if ty == "void" { return 0 }
    // String = {ptr, i64} = 16
    if ty == llvm_string() { return 16 }
    // List = {ptr, i64, i64, i64} = 32
    if ty == llvm_list_rt() { return 32 }
    // Structs and enums: use pointer size (8) as they're passed by ptr
    if ty.starts_with("%struct.") { return 8 }
    if ty.starts_with("%enum.") { return 8 }
    // Aggregate types: count fields
    if ty.starts_with("{") { return llvm_aggregate_size(ty) }
    return 8
}

fn llvm_aggregate_size(ty: String) -> Int {
    // Count comma-separated fields, each assumed 8 bytes
    let inner: String = ty.substr(1, len(ty) - 2)
    let parts: List<String> = inner.split(",")
    return len(parts) * 8
}

fn emit_list_push_call(st: EmitState, dest: Value, args: List<Value>) -> EmitState {
    let mut s: EmitState = st
    if len(args) >= 2 {
        let list_ref: String = args[0].name
        let list_ty_kind: String = args[0].ty.kind
        let elem_name: String = args[1].name
        let mut elem_ty: String = resolve_type(st, args[1].ty)
        if elem_ty == "i64" { elem_ty = resolve_mir_type(args[1].ty) }
        let cnt: String = toString(s.counter)
        s.counter = s.counter + 1
        let mut list_ptr: String = list_ref
        // If args[0] is a struct alloca (from FieldAccess push like st.lines.push),
        // GEP to the first list field (index 0 = lines field for EmitState).
        // The struct type is resolved from the args[0] MIR type.
        if list_ref.contains(".addr") && list_ty_kind == "struct" {
            // The type name may be "StructName:field_name" — strip the field part
            let type_name: String = args[0].ty.name
            let cp: Int = type_name.find(":")
            let base_name: String = if cp > 0 { type_name.substr(0, cp) } else { type_name }
            let struct_ty: String = "%struct." + base_name
            let field_idx: String = find_list_field_index(st, type_name, dest)
            let gep: String = "%push_gep" + cnt
            s = emit_line(s, "  " + gep + " = getelementptr inbounds " + struct_ty + ", ptr " + list_ref + ", i32 0, i32 " + field_idx)
            list_ptr = gep
        }
        if !list_ref.contains(".addr") {
            // Loaded list value — create temp alloca
            let la: String = "%push_la" + cnt
            s = emit_line(s, "  " + la + " = alloca " + llvm_list_rt())
            s = emit_line(s, "  store " + llvm_list_rt() + " " + list_ref + ", ptr " + la)
            list_ptr = la
        }
        let ea: String = "%push_ea" + cnt
        s = emit_line(s, "  " + ea + " = alloca " + elem_ty)
        s = emit_line(s, "  store " + elem_ty + " " + elem_name + ", ptr " + ea)
        s = emit_line(s, emit_call_void("__mn_list_push", "ptr " + list_ptr + ", ptr " + ea))
    }
    return s
}

fn emit_list_init(st: EmitState, dest: Value, elem_ty: MIRType, elements: List<Value>) -> EmitState {
    let mut s: EmitState = st
    let dn: String = dest.name

    // Create empty list. Use 64 bytes as default element size — this covers
    // all types (i64=8, String=16, List=32, structs≤64). The C runtime
    // uses elem_size for memcpy in push; oversizing wastes memory but
    // prevents truncation crashes.
    let list_name: String = dn + ".new"
    let elem_llvm_ty: String = resolve_mir_type(elem_ty)
    let mut elem_sz: Int = llvm_type_size(elem_llvm_ty)
    if elem_sz < 16 { elem_sz = 256 }
    s = emit_line(s, emit_call_ir(list_name, llvm_list_rt(), "__mn_list_new", "i64 " + toString(elem_sz)))

    // Alloca for push
    let alloca_name: String = dn + ".addr"
    s = emit_line(s, llvm_alloca(alloca_name, llvm_list_rt()))
    s = emit_line(s, llvm_store(llvm_list_rt(), list_name, alloca_name))

    // Push each element
    let mut i: Int = 0
    for _ in 0..100000 {
        if i >= len(elements) {
            // Load final list
            let final_list: String = dest.name
            s = emit_line(s, llvm_load(final_list, llvm_list_rt(), alloca_name))
            return s
        }
        let elem: Value = elements[i]
        let ety: String = resolve_mir_type(elem.ty)
        let elem_alloca: String = dn + ".e" + toString(i)
        s = emit_line(s, llvm_alloca(elem_alloca, ety))
        s = emit_line(s, llvm_store(ety, elem.name, elem_alloca))
        let cast_name: String = dn + ".c" + toString(i)
        s = emit_line(s, emit_bitcast(cast_name, ety + "*", elem_alloca, "ptr"))
        s = emit_line(s, emit_call_void("__mn_list_push", "ptr " + alloca_name + ", ptr " + cast_name))
        i = i + 1
    }
    return s
}

// ---------------------------------------------------------------------------
// IndexGet instruction
// ---------------------------------------------------------------------------

fn emit_index_get(st: EmitState, dest: Value, obj: Value, idx: Value) -> EmitState {
    let mut s: EmitState = st
    let dn: String = dest.name

    // String indexing → char_at
    if obj.ty.kind == "string" {
        s = emit_line(s, emit_call_ir(dn, llvm_string(), "__mn_str_char_at", llvm_string() + " " + obj.name + ", i64 " + idx.name))
        return s
    }

    // List indexing → list_get (needs pointer; alloca+store the list value)
    let lt: String = llvm_list_rt()
    let tmp: String = dn + ".lp"
    s = emit_line(s, "  " + tmp + " = alloca " + lt)
    s = emit_line(s, "  store " + lt + " " + obj.name + ", " + "ptr " + tmp)

    // If dest type is known, load from the ptr returned by list_get
    let dest_ty: String = resolve_type(st, dest.ty)
    if dest_ty != llvm_int() && dest_ty != "ptr" && dest_ty != "void" {
        let raw: String = dn + ".raw"
        s = emit_line(s, emit_call_ir(raw, "ptr", "__mn_list_get", "ptr " + tmp + ", i64 " + idx.name))
        // Opaque pointers: load directly from ptr, no bitcast needed
        s = emit_line(s, "  " + dn + " = load " + dest_ty + ", ptr " + raw)
    } else {
        // list_get returns ptr to element. Load the element value.
        let raw2: String = dn + ".raw"
        s = emit_line(s, emit_call_ir(raw2, "ptr", "__mn_list_get", "ptr " + tmp + ", i64 " + idx.name))
        s = emit_line(s, "  " + dn + " = load i64, ptr " + raw2)
    }
    return s
}

// ---------------------------------------------------------------------------
// IndexSet instruction
// ---------------------------------------------------------------------------

fn emit_index_set(st: EmitState, obj: Value, idx: Value, val: Value) -> EmitState {
    // List index set not yet implemented in runtime
    return st
}

// ---------------------------------------------------------------------------
// Alloca/Load/Store instructions
// ---------------------------------------------------------------------------

fn emit_alloca(st: EmitState, dest: Value, ty: MIRType) -> EmitState {
    return emit_line(st, llvm_alloca(dest.name, resolve_type(st, ty)))
}

fn emit_load(st: EmitState, dest: Value, ptr: Value) -> EmitState {
    return emit_line(st, llvm_load(dest.name, resolve_type(st, dest.ty), ptr.name))
}

fn emit_store(st: EmitState, ptr: Value, val: Value) -> EmitState {
    let val_ty: String = resolve_type(st, val.ty)
    let ptr_ty: String = resolve_type(st, ptr.ty)
    // When storing a generic None ({i1, ptr}) to a specific Option alloca
    // ({i1, %enum.T}), use zeroinitializer with the alloca's type instead.
    // None has tag=0 and null payload — zeroinitializer is equivalent.
    if val.ty.kind == "option" && ptr_ty != val_ty && ptr_ty.starts_with("{") {
        return emit_line(st, "  store " + ptr_ty + " zeroinitializer, " + "ptr " + ptr.name)
    }
    return emit_line(st, llvm_store(val_ty, val.name, ptr.name))
}

// ---------------------------------------------------------------------------
// MapInit instruction
// ---------------------------------------------------------------------------

fn emit_map_init(st: EmitState, dest: Value, key_ty: MIRType, val_ty: MIRType, pairs: List<KVPair>) -> EmitState {
    let mut s: EmitState = st
    let dn: String = dest.name
    // Maps are pointer-based; minimal implementation
    s = emit_line(s, "  " + dn + " =insertvalue " + llvm_map_type() + " undef, ptr null, 0")
    return s
}

// ---------------------------------------------------------------------------
// EnumInit instruction
// ---------------------------------------------------------------------------

fn emit_enum_init(st: EmitState, dest: Value, ty: MIRType, variant: String, payload: List<Value>) -> EmitState {
    let enum_ty: String = resolve_mir_type(ty)
    let mut s: EmitState = st
    let dn: String = dest.name

    // Resolve variant tag index
    let tag_val: String = toString(resolve_variant_index(s, ty.name, variant))

    // Alloca for the enum value, zero-initialize
    let ea: String = dn + ".ea"
    s = emit_line(s, "  " + ea + " = alloca " + enum_ty)
    // Zero-initialize to avoid garbage in unused payload slots
    s = emit_line(s, "  store " + enum_ty + " zeroinitializer, " + "ptr " + ea)
    // Store tag via GEP into field 0
    let tag_ptr: String = dn + ".tp"
    s = emit_line(s, "  " + tag_ptr + " = getelementptr inbounds " + enum_ty + ", " + "ptr " + ea + ", i32 0, i32 0")
    s = emit_line(s, "  store i64 " + tag_val + ", i64* " + tag_ptr)

    // Store payload values through bitcast: skip past the i64 tag (8 bytes).
    // All payload slots are i64-sized. Non-i64 values (double, i1) are stored
    // through type-punning (alloca+bitcast) to fit the i64 slot.
    let mut i: Int = 0
    for _ in 0..100 {
        if i >= len(payload) { break }
        let p: Value = payload[i]
        let mut pty: String = resolve_mir_type(p.ty)
        let mut pname: String = p.name
        // Type erasure: double → bitcast to i64 for the enum slot
        if pty == "double" {
            let bc: String = dn + ".fti" + toString(i)
            s = emit_line(s, "  " + bc + " = bitcast double " + pname + " to i64")
            pname = bc
            pty = "i64"
        }
        // Bitcast past tag to get payload pointer
        let bp: String = dn + ".bp" + toString(i)
        s = emit_line(s, "  " + bp + " = bitcast " + "ptr " + ea + " to ptr")
        let pp: String = dn + ".pp" + toString(i)
        let offset: String = toString(8 + i * 8)
        s = emit_line(s, "  " + pp + " = getelementptr inbounds i8, ptr " + bp + ", i64 " + offset)
        // Opaque pointers: store directly to ptr, no bitcast needed
        s = emit_line(s, "  store " + pty + " " + pname + ", ptr " + pp)
        i = i + 1
    }

    // Load the complete enum value
    s = emit_line(s, "  " + dn + " = load " + enum_ty + ", " + "ptr " + ea)
    return s
}

fn resolve_variant_index(st: EmitState, enum_name: String, variant: String) -> Int {
    let mut i: Int = 0
    for _ in 0..1000 {
        if i >= len(st.enum_infos) { break }
        let info: EnumInfo = st.enum_infos[i]
        if info.name == enum_name {
            let mut vi: Int = 0
            for _ in 0..1000 {
                if vi >= len(info.variants) { break }
                if info.variants[vi].name == variant {
                    return vi
                }
                vi = vi + 1
            }
        }
        i = i + 1
    }
    return 0
}

// ---------------------------------------------------------------------------
// EnumTag instruction
// ---------------------------------------------------------------------------

fn emit_enum_tag(st: EmitState, dest: Value, val: Value) -> EmitState {
    let mut s: EmitState = st
    let enum_ty: String = resolve_type(st, val.ty)
    let dn: String = dest.name
    // For Result/Option the tag field is i1; for enums it's i64.
    // Extract field 0 and zext to i64 if needed.
    if val.ty.kind == "result" || val.ty.kind == "option" {
        let raw_tag: String = dn + ".raw"
        s = emit_line(s, emit_extractvalue(raw_tag, enum_ty, val.name, "0"))
        s = emit_line(s, "  " + dn + " = zext i1 " + raw_tag + " to i64")
    } else {
        s = emit_line(s, emit_extractvalue(dn, enum_ty, val.name, "0"))
    }
    return s
}

// ---------------------------------------------------------------------------
// EnumPayload instruction
// ---------------------------------------------------------------------------

fn emit_enum_payload(st: EmitState, dest: Value, val: Value, variant: String) -> EmitState {
    let mut s: EmitState = st
    let enum_ty: String = resolve_type(st, val.ty)
    let dn: String = dest.name

    // For Result/Option: use extractvalue on the inner struct
    if val.ty.kind == "result" {
        // Result = {i1, {ok_ty, err_ty}}. Extract inner struct, then payload.
        let inner_r: String = dn + ".inner"
        s = emit_line(s, "  " + inner_r + " = extractvalue " + enum_ty + " " + val.name + ", 1")
        // Ok payload at index 0, Err payload at index 1
        let mut ok_ty: String = llvm_ptr()
        let mut err_ty: String = llvm_ptr()
        if len(val.ty.args) >= 2 {
            ok_ty = resolve_mir_type(val.ty.args[0])
            err_ty = resolve_mir_type(val.ty.args[1])
        }
        let inner_ty: String = "{ " + ok_ty + ", " + err_ty + " }"
        if variant == "Ok" {
            s = emit_line(s, "  " + dn + " = extractvalue " + inner_ty + " " + inner_r + ", 0")
        } else {
            s = emit_line(s, "  " + dn + " = extractvalue " + inner_ty + " " + inner_r + ", 1")
        }
        return s
    }
    if val.ty.kind == "option" {
        // Universal erasure: Option = {i1, ptr}. Extract ptr, then load.
        let ptr_name: String = dn + ".ptr"
        s = emit_line(s, "  " + ptr_name + " = extractvalue " + enum_ty + " " + val.name + ", 1")
        // Use destination type for load — avoids struct/enum name mismatches
        let inner_ty: String = resolve_type(st, dest.ty)
        s = emit_line(s, "  " + dn + " = load " + inner_ty + ", ptr " + ptr_name)
        return s
    }

    // Regular enum: byte-offset arithmetic (skip i64 tag).
    // If dest type is unknown (i64), look up actual payload type from enum info.
    let mut dest_ty: String = resolve_mir_type(dest.ty)
    if dest_ty == "i64" && dest.ty.kind == "unknown" {
        let enum_name: String = val.ty.name
        let mut ei2: Int = 0
        for _ in 0..1000 {
            if ei2 >= len(s.enum_infos) { break }
            let einfo: EnumInfo = s.enum_infos[ei2]
            if einfo.name == enum_name {
                let mut vi2: Int = 0
                for _ in 0..1000 {
                    if vi2 >= len(einfo.variants) { break }
                    let vinfo: EnumVariantInfo = einfo.variants[vi2]
                    if vinfo.name == variant {
                        if len(vinfo.payload_types) > 0 {
                            dest_ty = resolve_mir_type(vinfo.payload_types[0])
                        }
                        break
                    }
                    vi2 = vi2 + 1
                }
                break
            }
            ei2 = ei2 + 1
        }
    }
    // Correct struct→enum misclassification: if the payload type resolves to
    // %struct.X but a %enum.X type is registered, use the enum type.
    if dest_ty.starts_with("%struct.") {
        let payload_name: String = dest.ty.name
        if is_enum_type(s, payload_name) {
            dest_ty = "%enum." + payload_name
        }
    }
    s = emit_line(s, "  " + dn + ".ea = alloca " + enum_ty)
    s = emit_line(s, "  store " + enum_ty + " " + val.name + ", ptr " + dn + ".ea")
    s = emit_line(s, "  " + dn + ".pp = getelementptr inbounds i8, ptr " + dn + ".ea, i64 8")
    s = emit_line(s, "  " + dn + " = load " + dest_ty + ", ptr " + dn + ".pp")
    return s
}

// ---------------------------------------------------------------------------
// Option/Result wrapping
// ---------------------------------------------------------------------------

fn emit_wrap_some(st: EmitState, dest: Value, val: Value) -> EmitState {
    let mut s: EmitState = st
    let val_ty: String = resolve_type(st, val.ty)
    let dn: String = dest.name

    // Universal type erasure: all Option payloads stored via alloca + ptr.
    // Store value to alloca, then put the alloca ptr into {i1, ptr}.
    let ea: String = dn + ".ea"
    s = emit_line(s, "  " + ea + " = alloca " + val_ty)
    s = emit_line(s, "  store " + val_ty + " " + val.name + ", ptr " + ea)
    let opt_ty: String = llvm_option_type(llvm_ptr())
    let tag_name: String = dn + ".tag"
    s = emit_line(s, emit_insertvalue(tag_name, opt_ty, "undef", "1", "i1", "0"))
    s = emit_line(s, emit_insertvalue(dn, opt_ty, tag_name, ea, llvm_ptr(), "1"))
    return s
}

fn emit_wrap_none(st: EmitState, dest: Value, ty: MIRType) -> EmitState {
    // Universal erasure: all Option types are {i1, ptr}. None = {i1=0, null}.
    let opt_ty: String = llvm_option_type(llvm_ptr())
    let dn: String = dest.name
    let s: EmitState = emit_line(st, emit_insertvalue(dn, opt_ty, "undef", "0", "i1", "0"))
    return s
}

fn emit_wrap_ok(st: EmitState, dest: Value, val: Value) -> EmitState {
    let mut s: EmitState = st
    // Use dest's Result type args for correct ok/err layout
    let res_ty: String = resolve_mir_type(dest.ty)
    let val_ty: String = resolve_mir_type(val.ty)
    let mut ok_ty: String = val_ty
    let mut err_ty: String = llvm_ptr()
    if len(dest.ty.args) >= 2 {
        ok_ty = resolve_mir_type(dest.ty.args[0])
        err_ty = resolve_mir_type(dest.ty.args[1])
    }
    let inner_ty: String = "{ " + ok_ty + ", " + err_ty + " }"
    let dn: String = dest.name

    let tag_name: String = dn + ".tag"
    s = emit_line(s, emit_insertvalue(tag_name, res_ty, "undef", "1", "i1", "0"))
    let inner_name: String = dn + ".inner"
    s = emit_line(s, emit_insertvalue(inner_name, inner_ty, "undef", val.name, ok_ty, "0"))
    s = emit_line(s, emit_insertvalue(dn, res_ty, tag_name, inner_name, inner_ty, "1"))
    return s
}

fn emit_wrap_err(st: EmitState, dest: Value, val: Value) -> EmitState {
    let mut s: EmitState = st
    let res_ty: String = resolve_mir_type(dest.ty)
    let val_ty: String = resolve_mir_type(val.ty)
    let mut ok_ty: String = llvm_ptr()
    let mut err_ty: String = val_ty
    if len(dest.ty.args) >= 2 {
        ok_ty = resolve_mir_type(dest.ty.args[0])
        err_ty = resolve_mir_type(dest.ty.args[1])
    }
    let inner_ty: String = "{ " + ok_ty + ", " + err_ty + " }"
    let dn: String = dest.name

    let tag_name: String = dn + ".tag"
    s = emit_line(s, emit_insertvalue(tag_name, res_ty, "undef", "0", "i1", "0"))
    let inner_name: String = dn + ".inner"
    s = emit_line(s, emit_insertvalue(inner_name, inner_ty, "undef", val.name, err_ty, "1"))
    s = emit_line(s, emit_insertvalue(dn, res_ty, tag_name, inner_name, inner_ty, "1"))
    return s
}

// ---------------------------------------------------------------------------
// Unwrap instruction
// ---------------------------------------------------------------------------

fn emit_unwrap(st: EmitState, dest: Value, val: Value) -> EmitState {
    let mut s: EmitState = st
    let val_ty: String = resolve_mir_type(val.ty)
    let dn: String = dest.name
    if val.ty.kind == "option" {
        // Universal erasure: Option is {i1, ptr}. Extract ptr, then load.
        let ptr_name: String = dn + ".ptr"
        s = emit_line(s, emit_extractvalue(ptr_name, val_ty, val.name, "1"))
        // Use destination type for the load — avoids struct/enum name mismatches
        let inner_ty: String = resolve_type(st, dest.ty)
        s = emit_line(s, "  " + dn + " = load " + inner_ty + ", ptr " + ptr_name)
    } else {
        // Non-option: direct extractvalue
        s = emit_line(s, emit_extractvalue(dn, val_ty, val.name, "1"))
    }
    return s
}

// ---------------------------------------------------------------------------
// Call instruction
// ---------------------------------------------------------------------------

fn emit_mir_call(st: EmitState, dest: Value, fn_name: String, args: List<Value>) -> EmitState {
    let dn: String = dest.name

    // Built-in: print / println
    if fn_name == "print" {
        return emit_builtin_print(st, args)
    }
    if fn_name == "println" {
        return emit_builtin_println(st, args)
    }
    if fn_name == "len" {
        return emit_builtin_len(st, dest, args)
    }
    if fn_name == "toString" {
        return emit_builtin_tostring(st, dest, args)
    }
    if fn_name == "str" {
        return emit_builtin_tostring(st, dest, args)
    }
    if fn_name == "int" {
        return emit_builtin_int(st, dest, args)
    }
    if fn_name == "float" {
        return emit_builtin_float(st, dest, args)
    }

    // Range field extraction (counter-based for-loops)
    if fn_name == "__mn_range_start" {
        let mut s: EmitState = st
        s = emit_line(s, "  " + dn + " = extractvalue { i64, i64 } " + args[0].name + ", 0")
        return s
    }
    if fn_name == "__mn_range_end" {
        let mut s: EmitState = st
        s = emit_line(s, "  " + dn + " = extractvalue { i64, i64 } " + args[0].name + ", 1")
        return s
    }

    // String builtins
    if fn_name == "split" {
        let mut s: EmitState = st
        let arg_str: String = llvm_string() + " " + args[0].name + ", " + llvm_string() + " " + args[1].name
        s = emit_line(s, emit_call_ir(dn, llvm_list_rt(), "__mn_str_split", arg_str))
        return s
    }
    if fn_name == "contains" {
        let mut s: EmitState = st
        let arg_str: String = llvm_string() + " " + args[0].name + ", " + llvm_string() + " " + args[1].name
        s = emit_line(s, emit_call_ir(dn, llvm_bool(), "__mn_str_contains", arg_str))
        return s
    }
    if fn_name == "replace" {
        let mut s: EmitState = st
        let arg_str: String = llvm_string() + " " + args[0].name + ", " + llvm_string() + " " + args[1].name + ", " + llvm_string() + " " + args[2].name
        s = emit_line(s, emit_call_ir(dn, llvm_string(), "__mn_str_replace", arg_str))
        return s
    }
    if fn_name == "byte_at" {
        let mut s: EmitState = st
        let arg_str: String = llvm_string() + " " + args[0].name + ", i64 " + args[1].name
        s = emit_line(s, emit_call_ir(dn, llvm_int(), "__mn_str_byte_at", arg_str))
        return s
    }
    // join(sep, list) → String via C runtime. List passed by pointer.
    if fn_name == "join" {
        let mut s: EmitState = st
        // Alloca the list and pass pointer (C runtime expects MnList*)
        let la: String = "%" + strip_percent(dn) + ".la"
        s = emit_line(s, "  " + la + " = alloca " + llvm_list_rt())
        s = emit_line(s, "  store " + llvm_list_rt() + " " + args[1].name + ", ptr " + la)
        let arg_str: String = llvm_string() + " " + args[0].name + ", ptr " + la
        s = emit_line(s, emit_call_ir(dn, llvm_string(), "__mn_str_join", arg_str))
        return s
    }

    // List push: extract to helper to avoid return-inside-if bug
    if fn_name == "push" {
        return emit_list_push_call(st, dest, args)
    }

    // Synthetic struct constructor: __new_<StructName>(field_values...)
    // Use replace to remove the "__new_" prefix instead of substr
    // (substr has off-by-one issues in the compiled binary)
    if fn_name.contains("__new_") {
        let struct_name: String = fn_name.replace("__new_", "")
        let struct_ty: MIRType = mir_struct(struct_name)
        return emit_struct_init_from_values(st, dest, struct_ty, args)
    }

    // Resolve operands for all other calls
    let mut s: EmitState = st

    // String methods: dispatched to __mn_str_<method> runtime functions
    if len(args) >= 1 {
        let first_arg: Value = args[0]
        if first_arg.ty.kind == "string" {
            let s0: String = first_arg.name
            if fn_name == "contains" {
                s = emit_line(s, emit_call_ir(dn, llvm_bool(), "__mn_str_contains", llvm_string() + " " + s0 + ", " + llvm_string() + " " + args[1].name))
                return s
            }
            if fn_name == "starts_with" {
                s = emit_line(s, emit_call_ir(dn, llvm_bool(), "__mn_str_starts_with", llvm_string() + " " + s0 + ", " + llvm_string() + " " + args[1].name))
                return s
            }
            if fn_name == "ends_with" {
                s = emit_line(s, emit_call_ir(dn, llvm_bool(), "__mn_str_ends_with", llvm_string() + " " + s0 + ", " + llvm_string() + " " + args[1].name))
                return s
            }
            if fn_name == "find" {
                s = emit_line(s, emit_call_ir(dn, llvm_int(), "__mn_str_find", llvm_string() + " " + s0 + ", " + llvm_string() + " " + args[1].name))
                return s
            }
            if fn_name == "char_at" {
                s = emit_line(s, emit_call_ir(dn, llvm_string(), "__mn_str_char_at", llvm_string() + " " + s0 + ", i64 " + args[1].name))
                return s
            }
            if fn_name == "substr" {
                if len(args) >= 3 {
                    s = emit_line(s, emit_call_ir(dn, llvm_string(), "__mn_str_substr", llvm_string() + " " + s0 + ", i64 " + args[1].name + ", i64 " + args[2].name))
                    return s
                }
            }
            if fn_name == "to_upper" {
                s = emit_line(s, emit_call_ir(dn, llvm_string(), "__mn_str_to_upper", llvm_string() + " " + s0))
                return s
            }
            if fn_name == "to_lower" {
                s = emit_line(s, emit_call_ir(dn, llvm_string(), "__mn_str_to_lower", llvm_string() + " " + s0))
                return s
            }
            if fn_name == "replace" {
                if len(args) >= 3 {
                    s = emit_line(s, emit_call_ir(dn, llvm_string(), "__mn_str_replace", llvm_string() + " " + s0 + ", " + llvm_string() + " " + args[1].name + ", " + llvm_string() + " " + args[2].name))
                    return s
                }
            }
        }
    }

    // Look up registered function parameter types (more reliable than MIR)
    let fn_opt_pre: Option<FnEntry> = find_function(s, fn_name)
    let mut reg_param_types: List<String> = []
    match fn_opt_pre {
        Some(fe) => { reg_param_types = fe.param_types },
        _ => {}
    }

    // Build args with byref: large struct args → alloca + pass pointer
    let mut args_str: String = ""
    let mut j: Int = 0
    for _ in 0..1000 {
        if j >= len(args) { break }
        let mut aty: String = resolve_mir_type(args[j].ty)
        let mut an: String = args[j].name
        // Use registered param type when available
        if j < len(reg_param_types) {
            let rpt: String = reg_param_types[j]
            if rpt != aty && rpt != "i64" {
                if aty.starts_with("{ i1, ptr") && rpt.starts_with("{ i1,") {
                    an = "zeroinitializer"
                }
                if aty.starts_with("%enum.") && rpt.starts_with("%enum.") && aty != rpt {
                    let rc_a: String = "%ecast" + toString(s.counter)
                    s.counter = s.counter + 1
                    s = emit_line(s, "  " + rc_a + " = alloca " + rpt)
                    s = emit_line(s, "  store " + aty + " " + an + ", ptr " + rc_a)
                    let rc_ld: String = "%ecast_ld" + toString(s.counter)
                    s.counter = s.counter + 1
                    s = emit_line(s, "  " + rc_ld + " = load " + rpt + ", ptr " + rc_a)
                    an = rc_ld
                }
                aty = rpt
            }
        }
        // Byref: large struct args → store to alloca, pass pointer
        let mut pass_ty: String = aty
        let mut pass_name: String = an
        if is_byref_type(aty) {
            let ba: String = "%barg" + toString(s.counter)
            s.counter = s.counter + 1
            s = emit_line(s, "  " + ba + " = alloca " + aty)
            s = emit_line(s, "  store " + aty + " " + an + ", ptr " + ba)
            pass_ty = "ptr"
            pass_name = ba
        }
        if j > 0 {
            args_str = args_str + ", " + pass_ty + " " + pass_name
        } else {
            args_str = pass_ty + " " + pass_name
        }
        j = j + 1
    }

    // Look up return type and handle sret for large struct returns
    let fn_opt: Option<FnEntry> = find_function(s, fn_name)
    match fn_opt {
        Some(fe) => {
            if fe.ret_type == "void" {
                return emit_line(s, emit_call_void(fn_name, args_str))
            }
            // sret: large struct returns via hidden pointer
            if is_byref_type(fe.ret_type) {
                let sret_a: String = "%sret" + toString(s.counter)
                s.counter = s.counter + 1
                s = emit_line(s, "  " + sret_a + " = alloca " + fe.ret_type)
                s = emit_line(s, "  store " + fe.ret_type + " zeroinitializer, ptr " + sret_a)
                let sret_arg: String = "ptr sret(" + fe.ret_type + ") " + sret_a
                let full_args: String = if len(args_str) > 0 { sret_arg + ", " + args_str } else { sret_arg }
                s = emit_line(s, "  call void @" + fn_name + "(" + full_args + ")")
                s = emit_line(s, "  " + dn + " = load " + fe.ret_type + ", ptr " + sret_a)
                return s
            }
            s = emit_line(s, emit_call_ir(dn, fe.ret_type, fn_name, args_str))
            return s
        },
        _ => {
            let ret_ty: String = resolve_mir_type(dest.ty)
            if ret_ty == "void" {
                return emit_line(s, emit_call_void(fn_name, args_str))
            }
            s = emit_line(s, emit_call_ir(dn, ret_ty, fn_name, args_str))
            return s
        }
    }
}

// ---------------------------------------------------------------------------
// Built-in function emission
// ---------------------------------------------------------------------------

fn emit_builtin_print(st: EmitState, args: List<Value>) -> EmitState {
    if len(args) == 0 {
        return emit_line(st, emit_call_void("printf", "ptr @.newline"))
    }
    let arg: Value = args[0]
    let mut s: EmitState = st
    let an: String = arg.name

    if arg.ty.kind == "string" {
        return emit_line(s, emit_call_void("__mn_str_print", llvm_string() + " " + an))
    }
    if arg.ty.kind == "float" {
        return emit_line(s, "  call i32 (ptr, ...) @printf(ptr @.fmt_float, double " + an + ")")
    }
    if arg.ty.kind == "int" {
        return emit_line(s, "  call i32 (ptr, ...) @printf(ptr @.fmt_int, i64 " + an + ")")
    }
    if arg.ty.kind == "bool" {
        return emit_line(s, "  call i32 (ptr, ...) @printf(ptr @.fmt_int, i64 " + an + ")")
    }
    // Unknown type: assume string
    return emit_line(s, emit_call_void("__mn_str_print", llvm_string() + " " + an))
}

fn emit_builtin_println(st: EmitState, args: List<Value>) -> EmitState {
    if len(args) == 0 {
        return emit_line(st, emit_call_void("printf", "ptr @.newline"))
    }
    let arg: Value = args[0]
    let mut s: EmitState = st
    let an: String = arg.name

    if arg.ty.kind == "string" {
        return emit_line(s, emit_call_void("__mn_str_println", llvm_string() + " " + an))
    }
    if arg.ty.kind == "float" {
        return emit_line(s, "  call i32 (ptr, ...) @printf(ptr @.fmt_float_nl, double " + an + ")")
    }
    if arg.ty.kind == "int" {
        return emit_line(s, "  call i32 (ptr, ...) @printf(ptr @.fmt_int_nl, i64 " + an + ")")
    }
    if arg.ty.kind == "bool" {
        return emit_line(s, "  call i32 (ptr, ...) @printf(ptr @.fmt_int_nl, i64 " + an + ")")
    }
    // Unknown type: assume string (common from str()/toString() calls)
    return emit_line(s, emit_call_void("__mn_str_println", llvm_string() + " " + an))
}

fn emit_builtin_len(st: EmitState, dest: Value, args: List<Value>) -> EmitState {
    if len(args) == 0 { return st }
    let mut s: EmitState = st
    let an: String = args[0].name
    let dn: String = dest.name

    if args[0].ty.kind == "string" {
        s = emit_line(s, emit_call_ir(dn, llvm_int(), "__mn_str_len", llvm_string() + " " + an))
    } else {
        // __mn_list_len expects a pointer; alloca+store the list value first
        let tmp: String = dn + ".lp"
        let lt: String = llvm_list_rt()
        s = emit_line(s, "  " + tmp + " = alloca " + lt)
        s = emit_line(s, "  store " + lt + " " + an + ", " + "ptr " + tmp)
        s = emit_line(s, emit_call_ir(dn, llvm_int(), "__mn_list_len", "ptr " + tmp))
    }
    return s
}

fn emit_builtin_tostring(st: EmitState, dest: Value, args: List<Value>) -> EmitState {
    if len(args) == 0 { return st }
    let mut s: EmitState = st
    let an: String = args[0].name
    let dn: String = dest.name

    if args[0].ty.kind == "string" {
        return emit_copy(s, dest, args[0])
    }
    if args[0].ty.kind == "bool" {
        s = emit_line(s, emit_call_ir(dn, llvm_string(), "__mn_str_from_bool", "i1 " + an))
    } else {
    if args[0].ty.kind == "float" {
        s = emit_line(s, emit_call_ir(dn, llvm_string(), "__mn_str_from_float", "double " + an))
    } else {
        s = emit_line(s, emit_call_ir(dn, llvm_string(), "__mn_str_from_int", "i64 " + an))
    }}
    return s
}

fn emit_builtin_int(st: EmitState, dest: Value, args: List<Value>) -> EmitState {
    if len(args) == 0 { return st }
    let mut s: EmitState = st
    let an: String = args[0].name
    let dn: String = dest.name

    if args[0].ty.kind == "float" {
        s = emit_line(s, "  " + dn + " =fptosi double " + an + " to i64")
    } else {
    if args[0].ty.kind == "int" {
        return emit_copy(s, dest, args[0])
    } else {
        s = emit_line(s, emit_call_ir(dn, llvm_int(), "__mn_str_to_int", llvm_string() + " " + an))
    }}
    return s
}

fn emit_builtin_float(st: EmitState, dest: Value, args: List<Value>) -> EmitState {
    if len(args) == 0 { return st }
    let mut s: EmitState = st
    let an: String = args[0].name
    let dn: String = dest.name

    if args[0].ty.kind == "int" {
        s = emit_line(s, "  " + dn + " =sitofp i64 " + an + " to double")
    } else {
    if args[0].ty.kind == "float" {
        return emit_copy(s, dest, args[0])
    } else {
        s = emit_line(s, emit_call_ir(dn, llvm_float(), "__mn_str_to_float", llvm_string() + " " + an))
    }}
    return s
}

// ---------------------------------------------------------------------------
// Return instruction
// ---------------------------------------------------------------------------

fn emit_mir_return(st: EmitState, val_opt: Option<Value>) -> EmitState {
    match val_opt {
        Some(val) => {
            let ty: String = st.current_ret_type
            if ty == "void" {
                return emit_line(st, emit_ret_void())
            }
            // If using sret (large struct return), store to sret pointer and ret void
            if is_byref_type(ty) {
                let mut s: EmitState = emit_line(st, "  store " + ty + " " + val.name + ", ptr %__sret__")
                return emit_line(s, emit_ret_void())
            }
            return emit_line(st, emit_ret(ty, val.name))
        },
        _ => {
            // For non-void functions, emit zeroinitializer return (dead code from
            // match arms that all terminate). For void functions, emit ret void.
            let ret_ty: String = st.current_ret_type
            if ret_ty != "void" {
                return emit_line(st, "  ret " + ret_ty + " zeroinitializer")
            }
            return emit_line(st, emit_ret_void())
        }
    }
}

// ---------------------------------------------------------------------------
// Switch instruction
// ---------------------------------------------------------------------------

fn emit_mir_switch(st: EmitState, tag: Value, cases: List<SwitchCase>, default_bb: String) -> EmitState {
    let mut s: EmitState = emit_line(st, emit_switch_hdr(tag.name, default_bb))
    // Resolve the enum name from the tag value's type for variant index lookup
    let enum_name: String = tag.ty.name

    let mut i: Int = 0
    for _ in 0..1000 {
        if i >= len(cases) {
            s = emit_line(s, "  ]")
            return s
        }
        let c: SwitchCase = cases[i]
        // If the case value is a variant name (not a number), resolve to integer index
        // This mirrors the Python emitter's _vtag() method
        let mut case_val: String = c.tag_value
        if len(case_val) > 0 {
            let first_ch: Int = c.tag_value.byte_at(0)
            // If not a digit (0-9) and not '-', it's a variant name → resolve to index
            if first_ch < 48 || first_ch > 57 {
                if first_ch != 45 {
                    // Hardcoded indices for Result/Option builtins
                    if case_val == "Ok" || case_val == "Some" {
                        case_val = "1"
                    } else if case_val == "Err" || case_val == "None" {
                        case_val = "0"
                    } else {
                        case_val = toString(resolve_variant_index(s, enum_name, case_val))
                    }
                }
            }
        }
        s = emit_line(s, emit_switch_case(case_val, c.block_label))
        i = i + 1
    }
    s = emit_line(s, "  ]")
    return s
}

// ---------------------------------------------------------------------------
// Agent instructions
// ---------------------------------------------------------------------------

fn emit_agent_spawn(st: EmitState, dest: Value, ty: MIRType, args: List<Value>) -> EmitState {
    let dn: String = dest.name
    let mut s: EmitState = st
    // Call agent spawn runtime function
    s = emit_line(s, emit_call_ir(dn, "ptr", "__mn_agent_spawn", "ptr null, ptr null"))
    return s
}

fn emit_agent_send(st: EmitState, ag: Value, channel: String, val: Value) -> EmitState {
    return emit_line(st, emit_call_void("__mn_agent_send", "ptr " + ag.name + ", ptr null, ptr null"))
}

fn emit_agent_sync(st: EmitState, dest: Value, ag: Value, channel: String) -> EmitState {
    let dn: String = dest.name
    let s2: EmitState = emit_line(st, emit_call_ir(dn, "ptr", "__mn_agent_sync", "ptr " + ag.name + ", ptr null"))
    return s2
}

// ---------------------------------------------------------------------------
// Signal instructions
// ---------------------------------------------------------------------------

fn emit_signal_init(st: EmitState, dest: Value, ty: MIRType, val: Value) -> EmitState {
    let dn: String = dest.name
    let s2: EmitState = emit_line(st, emit_call_ir(dn, "ptr", "__mn_signal_new", "ptr null"))
    return s2
}

fn emit_signal_get(st: EmitState, dest: Value, sig: Value) -> EmitState {
    let dn: String = dest.name
    let s2: EmitState = emit_line(st, emit_call_ir(dn, "ptr", "__mn_signal_get", "ptr " + sig.name))
    return s2
}

fn emit_signal_set(st: EmitState, sig: Value, val: Value) -> EmitState {
    return emit_line(st, emit_call_void("__mn_signal_set", "ptr " + sig.name + ", ptr null"))
}

// ---------------------------------------------------------------------------
// StreamOp instruction
// ---------------------------------------------------------------------------

fn emit_stream_op(st: EmitState, dest: Value, kind: StreamOpKind, source: Value, args: List<Value>) -> EmitState {
    let mut s: EmitState = st
    let dn: String = dest.name
    // Stream operations are runtime-dispatched; minimal LLVM lowering
    let s2: EmitState = emit_line(s, "  " + dn + " =bitcast ptr " + source.name + " to ptr")
    return s2
}

// ---------------------------------------------------------------------------
// InterpConcat instruction
// ---------------------------------------------------------------------------

fn emit_interp_concat(st: EmitState, dest: Value, parts: List<Value>) -> EmitState {
    if len(parts) == 0 {
        return emit_const(st, dest, mir_string(), "")
    }
    if len(parts) == 1 {
        return emit_copy(st, dest, parts[0])
    }

    // Concatenate parts left-to-right using __mn_str_concat
    let mut s: EmitState = st
    let dn: String = dest.name

    let mut acc: String = parts[0].name

    let mut i: Int = 1
    for _ in 0..1000 {
        if i >= len(parts) {
            break
        }
        let tmp: String = dn + ".c" + toString(i)
        s = emit_line(s, emit_call_ir(tmp, llvm_string(), "__mn_str_concat", llvm_string() + " " + acc + ", " + llvm_string() + " " + parts[i].name))
        acc = tmp
        i = i + 1
    }
    return s
}

// ---------------------------------------------------------------------------
// Phi instruction
// ---------------------------------------------------------------------------

fn emit_mir_phi(st: EmitState, dest: Value, incoming: List<PhiEntry>) -> EmitState {
    let mut ty: String = resolve_type(st, dest.ty)
    let dn: String = dest.name

    let mut s: EmitState = st
    let mut skip: Bool = false
    if len(incoming) == 0 { skip = true }
    if ty == "void" { skip = true }
    // For Phis with i64 type (unresolved): recover the actual type from
    // the incoming values. Uses a flag instead of break to avoid the
    // Python lowerer's control flow bug that swallows break-inside-if.
    if ty == "i64" && len(incoming) > 0 {
        let mut found: Bool = false
        let mut ci: Int = 0
        for _ in 0..100 {
            if ci >= len(incoming) { ci = 999 }
            if !found && ci < len(incoming) {
                let inc_ty: String = resolve_type(st, incoming[ci].val.ty)
                if inc_ty != "i64" && inc_ty != "void" {
                    ty = inc_ty
                    found = true
                }
            }
            ci = ci + 1
        }
    }

    if !skip {
        let mut phi_str: String = "  " + dn + " = phi " + ty + " "
        let mut i: Int = 0
        for _ in 0..1000 {
            if i >= len(incoming) { break }
            let e: PhiEntry = incoming[i]
            if i > 0 {
                phi_str = phi_str + ", "
            }
            phi_str = phi_str + "[ " + e.val.name + ", %" + e.block_label + " ]"
            i = i + 1
        }
        s = emit_line(s, phi_str)
    }
    return s
}

// ---------------------------------------------------------------------------
// MIR basic block emission
// ---------------------------------------------------------------------------

fn emit_mir_basic_block(st: EmitState, bb: BasicBlock) -> EmitState {
    let mut s: EmitState = emit_line(st, bb.label + ":")
    let mut i: Int = 0
    for _ in 0..100000 {
        if i >= len(bb.instructions) { return s }
        let inst: Instruction = bb.instructions[i]
        s = emit_mir_instruction(s, inst)
        i = i + 1
    }
    return s
}

// ---------------------------------------------------------------------------
// MIR function emission
// ---------------------------------------------------------------------------

fn emit_mir_function(st: EmitState, f: MIRFunction) -> EmitState {
    // Resolve return type
    let mut ret_ty: String = resolve_mir_type(f.return_type)
    if ret_ty.starts_with("%struct.") {
        let ret_name: String = f.return_type.name
        if is_enum_type(st, ret_name) {
            ret_ty = "%enum." + ret_name
        }
    }

    // Determine byref/sret: large structs passed by pointer
    let use_sret: Bool = is_byref_type(ret_ty) && f.name != "main"

    // Build parameter list with byref adjustments
    let mut params_str: String = ""
    let mut param_types: List<String> = []
    // If sret, first param is the return pointer
    if use_sret {
        params_str = "ptr sret(" + ret_ty + ") %__sret__"
    }
    let mut pi: Int = 0
    for _ in 0..1000 {
        if pi >= len(f.params) { break }
        let p: MIRParam = f.params[pi]
        let pty: String = resolve_mir_type(p.ty)
        param_types.push(pty)
        let need_sep: Bool = pi > 0 || use_sret
        let sep: String = if need_sep { ", " } else { "" }
        if is_byref_type(pty) {
            // Large param: pass by pointer
            params_str = params_str + sep + "ptr %" + p.name + ".byref"
        } else {
            params_str = params_str + sep + pty + " %" + p.name
        }
        pi = pi + 1
    }

    // Register function (with original types for caller resolution)
    let entry: FnEntry = new_fn_entry(f.name, ret_ty, param_types)
    let mut s: EmitState = st
    s.functions.push(entry)

    // Track current function's return type and sret flag
    s.current_ret_type = ret_ty

    // Emit function header
    let fn_name: String = strip_percent(f.name)
    let is_lambda: Bool = fn_name != f.name
    let visibility: String = if is_lambda { "define internal" } else { "define" }
    let abi_ret: String = if use_sret { "void" } else { ret_ty }
    s = emit_line(s, visibility + " " + abi_ret + " @" + fn_name + "(" + params_str + ") {")

    // Emit basic blocks — with byref param fixup in the entry block.
    // The MIR's entry block has Store(param_alloca, param_value) for each param.
    // For byref params, param_value is a POINTER (not the actual value).
    // We need to emit a load from the pointer before the store.
    // Strategy: emit the entry block label, then byref loads, then regular block.
    let mut bi: Int = 0
    for _ in 0..100000 {
        if bi >= len(f.blocks) {
            s = emit_line(s, "}")
            return emit_blank(s)
        }
        let bb: BasicBlock = f.blocks[bi]
        // For the first block (entry), add byref parameter loads
        if bi == 0 {
            s = emit_line(s, bb.label + ":")
            // Emit byref loads: for each byref param, alloca + load from ptr + store
            let mut pi3: Int = 0
            for _ in 0..100 {
                if pi3 >= len(f.params) { break }
                let p: MIRParam = f.params[pi3]
                let pty: String = resolve_mir_type(p.ty)
                if is_byref_type(pty) {
                    s = emit_line(s, "  %" + p.name + ".addr = alloca " + pty)
                    s = emit_line(s, "  %" + p.name + ".bp = load " + pty + ", ptr %" + p.name + ".byref")
                    s = emit_line(s, "  store " + pty + " %" + p.name + ".bp, ptr %" + p.name + ".addr")
                }
                pi3 = pi3 + 1
            }
            // Build set of byref param names for skip detection
            let mut byref_names: List<String> = []
            let mut pn: Int = 0
            for _ in 0..100 {
                if pn >= len(f.params) { break }
                let pp: MIRParam = f.params[pn]
                let ppty: String = resolve_mir_type(pp.ty)
                if is_byref_type(ppty) {
                    byref_names.push(pp.name)
                }
                pn = pn + 1
            }
            // Emit block instructions, skipping Alloca+Store ONLY for byref params
            let mut ii: Int = 0
            for _ in 0..100000 {
                if ii >= len(bb.instructions) { break }
                let inst: Instruction = bb.instructions[ii]
                let mut should_skip: Bool = false
                match inst {
                    Alloca(dest, ty) => {
                        should_skip = is_name_in_byref(byref_names, dest.name)
                    },
                    Store(ptr, val) => {
                        should_skip = is_name_in_byref(byref_names, ptr.name)
                    },
                    _ => {}
                }
                if !should_skip {
                    s = emit_mir_instruction(s, inst)
                }
                ii = ii + 1
            }
        } else {
            s = emit_mir_basic_block(s, bb)
        }
        bi = bi + 1
    }

    s = emit_line(s, "}")
    return emit_blank(s)
}

// ---------------------------------------------------------------------------
// Format constants (printf format strings)
// ---------------------------------------------------------------------------

fn emit_format_constants(st: EmitState) -> EmitState {
    let mut s: EmitState = st
    s = emit_line(s, "@.newline = private constant [2 x i8] c\"\\0A\\00\"")
    s = emit_line(s, "@.fmt_int = private constant [4 x i8] c\"%ld\\00\"")
    s = emit_line(s, "@.fmt_int_nl = private constant [5 x i8] c\"%ld\\0A\\00\"")
    s = emit_line(s, "@.fmt_float = private constant [4 x i8] c\"%lf\\00\"")
    s = emit_line(s, "@.fmt_float_nl = private constant [5 x i8] c\"%lf\\0A\\00\"")
    return emit_blank(s)
}

// ---------------------------------------------------------------------------
// Public API: emit_mir_module
// ---------------------------------------------------------------------------

fn str_join(sep: String, parts: List<String>) -> String {
    return join(sep, parts)
}

pub fn emit_mir_module(module: MIRModule, module_name: String) -> String {
    let mut st: EmitState = new_emit_state(module_name)

    // Module header
    st = emit_line(st, "; ModuleID = '" + module_name + "'")
    st = emit_line(st, "source_filename = \"" + module_name + "\"")
    st = emit_blank(st)

    // Format string constants
    st = emit_format_constants(st)

    // Runtime declarations
    st = declare_all_runtime(st)

    // Register struct types
    let mut si: Int = 0
    for _ in 0..1000 {
        if si >= len(module.structs) { break }
        st = register_mir_struct(st, module.structs[si])
        si = si + 1
    }

    // Register enum types
    let mut ei: Int = 0
    for _ in 0..1000 {
        if ei >= len(module.enums) { break }
        st = register_mir_enum(st, module.enums[ei])
        ei = ei + 1
    }

    if len(module.structs) > 0 { st = emit_blank(st) }
    if len(module.enums) > 0 { st = emit_blank(st) }

    // Declare extern functions
    let mut xi: Int = 0
    for _ in 0..1000 {
        if xi >= len(module.extern_fns) { break }
        st = declare_mir_extern(st, module.extern_fns[xi])
        xi = xi + 1
    }
    if len(module.extern_fns) > 0 { st = emit_blank(st) }

    // Forward-declare all functions (for mutual recursion)
    let mut di: Int = 0
    for _ in 0..100000 {
        if di >= len(module.functions) { break }
        let f: MIRFunction = module.functions[di]
        let ret_ty: String = resolve_mir_type(f.return_type)
        let mut fparams: String = ""
        let mut fpi: Int = 0
        for _ in 0..1000 {
            if fpi >= len(f.params) { break }
            let fp: MIRParam = f.params[fpi]
            let fpty: String = resolve_mir_type(fp.ty)
            if fpi > 0 {
                fparams = fparams + ", " + fpty
            } else {
                fparams = fpty
            }
            fpi = fpi + 1
        }
        let mut fn_types: List<String> = []
        let mut fti: Int = 0
        for _ in 0..1000 {
            if fti >= len(f.params) { break }
            fn_types.push(resolve_mir_type(f.params[fti].ty))
            fti = fti + 1
        }
        let fe: FnEntry = new_fn_entry(f.name, ret_ty, fn_types)
        st.functions.push(fe)
        di = di + 1
    }

    // Emit function bodies
    let total_fns: Int = len(module.functions)
    let mut fi: Int = 0
    for _ in 0..100000 {
        if fi >= total_fns { break }
        let f: MIRFunction = module.functions[fi]
        if len(f.blocks) > 0 {
            st = emit_mir_function(st, f)
        }
        fi = fi + 1
    }

    // Append string globals
    let mut gi: Int = 0
    for _ in 0..1000000 {
        if gi >= len(st.str_globals) { break }
        st = emit_line(st, st.str_globals[gi])
        gi = gi + 1
    }
    // Join all lines with newline
    let result: String = str_join("\n", st.lines)
    return result
}

// ---------------------------------------------------------------------------
// Streaming API: emit module header, then individual functions
// ---------------------------------------------------------------------------

pub fn emit_header(module: MIRModule, module_name: String) -> EmitState {
    let mut st: EmitState = new_emit_state(module_name)

    st = emit_line(st, "; ModuleID = '" + module_name + "'")
    st = emit_line(st, "source_filename = \"" + module_name + "\"")
    st = emit_blank(st)
    st = emit_format_constants(st)
    st = declare_all_runtime(st)

    let mut si: Int = 0
    for _ in 0..1000 {
        if si >= len(module.structs) { break }
        st = register_mir_struct(st, module.structs[si])
        si = si + 1
    }
    let mut ei: Int = 0
    for _ in 0..1000 {
        if ei >= len(module.enums) { break }
        st = register_mir_enum(st, module.enums[ei])
        ei = ei + 1
    }
    if len(module.structs) > 0 { st = emit_blank(st) }
    if len(module.enums) > 0 { st = emit_blank(st) }

    let mut xi: Int = 0
    for _ in 0..1000 {
        if xi >= len(module.extern_fns) { break }
        st = declare_mir_extern(st, module.extern_fns[xi])
        xi = xi + 1
    }
    if len(module.extern_fns) > 0 { st = emit_blank(st) }

    return st
}

pub fn register_fn_sig(st: EmitState, f: MIRFunction) -> EmitState {
    let mut ret_ty: String = resolve_mir_type(f.return_type)
    if ret_ty.starts_with("%struct.") {
        if is_enum_type(st, f.return_type.name) {
            ret_ty = "%enum." + f.return_type.name
        }
    }
    let fn_types: List<String> = []
    let fe: FnEntry = new_fn_entry(f.name, ret_ty, fn_types)
    let mut s: EmitState = st
    s.functions.push(fe)
    return s
}

pub fn emit_one_fn(st: EmitState, f: MIRFunction) -> EmitState {
    return emit_mir_function(st, f)
}

pub fn emit_finalize(st: EmitState) -> String {
    let nlines: Int = len(st.lines)
    let mut result: String = ""
    let mut li: Int = 0
    for _ in 0..1000000 {
        if li >= nlines { break }
        result = result + st.lines[li] + "\n"
        li = li + 1
    }
    let mut gi: Int = 0
    for _ in 0..1000000 {
        if gi >= len(st.str_globals) { break }
        result = result + st.str_globals[gi] + "\n"
        gi = gi + 1
    }
    return result
}

// ===== main.mn =====
// main.mn — Compiler driver for the Mapanare self-hosted compiler.
// Wires the pipeline: source -> parse -> check -> lower -> emit_llvm -> LLVM IR.


// ---------------------------------------------------------------------------
// Compilation result
// ---------------------------------------------------------------------------

struct CompileResult {
    success: Bool,
    ir_text: String,
    errors: List<SemanticError>
}

fn new_compile_result(success: Bool, ir_text: String, errors: List<SemanticError>) -> CompileResult {
    return new CompileResult { success: success, ir_text: ir_text, errors: errors }
}

// ---------------------------------------------------------------------------
// version — return the compiler version string
// ---------------------------------------------------------------------------

fn version() -> String {
    return "mapanare 2.1.0"
}

// ---------------------------------------------------------------------------
// compile — run the full pipeline on a source string
// ---------------------------------------------------------------------------

fn compile(source: String, filename: String) -> CompileResult {
    // Stage 1: parse
    let program: Program = parse(source, filename)

    // Stage 2: semantic analysis
    let errors: List<SemanticError> = check(program, filename)
    if len(errors) > 0 {
        return new_compile_result(false, "", errors)
    }

    // Stage 3: lower AST to MIR
    let mir_module: MIRModule = lower(program, filename)

    // Stage 4: emit LLVM IR from MIR
    let ir_text: String = emit_mir_module(mir_module, filename)
    let no_errors: List<SemanticError> = []
    return new_compile_result(true, ir_text, no_errors)
}

// ---------------------------------------------------------------------------
// format_error — format a SemanticError for display
// ---------------------------------------------------------------------------

fn format_error(err: SemanticError) -> String {
    return err.filename + ":" + toString(err.line) + ":" + toString(err.column) + ": error: " + err.message
}

// ---------------------------------------------------------------------------
// compile_and_print — compile and print result or errors to stdout
// ---------------------------------------------------------------------------

fn compile_and_print(source: String, filename: String) -> CompileResult {
    let cr: CompileResult = compile(source, filename)

    if cr.success {
        print(cr.ir_text)
    } else {
        for i in 0..len(cr.errors) {
            let err: SemanticError = cr.errors[i]
            print(format_error(err))
        }
    }
    return cr
}
