    match e { MapLit(m) => { return m }, _ => { let empty: List<MapEntry> = []; return empty } }
}

// Construct
pub fn expr_construct_name(e: Expr) -> String {
    match e { Construct(n, _) => { return n }, _ => { return "" } }
}
pub fn expr_construct_fields(e: Expr) -> List<FieldInit> {
    match e { Construct(_, f) => { return f }, _ => { let empty: List<FieldInit> = []; return empty } }
}

// SomeWrap / OkWrap / ErrWrap — single inner Expr
pub fn expr_wrap_inner(e: Expr) -> Expr {
    match e {
        SomeWrap(x) => { return x },
        OkWrap(x) => { return x },
        ErrWrap(x) => { return x },
        _ => { return Expr::NoneLit }
    }
}

// SignalVal
pub fn expr_signal_inner(e: Expr) -> Expr {
    match e { SignalVal(x, _) => { return x }, _ => { return Expr::NoneLit } }
}
pub fn expr_signal_computed(e: Expr) -> Bool {
    match e { SignalVal(_, c) => { return c }, _ => { return false } }
}

// Assign
pub fn expr_assign_target(e: Expr) -> Expr {
    match e { Assign(t, _, _) => { return t }, _ => { return Expr::NoneLit } }
}
