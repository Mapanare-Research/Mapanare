// If
pub fn expr_if_cond(e: Expr) -> Expr {
    match e { If(c, _, _) => { return c }, _ => { return Expr::NoneLit } }
}
pub fn expr_if_then(e: Expr) -> Block {
    match e { If(_, b, _) => { return b }, _ => { let s: List<Stmt> = []; return new_block(make_span(0,0,0,0), s) } }
}
pub fn expr_if_else(e: Expr) -> Option<ElseClause> {
    match e { If(_, _, ec) => { return ec }, _ => { return none } }
}

// Match
pub fn expr_match_subject(e: Expr) -> Expr {
    match e { Match(s, _) => { return s }, _ => { return Expr::NoneLit } }
}
pub fn expr_match_arms(e: Expr) -> List<MatchArm> {
    match e { Match(_, a) => { return a }, _ => { let empty: List<MatchArm> = []; return empty } }
}

// ---- Stmt kind + accessors ------------------------------------------------

pub fn stmt_kind(s: Stmt) -> String {
    match s {
        Let(_, _, _, _) => { return "let" },
        ExprStmt(_) => { return "expr_stmt" },
        Return(_) => { return "return" },
        For(_, _, _) => { return "for" },
        SignalDecl(_, _, _, _, _) => { return "signal_decl" },
        StreamDecl(_, _, _) => { return "stream_decl" }
    }
}

pub fn stmt_let_name(s: Stmt) -> String {
    match s { Let(n, _, _, _) => { return n }, _ => { return "" } }
}
pub fn stmt_let_mutable(s: Stmt) -> Bool {
    match s { Let(_, m, _, _) => { return m }, _ => { return false } }
}
pub fn stmt_let_type(s: Stmt) -> Option<TypeExpr> {
    match s { Let(_, _, t, _) => { return t }, _ => { return none } }
}
pub fn stmt_let_value(s: Stmt) -> Expr {
    match s { Let(_, _, _, v) => { return v }, _ => { return Expr::NoneLit } }
}
pub fn stmt_expr(s: Stmt) -> Expr {
    match s { ExprStmt(e) => { return e }, _ => { return Expr::NoneLit } }
}
pub fn stmt_return_val(s: Stmt) -> Option<Expr> {
    match s { Return(v) => { return v }, _ => { return none } }
}
pub fn stmt_for_var(s: Stmt) -> String {
    match s { For(v, _, _) => { return v }, _ => { return "" } }
}
pub fn stmt_for_iter(s: Stmt) -> Expr {
    match s { For(_, e, _) => { return e }, _ => { return Expr::NoneLit } }
}
pub fn stmt_for_body(s: Stmt) -> Block {
    match s { For(_, _, b) => { return b }, _ => { let st: List<Stmt> = []; return new_block(make_span(0,0,0,0), st) } }
}
pub fn stmt_signal_name(s: Stmt) -> String {
    match s { SignalDecl(n, _, _, _, _) => { return n }, _ => { return "" } }
}
pub fn stmt_signal_mutable(s: Stmt) -> Bool {
    match s { SignalDecl(_, m, _, _, _) => { return m }, _ => { return false } }
}
pub fn stmt_signal_type(s: Stmt) -> Option<TypeExpr> {
    match s { SignalDecl(_, _, t, _, _) => { return t }, _ => { return none } }
}
pub fn stmt_signal_value(s: Stmt) -> Expr {
    match s { SignalDecl(_, _, _, v, _) => { return v }, _ => { return Expr::NoneLit } }
}
pub fn stmt_signal_computed(s: Stmt) -> Bool {
    match s { SignalDecl(_, _, _, _, c) => { return c }, _ => { return false } }
}
pub fn stmt_stream_name(s: Stmt) -> String {
    match s { StreamDecl(n, _, _) => { return n }, _ => { return "" } }
}
pub fn stmt_stream_type(s: Stmt) -> Option<TypeExpr> {
    match s { StreamDecl(_, t, _) => { return t }, _ => { return none } }
}
pub fn stmt_stream_value(s: Stmt) -> Expr {
    match s { StreamDecl(_, _, v) => { return v }, _ => { return Expr::NoneLit } }
}

// ---- Definition kind + accessors ------------------------------------------

pub fn def_kind(d: Definition) -> String {
    match d {
        FnDef(_) => { return "fn_def" },
        AgentDef(_) => { return "agent_def" },
        PipeDef(_) => { return "pipe_def" },
        StructDef(_) => { return "struct_def" },
        EnumDef(_) => { return "enum_def" },
        TypeAlias(_, _) => { return "type_alias" },
        ImplDef(_, _) => { return "impl_def" },
        ImportDef(_, _) => { return "import_def" },
        ExportDef(_, _) => { return "export_def" },
        ExternFnDef(_, _, _, _) => { return "extern_fn_def" }
    }
}

pub fn def_fn_data(d: Definition) -> FnDefData {
    match d { FnDef(data) => { return data }, _ => { let e: List<String> = []; let p: List<Param> = []; let dc: List<Decorator> = []; let st: List<Stmt> = []; return new_fn_def_data(make_span(0,0,0,0), "", false, e, p, none, new_block(make_span(0,0,0,0), st), dc) } }
}
pub fn def_agent_data(d: Definition) -> AgentDefData {
    match d { AgentDef(data) => { return data }, _ => { let i: List<AgentInput> = []; let o: List<AgentOutput> = []; let s: List<Stmt> = []; let m: List<FnDefData> = []; let dc: List<Decorator> = []; return new AgentDefData { span: make_span(0,0,0,0), name: "", public: false, inputs: i, outputs: o, state: s, methods: m, decorators: dc } } }
}
pub fn def_pipe_data(d: Definition) -> PipeDefData {
    match d { PipeDef(data) => { return data }, _ => { let s: List<Expr> = []; return new PipeDefData { span: make_span(0,0,0,0), name: "", public: false, stages: s } } }
}
pub fn def_struct_data(d: Definition) -> StructDefData {
    match d { StructDef(data) => { return data }, _ => { let tp: List<String> = []; let f: List<StructField> = []; return new StructDefData { span: make_span(0,0,0,0), name: "", public: false, type_params: tp, fields: f } } }
}
pub fn def_enum_data(d: Definition) -> EnumDefData {
    match d { EnumDef(data) => { return data }, _ => { let tp: List<String> = []; let v: List<EnumVariant> = []; return new EnumDefData { span: make_span(0,0,0,0), name: "", public: false, type_params: tp, variants: v } } }
}
pub fn def_impl_target(d: Definition) -> String {
    match d { ImplDef(t, _) => { return t }, _ => { return "" } }
}
pub fn def_impl_methods(d: Definition) -> List<FnDefData> {
    match d { ImplDef(_, m) => { return m }, _ => { let empty: List<FnDefData> = []; return empty } }
}
pub fn def_import_path(d: Definition) -> List<String> {
    match d { ImportDef(p, _) => { return p }, _ => { let empty: List<String> = []; return empty } }
}
pub fn def_import_items(d: Definition) -> List<String> {
    match d { ImportDef(_, i) => { return i }, _ => { let empty: List<String> = []; return empty } }
}
pub fn def_export_inner(d: Definition) -> Option<Definition> {
    match d { ExportDef(i, _) => { return i }, _ => { return none } }
}
pub fn def_export_names(d: Definition) -> List<String> {
    match d { ExportDef(_, n) => { return n }, _ => { let empty: List<String> = []; return empty } }
}
pub fn def_type_alias_name(d: Definition) -> String {
    match d { TypeAlias(n, _) => { return n }, _ => { return "" } }
}
pub fn def_type_alias_type(d: Definition) -> TypeExpr {
    match d { TypeAlias(_, t) => { return t }, _ => { return TypeExpr::Named("Void") } }
}
pub fn def_extern_abi(d: Definition) -> String {
    match d { ExternFnDef(abi, _, _, _) => { return abi }, _ => { return "" } }
}
pub fn def_extern_name(d: Definition) -> String {
    match d { ExternFnDef(_, n, _, _) => { return n }, _ => { return "" } }
}
pub fn def_extern_params(d: Definition) -> List<Param> {
    match d { ExternFnDef(_, _, p, _) => { return p }, _ => { let empty: List<Param> = []; return empty } }
}
pub fn def_extern_return_type(d: Definition) -> Option<TypeExpr> {
    match d { ExternFnDef(_, _, _, r) => { return r }, _ => { return none } }
}

// ---- TypeExpr kind + accessors --------------------------------------------

pub fn type_expr_kind(te: TypeExpr) -> String {
    match te {
        Named(_) => { return "named" },
        Generic(_, _) => { return "generic" },
        TensorTy(_, _) => { return "tensor" },
        FnTy(_, _) => { return "fn" }
    }
}

pub fn type_expr_name(te: TypeExpr) -> String {
    match te {
        Named(n) => { return n },
        Generic(n, _) => { return n },
        _ => { return "" }
    }
}
pub fn type_expr_args(te: TypeExpr) -> List<TypeExpr> {
    match te { Generic(_, a) => { return a }, _ => { let empty: List<TypeExpr> = []; return empty } }
}
pub fn type_expr_fn_params(te: TypeExpr) -> List<TypeExpr> {
    match te { FnTy(p, _) => { return p }, _ => { let empty: List<TypeExpr> = []; return empty } }
}
pub fn type_expr_fn_ret(te: TypeExpr) -> TypeExpr {
    match te { FnTy(_, r) => { return r }, _ => { return TypeExpr::Named("Void") } }
}

// ---- Pattern kind + accessors ---------------------------------------------

pub fn pattern_kind(p: Pattern) -> String {
    match p {
        Wildcard => { return "wildcard" },
        IdentPat(_) => { return "ident" },
        LiteralPat(_) => { return "literal" },
        ConstructorPat(_, _) => { return "constructor" }
    }
}

pub fn pattern_ident_name(p: Pattern) -> String {
    match p { IdentPat(n) => { return n }, _ => { return "" } }
}
pub fn pattern_literal_expr(p: Pattern) -> Expr {
    match p { LiteralPat(e) => { return e }, _ => { return Expr::NoneLit } }
}
pub fn pattern_ctor_name(p: Pattern) -> String {
    match p { ConstructorPat(n, _) => { return n }, _ => { return "" } }
}
pub fn pattern_ctor_args(p: Pattern) -> List<Pattern> {
    match p { ConstructorPat(_, a) => { return a }, _ => { let empty: List<Pattern> = []; return empty } }
}

// ---- MatchArmBody kind + accessors ----------------------------------------

pub fn match_arm_body_kind(b: MatchArmBody) -> String {
    match b {
        ExprBody(_) => { return "expr" },
        BlockBody(_) => { return "block" }
    }
}

pub fn match_arm_body_expr(b: MatchArmBody) -> Expr {
    match b { ExprBody(e) => { return e }, _ => { return Expr::NoneLit } }
}
pub fn match_arm_body_block(b: MatchArmBody) -> Block {
    match b { BlockBody(bl) => { return bl }, _ => { let s: List<Stmt> = []; return new_block(make_span(0,0,0,0), s) } }
}

// ---- LambdaBody kind + accessors ------------------------------------------

pub fn lambda_body_kind(b: LambdaBody) -> String {
    match b {
        ExprBody(_) => { return "expr" },
        BlockBody(_) => { return "block" }
    }
}

pub fn lambda_body_expr(b: LambdaBody) -> Expr {
    match b { ExprBody(e) => { return e }, _ => { return Expr::NoneLit } }
}
pub fn lambda_body_block(b: LambdaBody) -> Block {
    match b { BlockBody(bl) => { return bl }, _ => { let s: List<Stmt> = []; return new_block(make_span(0,0,0,0), s) } }
}

// ---- ElseClause kind + accessors ------------------------------------------

pub fn else_clause_kind(ec: ElseClause) -> String {
    match ec {
        ElseBlock(_) => { return "else_block" },
        ElseIf(_, _, _) => { return "else_if" }
    }
}

pub fn else_clause_block(ec: ElseClause) -> Block {
    match ec { ElseBlock(b) => { return b }, _ => { let s: List<Stmt> = []; return new_block(make_span(0,0,0,0), s) } }
}
pub fn else_clause_cond(ec: ElseClause) -> Expr {
    match ec { ElseIf(c, _, _) => { return c }, _ => { return Expr::NoneLit } }
}
pub fn else_clause_then(ec: ElseClause) -> Block {
    match ec { ElseIf(_, b, _) => { return b }, _ => { let s: List<Stmt> = []; return new_block(make_span(0,0,0,0), s) } }
}
pub fn else_clause_else(ec: ElseClause) -> Option<ElseClause> {
    match ec { ElseIf(_, _, e) => { return e }, _ => { return none } }
}

// ===== lexer.mn =====
// lexer.mn — Mapanare lexer, self-hosted.
// Tokenizes .mn source files into a token stream.
// Character-by-character scanner replacing the Lark-based Python lexer.


// ---------------------------------------------------------------------------
// Token
// ---------------------------------------------------------------------------

struct Token {
    tok_type: String,
    value: String,
    line: Int,
    column: Int,
    end_line: Int,
    end_column: Int
}

// ---------------------------------------------------------------------------
// LexError
// ---------------------------------------------------------------------------

struct LexError {
    message: String,
    line: Int,
    column: Int,
    filename: String
}

// ---------------------------------------------------------------------------
// Lexer state
// ---------------------------------------------------------------------------

struct Lexer {
    source: String,
    pos: Int,
    line: Int,
    column: Int,
    filename: String
}

// ---------------------------------------------------------------------------
// Constructor functions
// ---------------------------------------------------------------------------

fn new_token(tok_type: String, value: String, line: Int, col: Int, end_line: Int, end_col: Int) -> Token {
    return new Token { tok_type: tok_type, value: value, line: line, column: col, end_line: end_line, end_column: end_col }
}

fn new_lexer(source: String, pos: Int, line: Int, column: Int, filename: String) -> Lexer {
    return new Lexer { source: source, pos: pos, line: line, column: column, filename: filename }
}

// ---------------------------------------------------------------------------
// Keywords (28 total)
// ---------------------------------------------------------------------------

fn is_keyword(name: String) -> Bool {
    if name == "let" { return true }
    if name == "pon" { return true }
    if name == "mut" { return true }
    if name == "fn" { return true }
    if name == "return" { return true }
    if name == "da" { return true }
    if name == "pub" { return true }
    if name == "self" { return true }
    if name == "yo" { return true }
    if name == "agent" { return true }
    if name == "spawn" { return true }
    if name == "sync" { return true }
    if name == "signal" { return true }
    if name == "stream" { return true }
    if name == "pipe" { return true }
    if name == "if" { return true }
    if name == "si" { return true }
    if name == "else" { return true }
    if name == "sino" { return true }
    if name == "match" { return true }
    if name == "for" { return true }
    if name == "cada" { return true }
    if name == "while" { return true }
    if name == "mien" { return true }
    if name == "in" { return true }
    if name == "en" { return true }
    if name == "type" { return true }
    if name == "tipo" { return true }
    if name == "struct" { return true }
    if name == "enum" { return true }
    if name == "impl" { return true }
    if name == "trait" { return true }
    if name == "modo" { return true }
    if name == "way" { return true }
    if name == "import" { return true }
    if name == "usa" { return true }
    if name == "export" { return true }
    if name == "extern" { return true }
    if name == "true" { return true }
    if name == "false" { return true }
    if name == "none" { return true }
    if name == "nada" { return true }
    if name == "new" { return true }
    if name == "input" { return true }
    if name == "output" { return true }
    if name == "assert" { return true }
    if name == "break" { return true }
    if name == "sal" { return true }
    if name == "continue" { return true }
    if name == "sigue" { return true }
    if name == "di" { return true }
    return false
}

fn keyword_token_type(name: String) -> String {
    if name == "let" { return "KW_LET" }
    if name == "pon" { return "KW_LET" }
    if name == "mut" { return "KW_MUT" }
    if name == "fn" { return "KW_FN" }
    if name == "return" { return "KW_RETURN" }
    if name == "da" { return "KW_RETURN" }
    if name == "pub" { return "KW_PUB" }
    if name == "self" { return "KW_SELF" }
    if name == "yo" { return "KW_SELF" }
    if name == "agent" { return "KW_AGENT" }
    if name == "spawn" { return "KW_SPAWN" }
    if name == "sync" { return "KW_SYNC" }
    if name == "signal" { return "KW_SIGNAL" }
    if name == "stream" { return "KW_STREAM" }
    if name == "pipe" { return "KW_PIPE" }
    if name == "if" { return "KW_IF" }
    if name == "si" { return "KW_IF" }
    if name == "else" { return "KW_ELSE" }
    if name == "sino" { return "KW_ELSE" }
    if name == "match" { return "KW_MATCH" }
    if name == "for" { return "KW_FOR" }
    if name == "cada" { return "KW_FOR" }
    if name == "while" { return "KW_WHILE" }
    if name == "mien" { return "KW_WHILE" }
    if name == "in" { return "KW_IN" }
    if name == "en" { return "KW_IN" }
    if name == "type" { return "KW_TYPE" }
    if name == "tipo" { return "KW_TYPE" }
    if name == "struct" { return "KW_STRUCT" }
    if name == "enum" { return "KW_ENUM" }
    if name == "impl" { return "KW_IMPL" }
    if name == "trait" { return "KW_TRAIT" }
    if name == "modo" { return "KW_TRAIT" }
    if name == "way" { return "KW_TRAIT" }
    if name == "import" { return "KW_IMPORT" }
    if name == "usa" { return "KW_IMPORT" }
    if name == "export" { return "KW_EXPORT" }
    if name == "extern" { return "KW_EXTERN" }
    if name == "true" { return "KW_TRUE" }
    if name == "false" { return "KW_FALSE" }
    if name == "none" { return "KW_NONE" }
    if name == "nada" { return "KW_NONE" }
    if name == "new" { return "KW_NEW" }
    if name == "input" { return "KW_INPUT" }
    if name == "output" { return "KW_OUTPUT" }
    if name == "assert" { return "KW_ASSERT" }
    if name == "break" { return "KW_BREAK" }
    if name == "sal" { return "KW_BREAK" }
    if name == "continue" { return "KW_CONTINUE" }
    if name == "sigue" { return "KW_CONTINUE" }
    if name == "di" { return "KW_DI" }
    return "NAME"
}

// ---------------------------------------------------------------------------
// Character classification helpers
// ---------------------------------------------------------------------------

fn is_alpha(ch: String) -> Bool {
    if ch == "_" { return true }
    if ch >= "a" { if ch <= "z" { return true } }
    if ch >= "A" { if ch <= "Z" { return true } }
    return false
}

fn is_digit(ch: String) -> Bool {
    if ch >= "0" { if ch <= "9" { return true } }
    return false
}

fn is_alnum(ch: String) -> Bool {
    if is_alpha(ch) { return true }
    if is_digit(ch) { return true }
    return false
}

fn is_whitespace(ch: String) -> Bool {
    if ch == " " { return true }
    if ch == "\t" { return true }
    if ch == "\r" { return true }
    return false
}

fn is_hex_digit(ch: String) -> Bool {
    if is_digit(ch) { return true }
    if ch >= "a" { if ch <= "f" { return true } }
    if ch >= "A" { if ch <= "F" { return true } }
    return false
}

// ---------------------------------------------------------------------------
// Lexer helpers — use positional args, no struct literals
// ---------------------------------------------------------------------------

fn lexer_at_end(source: String, pos: Int) -> Bool {
    return pos >= len(source)
}

fn lexer_peek(source: String, pos: Int) -> String {
    if pos >= len(source) { return "" }
    return source.char_at(pos)
}

fn lexer_peek_at(source: String, pos: Int, offset: Int) -> String {
    let idx: Int = pos + offset
    if idx >= len(source) { return "" }
    return source.char_at(idx)
}

// ---------------------------------------------------------------------------
// Scan identifier / keyword
// ---------------------------------------------------------------------------

fn scan_ident(source: String, pos: Int, line: Int, col: Int) -> Token {
    let mut p: Int = pos
    let mut value: String = ""
    for _ in 0..10000 {
        if p >= len(source) { return new_token(keyword_token_type(value), value, line, col, line, col + len(value)) }
        let ch: String = source.char_at(p)
        if is_alnum(ch) {
            value = value + ch
            p = p + 1
        } else {
            return new_token(keyword_token_type(value), value, line, col, line, col + len(value))
        }
    }
    return new_token(keyword_token_type(value), value, line, col, line, col + len(value))
}

// ---------------------------------------------------------------------------
// Scan number literal
// ---------------------------------------------------------------------------

fn scan_number(source: String, pos: Int, line: Int, col: Int) -> Token {
    let mut p: Int = pos
    let mut value: String = ""
    let mut is_float: Bool = false
    let ch0: String = source.char_at(p)

    // Check 0x, 0b, 0o prefixes
    if ch0 == "0" {
        let ch1: String = lexer_peek(source, p + 1)
        if ch1 == "x" {
            value = "0x"
            p = p + 2
            for _ in 0..100 {
                if p >= len(source) { return new_token("HEX_INT", value, line, col, line, col + p - pos) }
                let hc: String = source.char_at(p)
                if is_hex_digit(hc) { value = value + hc } else { if hc != "_" { return new_token("HEX_INT", value, line, col, line, col + p - pos) } }
                p = p + 1
            }
            return new_token("HEX_INT", value, line, col, line, col + p - pos)
        }
        if ch1 == "b" {
            value = "0b"
            p = p + 2
            for _ in 0..100 {
                if p >= len(source) { return new_token("BIN_INT", value, line, col, line, col + p - pos) }
                let bc: String = source.char_at(p)
                if bc == "0" { value = value + bc } else { if bc == "1" { value = value + bc } else { if bc != "_" { return new_token("BIN_INT", value, line, col, line, col + p - pos) } } }
                p = p + 1
            }
            return new_token("BIN_INT", value, line, col, line, col + p - pos)
        }
        if ch1 == "o" {
            value = "0o"
            p = p + 2
            for _ in 0..100 {
                if p >= len(source) { return new_token("OCT_INT", value, line, col, line, col + p - pos) }
                let oc: String = source.char_at(p)
                if oc >= "0" { if oc <= "7" { value = value + oc } else { if oc != "_" { return new_token("OCT_INT", value, line, col, line, col + p - pos) } } } else { return new_token("OCT_INT", value, line, col, line, col + p - pos) }
                p = p + 1
            }
            return new_token("OCT_INT", value, line, col, line, col + p - pos)
        }
    }

    // Decimal / float
    for _ in 0..100 {
        if p >= len(source) {
            if is_float { return new_token("FLOAT_LIT", value, line, col, line, col + p - pos) }
            return new_token("DEC_INT", value, line, col, line, col + p - pos)
        }
        let dc: String = source.char_at(p)
        if is_digit(dc) {
            value = value + dc
            p = p + 1
        } else {
            if dc == "_" {
                p = p + 1
            } else {
                if dc == "." {
                    if lexer_peek(source, p + 1) == "." {
                        if is_float { return new_token("FLOAT_LIT", value, line, col, line, col + p - pos) }
                        return new_token("DEC_INT", value, line, col, line, col + p - pos)
                    }
                    is_float = true
                    value = value + "."
                    p = p + 1
                } else {
                    if is_float { return new_token("FLOAT_LIT", value, line, col, line, col + p - pos) }
                    return new_token("DEC_INT", value, line, col, line, col + p - pos)
                }
            }
        }
    }
    if is_float { return new_token("FLOAT_LIT", value, line, col, line, col + p - pos) }
    return new_token("DEC_INT", value, line, col, line, col + p - pos)
}

// ---------------------------------------------------------------------------
// Scan string literal
// ---------------------------------------------------------------------------

fn scan_string(source: String, pos: Int, line: Int, col: Int) -> Token {
    let mut p: Int = pos + 1
    let mut value: String = ""
    let mut cur_line: Int = line
    for _ in 0..100000 {
        if p >= len(source) { return new_token("STRING_LIT", value, line, col, cur_line, col + p - pos) }
        let ch: String = source.char_at(p)
        if ch == "\"" {
            p = p + 1
            return new_token("STRING_LIT", value, line, col, cur_line, col + p - pos)
        }
        if ch == "\\" {
            p = p + 1
            if p >= len(source) { return new_token("STRING_LIT", value, line, col, cur_line, col + p - pos) }
            let esc: String = source.char_at(p)
            if esc == "n" { value = value + "\n" }
            if esc == "t" { value = value + "\t" }
            if esc == "r" { value = value + "\r" }
            if esc == "\\" { value = value + "\\" }
            if esc == "\"" { value = value + "\"" }
            if esc == "0" { value = value + "\0" }
            if esc == "$" { value = value + "$" }
            p = p + 1
        } else {
            if ch == "\n" { cur_line = cur_line + 1 }
            value = value + ch
            p = p + 1
        }
    }
    return new_token("STRING_LIT", value, line, col, cur_line, col + p - pos)
}

// ---------------------------------------------------------------------------
// Scan char literal
// ---------------------------------------------------------------------------

fn scan_char(source: String, pos: Int, line: Int, col: Int) -> Token {
    let mut p: Int = pos + 1
    let mut value: String = ""
    if p >= len(source) { return new_token("CHAR_LIT", "", line, col, line, col + 2) }
    let ch: String = source.char_at(p)
    if ch == "\\" {
        p = p + 1
        let esc: String = source.char_at(p)
        if esc == "n" { value = "\n" }
        if esc == "t" { value = "\t" }
        if esc == "\\" { value = "\\" }
        if esc == "'" { value = "'" }
        p = p + 1
    } else {
        value = ch
        p = p + 1
    }
    if p < len(source) { if source.char_at(p) == "'" { p = p + 1 } }
    return new_token("CHAR_LIT", value, line, col, line, col + p - pos)
}

// ---------------------------------------------------------------------------
// Scan operator / punctuation — returns token + its width
// ---------------------------------------------------------------------------

fn scan_op(source: String, pos: Int, line: Int, col: Int) -> Token {
    let ch: String = source.char_at(pos)
    let ch1: String = lexer_peek(source, pos + 1)

    if ch == "|" {
        if ch1 == ">" { return new_token("PIPE_OP", "|>", line, col, line, col + 2) }
        if ch1 == "|" { return new_token("OR", "||", line, col, line, col + 2) }
        return new_token("BAR", "|", line, col, line, col + 1)
    }
    if ch == "&" { if ch1 == "&" { return new_token("AND", "&&", line, col, line, col + 2) } }
    if ch == "=" {
        if ch1 == "=" { return new_token("EQEQ", "==", line, col, line, col + 2) }
        if ch1 == ">" { return new_token("FAT_ARROW", "=>", line, col, line, col + 2) }
        return new_token("ASSIGN", "=", line, col, line, col + 1)
    }
    if ch == "!" {
        if ch1 == "=" { return new_token("NEQ", "!=", line, col, line, col + 2) }
        return new_token("BANG", "!", line, col, line, col + 1)
    }
    if ch == "<" {
        if ch1 == "=" { return new_token("LTE", "<=", line, col, line, col + 2) }
        if ch1 == "-" { return new_token("SEND", "<-", line, col, line, col + 2) }
        return new_token("LT", "<", line, col, line, col + 1)
    }
    if ch == ">" {
        if ch1 == "=" { return new_token("GTE", ">=", line, col, line, col + 2) }
        return new_token("GT", ">", line, col, line, col + 1)
    }
    if ch == "-" {
        if ch1 == ">" { return new_token("ARROW", "->", line, col, line, col + 2) }
        if ch1 == "=" { return new_token("MINUS_EQ", "-=", line, col, line, col + 2) }
        return new_token("MINUS", "-", line, col, line, col + 1)
    }
    if ch == "+" {
        if ch1 == "=" { return new_token("PLUS_EQ", "+=", line, col, line, col + 2) }
        return new_token("PLUS", "+", line, col, line, col + 1)
    }
    if ch == "*" {
        if ch1 == "=" { return new_token("STAR_EQ", "*=", line, col, line, col + 2) }
        return new_token("STAR", "*", line, col, line, col + 1)
    }
    if ch == "/" {
        if ch1 == "=" { return new_token("SLASH_EQ", "/=", line, col, line, col + 2) }
        return new_token("SLASH", "/", line, col, line, col + 1)
    }
    if ch == ":" {
        if ch1 == ":" { return new_token("DOUBLE_COLON", "::", line, col, line, col + 2) }
        return new_token("COLON", ":", line, col, line, col + 1)
    }
    if ch == "." {
        if ch1 == "." {
            if lexer_peek(source, pos + 2) == "=" { return new_token("RANGE_INCL", "..=", line, col, line, col + 3) }
            return new_token("RANGE", "..", line, col, line, col + 2)
        }
        return new_token("DOT", ".", line, col, line, col + 1)
    }
    if ch == "(" { return new_token("LPAREN", "(", line, col, line, col + 1) }
    if ch == ")" { return new_token("RPAREN", ")", line, col, line, col + 1) }
    if ch == "{" { return new_token("LBRACE", "{", line, col, line, col + 1) }
    if ch == "}" { return new_token("RBRACE", "}", line, col, line, col + 1) }
    if ch == "[" { return new_token("LBRACKET", "[", line, col, line, col + 1) }
    if ch == "]" { return new_token("RBRACKET", "]", line, col, line, col + 1) }
    if ch == "," { return new_token("COMMA", ",", line, col, line, col + 1) }
    if ch == ";" { return new_token("SEMICOLON", ";", line, col, line, col + 1) }
    if ch == "?" { return new_token("QUESTION", "?", line, col, line, col + 1) }
    if ch == "@" { return new_token("AT", "@", line, col, line, col + 1) }
    if ch == "%" { return new_token("PERCENT", "%", line, col, line, col + 1) }
    if ch == "#" {
        if ch1 == "{" { return new_token("MAP_OPEN", "#{", line, col, line, col + 2) }
        return new_token("HASH", "#", line, col, line, col + 1)
    }

    return new_token("UNKNOWN", ch, line, col, line, col + 1)
}

// ---------------------------------------------------------------------------
// Public API
// ---------------------------------------------------------------------------

// Helper: skip to end of line comment, return new position.
// Uses return (not break) to exit the loop — return works, break doesn't.
fn skip_comment_to_eol(source: String, pos: Int, slen: Int) -> Int {
    let mut p: Int = pos
    for _ in 0..100000 {
        if p >= slen { return p }
        if source.char_at(p) == "\n" { return p + 1 }
        p = p + 1
    }
    return p
}

fn tokenize(source: String, filename: String) -> List<Token> {
    let mut tokens: List<Token> = []
    let mut pos: Int = 0
    let mut line: Int = 1
    let mut col: Int = 1
    let slen: Int = len(source)

    // Single loop: handles whitespace, comments, and tokens.
    // No inner whitespace loop (avoids break-inside-if-inside-for bug).
    // No nested else chain (avoids dropped else body pattern).
    for _ in 0..2000000 {
        if pos >= slen { return tokens }

        let c: String = source.char_at(pos)

        // --- Whitespace (one char per iteration, main loop repeats) ---
        let mut skip: Bool = false
        if c == " " { pos = pos + 1; col = col + 1; skip = true }
        if c == "\t" { pos = pos + 1; col = col + 1; skip = true }
        if c == "\r" { pos = pos + 1; skip = true }
        if c == "\n" { pos = pos + 1; line = line + 1; col = 1; skip = true }

        // --- Line comment (// to end of line) ---
        if c == "/" {
            if lexer_peek(source, pos + 1) == "/" {
                let new_pos: Int = skip_comment_to_eol(source, pos + 2, slen)
                pos = new_pos
                line = line + 1
                col = 1
                skip = true
            }
        }

        if !skip {
            // --- Token classification (flat if-chain, no nested else) ---
            let mut handled: Bool = false

            if is_alpha(c) {
                handled = true
                let tok_id: Token = scan_ident(source, pos, line, col)
                pos = pos + len(tok_id.value)
                col = col + len(tok_id.value)
                tokens.push(tok_id)
            }

            if !handled {
                if is_digit(c) {
                    handled = true
                    let tok_num: Token = scan_number(source, pos, line, col)
                    let width_num: Int = tok_num.end_column - tok_num.column
                    pos = pos + width_num
                    col = col + width_num
                    tokens.push(tok_num)
                }
            }

            if !handled {
                if c == "\"" {
                    handled = true
                    let tok_str: Token = scan_string(source, pos, line, col)
                    let width_str: Int = tok_str.end_column - tok_str.column
                    pos = pos + width_str
                    col = col + width_str
                    line = tok_str.end_line
                    tokens.push(tok_str)
                }
            }

            if !handled {
                if c == "'" {
                    handled = true
                    let tok_chr: Token = scan_char(source, pos, line, col)
                    let width_chr: Int = tok_chr.end_column - tok_chr.column
                    pos = pos + width_chr
                    col = col + width_chr
                    tokens.push(tok_chr)
                }
            }

            if !handled {
                let tok_op: Token = scan_op(source, pos, line, col)
                let width_op: Int = len(tok_op.value)
                pos = pos + width_op
                col = col + width_op
                tokens.push(tok_op)
            }
        }
    }

    return tokens
}

fn tokenize_with_newlines(source: String, filename: String) -> List<Token> {
    return tokenize(source, filename)
}

// ===== parser.mn =====
// parser.mn — Mapanare parser, self-hosted.
// Recursive descent with precedence climbing.
// Builds AST from token stream produced by lexer.mn.
//
// NOTE: Struct construction syntax (Name { field: val }) is not yet in the
// Lark grammar, so all struct creation uses constructor functions.


// ---------------------------------------------------------------------------
// ParseError
// ---------------------------------------------------------------------------

struct ParseError {
    message: String,
    line: Int,
    column: Int,
    filename: String
}

// ---------------------------------------------------------------------------
// Parser state
// ---------------------------------------------------------------------------

struct Parser {
    tokens: List<Token>,
    pos: Int,
    filename: String
}

// ---------------------------------------------------------------------------
// Token classification helpers
// ---------------------------------------------------------------------------

fn is_skip_token(tok_type: String) -> Bool {
    if tok_type == "KW_FN" { return true }
    if tok_type == "KW_LET" { return true }
    if tok_type == "KW_AGENT" { return true }
    if tok_type == "KW_PIPE" { return true }
    if tok_type == "KW_STRUCT" { return true }
    if tok_type == "KW_ENUM" { return true }
    if tok_type == "KW_TYPE" { return true }
    if tok_type == "KW_IMPL" { return true }
    if tok_type == "KW_IF" { return true }
    if tok_type == "KW_ELSE" { return true }
    if tok_type == "KW_MATCH" { return true }
    if tok_type == "KW_FOR" { return true }
    if tok_type == "KW_IN" { return true }
    if tok_type == "KW_RETURN" { return true }
    if tok_type == "KW_IMPORT" { return true }
    if tok_type == "KW_EXPORT" { return true }
    if tok_type == "KW_SPAWN" { return true }
    if tok_type == "KW_SYNC" { return true }
    if tok_type == "KW_SIGNAL" { return true }
    if tok_type == "KW_STREAM" { return true }
    if tok_type == "KW_INPUT" { return true }
    if tok_type == "KW_OUTPUT" { return true }
    if tok_type == "KW_TENSOR" { return true }
    if tok_type == "KW_WILDCARD" { return true }
    if tok_type == "KW_TRUE" { return true }
    if tok_type == "KW_FALSE" { return true }
    if tok_type == "KW_NONE" { return true }
    if tok_type == "LPAREN" { return true }
    if tok_type == "RPAREN" { return true }
    if tok_type == "LBRACE" { return true }
    if tok_type == "RBRACE" { return true }
    if tok_type == "LBRACKET" { return true }
    if tok_type == "RBRACKET" { return true }
    if tok_type == "COMMA" { return true }
    if tok_type == "COLON" { return true }
    if tok_type == "SEMICOLON" { return true }
    if tok_type == "ASSIGN" { return true }
    if tok_type == "ARROW" { return true }
    if tok_type == "FAT_ARROW" { return true }
    if tok_type == "PIPE_OP" { return true }
    if tok_type == "DOUBLE_COLON" { return true }
    if tok_type == "DOT" { return true }
    if tok_type == "QUESTION" { return true }
    if tok_type == "SEND" { return true }
    return false
}

fn is_keep_token(tok_type: String) -> Bool {
    if tok_type == "KW_PUB" { return true }
    if tok_type == "KW_MUT" { return true }
    if tok_type == "KW_SELF" { return true }
    if tok_type == "NAME" { return true }
    if tok_type == "DEC_INT" { return true }
    if tok_type == "HEX_INT" { return true }
    if tok_type == "BIN_INT" { return true }
    if tok_type == "OCT_INT" { return true }
    if tok_type == "FLOAT_LIT" { return true }
    if tok_type == "STRING_LIT" { return true }
    if tok_type == "CHAR_LIT" { return true }
    return false
}

// ---------------------------------------------------------------------------
// Integer parsing helpers
// ---------------------------------------------------------------------------

fn parse_int_token(tok_type: String, value: String) -> Int {
    return 0
}

// ---------------------------------------------------------------------------
// Binary operator helpers
// ---------------------------------------------------------------------------

fn is_arithmetic_op(op: String) -> Bool {
    if op == "+" { return true }
    if op == "-" { return true }
    if op == "*" { return true }
    if op == "/" { return true }
    if op == "%" { return true }
    if op == "@" { return true }
    return false
}

fn is_comparison_op(op: String) -> Bool {
    if op == "<" { return true }
    if op == ">" { return true }
    if op == "<=" { return true }
    if op == ">=" { return true }
    if op == "==" { return true }
    if op == "!=" { return true }
    return false
}

fn is_logical_op(op: String) -> Bool {
    if op == "&&" { return true }
    if op == "||" { return true }
    return false
}

fn is_assign_op(op: String) -> Bool {
    if op == "=" { return true }
    if op == "+=" { return true }
    if op == "-=" { return true }
    if op == "*=" { return true }
    if op == "/=" { return true }
    return false
}

// ---------------------------------------------------------------------------
// Result structs — each parse function returns (value, new position)
// ---------------------------------------------------------------------------

struct ExprResult {
    expr: Expr,
    pos: Int
}

struct StmtResult {
    stmt: Stmt,
    pos: Int
}

struct BlockResult {
    block: Block,
    pos: Int
}

struct TypeResult {
    type_expr: TypeExpr,
    pos: Int
}

struct PatternResult {
    pattern: Pattern,
    pos: Int
}

struct DefResult {
    def_node: Definition,
    pos: Int
}

struct ParamResult {
    param: Param,
    pos: Int
}

struct MatchArmResult {
    arm: MatchArm,
    pos: Int
}

// ---------------------------------------------------------------------------
// Constructor functions — populate result structs positionally
// ---------------------------------------------------------------------------

fn new_expr_result(expr: Expr, pos: Int) -> ExprResult {
    return new ExprResult { expr: expr, pos: pos }
}

fn new_stmt_result(stmt: Stmt, pos: Int) -> StmtResult {
    return new StmtResult { stmt: stmt, pos: pos }
}

fn new_block_result(block: Block, pos: Int) -> BlockResult {
    return new BlockResult { block: block, pos: pos }
}

fn new_type_result(type_expr: TypeExpr, pos: Int) -> TypeResult {
    return new TypeResult { type_expr: type_expr, pos: pos }
}

fn new_pattern_result(pattern: Pattern, pos: Int) -> PatternResult {
    return new PatternResult { pattern: pattern, pos: pos }
}

fn new_def_result(def_node: Definition, pos: Int) -> DefResult {
    return new DefResult { def_node: def_node, pos: pos }
}

fn new_param_result(param: Param, pos: Int) -> ParamResult {
    return new ParamResult { param: param, pos: pos }
}

fn new_match_arm_result(arm: MatchArm, pos: Int) -> MatchArmResult {
    return new MatchArmResult { arm: arm, pos: pos }
}

// AST node constructors (new_span, new_block, new_fn_def_data are in ast.mn)

fn new_param(name: String, type_ann: Option<TypeExpr>) -> Param {
    return new Param { span: new_span(0, 0, 0, 0), name: name, type_annotation: type_ann }
}

fn new_struct_field(name: String, type_ann: TypeExpr) -> StructField {
    return new StructField { span: new_span(0, 0, 0, 0), name: name, type_annotation: type_ann }
}

fn new_enum_variant(name: String, fields: List<TypeExpr>) -> EnumVariant {
    return new EnumVariant { span: new_span(0, 0, 0, 0), name: name, fields: fields }
}

fn new_match_arm(pattern: Pattern, body: MatchArmBody) -> MatchArm {
    return new MatchArm { span: new_span(0, 0, 0, 0), pattern: pattern, body: body }
}

fn new_struct_def_data(name: String, public: Bool, type_params: List<String>, fields: List<StructField>) -> StructDefData {
    return new StructDefData { span: new_span(0, 0, 0, 0), name: name, public: public, type_params: type_params, fields: fields }
}

fn new_enum_def_data(name: String, public: Bool, type_params: List<String>, variants: List<EnumVariant>) -> EnumDefData {
    return new EnumDefData { span: new_span(0, 0, 0, 0), name: name, public: public, type_params: type_params, variants: variants }
}

fn new_agent_def_data(name: String, public: Bool, inputs: List<AgentInput>, outputs: List<AgentOutput>, state: List<Stmt>, methods: List<FnDefData>, decorators: List<Decorator>) -> AgentDefData {
    return new AgentDefData { span: new_span(0, 0, 0, 0), name: name, public: public, inputs: inputs, outputs: outputs, state: state, methods: methods, decorators: decorators }
}

fn new_pipe_def_data(name: String, public: Bool, stages: List<Expr>) -> PipeDefData {
    return new PipeDefData { span: new_span(0, 0, 0, 0), name: name, public: public, stages: stages }
}

fn new_decorator(name: String, args: List<Expr>) -> Decorator {
    return new Decorator { span: new_span(0, 0, 0, 0), name: name, args: args }
}

// ---------------------------------------------------------------------------
// Token access helpers
// ---------------------------------------------------------------------------

fn peek_type(tokens: List<Token>, pos: Int) -> String {
    if pos >= len(tokens) { return "EOF" }
    let tok: Token = tokens[pos]
    return tok.tok_type
}

fn peek_value(tokens: List<Token>, pos: Int) -> String {
    if pos >= len(tokens) { return "" }
    let tok: Token = tokens[pos]
    return tok.value
}

fn at_end(tokens: List<Token>, pos: Int) -> Bool {
    return pos >= len(tokens)
}

fn expect(tokens: List<Token>, pos: Int, expected: String) -> Int {
    let tt: String = peek_type(tokens, pos)
    if tt != expected {
        let msg: String = "Expected " + expected + " but got " + tt
        print(msg)
    }
    return pos + 1
}

fn skip_semis(tokens: List<Token>, pos: Int) -> Int {
    let mut p: Int = pos
    for _ in 0..100000 {
        if p >= len(tokens) { return p }
        if peek_type(tokens, p) == "SEMICOLON" {
            p = p + 1
        } else {
            return p
        }
    }
    return p
}

// ---------------------------------------------------------------------------
// Operator helpers
// ---------------------------------------------------------------------------

fn tok_to_binop(tt: String) -> String {
    if tt == "PLUS" { return "+" }
    if tt == "MINUS" { return "-" }
    if tt == "STAR" { return "*" }
    if tt == "SLASH" { return "/" }
    if tt == "PERCENT" { return "%" }
    if tt == "AT" { return "@" }
    if tt == "EQEQ" { return "==" }
    if tt == "NEQ" { return "!=" }
    if tt == "LT" { return "<" }
    if tt == "GT" { return ">" }
    if tt == "LTE" { return "<=" }
    if tt == "GTE" { return ">=" }
    if tt == "AND" { return "&&" }
    if tt == "OR" { return "||" }
    if tt == "PIPE_OP" { return "|>" }
    if tt == "RANGE" { return ".." }
    if tt == "RANGE_INCL" { return "..=" }
    return ""
}

fn op_precedence(op: String) -> Int {
    if op == "||" { return 1 }
    if op == "&&" { return 2 }
    if op == "==" { return 3 }
    if op == "!=" { return 3 }
    if op == "<" { return 4 }
    if op == ">" { return 4 }
    if op == "<=" { return 4 }
    if op == ">=" { return 4 }
    if op == "|>" { return 5 }
    if op == ".." { return 6 }
    if op == "..=" { return 6 }
    if op == "+" { return 7 }
    if op == "-" { return 7 }
    if op == "*" { return 8 }
    if op == "/" { return 8 }
    if op == "%" { return 8 }
    if op == "@" { return 8 }
    return 0
}

fn is_right_assoc(op: String) -> Bool {
    if op == ".." { return true }
    if op == "..=" { return true }
    return false
}

// ---------------------------------------------------------------------------
// Public API
// ---------------------------------------------------------------------------

fn is_definition_start(tt: String) -> Bool {
    if tt == "KW_IMPORT" { return true }
    if tt == "KW_EXPORT" { return true }
    if tt == "KW_PUB" { return true }
    if tt == "KW_FN" { return true }
    if tt == "KW_STRUCT" { return true }
    if tt == "KW_ENUM" { return true }
    if tt == "KW_AGENT" { return true }
    if tt == "KW_PIPE" { return true }
    if tt == "KW_TYPE" { return true }
    if tt == "KW_IMPL" { return true }
    if tt == "KW_EXTERN" { return true }
    if tt == "AT" { return true }
    return false
}

fn has_explicit_main(defs: List<Definition>) -> Bool {
    for i in 0..len(defs) {
        let d: Definition = defs[i]
        match d {
            FnDef(fd) => {
                if fd.name == "main" {
                    return true
                }
            },
            _ => {}
        }
    }
    return false
}

pub fn parse(source: String, filename: String) -> Program {
    let tokens: List<Token> = tokenize(source, filename)
    let mut pos: Int = 0
    let mut defs: List<Definition> = []
    let mut top_stmts: List<Stmt> = []

    for _ in 0..100000 {
        pos = skip_semis(tokens, pos)
        if pos >= len(tokens) {
            if len(top_stmts) > 0 {
                if !has_explicit_main(defs) {
                    let body_early: Block = new_block(new_span(0, 0, 0, 0), top_stmts)
                    let empty_tp: List<String> = []
                    let empty_params: List<Param> = []
                    let empty_decs: List<Decorator> = []
                    let main_fn_early: FnDefData = new_fn_def_data(new_span(0, 0, 0, 0), "main", false, empty_tp, empty_params, none, body_early, empty_decs)
                    defs.push(Definition::FnDef(main_fn_early))
                }
            }
            return Program::start(defs)
        }

        let tt: String = peek_type(tokens, pos)
        if is_definition_start(tt) {
            let r: DefResult = parse_definition(tokens, pos, filename)
            defs.push(r.def_node)
            pos = r.pos
        } else {
            let sr: StmtResult = parse_stmt(tokens, pos, filename)
            top_stmts.push(sr.stmt)
            pos = sr.pos
        }
    }

    if len(top_stmts) > 0 {
        if !has_explicit_main(defs) {
            let body_final: Block = new_block(new_span(0, 0, 0, 0), top_stmts)
            let empty_tp2: List<String> = []
            let empty_params2: List<Param> = []
            let empty_decs2: List<Decorator> = []
            let main_fn_final: FnDefData = new_fn_def_data(new_span(0, 0, 0, 0), "main", false, empty_tp2, empty_params2, none, body_final, empty_decs2)
            defs.push(Definition::FnDef(main_fn_final))
        }
    }

    return Program::start(defs)
}

// ---------------------------------------------------------------------------
// Definition dispatch
// ---------------------------------------------------------------------------

fn parse_definition(tokens: List<Token>, pos: Int, filename: String) -> DefResult {
    let tt: String = peek_type(tokens, pos)

    if tt == "KW_IMPORT" {
        return parse_import_def(tokens, pos, filename)
    }
    if tt == "KW_EXPORT" {
        return parse_export_def(tokens, pos, filename)
    }
    if tt == "KW_PUB" {
        let next_tt: String = peek_type(tokens, pos + 1)
        if next_tt == "KW_FN" { return parse_fn_def(tokens, pos, filename) }
        if next_tt == "KW_STRUCT" { return parse_struct_def(tokens, pos, filename) }
        if next_tt == "KW_ENUM" { return parse_enum_def(tokens, pos, filename) }
        if next_tt == "KW_AGENT" { return parse_agent_def(tokens, pos, filename) }
        if next_tt == "KW_PIPE" { return parse_pipe_def(tokens, pos, filename) }
    }
    if tt == "KW_FN" { return parse_fn_def(tokens, pos, filename) }
    if tt == "KW_STRUCT" { return parse_struct_def(tokens, pos, filename) }
    if tt == "KW_ENUM" { return parse_enum_def(tokens, pos, filename) }
    if tt == "KW_AGENT" { return parse_agent_def(tokens, pos, filename) }
    if tt == "KW_PIPE" { return parse_pipe_def(tokens, pos, filename) }
    if tt == "KW_TYPE" {
        // tipo/type can be either a type alias (type Foo = Bar) or
        // a tipo definition (tipo Foo { fields/variants }). Peek ahead
        // to decide: KW_TYPE NAME LBRACE → struct-like, else → alias.
        let tipo_name_pos: Int = pos + 1
        if tipo_name_pos + 1 < len(tokens) {
            let after_name_tt: String = peek_type(tokens, tipo_name_pos + 1)
            if after_name_tt == "LBRACE" {
                return parse_tipo_def(tokens, pos, filename)
            }
        }
        return parse_type_alias_def(tokens, pos, filename)
    }
    if tt == "KW_IMPL" { return parse_impl_def(tokens, pos, filename) }
    if tt == "KW_EXTERN" { return parse_extern_def(tokens, pos, filename) }
    if tt == "AT" { return parse_decorated_def(tokens, pos, filename) }

    // Fallback: skip unknown token
    let empty_path: List<String> = []
    let empty_items: List<String> = []
    let d: Definition = Definition::ImportDef(empty_path, empty_items)
    return new_def_result(d, pos + 1)
}

// ---------------------------------------------------------------------------
// Import definition
// ---------------------------------------------------------------------------

fn parse_import_def(tokens: List<Token>, pos: Int, filename: String) -> DefResult {
    let mut p: Int = pos + 1
    let mut path: List<String> = []

    let name0: String = peek_value(tokens, p)
    path.push(name0)
    p = p + 1

    for _ in 0..100 {
        if peek_type(tokens, p) != "DOUBLE_COLON" {
            let imp_items: List<String> = []
            return new_def_result(Definition::ImportDef(path, imp_items), p)
        }
        p = p + 1
        let seg: String = peek_value(tokens, p)
        path.push(seg)
        p = p + 1
    }

    let trail_items: List<String> = []
    return new_def_result(Definition::ImportDef(path, trail_items), p)
}

// ---------------------------------------------------------------------------
// Extern "C" function declaration
// ---------------------------------------------------------------------------

fn parse_extern_def(tokens: List<Token>, pos: Int, filename: String) -> DefResult {
    // extern "C" fn name(params) -> RetType
    let mut p: Int = pos + 1
    // Skip the "C" string literal (ABI specifier)
    let abi: String = peek_value(tokens, p)
    p = p + 1
    p = expect(tokens, p, "KW_FN")

    let name: String = peek_value(tokens, p)
    p = p + 1

    // Parse parameters
    p = expect(tokens, p, "LPAREN")
    let mut params: List<Param> = []
    if peek_type(tokens, p) != "RPAREN" {
        let pr: ParamResult = parse_param(tokens, p, filename)
        params.push(pr.param)
        p = pr.pos
        for _ in 0..50 {
            if peek_type(tokens, p) != "COMMA" {
                p = expect(tokens, p, "RPAREN")
                let mut ret_type: Option<TypeExpr> = none
                if peek_type(tokens, p) == "ARROW" {
                    p = p + 1
                    let tr: TypeResult = parse_type_expr(tokens, p, filename)
                    ret_type = Some(tr.type_expr)
                    p = tr.pos
                }
                return new_def_result(Definition::ExternFnDef(abi, name, params, ret_type), p)
            }
            p = p + 1
            let pr2: ParamResult = parse_param(tokens, p, filename)
            params.push(pr2.param)
            p = pr2.pos
        }
    }
    p = expect(tokens, p, "RPAREN")

    let mut ret_type: Option<TypeExpr> = none
    if peek_type(tokens, p) == "ARROW" {
        p = p + 1
        let tr: TypeResult = parse_type_expr(tokens, p, filename)
        ret_type = Some(tr.type_expr)
        p = tr.pos
    }
    return new_def_result(Definition::ExternFnDef(abi, name, params, ret_type), p)
}

// ---------------------------------------------------------------------------
// Export definition
// ---------------------------------------------------------------------------

fn parse_export_def(tokens: List<Token>, pos: Int, filename: String) -> DefResult {
    let mut p: Int = pos + 1
    let tt: String = peek_type(tokens, p)

    if tt == "KW_FN" {
        let r_fn: DefResult = parse_fn_def(tokens, p, filename)
        let exp_items_fn: List<String> = []
        return new_def_result(Definition::ExportDef(none, exp_items_fn), r_fn.pos)
    }
    if tt == "KW_STRUCT" {
        let r_st: DefResult = parse_struct_def(tokens, p, filename)
        let exp_items_st: List<String> = []
        return new_def_result(Definition::ExportDef(none, exp_items_st), r_st.pos)
    }

    let mut names: List<String> = []
    names.push(peek_value(tokens, p))
    p = p + 1
    for _ in 0..100 {
        if peek_type(tokens, p) != "COMMA" {
            return new_def_result(Definition::ExportDef(none, names), p)
        }
        p = p + 1
        names.push(peek_value(tokens, p))
        p = p + 1
    }
    return new_def_result(Definition::ExportDef(none, names), p)
}

// ---------------------------------------------------------------------------
// Function definition
// ---------------------------------------------------------------------------

fn parse_fn_def(tokens: List<Token>, pos: Int, filename: String) -> DefResult {
    let mut p: Int = pos
    let mut is_pub: Bool = false

    if peek_type(tokens, p) == "KW_PUB" {
        is_pub = true
        p = p + 1
    }
    p = expect(tokens, p, "KW_FN")

    let name: String = peek_value(tokens, p)
    p = p + 1

    // Optional type params <T, U>
    let mut type_params: List<String> = []
    if peek_type(tokens, p) == "LT" {
        p = p + 1
        type_params.push(peek_value(tokens, p))
        p = p + 1
        for _ in 0..20 {
            if peek_type(tokens, p) != "COMMA" {
                p = expect(tokens, p, "GT")
                return parse_fn_params(tokens, p, filename, name, is_pub, type_params)
            }
            p = p + 1
            type_params.push(peek_value(tokens, p))
            p = p + 1
        }
        p = expect(tokens, p, "GT")
    }

    return parse_fn_params(tokens, p, filename, name, is_pub, type_params)
}

fn parse_fn_params(tokens: List<Token>, pos: Int, filename: String, name: String, is_pub: Bool, type_params: List<String>) -> DefResult {
    let mut p: Int = pos
    p = expect(tokens, p, "LPAREN")
    let mut params: List<Param> = []

    if peek_type(tokens, p) != "RPAREN" {
        let pr: ParamResult = parse_param(tokens, p, filename)
        params.push(pr.param)
        p = pr.pos

        for _ in 0..50 {
            if peek_type(tokens, p) != "COMMA" {
                p = expect(tokens, p, "RPAREN")
                return parse_fn_body(tokens, p, filename, name, is_pub, type_params, params)
            }
            p = p + 1
            if peek_type(tokens, p) == "RPAREN" {
                p = p + 1
                return parse_fn_body(tokens, p, filename, name, is_pub, type_params, params)
            }
            let pr2: ParamResult = parse_param(tokens, p, filename)
            params.push(pr2.param)
            p = pr2.pos
        }
    }
    p = expect(tokens, p, "RPAREN")

    return parse_fn_body(tokens, p, filename, name, is_pub, type_params, params)
}

fn parse_fn_body(tokens: List<Token>, pos: Int, filename: String, name: String, is_pub: Bool, type_params: List<String>, params: List<Param>) -> DefResult {
    let mut p: Int = pos

    let mut ret_type: Option<TypeExpr> = none
    if peek_type(tokens, p) == "ARROW" {
        p = p + 1
        let tr: TypeResult = parse_type_expr(tokens, p, filename)
        ret_type = Some(tr.type_expr)
        p = tr.pos
    }

    let br: BlockResult = parse_block(tokens, p, filename)
    p = br.pos

    let decorators: List<Decorator> = []
    let fd: FnDefData = new_fn_def_data(new_span(0, 0, 0, 0), name, is_pub, type_params, params, ret_type, br.block, decorators)
    return new_def_result(Definition::FnDef(fd), p)
}

fn parse_param(tokens: List<Token>, pos: Int, filename: String) -> ParamResult {
    let name: String = peek_value(tokens, pos)
    let mut p: Int = pos + 1
    p = expect(tokens, p, "COLON")
    let tr: TypeResult = parse_type_expr(tokens, p, filename)
    let param: Param = new_param(name, Some(tr.type_expr))
    return new_param_result(param, tr.pos)
}

// ---------------------------------------------------------------------------
// Struct definition
// ---------------------------------------------------------------------------

fn parse_struct_def(tokens: List<Token>, pos: Int, filename: String) -> DefResult {
    let mut p: Int = pos
    let mut is_pub: Bool = false

    if peek_type(tokens, p) == "KW_PUB" {
        is_pub = true
        p = p + 1
    }
    p = expect(tokens, p, "KW_STRUCT")

    let name: String = peek_value(tokens, p)
    p = p + 1

    let mut type_params: List<String> = []
    if peek_type(tokens, p) == "LT" {
        p = p + 1
        type_params.push(peek_value(tokens, p))
        p = p + 1
        for _ in 0..20 {
            if peek_type(tokens, p) != "COMMA" {
                p = expect(tokens, p, "GT")
                return parse_struct_fields(tokens, p, filename, name, is_pub, type_params)
            }
            p = p + 1
            type_params.push(peek_value(tokens, p))
            p = p + 1
        }
        p = expect(tokens, p, "GT")
    }

    return parse_struct_fields(tokens, p, filename, name, is_pub, type_params)
}

fn parse_struct_fields(tokens: List<Token>, pos: Int, filename: String, name: String, is_pub: Bool, type_params: List<String>) -> DefResult {
    let mut p: Int = pos
    p = expect(tokens, p, "LBRACE")

    let mut fields: List<StructField> = []
    for _ in 0..100 {
        p = skip_semis(tokens, p)
        if peek_type(tokens, p) == "RBRACE" {
            p = p + 1
            let sd_early: StructDefData = new_struct_def_data(name, is_pub, type_params, fields)
            return new_def_result(Definition::StructDef(sd_early), p)
        }

        let fname: String = peek_value(tokens, p)
        p = p + 1
        p = expect(tokens, p, "COLON")
        let tr: TypeResult = parse_type_expr(tokens, p, filename)
        p = tr.pos

        let field: StructField = new_struct_field(fname, tr.type_expr)
        fields.push(field)

        if peek_type(tokens, p) == "COMMA" { p = p + 1 }
    }

    let sd_final: StructDefData = new_struct_def_data(name, is_pub, type_params, fields)
    return new_def_result(Definition::StructDef(sd_final), p)
}

// ---------------------------------------------------------------------------
// Enum definition
// ---------------------------------------------------------------------------

fn parse_enum_def(tokens: List<Token>, pos: Int, filename: String) -> DefResult {
    let mut p: Int = pos
    let mut is_pub: Bool = false

    if peek_type(tokens, p) == "KW_PUB" {
        is_pub = true
        p = p + 1
    }
    p = expect(tokens, p, "KW_ENUM")

    let name: String = peek_value(tokens, p)
    p = p + 1

    let mut type_params: List<String> = []
    if peek_type(tokens, p) == "LT" {
        p = p + 1
        type_params.push(peek_value(tokens, p))
        p = p + 1
        for _ in 0..20 {
            if peek_type(tokens, p) != "COMMA" {
                p = expect(tokens, p, "GT")
                return parse_enum_body(tokens, p, filename, name, is_pub, type_params)
            }
            p = p + 1
            type_params.push(peek_value(tokens, p))
            p = p + 1
        }
        p = expect(tokens, p, "GT")
    }

    return parse_enum_body(tokens, p, filename, name, is_pub, type_params)
}

fn parse_enum_body(tokens: List<Token>, pos: Int, filename: String, name: String, is_pub: Bool, type_params: List<String>) -> DefResult {
    let mut p: Int = pos
    p = expect(tokens, p, "LBRACE")

    let mut variants: List<EnumVariant> = []
    for _ in 0..100 {
        p = skip_semis(tokens, p)
        if peek_type(tokens, p) == "RBRACE" {
            p = p + 1
            let ed_early: EnumDefData = new_enum_def_data(name, is_pub, type_params, variants)
            return new_def_result(Definition::EnumDef(ed_early), p)
        }

        let vname: String = peek_value(tokens, p)
        p = p + 1
        let mut vtypes: List<TypeExpr> = []

        if peek_type(tokens, p) == "LPAREN" {
            p = p + 1
            if peek_type(tokens, p) != "RPAREN" {
                let tr: TypeResult = parse_type_expr(tokens, p, filename)
                vtypes.push(tr.type_expr)
                p = tr.pos
                for _ in 0..20 {
                    if peek_type(tokens, p) != "COMMA" {
                        p = expect(tokens, p, "RPAREN")
                        let v_inner: EnumVariant = new_enum_variant(vname, vtypes)
                        variants.push(v_inner)
                        if peek_type(tokens, p) == "COMMA" { p = p + 1 }
                        // Continue loop
                        return parse_enum_body_continue(tokens, p, filename, name, is_pub, type_params, variants)
                    }
                    p = p + 1
                    let tr2: TypeResult = parse_type_expr(tokens, p, filename)
                    vtypes.push(tr2.type_expr)
                    p = tr2.pos
                }
            }
            p = expect(tokens, p, "RPAREN")
        }

        let v_outer: EnumVariant = new_enum_variant(vname, vtypes)
        variants.push(v_outer)

        if peek_type(tokens, p) == "COMMA" { p = p + 1 }
    }

    let ed_final: EnumDefData = new_enum_def_data(name, is_pub, type_params, variants)
    return new_def_result(Definition::EnumDef(ed_final), p)
}

fn parse_enum_body_continue(tokens: List<Token>, pos: Int, filename: String, name: String, is_pub: Bool, type_params: List<String>, variants: List<EnumVariant>) -> DefResult {
    let mut p: Int = pos
    let mut vars: List<EnumVariant> = variants

    for _ in 0..100 {
        p = skip_semis(tokens, p)
        if peek_type(tokens, p) == "RBRACE" {
            p = p + 1
            let ed_c_early: EnumDefData = new_enum_def_data(name, is_pub, type_params, vars)
            return new_def_result(Definition::EnumDef(ed_c_early), p)
        }

        let vn: String = peek_value(tokens, p)
        p = p + 1
        let mut vt: List<TypeExpr> = []

        if peek_type(tokens, p) == "LPAREN" {
            p = p + 1
            if peek_type(tokens, p) != "RPAREN" {
                let tr: TypeResult = parse_type_expr(tokens, p, filename)
                vt.push(tr.type_expr)
                p = tr.pos
                for _ in 0..20 {
                    if peek_type(tokens, p) != "COMMA" {
                        p = expect(tokens, p, "RPAREN")
                        let v2: EnumVariant = new_enum_variant(vn, vt)
                        vars.push(v2)
                        if peek_type(tokens, p) == "COMMA" { p = p + 1 }
                        return parse_enum_body_continue(tokens, p, filename, name, is_pub, type_params, vars)
                    }
                    p = p + 1
                    let tr2: TypeResult = parse_type_expr(tokens, p, filename)
                    vt.push(tr2.type_expr)
                    p = tr2.pos
                }
            }
            p = expect(tokens, p, "RPAREN")
        }

        let v: EnumVariant = new_enum_variant(vn, vt)
        vars.push(v)

        if peek_type(tokens, p) == "COMMA" { p = p + 1 }
    }

    let ed_c_final: EnumDefData = new_enum_def_data(name, is_pub, type_params, vars)
    return new_def_result(Definition::EnumDef(ed_c_final), p)
}

// ---------------------------------------------------------------------------
// Type alias
// ---------------------------------------------------------------------------

fn parse_type_alias_def(tokens: List<Token>, pos: Int, filename: String) -> DefResult {
    let mut p: Int = pos + 1
    let name: String = peek_value(tokens, p)
    p = p + 1
    p = expect(tokens, p, "ASSIGN")
    let tr: TypeResult = parse_type_expr(tokens, p, filename)
    return new_def_result(Definition::TypeAlias(name, tr.type_expr), tr.pos)
}

fn parse_tipo_def(tokens: List<Token>, pos: Int, filename: String) -> DefResult {
    // tipo Name { fields | variants } — unified type definition.
    // If first member starts with BAR → enum, else → struct.
    let mut p: Int = pos
    let mut is_pub: Bool = false
    if peek_type(tokens, p) == "KW_PUB" {
        is_pub = true
        p = p + 1
    }
    p = p + 1
    let name: String = peek_value(tokens, p)
    p = p + 1

    let mut type_params: List<String> = []
    if peek_type(tokens, p) == "LT" {
        p = p + 1
        type_params.push(peek_value(tokens, p))
        p = p + 1
        for _ in 0..20 {
            if peek_type(tokens, p) != "COMMA" {
                p = expect(tokens, p, "GT")
                // Peek after LBRACE to decide struct vs enum
                let peek_pos: Int = p + 1
                let first_tt: String = peek_type(tokens, skip_semis(tokens, peek_pos))
                if first_tt == "BAR" {
                    return parse_tipo_enum(tokens, p, filename, name, is_pub, type_params)
                }
                return parse_struct_fields(tokens, p, filename, name, is_pub, type_params)
            }
            p = p + 1
            type_params.push(peek_value(tokens, p))
            p = p + 1
        }
        p = expect(tokens, p, "GT")
    }

    // Peek inside { to decide: BAR → enum variants, else → struct fields
    let peek_inside: Int = skip_semis(tokens, p + 1)
    if peek_type(tokens, peek_inside) == "BAR" {
        return parse_tipo_enum(tokens, p, filename, name, is_pub, type_params)
    }
    return parse_struct_fields(tokens, p, filename, name, is_pub, type_params)
}

fn parse_tipo_enum(tokens: List<Token>, pos: Int, filename: String, name: String, is_pub: Bool, type_params: List<String>) -> DefResult {
    // Parse { | Variant1 | Variant2(Type) | ... }
    let mut p: Int = pos
    p = expect(tokens, p, "LBRACE")

    let mut variants: List<EnumVariant> = []
    for _ in 0..200 {
        p = skip_semis(tokens, p)
        if peek_type(tokens, p) == "RBRACE" {
            p = p + 1
            let ed: EnumDefData = new_enum_def_data(name, is_pub, type_params, variants)
            return new_def_result(Definition::EnumDef(ed), p)
        }
        p = expect(tokens, p, "BAR")
        let vname: String = peek_value(tokens, p)
        p = p + 1

        let mut vtypes: List<TypeExpr> = []
        if peek_type(tokens, p) == "LPAREN" {
            p = p + 1
            let mut done_args: Bool = false
            for _ in 0..20 {
                if !done_args {
                    if peek_type(tokens, p) == "RPAREN" {
                        p = p + 1
                        done_args = true
                    }
                }
                if !done_args {
                    let tr: TypeResult = parse_type_expr(tokens, p, filename)
                    vtypes.push(tr.type_expr)
                    p = tr.pos
                    if peek_type(tokens, p) == "COMMA" { p = p + 1 }
                }
            }
        }
        let v_parsed: EnumVariant = new_enum_variant(vname, vtypes)
        variants.push(v_parsed)
    }
    let ed_final: EnumDefData = new_enum_def_data(name, is_pub, type_params, variants)
    return new_def_result(Definition::EnumDef(ed_final), p)
}

// ---------------------------------------------------------------------------
// Impl definition
// ---------------------------------------------------------------------------

fn parse_impl_def(tokens: List<Token>, pos: Int, filename: String) -> DefResult {
    let mut p: Int = pos + 1
    let name: String = peek_value(tokens, p)
    p = p + 1
    p = expect(tokens, p, "LBRACE")

    let mut methods: List<FnDefData> = []
    for _ in 0..100 {
        p = skip_semis(tokens, p)
        if peek_type(tokens, p) == "RBRACE" {
            p = p + 1
            return new_def_result(Definition::ImplDef(name, methods), p)
        }
        let r: DefResult = parse_fn_def(tokens, p, filename)
        p = r.pos
    }

    return new_def_result(Definition::ImplDef(name, methods), p)
}

// ---------------------------------------------------------------------------
// Agent definition (brace-skip for bootstrap)
// ---------------------------------------------------------------------------

fn parse_agent_def(tokens: List<Token>, pos: Int, filename: String) -> DefResult {
    // Pre-create typed empty lists for AgentDefData constructor
    let no_inputs: List<AgentInput> = []
    let no_outputs: List<AgentOutput> = []
    let no_state: List<Stmt> = []
    let no_methods: List<FnDefData> = []
    let no_adecs: List<Decorator> = []
    let mut p: Int = pos
    let mut is_pub: Bool = false
    if peek_type(tokens, p) == "KW_PUB" {
        is_pub = true
        p = p + 1
    }
    p = expect(tokens, p, "KW_AGENT")
    let name: String = peek_value(tokens, p)
    p = p + 1
    p = expect(tokens, p, "LBRACE")
    let mut depth: Int = 1
    for _ in 0..100000 {
        if p >= len(tokens) {
            let ad_eof: AgentDefData = new_agent_def_data(name, is_pub, no_inputs, no_outputs, no_state, no_methods, no_adecs)
            return new_def_result(Definition::AgentDef(ad_eof), p)
        }
        let tt: String = peek_type(tokens, p)
        if tt == "LBRACE" { depth = depth + 1 }
        if tt == "RBRACE" {
            depth = depth - 1
            if depth == 0 {
                p = p + 1
                let ad_close: AgentDefData = new_agent_def_data(name, is_pub, no_inputs, no_outputs, no_state, no_methods, no_adecs)
                return new_def_result(Definition::AgentDef(ad_close), p)
            }
        }
        p = p + 1
    }
    let ad_end: AgentDefData = new_agent_def_data(name, is_pub, no_inputs, no_outputs, no_state, no_methods, no_adecs)
    return new_def_result(Definition::AgentDef(ad_end), p)
}

// ---------------------------------------------------------------------------
// Pipe definition (brace-skip for bootstrap)
// ---------------------------------------------------------------------------

fn parse_pipe_def(tokens: List<Token>, pos: Int, filename: String) -> DefResult {
    let no_stages: List<Expr> = []
    let mut p: Int = pos
    let mut is_pub: Bool = false
    if peek_type(tokens, p) == "KW_PUB" {
        is_pub = true
        p = p + 1
    }
    p = expect(tokens, p, "KW_PIPE")
    let name: String = peek_value(tokens, p)
    p = p + 1
    p = expect(tokens, p, "LBRACE")
    let mut depth: Int = 1
    for _ in 0..100000 {
        if p >= len(tokens) {
            let pd_eof: PipeDefData = new_pipe_def_data(name, is_pub, no_stages)
            return new_def_result(Definition::PipeDef(pd_eof), p)
        }
        let tt: String = peek_type(tokens, p)
        if tt == "LBRACE" { depth = depth + 1 }
        if tt == "RBRACE" {
            depth = depth - 1
            if depth == 0 {
                p = p + 1
                let pd_close: PipeDefData = new_pipe_def_data(name, is_pub, no_stages)
                return new_def_result(Definition::PipeDef(pd_close), p)
            }
        }
        p = p + 1
    }
    let pd_end: PipeDefData = new_pipe_def_data(name, is_pub, no_stages)
    return new_def_result(Definition::PipeDef(pd_end), p)
}

// ---------------------------------------------------------------------------
// Decorated definition
// ---------------------------------------------------------------------------

fn parse_decorated_def(tokens: List<Token>, pos: Int, filename: String) -> DefResult {
    let mut p: Int = pos
    for _ in 0..10 {
        if peek_type(tokens, p) != "AT" { return parse_definition(tokens, p, filename) }
        p = p + 1
        p = p + 1
        if peek_type(tokens, p) == "LPAREN" {
            p = p + 1
            let mut depth: Int = 1
            for _ in 0..1000 {
                if p >= len(tokens) { return parse_definition(tokens, p, filename) }
                if peek_type(tokens, p) == "LPAREN" { depth = depth + 1 }
                if peek_type(tokens, p) == "RPAREN" {
                    depth = depth - 1
                    if depth == 0 {
                        p = p + 1
                        return parse_definition(tokens, p, filename)
                    }
                }
                p = p + 1
            }
        }
    }
    return parse_definition(tokens, p, filename)
}

// ---------------------------------------------------------------------------
// Block
// ---------------------------------------------------------------------------

fn parse_block(tokens: List<Token>, pos: Int, filename: String) -> BlockResult {
    let mut p: Int = pos
    p = expect(tokens, p, "LBRACE")

    let mut stmts: List<Stmt> = []
    for _ in 0..100000 {
        p = skip_semis(tokens, p)
        if at_end(tokens, p) {
            let blk_eof: Block = new_block(new_span(0, 0, 0, 0), stmts)
            return new_block_result(blk_eof, p)
        }
        if peek_type(tokens, p) == "RBRACE" {
            p = p + 1
            let blk_close: Block = new_block(new_span(0, 0, 0, 0), stmts)
            return new_block_result(blk_close, p)
        }

        let sr: StmtResult = parse_stmt(tokens, p, filename)
        stmts.push(sr.stmt)
        p = sr.pos
    }

    let blk_end: Block = new_block(new_span(0, 0, 0, 0), stmts)
    return new_block_result(blk_end, p)
}

// ---------------------------------------------------------------------------
// Statement dispatch
// ---------------------------------------------------------------------------

fn parse_stmt(tokens: List<Token>, pos: Int, filename: String) -> StmtResult {
    let tt: String = peek_type(tokens, pos)

    if tt == "KW_LET" { return parse_let_stmt(tokens, pos, filename) }
    if tt == "KW_RETURN" { return parse_return_stmt(tokens, pos, filename) }
    if tt == "KW_FOR" { return parse_for_stmt(tokens, pos, filename) }
    if tt == "KW_WHILE" { return parse_while_stmt(tokens, pos, filename) }

    let er: ExprResult = parse_expr(tokens, pos, filename, 0)
    return new_stmt_result(Stmt::ExprStmt(er.expr), er.pos)
}

// ---------------------------------------------------------------------------
// Let statement
// ---------------------------------------------------------------------------

fn parse_let_stmt(tokens: List<Token>, pos: Int, filename: String) -> StmtResult {
    let mut p: Int = pos + 1
    let mut is_mut: Bool = false

    if peek_type(tokens, p) == "KW_MUT" {
        is_mut = true
        p = p + 1
    }

    let name: String = peek_value(tokens, p)
    p = p + 1

    let mut type_ann: Option<TypeExpr> = none
    if peek_type(tokens, p) == "COLON" {
        p = p + 1
        let tr: TypeResult = parse_type_expr(tokens, p, filename)
        type_ann = Some(tr.type_expr)
        p = tr.pos
    }

    p = expect(tokens, p, "ASSIGN")

    let er: ExprResult = parse_expr(tokens, p, filename, 0)
    return new_stmt_result(Stmt::Let(name, is_mut, type_ann, er.expr), er.pos)
}

// ---------------------------------------------------------------------------
// Return statement
// ---------------------------------------------------------------------------

fn parse_return_stmt(tokens: List<Token>, pos: Int, filename: String) -> StmtResult {
    let mut p: Int = pos + 1

    let tt: String = peek_type(tokens, p)
    if tt == "RBRACE" { return new_stmt_result(Stmt::Return(none), p) }
    if tt == "SEMICOLON" { return new_stmt_result(Stmt::Return(none), p) }
    if at_end(tokens, p) { return new_stmt_result(Stmt::Return(none), p) }

    let er: ExprResult = parse_expr(tokens, p, filename, 0)
    return new_stmt_result(Stmt::Return(Some(er.expr)), er.pos)
}

// ---------------------------------------------------------------------------
// For statement
// ---------------------------------------------------------------------------

fn parse_for_stmt(tokens: List<Token>, pos: Int, filename: String) -> StmtResult {
    let mut p: Int = pos + 1
    let var_name: String = peek_value(tokens, p)
    p = p + 1
    p = expect(tokens, p, "KW_IN")

    let er: ExprResult = parse_expr(tokens, p, filename, 0)
    p = er.pos

    let br: BlockResult = parse_block(tokens, p, filename)
    return new_stmt_result(Stmt::For(var_name, er.expr, br.block), br.pos)
}

fn parse_while_stmt(tokens: List<Token>, pos: Int, filename: String) -> StmtResult {
    // Desugar: while cond { body }
    // → for __w in 0..1000000 { if !(cond) { return } else { body } }
    // But we don't have break/return-from-loop. Instead, use a simpler
    // desugaring that reuses the for-loop infrastructure:
    //   for __w in 0..1000000 { if cond { body-stmts } }
    // This runs the body only while cond is true.
    // To avoid stack overflow from allocas in the loop, we keep the body
    // minimal (no extra allocas beyond what the body already needs).
    let mut p: Int = pos + 1

    // Parse condition expression
    let cond_r: ExprResult = parse_expr(tokens, p, filename, 0)
    p = cond_r.pos

    // Parse body block
    let body_r: BlockResult = parse_block(tokens, p, filename)
    p = body_r.pos

    // Build: if cond { body-stmts } — reuse the body's stmts directly
    let if_expr: Expr = Expr::If(cond_r.expr, body_r.block, none)
    let if_stmt: Stmt = Stmt::ExprStmt(if_expr)

    // Build loop body with just the if
    let mut loop_stmts: List<Stmt> = []
    loop_stmts.push(if_stmt)
    let loop_block: Block = new_block(new_span(0, 0, 0, 0), loop_stmts)

    // Range 0..100000 (reasonable limit for while loops)
    let range_expr: Expr = Expr::Range(Expr::IntLit(0), Expr::IntLit(100000), false)

    return new_stmt_result(Stmt::For("__w", range_expr, loop_block), p)
}

// ---------------------------------------------------------------------------
// Expression parser — precedence climbing
// ---------------------------------------------------------------------------

fn parse_expr(tokens: List<Token>, pos: Int, filename: String, min_prec: Int) -> ExprResult {
    let mut left_r: ExprResult = parse_unary(tokens, pos, filename)
    let mut left: Expr = left_r.expr
    let mut p: Int = left_r.pos

    // Assignment operators (right-associative, lowest precedence)
    if min_prec == 0 {
        let att: String = peek_type(tokens, p)
        if att == "ASSIGN" {
            p = p + 1
            let rhs_eq: ExprResult = parse_expr(tokens, p, filename, 0)
            return new_expr_result(Expr::Assign(left, "=", rhs_eq.expr), rhs_eq.pos)
        }
        if att == "PLUS_EQ" {
            p = p + 1
            let rhs_add: ExprResult = parse_expr(tokens, p, filename, 0)
            return new_expr_result(Expr::Assign(left, "+=", rhs_add.expr), rhs_add.pos)
        }
        if att == "MINUS_EQ" {
            p = p + 1
            let rhs_sub: ExprResult = parse_expr(tokens, p, filename, 0)
            return new_expr_result(Expr::Assign(left, "-=", rhs_sub.expr), rhs_sub.pos)
        }
        if att == "STAR_EQ" {
            p = p + 1
            let rhs_mul: ExprResult = parse_expr(tokens, p, filename, 0)
            return new_expr_result(Expr::Assign(left, "*=", rhs_mul.expr), rhs_mul.pos)
        }
        if att == "SLASH_EQ" {
            p = p + 1
            let rhs_div: ExprResult = parse_expr(tokens, p, filename, 0)
            return new_expr_result(Expr::Assign(left, "/=", rhs_div.expr), rhs_div.pos)
        }
        if att == "SEND" {
            p = p + 1
            let rhs_send: ExprResult = parse_expr(tokens, p, filename, 0)
            return new_expr_result(Expr::Send(left, rhs_send.expr), rhs_send.pos)
        }
        if att == "FAT_ARROW" {
            p = p + 1
            let body: ExprResult = parse_expr(tokens, p, filename, 0)
            // Extract lambda params from the left-hand side expression.
            // (n) => ... parses as Ident("n") on the left of =>
            let mut params: List<Param> = []
            match left {
                Ident(name) => {
                    params.push(new_param(name, none))
                },
                _ => {}
            }
            return new_expr_result(Expr::Lambda(params, LambdaBody::ExprBody(body.expr)), body.pos)
        }
    }

    // Binary operator loop
    for _ in 0..10000 {
        if at_end(tokens, p) { return new_expr_result(left, p) }

        let op_tt: String = peek_type(tokens, p)
        let op: String = tok_to_binop(op_tt)
        if op == "" { return new_expr_result(left, p) }

        let prec: Int = op_precedence(op)
        if prec < min_prec { return new_expr_result(left, p) }

        p = p + 1

        let mut next_prec: Int = prec + 1
        if is_right_assoc(op) { next_prec = prec }

        let right_r: ExprResult = parse_expr(tokens, p, filename, next_prec)
        p = right_r.pos

        if op == "|>" {
            left = Expr::Pipe(left, right_r.expr)
        } else {
            if op == ".." {
                left = Expr::Range(left, right_r.expr, false)
            } else {
                if op == "..=" {
                    left = Expr::Range(left, right_r.expr, true)
                } else {
                    left = Expr::Binary(left, op, right_r.expr)
                }
            }
        }
    }

    return new_expr_result(left, p)
}

// ---------------------------------------------------------------------------
// Unary expressions
// ---------------------------------------------------------------------------

fn parse_unary(tokens: List<Token>, pos: Int, filename: String) -> ExprResult {
    let tt: String = peek_type(tokens, pos)

    if tt == "MINUS" {
        let r_neg: ExprResult = parse_unary(tokens, pos + 1, filename)
        return new_expr_result(Expr::Unary("-", r_neg.expr), r_neg.pos)
    }
    if tt == "BANG" {
        let r_not: ExprResult = parse_unary(tokens, pos + 1, filename)
        return new_expr_result(Expr::Unary("!", r_not.expr), r_not.pos)
    }

    return parse_postfix(tokens, pos, filename)
}

// ---------------------------------------------------------------------------
// Postfix expressions
// ---------------------------------------------------------------------------

fn parse_postfix(tokens: List<Token>, pos: Int, filename: String) -> ExprResult {
    let mut ar: ExprResult = parse_atom(tokens, pos, filename)
    let mut left: Expr = ar.expr
    let mut p: Int = ar.pos

    for _ in 0..10000 {
        if at_end(tokens, p) { return new_expr_result(left, p) }

        let tt: String = peek_type(tokens, p)

        if tt == "LPAREN" {
            let cr: ExprResult = parse_call_args(tokens, p, filename, left)
            left = cr.expr
            p = cr.pos
        } else {
            if tt == "DOT" {
                p = p + 1
                let field_name: String = peek_value(tokens, p)
                p = p + 1

                if peek_type(tokens, p) == "LPAREN" {
                    let mr: ExprResult = parse_method_args(tokens, p, filename, left, field_name)
                    left = mr.expr
                    p = mr.pos
                } else {
                    left = Expr::FieldAccess(left, field_name)
                }
            } else {
                if tt == "LBRACKET" {
                    p = p + 1
                    let idx_r: ExprResult = parse_expr(tokens, p, filename, 0)
                    p = idx_r.pos
                    p = expect(tokens, p, "RBRACKET")
                    left = Expr::Index(left, idx_r.expr)
                } else {
                    if tt == "QUESTION" {
                        p = p + 1
                        left = Expr::ErrorProp(left)
                    } else {
                        return new_expr_result(left, p)
                    }
                }
            }
        }
    }

    return new_expr_result(left, p)
}

fn parse_call_args(tokens: List<Token>, pos: Int, filename: String, callee: Expr) -> ExprResult {
    let mut p: Int = pos + 1
    let mut args: List<Expr> = []

    if peek_type(tokens, p) == "RPAREN" {
        p = p + 1
        return new_expr_result(Expr::Call(callee, args), p)
    }

    let a0: ExprResult = parse_expr(tokens, p, filename, 0)
    args.push(a0.expr)
    p = a0.pos

    for _ in 0..100 {
        if peek_type(tokens, p) != "COMMA" {
            p = expect(tokens, p, "RPAREN")
            return new_expr_result(Expr::Call(callee, args), p)
        }
        p = p + 1
        if peek_type(tokens, p) == "RPAREN" {
            p = p + 1
            return new_expr_result(Expr::Call(callee, args), p)
        }
        let an: ExprResult = parse_expr(tokens, p, filename, 0)
        args.push(an.expr)
        p = an.pos
    }

    p = expect(tokens, p, "RPAREN")
    return new_expr_result(Expr::Call(callee, args), p)
}

fn parse_method_args(tokens: List<Token>, pos: Int, filename: String, obj: Expr, method: String) -> ExprResult {
    let mut p: Int = pos + 1
    let mut args: List<Expr> = []

    if peek_type(tokens, p) == "RPAREN" {
        p = p + 1
        return new_expr_result(Expr::MethodCall(obj, method, args), p)
    }

    let a0: ExprResult = parse_expr(tokens, p, filename, 0)
    args.push(a0.expr)
    p = a0.pos

    for _ in 0..100 {
        if peek_type(tokens, p) != "COMMA" {
            p = expect(tokens, p, "RPAREN")
            return new_expr_result(Expr::MethodCall(obj, method, args), p)
        }
        p = p + 1
        if peek_type(tokens, p) == "RPAREN" {
            p = p + 1
            return new_expr_result(Expr::MethodCall(obj, method, args), p)
        }
        let an: ExprResult = parse_expr(tokens, p, filename, 0)
        args.push(an.expr)
        p = an.pos
    }

    p = expect(tokens, p, "RPAREN")
    return new_expr_result(Expr::MethodCall(obj, method, args), p)
}

// ---------------------------------------------------------------------------
// String interpolation helpers
// ---------------------------------------------------------------------------

fn has_interpolation(s: String) -> Bool {
    for i in 0..len(s) {
        if s.char_at(i) == "$" {
            if i + 1 < len(s) {
                if s.char_at(i + 1) == "{" {
                    // Check not escaped
                    if i == 0 { return true }
                    if s.char_at(i - 1) != "\\" { return true }
                }
            }
        }
    }
    return false
}

fn split_interp_parts(s: String) -> List<Expr> {
    let mut parts: List<Expr> = []
    let mut lit: String = ""
    let mut i: Int = 0
    for _ in 0..100000 {
        if i >= len(s) {
            if len(lit) > 0 { parts.push(Expr::StringLit(lit)) }
            return parts
        }
        let ch: String = s.char_at(i)
        if ch == "\\" {
            if i + 1 < len(s) {
                if s.char_at(i + 1) == "$" {
                    lit = lit + "$"
                    i = i + 2
                } else {
                    lit = lit + ch
                    i = i + 1
                }
            } else {
                lit = lit + ch
                i = i + 1
            }
        } else {
            if ch == "$" {
                if i + 1 < len(s) {
                    if s.char_at(i + 1) == "{" {
                        // Flush literal
                        if len(lit) > 0 {
                            parts.push(Expr::StringLit(lit))
                            lit = ""
                        }
                        // Find matching }
                        let mut depth: Int = 1
                        let mut j: Int = i + 2
                        for _ in 0..10000 {
                            if j >= len(s) { return parts }
                            if depth == 0 { return parts }
                            if s.char_at(j) == "{" { depth = depth + 1 }
                            if s.char_at(j) == "}" {
                                depth = depth - 1
                                if depth == 0 {
                                    // Extract expression text between ${ and }
                                    let expr_text: String = s.substr(i + 2, j)
                                    // For now, treat as Ident (simple variable reference)
                                    parts.push(Expr::Ident(expr_text))
                                    i = j + 1
                                    return parts
                                }
                            }
                            j = j + 1
                        }
                        i = j
                    } else {
                        lit = lit + ch
                        i = i + 1
                    }
                } else {
                    lit = lit + ch
                    i = i + 1
                }
            } else {
                lit = lit + ch
                i = i + 1
            }
        }
    }
    if len(lit) > 0 { parts.push(Expr::StringLit(lit)) }
    return parts
}

// ---------------------------------------------------------------------------
// Atom expressions
// ---------------------------------------------------------------------------

fn parse_struct_fields_to_list(tokens: List<Token>, pos: Int, filename: String) -> ExprResult {
    // Parse field values: name: expr, name: expr, ...
    // Returns a ListLit of the field values (ignoring field names)
    let mut p: Int = pos
    let mut vals: List<Expr> = []
    for _ in 0..100 {
        if peek_type(tokens, p) == "RBRACE" {
            return new_expr_result(Expr::ListLit(vals), p + 1)
        }
        p = p + 1  // skip field name
        p = expect(tokens, p, "COLON")
        let er: ExprResult = parse_expr(tokens, p, filename, 0)
        p = er.pos
        vals.push(er.expr)
        if peek_type(tokens, p) == "COMMA" { p = p + 1 }
    }
    return new_expr_result(Expr::ListLit(vals), p)
}

fn parse_struct_construct(tokens: List<Token>, pos: Int, filename: String) -> ExprResult {
    // Parse: new Name { field1: val1, field2: val2 }
    // Returns Call(Ident("__new_Name"), [val1, val2])
    let struct_name: String = peek_value(tokens, pos + 1)
    let mut p: Int = pos + 2
    p = expect(tokens, p, "LBRACE")

    // Parse field values (returns ListLit wrapping the values)
    let fields_r: ExprResult = parse_struct_fields_to_list(tokens, p, filename)
    p = fields_r.pos

    // Extract the values from ListLit
    // The lowerer will handle Call("__new_Name", args) as struct construction
    let callee: Expr = Expr::Ident("__new_" + struct_name)
    match fields_r.expr {
        ListLit(vals) => {
            return new_expr_result(Expr::Call(callee, vals), p)
        },
        _ => {
            let empty: List<Expr> = []
            return new_expr_result(Expr::Call(callee, empty), p)
        }
    }
}

fn parse_atom(tokens: List<Token>, pos: Int, filename: String) -> ExprResult {
    let tt: String = peek_type(tokens, pos)
    let val: String = peek_value(tokens, pos)

    // Integer literals
    if tt == "DEC_INT" { return new_expr_result(Expr::IntLit(int(val)), pos + 1) }
    if tt == "HEX_INT" { return new_expr_result(Expr::IntLit(int(val)), pos + 1) }
    if tt == "BIN_INT" { return new_expr_result(Expr::IntLit(int(val)), pos + 1) }
    if tt == "OCT_INT" { return new_expr_result(Expr::IntLit(int(val)), pos + 1) }

    // Float literal
    if tt == "FLOAT_LIT" { return new_expr_result(Expr::FloatLit(float(val)), pos + 1) }

    // String literal — check for interpolation ${...}
    if tt == "STRING_LIT" {
        if has_interpolation(val) {
            let parts: List<Expr> = split_interp_parts(val)
            if len(parts) > 1 {
                // Multiple parts: return as a binary concat chain
                let mut result: Expr = parts[0]
                for i in 1..len(parts) {
                    result = Expr::Binary(result, "+", parts[i])
                }
                return new_expr_result(result, pos + 1)
            }
        }
        return new_expr_result(Expr::StringLit(val), pos + 1)
    }

    // Char literal
    if tt == "CHAR_LIT" { return new_expr_result(Expr::CharLit(val), pos + 1) }

    // Bool literals
    if tt == "KW_TRUE" { return new_expr_result(Expr::BoolLit(true), pos + 1) }
    if tt == "KW_FALSE" { return new_expr_result(Expr::BoolLit(false), pos + 1) }

    // None literal
    if tt == "KW_NONE" { return new_expr_result(Expr::NoneLit, pos + 1) }

    // Self
    if tt == "KW_SELF" { return new_expr_result(Expr::Ident("self"), pos + 1) }

    // If expression
    if tt == "KW_IF" { return parse_if_expr(tokens, pos, filename) }

    // Match expression
    if tt == "KW_MATCH" { return parse_match_expr(tokens, pos, filename) }

    // Spawn expression
    if tt == "KW_SPAWN" { return parse_spawn_expr(tokens, pos, filename) }

    // Sync expression
    if tt == "KW_SYNC" {
        let sr: ExprResult = parse_postfix(tokens, pos + 1, filename)
        return new_expr_result(Expr::Sync(sr.expr), sr.pos)
    }

    // Signal expression
    if tt == "KW_SIGNAL" { return parse_signal_expr(tokens, pos, filename) }

    // Map literal: #{ key: val, ... }
    if tt == "MAP_OPEN" { return parse_map_lit(tokens, pos, filename) }

    // List literal
    if tt == "LBRACKET" { return parse_list_lit(tokens, pos, filename) }

    // Parenthesized expression
    if tt == "LPAREN" { return parse_paren_expr(tokens, pos, filename) }

    // Struct constructor: new Name { field: val, ... }
    // Emits as Call(Ident("__new_Name"), [val1, val2, ...]).
    // The emitter handles __new_ calls as struct construction.
    if tt == "KW_NEW" {
        return parse_struct_construct(tokens, pos, filename)
    }

    // Identifier or namespace access
    if tt == "NAME" {
        let name: String = val
        if peek_type(tokens, pos + 1) == "DOUBLE_COLON" {
            let ns_member: String = peek_value(tokens, pos + 2)
            return new_expr_result(Expr::NamespaceAccess(name, ns_member), pos + 3)
        }
        return new_expr_result(Expr::Ident(name), pos + 1)
    }

    // Fallback
    return new_expr_result(Expr::NoneLit, pos + 1)
}

// ---------------------------------------------------------------------------
// If expression
// ---------------------------------------------------------------------------

fn parse_if_expr(tokens: List<Token>, pos: Int, filename: String) -> ExprResult {
    let mut p: Int = pos + 1

    let cond_r: ExprResult = parse_expr(tokens, p, filename, 0)
    p = cond_r.pos

    let then_r: BlockResult = parse_block(tokens, p, filename)
    p = then_r.pos

    if peek_type(tokens, p) != "KW_ELSE" {
        return new_expr_result(Expr::If(cond_r.expr, then_r.block, none), p)
    }

    p = p + 1

    if peek_type(tokens, p) == "KW_IF" {
        let elif_r: ExprResult = parse_if_expr(tokens, p, filename)
        let else_stmts: List<Stmt> = [Stmt::ExprStmt(elif_r.expr)]
        let else_block: Block = new_block(new_span(0, 0, 0, 0), else_stmts)
        let ec_elif: ElseClause = ElseClause::ElseBlock(else_block)
        return new_expr_result(Expr::If(cond_r.expr, then_r.block, Some(ec_elif)), elif_r.pos)
    }

    let else_r: BlockResult = parse_block(tokens, p, filename)
    let ec_else: ElseClause = ElseClause::ElseBlock(else_r.block)
    return new_expr_result(Expr::If(cond_r.expr, then_r.block, Some(ec_else)), else_r.pos)
}

// ---------------------------------------------------------------------------
// Match expression
// ---------------------------------------------------------------------------

fn parse_match_expr(tokens: List<Token>, pos: Int, filename: String) -> ExprResult {
    let mut p: Int = pos + 1

    let subj_r: ExprResult = parse_expr(tokens, p, filename, 0)
    p = subj_r.pos

    p = expect(tokens, p, "LBRACE")

    let mut arms: List<MatchArm> = []
    for _ in 0..100 {
        p = skip_semis(tokens, p)
        if peek_type(tokens, p) == "RBRACE" {
            p = p + 1
            return new_expr_result(Expr::Match(subj_r.expr, arms), p)
        }

        let mar: MatchArmResult = parse_match_arm_item(tokens, p, filename)
        arms.push(mar.arm)
        p = mar.pos

        if peek_type(tokens, p) == "COMMA" { p = p + 1 }
    }

    return new_expr_result(Expr::Match(subj_r.expr, arms), p)
}

fn parse_match_arm_item(tokens: List<Token>, pos: Int, filename: String) -> MatchArmResult {
    let pr: PatternResult = parse_pattern(tokens, pos, filename)
    let mut p: Int = pr.pos
    p = expect(tokens, p, "FAT_ARROW")

    if peek_type(tokens, p) == "LBRACE" {
        let br: BlockResult = parse_block(tokens, p, filename)
        let arm_blk: MatchArm = new_match_arm(pr.pattern, MatchArmBody::BlockBody(br.block))
        return new_match_arm_result(arm_blk, br.pos)
    }

    let er: ExprResult = parse_expr(tokens, p, filename, 0)
    let arm_expr: MatchArm = new_match_arm(pr.pattern, MatchArmBody::ExprBody(er.expr))
    return new_match_arm_result(arm_expr, er.pos)
}

// ---------------------------------------------------------------------------
// Pattern
// ---------------------------------------------------------------------------

fn parse_pattern(tokens: List<Token>, pos: Int, filename: String) -> PatternResult {
    let tt: String = peek_type(tokens, pos)
    let val: String = peek_value(tokens, pos)

    if val == "_" {
        return new_pattern_result(Pattern::Wildcard, pos + 1)
    }

    if tt == "DEC_INT" { return new_pattern_result(Pattern::LiteralPat(Expr::IntLit(int(val))), pos + 1) }
    if tt == "FLOAT_LIT" { return new_pattern_result(Pattern::LiteralPat(Expr::FloatLit(float(val))), pos + 1) }
    if tt == "STRING_LIT" { return new_pattern_result(Pattern::LiteralPat(Expr::StringLit(val)), pos + 1) }
    if tt == "KW_TRUE" { return new_pattern_result(Pattern::LiteralPat(Expr::BoolLit(true)), pos + 1) }
    if tt == "KW_FALSE" { return new_pattern_result(Pattern::LiteralPat(Expr::BoolLit(false)), pos + 1) }

    if tt == "NAME" {
        if peek_type(tokens, pos + 1) == "LPAREN" {
            let name: String = val
            let mut p: Int = pos + 2
            let mut pats: List<Pattern> = []

            if peek_type(tokens, p) != "RPAREN" {
                let p0: PatternResult = parse_pattern(tokens, p, filename)
                pats.push(p0.pattern)
                p = p0.pos
                for _ in 0..20 {
                    if peek_type(tokens, p) != "COMMA" {
                        p = expect(tokens, p, "RPAREN")
                        return new_pattern_result(Pattern::ConstructorPat(name, pats), p)
                    }
                    p = p + 1
                    let pn: PatternResult = parse_pattern(tokens, p, filename)
                    pats.push(pn.pattern)
                    p = pn.pos
                }
            }
            p = expect(tokens, p, "RPAREN")
            return new_pattern_result(Pattern::ConstructorPat(name, pats), p)
        }

        return new_pattern_result(Pattern::IdentPat(val), pos + 1)
    }

    return new_pattern_result(Pattern::Wildcard, pos + 1)
}

// ---------------------------------------------------------------------------
// Spawn expression
// ---------------------------------------------------------------------------

fn parse_spawn_expr(tokens: List<Token>, pos: Int, filename: String) -> ExprResult {
    let mut p: Int = pos + 1
    let name: String = peek_value(tokens, p)
    p = p + 1

    p = expect(tokens, p, "LPAREN")
    let mut args: List<Expr> = []
    if peek_type(tokens, p) != "RPAREN" {
        let a0: ExprResult = parse_expr(tokens, p, filename, 0)
        args.push(a0.expr)
        p = a0.pos
        for _ in 0..50 {
            if peek_type(tokens, p) != "COMMA" {
                p = expect(tokens, p, "RPAREN")
                let callee_early: Expr = Expr::Ident(name)
                return new_expr_result(Expr::Spawn(callee_early, args), p)
            }
            p = p + 1
            let an: ExprResult = parse_expr(tokens, p, filename, 0)
            args.push(an.expr)
            p = an.pos
        }
    }
    p = expect(tokens, p, "RPAREN")
    let callee_final: Expr = Expr::Ident(name)
    return new_expr_result(Expr::Spawn(callee_final, args), p)
}

// ---------------------------------------------------------------------------
// Signal expression
// ---------------------------------------------------------------------------

fn parse_signal_expr(tokens: List<Token>, pos: Int, filename: String) -> ExprResult {
    let mut p: Int = pos + 1

    if peek_type(tokens, p) == "LPAREN" {
        p = p + 1
        let er: ExprResult = parse_expr(tokens, p, filename, 0)
        p = er.pos
        p = expect(tokens, p, "RPAREN")
        return new_expr_result(Expr::SignalVal(er.expr, false), p)
    }

    if peek_type(tokens, p) == "LBRACE" {
        let br: BlockResult = parse_block(tokens, p, filename)
        return new_expr_result(Expr::SignalVal(Expr::NoneLit, true), br.pos)
    }

    return new_expr_result(Expr::NoneLit, p)
}

// ---------------------------------------------------------------------------
// List literal
// ---------------------------------------------------------------------------

fn parse_map_lit(tokens: List<Token>, pos: Int, filename: String) -> ExprResult {
    // MAP_OPEN = "#{", already consumed one token (pos is at MAP_OPEN)
    let mut p: Int = pos + 1
    let mut entries: List<MapEntry> = []

    // Empty map: #{}
    if peek_type(tokens, p) == "RBRACE" {
        p = p + 1
        return new_expr_result(Expr::MapLit(entries), p)
    }

    // First entry: key: value
    let k0: ExprResult = parse_expr(tokens, p, filename, 0)
    p = k0.pos
    p = expect(tokens, p, "COLON")
    let v0: ExprResult = parse_expr(tokens, p, filename, 0)
    p = v0.pos
    entries.push(new MapEntry { key: k0.expr, value: v0.expr })

    for _ in 0..10000 {
        if peek_type(tokens, p) != "COMMA" {
            p = expect(tokens, p, "RBRACE")
            return new_expr_result(Expr::MapLit(entries), p)
        }
        p = p + 1
        if peek_type(tokens, p) == "RBRACE" {
            p = p + 1
            return new_expr_result(Expr::MapLit(entries), p)
        }
        let kn: ExprResult = parse_expr(tokens, p, filename, 0)
        p = kn.pos
        p = expect(tokens, p, "COLON")
        let vn: ExprResult = parse_expr(tokens, p, filename, 0)
        p = vn.pos
        entries.push(new MapEntry { key: kn.expr, value: vn.expr })
    }

    p = expect(tokens, p, "RBRACE")
    return new_expr_result(Expr::MapLit(entries), p)
}

fn parse_list_lit(tokens: List<Token>, pos: Int, filename: String) -> ExprResult {
    let mut p: Int = pos + 1
    let mut elems: List<Expr> = []

    if peek_type(tokens, p) == "RBRACKET" {
        p = p + 1
        return new_expr_result(Expr::ListLit(elems), p)
    }

    let e0: ExprResult = parse_expr(tokens, p, filename, 0)
    elems.push(e0.expr)
    p = e0.pos

    for _ in 0..10000 {
        if peek_type(tokens, p) != "COMMA" {
            p = expect(tokens, p, "RBRACKET")
            return new_expr_result(Expr::ListLit(elems), p)
        }
        p = p + 1
        if peek_type(tokens, p) == "RBRACKET" {
            p = p + 1
            return new_expr_result(Expr::ListLit(elems), p)
        }
        let en_val: ExprResult = parse_expr(tokens, p, filename, 0)
        elems.push(en_val.expr)
        p = en_val.pos
    }

    p = expect(tokens, p, "RBRACKET")
    return new_expr_result(Expr::ListLit(elems), p)
}

// ---------------------------------------------------------------------------
// Parenthesized expression
// ---------------------------------------------------------------------------

fn parse_paren_expr(tokens: List<Token>, pos: Int, filename: String) -> ExprResult {
    let mut p: Int = pos + 1

    let er: ExprResult = parse_expr(tokens, p, filename, 0)
    p = er.pos

    if peek_type(tokens, p) == "RPAREN" {
        p = p + 1
        return new_expr_result(er.expr, p)
    }

    // Tuple: (expr, expr, ...)
    let mut elems: List<Expr> = [er.expr]
    for _ in 0..100 {
        if peek_type(tokens, p) != "COMMA" {
            p = expect(tokens, p, "RPAREN")
            return new_expr_result(Expr::ListLit(elems), p)
        }
        p = p + 1
        let en_val: ExprResult = parse_expr(tokens, p, filename, 0)
        elems.push(en_val.expr)
        p = en_val.pos
    }
    p = expect(tokens, p, "RPAREN")
    return new_expr_result(Expr::ListLit(elems), p)
}

// ---------------------------------------------------------------------------
// Type expression parser
// ---------------------------------------------------------------------------

fn parse_type_expr(tokens: List<Token>, pos: Int, filename: String) -> TypeResult {
    let tt: String = peek_type(tokens, pos)

    if tt == "KW_FN" { return parse_fn_type(tokens, pos, filename) }

    if tt == "NAME" {
        let name: String = peek_value(tokens, pos)
        if peek_type(tokens, pos + 1) == "LT" {
            return parse_generic_type(tokens, pos, filename)
        }
        return new_type_result(TypeExpr::Named(name), pos + 1)
    }

    return new_type_result(TypeExpr::Named("Void"), pos + 1)
}

fn parse_generic_type(tokens: List<Token>, pos: Int, filename: String) -> TypeResult {
    let name: String = peek_value(tokens, pos)
    let mut p: Int = pos + 1
    p = expect(tokens, p, "LT")

    let mut args: List<TypeExpr> = []
    let t0: TypeResult = parse_type_expr(tokens, p, filename)
    args.push(t0.type_expr)
    p = t0.pos

    for _ in 0..20 {
        if peek_type(tokens, p) != "COMMA" {
            p = expect(tokens, p, "GT")
            return new_type_result(TypeExpr::Generic(name, args), p)
        }
        p = p + 1
        let tn: TypeResult = parse_type_expr(tokens, p, filename)
        args.push(tn.type_expr)
        p = tn.pos
    }

    p = expect(tokens, p, "GT")
    return new_type_result(TypeExpr::Generic(name, args), p)
}

fn parse_fn_type(tokens: List<Token>, pos: Int, filename: String) -> TypeResult {
    let mut p: Int = pos + 1
    p = expect(tokens, p, "LPAREN")

    let mut param_types: List<TypeExpr> = []
    if peek_type(tokens, p) != "RPAREN" {
        let t0: TypeResult = parse_type_expr(tokens, p, filename)
        param_types.push(t0.type_expr)
        p = t0.pos
        for _ in 0..20 {
            if peek_type(tokens, p) != "COMMA" {
                p = expect(tokens, p, "RPAREN")
                p = expect(tokens, p, "ARROW")
                let ret_early: TypeResult = parse_type_expr(tokens, p, filename)
                return new_type_result(TypeExpr::FnTy(param_types, ret_early.type_expr), ret_early.pos)
            }
            p = p + 1
            let tn: TypeResult = parse_type_expr(tokens, p, filename)
            param_types.push(tn.type_expr)
            p = tn.pos
        }
    }
    p = expect(tokens, p, "RPAREN")
    p = expect(tokens, p, "ARROW")
    let ret_final: TypeResult = parse_type_expr(tokens, p, filename)
    return new_type_result(TypeExpr::FnTy(param_types, ret_final.type_expr), ret_final.pos)
}

// ===== semantic.mn =====
// semantic.mn — Semantic analysis for the Mapanare self-hosted compiler.
// Port of mapa/semantic.py to native Mapanare.
// Performs type checking and scope resolution via two-pass analysis:
//   Pass 1: register all top-level definitions (names & signatures)
//   Pass 2: check function bodies, expressions, and statements


// ---------------------------------------------------------------------------
// SemanticError
// ---------------------------------------------------------------------------

struct SemanticError {
    message: String,
    line: Int,
    column: Int,
    filename: String
}

fn new_semantic_error(msg: String, line: Int, col: Int, fname: String) -> SemanticError {
    return new SemanticError { message: msg, line: line, column: col, filename: fname }
}

// ---------------------------------------------------------------------------
// Type representation
// ---------------------------------------------------------------------------

struct TypeInfo {
    name: String,
    args: List<TypeInfo>,
    is_function: Bool,
    param_types: List<TypeInfo>,
    return_type: Option<TypeInfo>,
    tensor_shape: Option<List<Int>>
}

fn new_type_info(name: String, args: List<TypeInfo>, is_fn: Bool, params: List<TypeInfo>, ret: Option<TypeInfo>, shape: Option<List<Int>>) -> TypeInfo {
    return new TypeInfo { name: name, args: args, is_function: is_fn, param_types: params, return_type: ret, tensor_shape: shape }
}

// Singleton type constructors
fn unknown_type() -> TypeInfo {
    return make_type("<unknown>")
}

fn int_type() -> TypeInfo {
    return make_type("Int")
}

fn float_type() -> TypeInfo {
    return make_type("Float")
}

fn bool_type() -> TypeInfo {
    return make_type("Bool")
}

fn string_type() -> TypeInfo {
    return make_type("String")
}

fn char_type() -> TypeInfo {
    return make_type("Char")
}

fn void_type() -> TypeInfo {
    return make_type("Void")
}

fn make_type(name: String) -> TypeInfo {
    let args: List<TypeInfo> = []
    let params: List<TypeInfo> = []
    return new_type_info(name, args, false, params, none, none)
}

fn make_generic_type(name: String, args: List<TypeInfo>) -> TypeInfo {
    let params: List<TypeInfo> = []
    return new_type_info(name, args, false, params, none, none)
}

fn make_fn_type(params: List<TypeInfo>, ret: TypeInfo) -> TypeInfo {
    let args: List<TypeInfo> = []
    return new_type_info("<fn>", args, true, params, Some(ret), none)
}

fn make_builtin_fn_type(ret: TypeInfo) -> TypeInfo {
    let args: List<TypeInfo> = []
    let params: List<TypeInfo> = []
    return new_type_info("<builtin>", args, true, params, Some(ret), none)
}

// ---------------------------------------------------------------------------
// Primitive and builtin type sets
// ---------------------------------------------------------------------------

fn is_primitive_type(name: String) -> Bool {
    if name == "Int" { return true }
    if name == "Float" { return true }
    if name == "Bool" { return true }
    if name == "String" { return true }
    if name == "Char" { return true }
    if name == "Void" { return true }
    return false
}

fn is_builtin_generic(name: String) -> Bool {
    if name == "Option" { return true }
    if name == "Result" { return true }
    if name == "List" { return true }
    if name == "Map" { return true }
    if name == "Signal" { return true }
    if name == "Stream" { return true }
    if name == "Channel" { return true }
    if name == "Tensor" { return true }
    return false
}

fn is_builtin_function(name: String) -> Bool {
    if name == "print" { return true }
    if name == "println" { return true }
    if name == "len" { return true }
    if name == "toString" { return true }
    if name == "str" { return true }
    if name == "int" { return true }
    if name == "float" { return true }
    if name == "Some" { return true }
    if name == "Ok" { return true }
    if name == "Err" { return true }
    if name == "signal" { return true }
    if name == "stream" { return true }
    if name == "ord" { return true }
    if name == "chr" { return true }
    if name == "join" { return true }
    return false
}

fn builtin_return_type(name: String) -> String {
    if name == "print" { return "Void" }
    if name == "println" { return "Void" }
    if name == "len" { return "Int" }
    if name == "toString" { return "String" }
    if name == "str" { return "String" }
    if name == "int" { return "Int" }
    if name == "float" { return "Float" }
    if name == "Some" { return "Option" }
    if name == "Ok" { return "Result" }
    if name == "Err" { return "Result" }
    if name == "signal" { return "Signal" }
    if name == "stream" { return "Stream" }
    if name == "ord" { return "Int" }
    if name == "chr" { return "String" }
    if name == "join" { return "String" }
    return "Void"
}

// ---------------------------------------------------------------------------
// Symbol table
// ---------------------------------------------------------------------------

struct Symbol {
    name: String,
    kind: String,
    type_info: TypeInfo,
    mutable: Bool
}

fn new_symbol(name: String, kind: String, ti: TypeInfo, mutable: Bool) -> Symbol {
    return new Symbol { name: name, kind: kind, type_info: ti, mutable: mutable }
}

struct Scope {
    parent: Option<Scope>,
    symbols: List<Symbol>
}

fn new_scope(parent: Option<Scope>) -> Scope {
    let syms: List<Symbol> = []
    return new Scope { parent: parent, symbols: syms }
}

fn scope_define(scope: Scope, name: String, sym: Symbol) -> Scope {
    // Append symbol to scope's symbol list.
    // Later entries shadow earlier ones (last-match-wins in lookup).
    let mut syms: List<Symbol> = scope.symbols
    // syms.push(sym) — append to list
    return new_scope(scope.parent)
}

fn scope_lookup(scope: Scope, name: String) -> Option<Symbol> {
    // Linear search through symbols (last to first for shadowing).
    let mut i: Int = len(scope.symbols) - 1
    for _ in 0..1000000 {
        if i < 0 {
            // Not found locally; walk to parent scope.
            match scope.parent {
                Some(parent) => { return scope_lookup(parent, name) },
                _ => { return none }
            }
        }
        let sym: Symbol = scope.symbols[i]
        if sym.name == name { return Some(sym) }
        i = i - 1
    }
    return none
}

fn scope_lookup_local(scope: Scope, name: String) -> Option<Symbol> {
    // Only search the current scope (no parent walk).
    let mut i: Int = len(scope.symbols) - 1
    for _ in 0..1000000 {
        if i < 0 { return none }
        let sym: Symbol = scope.symbols[i]
        if sym.name == name { return Some(sym) }
        i = i - 1
    }
    return none
}

// ---------------------------------------------------------------------------
// Semantic checker state
// ---------------------------------------------------------------------------

struct SemanticChecker {
    filename: String,
    errors: List<SemanticError>,
    global_scope: Scope,
    current_scope: Scope
}

fn new_checker(filename: String) -> SemanticChecker {
    let scope: Scope = new_scope(none)
    let errs: List<SemanticError> = []
    return new SemanticChecker { filename: filename, errors: errs, global_scope: scope, current_scope: scope }
}

// ---------------------------------------------------------------------------
// State threading — result structs for functions that return a value + state
// ---------------------------------------------------------------------------

struct SemState {
    errors: List<SemanticError>,
    scope: Scope,
    filename: String
}

struct InferResult {
    type_info: TypeInfo,
    st: SemState
}

struct CheckResult {
    st: SemState
}

fn new_sem_state(filename: String) -> SemState {
    let scope: Scope = new_scope(none)
    let sem_errs: List<SemanticError> = []
    return new SemState { errors: sem_errs, scope: scope, filename: filename }
}

fn new_infer_result(ti: TypeInfo, st: SemState) -> InferResult {
    return new InferResult { type_info: ti, st: st }
}

fn new_check_result(st: SemState) -> CheckResult {
    return new CheckResult { st: st }
}

// ---------------------------------------------------------------------------
// Error helpers
// ---------------------------------------------------------------------------

fn add_error(st: SemState, msg: String, line: Int, col: Int) -> SemState {
    let err: SemanticError = new_semantic_error(msg, line, col, st.filename)
    // st.errors.push(err)
    return st
}

fn add_error_msg(st: SemState, msg: String) -> SemState {
    return add_error(st, msg, 0, 0)
}

// ---------------------------------------------------------------------------
// Scope helpers
// ---------------------------------------------------------------------------

fn push_scope(st: SemState) -> SemState {
    let child: Scope = new_scope(Some(st.scope))
    let new_st: SemState = new SemState { errors: st.errors, scope: child, filename: st.filename }
    return new_st
}

fn pop_scope(st: SemState) -> SemState {
    match st.scope.parent {
        Some(parent) => {
            let new_st: SemState = new SemState { errors: st.errors, scope: parent, filename: st.filename }
            return new_st
        },
        _ => { return st }
    }
}

fn define_in_scope(st: SemState, name: String, sym: Symbol) -> SemState {
    let new_scope_val: Scope = scope_define(st.scope, name, sym)
    let new_st: SemState = new SemState { errors: st.errors, scope: new_scope_val, filename: st.filename }
    return new_st
}

// ---------------------------------------------------------------------------
// Type compatibility checking
// ---------------------------------------------------------------------------

fn types_compatible(a: TypeInfo, b: TypeInfo) -> Bool {
    if a.name == "<unknown>" { return true }
    if b.name == "<unknown>" { return true }
    if a.is_function {
        if b.is_function {
            // Compare param counts and return types
            if len(a.param_types) != len(b.param_types) { return false }
            return true
        }
        return false
    }
    if a.name != b.name { return false }
    return true
}

fn is_numeric_type(name: String) -> Bool {
    if name == "Int" { return true }
    if name == "Float" { return true }
    if name == "<unknown>" { return true }
    return false
}

fn is_arithmetic_operand(name: String) -> Bool {
    if name == "Int" { return true }
    if name == "Float" { return true }
    if name == "String" { return true }
    if name == "Tensor" { return true }
    if name == "<unknown>" { return true }
    return false
}

fn type_exists(st: SemState, t: TypeInfo) -> Bool {
    if is_primitive_type(t.name) { return true }
    if is_builtin_generic(t.name) { return true }
    let sym: Option<Symbol> = scope_lookup(st.scope, t.name)
    match sym {
        Some(s) => {
            if s.kind == "struct" { return true }
            if s.kind == "enum" { return true }
            if s.kind == "agent" { return true }
            if s.kind == "type_alias" { return true }
            return false
        },
        _ => { return false }
    }
}

// ---------------------------------------------------------------------------
// Binary operator type rules
// ---------------------------------------------------------------------------

fn check_arithmetic_result(left: String, right: String, op: String) -> String {
    if left == "Tensor" { return "Tensor" }
    if right == "Tensor" { return "Tensor" }
    if op == "+" {
        if left == "String" { return "String" }
        if right == "String" { return "String" }
    }
    if left == "Float" { return "Float" }
    if right == "Float" { return "Float" }
    if left == "Int" {
        if right == "Int" { return "Int" }
    }
    return "<unknown>"
}

fn check_comparison_result(left: String, right: String) -> String {
    return "Bool"
}

fn check_logical_result(left: String, right: String) -> String {
    return "Bool"
}

// ---------------------------------------------------------------------------
// Type resolution — convert TypeExpr AST nodes to TypeInfo
// ---------------------------------------------------------------------------

fn resolve_type_expr(te: TypeExpr) -> TypeInfo {
    let tek: String = type_expr_kind(te)
    if tek == "named" { return make_type(type_expr_name(te)) }
    if tek == "generic" {
        let name: String = type_expr_name(te)
        let args: List<TypeExpr> = type_expr_args(te)
        let mut resolved: List<TypeInfo> = []
        let mut i: Int = 0
        for _ in 0..200 {
            if i >= len(args) { return make_generic_type(name, resolved) }
            let arg: TypeExpr = args[i]
            let rt: TypeInfo = resolve_type_expr(arg)
            resolved.push(rt)
            i = i + 1
        }
        return make_generic_type(name, resolved)
    }
    if tek == "fn" {
        let param_types: List<TypeExpr> = type_expr_fn_params(te)
        let return_type: TypeExpr = type_expr_fn_ret(te)
        let mut params: List<TypeInfo> = []
        let mut i_fn: Int = 0
        for _ in 0..200 {
            if i_fn >= len(param_types) {
                let ret: TypeInfo = resolve_type_expr(return_type)
                return make_fn_type(params, ret)
            }
            let pt: TypeExpr = param_types[i_fn]
            let rp: TypeInfo = resolve_type_expr(pt)
            params.push(rp)
            i_fn = i_fn + 1
        }
        let ret2: TypeInfo = resolve_type_expr(return_type)
        return make_fn_type(params, ret2)
    }
    return unknown_type()
}

fn resolve_type_opt(te: Option<TypeExpr>) -> TypeInfo {
    match te {
        Some(t) => { return resolve_type_expr(t) },
        _ => { return unknown_type() }
    }
}

// ---------------------------------------------------------------------------
// Expression type inference
// ---------------------------------------------------------------------------

fn infer_expr(st: SemState, expr: Expr) -> InferResult {
    let ek: String = expr_kind(expr)
    if ek == "int_lit" { return new_infer_result(int_type(), st) }
    if ek == "float_lit" { return new_infer_result(float_type(), st) }
    if ek == "bool_lit" { return new_infer_result(bool_type(), st) }
    if ek == "string_lit" { return new_infer_result(string_type(), st) }
    if ek == "char_lit" { return new_infer_result(char_type(), st) }
    if ek == "none_lit" { return new_infer_result(make_type("Option"), st) }

    if ek == "ident" {
        let name: String = expr_ident_name(expr)
        let result: Option<Symbol> = scope_lookup(st.scope, name)
        match result {
            Some(sym) => { return new_infer_result(sym.type_info, st) },
            _ => {
                let st_ident_err: SemState = add_error(st, "Undefined variable '" + name + "'", 0, 0)
                return new_infer_result(unknown_type(), st_ident_err)
            }
        }
    }

    if ek == "binary" { return check_binary_expr(st, expr_binary_left(expr), expr_binary_op(expr), expr_binary_right(expr)) }
    if ek == "unary" { return check_unary_expr(st, expr_unary_op(expr), expr_unary_operand(expr)) }
    if ek == "call" { return check_call_expr(st, expr_call_callee(expr), expr_call_args(expr)) }

    if ek == "method_call" {
        let obj_r: InferResult = infer_expr(st, expr_method_obj(expr))
        let mut st_method: SemState = obj_r.st
        let args: List<Expr> = expr_method_args(expr)
        let mut i_method: Int = 0
        for _ in 0..200 {
            if i_method >= len(args) { return new_infer_result(unknown_type(), st_method) }
            let arg: Expr = args[i_method]
            let ar: InferResult = infer_expr(st_method, arg)
            st_method = ar.st
            i_method = i_method + 1
        }
        return new_infer_result(unknown_type(), st_method)
    }

    if ek == "field_access" {
        let obj_r_field: InferResult = infer_expr(st, expr_field_obj(expr))
        return new_infer_result(unknown_type(), obj_r_field.st)
    }

    if ek == "namespace_access" {
        return new_infer_result(unknown_type(), st)
    }

    if ek == "index" {
        let obj_r_idx: InferResult = infer_expr(st, expr_index_obj(expr))
        let idx_r: InferResult = infer_expr(obj_r_idx.st, expr_index_idx(expr))
        // List<T>[i] -> T
        if obj_r_idx.type_info.name == "List" {
            if len(obj_r_idx.type_info.args) > 0 {
                let elem_ti: TypeInfo = obj_r_idx.type_info.args[0]
                return new_infer_result(elem_ti, idx_r.st)
            }
        }
        return new_infer_result(unknown_type(), idx_r.st)
    }

    if ek == "pipe" { return check_pipe_expr(st, expr_pipe_left(expr), expr_pipe_right(expr)) }

    if ek == "range" {
        let sr: InferResult = infer_expr(st, expr_range_start(expr))
        let er_range: InferResult = infer_expr(sr.st, expr_range_end(expr))
        return new_infer_result(make_type("Range"), er_range.st)
    }

    if ek == "lambda" { return check_lambda_expr(st, expr_lambda_params(expr), expr_lambda_body(expr)) }
    if ek == "spawn" { return check_spawn_expr(st, expr_spawn_callee(expr), expr_spawn_args(expr)) }

    if ek == "sync" {
        let ir_sync: InferResult = infer_expr(st, expr_sync_inner(expr))
        return new_infer_result(unknown_type(), ir_sync.st)
    }

    if ek == "send" {
        let st_send: SemState = check_send_expr(st, expr_send_target(expr), expr_send_value(expr))
        return new_infer_result(void_type(), st_send)
    }

    if ek == "error_prop" {
        let ir_errprop: InferResult = infer_expr(st, expr_errorprop_inner(expr))
        return new_infer_result(unknown_type(), ir_errprop.st)
    }

    if ek == "list_lit" {
        let elements: List<Expr> = expr_list_elements(expr)
        if len(elements) > 0 {
            let first: Expr = elements[0]
            let fr_list: InferResult = infer_expr(st, first)
            let mut st_list: SemState = fr_list.st
            let mut i_list: Int = 1
            for _ in 0..600 {
                if i_list >= len(elements) {
                    let args_list: List<TypeInfo> = []
                    return new_infer_result(make_generic_type("List", args_list), st_list)
                }
                let elem: Expr = elements[i_list]
                let er_list: InferResult = infer_expr(st_list, elem)
                st_list = er_list.st
                i_list = i_list + 1
            }
            let args2: List<TypeInfo> = []
            return new_infer_result(make_generic_type("List", args2), st_list)
        }
        let empty_args: List<TypeInfo> = []
        return new_infer_result(make_generic_type("List", empty_args), st)
    }

    if ek == "construct" {
        let name: String = expr_construct_name(expr)
        let fields: List<FieldInit> = expr_construct_fields(expr)
        let mut st_ctor: SemState = st
        let mut i_ctor: Int = 0
        for _ in 0..200 {
            if i_ctor >= len(fields) { return new_infer_result(make_type(name), st_ctor) }
            let fi: FieldInit = fields[i_ctor]
            let fr_ctor: InferResult = infer_expr(st_ctor, fi.value)
            st_ctor = fr_ctor.st
            i_ctor = i_ctor + 1
        }
        return new_infer_result(make_type(name), st_ctor)
    }

    if ek == "some_wrap" {
        let vr_some: InferResult = infer_expr(st, expr_wrap_inner(expr))
        let args_some: List<TypeInfo> = []
        return new_infer_result(make_generic_type("Option", args_some), vr_some.st)
    }

    if ek == "ok_wrap" {
        let vr_ok: InferResult = infer_expr(st, expr_wrap_inner(expr))
        let args_ok: List<TypeInfo> = []
        return new_infer_result(make_generic_type("Result", args_ok), vr_ok.st)
    }

    if ek == "err_wrap" {
        let vr_err: InferResult = infer_expr(st, expr_wrap_inner(expr))
        let args_err: List<TypeInfo> = []
        return new_infer_result(make_generic_type("Result", args_err), vr_err.st)
    }

    if ek == "signal_val" {
        let vr_signal: InferResult = infer_expr(st, expr_signal_inner(expr))
        let args_signal: List<TypeInfo> = []
        return new_infer_result(make_generic_type("Signal", args_signal), vr_signal.st)
    }

    if ek == "assign" { return check_assign_expr(st, expr_assign_target(expr), expr_assign_op(expr), expr_assign_value(expr)) }
    if ek == "if" { return check_if_expr(st, expr_if_cond(expr), expr_if_then(expr), expr_if_else(expr)) }
    if ek == "match" { return check_match_expr(st, expr_match_subject(expr), expr_match_arms(expr)) }

    return new_infer_result(unknown_type(), st)
}

// ---------------------------------------------------------------------------
// Binary operators
// ---------------------------------------------------------------------------

fn check_binary_expr(st: SemState, left: Expr, op: String, right: Expr) -> InferResult {
    let lr: InferResult = infer_expr(st, left)
    let rr: InferResult = infer_expr(lr.st, right)
    let lt: String = lr.type_info.name
    let rt: String = rr.type_info.name
    let st2: SemState = rr.st

    // Arithmetic operators
    if op == "+" { return check_arithmetic_binary(st2, lt, rt, op, lr.type_info, rr.type_info) }
    if op == "-" { return check_arithmetic_binary(st2, lt, rt, op, lr.type_info, rr.type_info) }
    if op == "*" { return check_arithmetic_binary(st2, lt, rt, op, lr.type_info, rr.type_info) }
    if op == "/" { return check_arithmetic_binary(st2, lt, rt, op, lr.type_info, rr.type_info) }
    if op == "%" { return check_arithmetic_binary(st2, lt, rt, op, lr.type_info, rr.type_info) }

    // Comparison and equality operators
    if op == "<" { return new_infer_result(bool_type(), st2) }
    if op == ">" { return new_infer_result(bool_type(), st2) }
    if op == "<=" { return new_infer_result(bool_type(), st2) }
    if op == ">=" { return new_infer_result(bool_type(), st2) }
    if op == "==" { return new_infer_result(bool_type(), st2) }
    if op == "!=" { return new_infer_result(bool_type(), st2) }

    // Logical operators
    if op == "&&" { return check_logical_binary(st2, lt, rt, op) }
    if op == "||" { return check_logical_binary(st2, lt, rt, op) }

    // Matrix multiply
    if op == "@" { return check_matmul_binary(st2, lt, rt, lr.type_info, rr.type_info) }

    return new_infer_result(unknown_type(), st2)
}

fn check_arithmetic_binary(st: SemState, lt: String, rt: String, op: String, left_ti: TypeInfo, right_ti: TypeInfo) -> InferResult {
    // Tensor element-wise operations
    if lt == "Tensor" {
        if rt != "<unknown>" {
            if rt != "Tensor" {
                if rt != "Int" {
                    if rt != "Float" {
                        let st_tensor_lt: SemState = add_error(st, "Operator '" + op + "' not supported for Tensor and " + rt, 0, 0)
                        return new_infer_result(make_type("Tensor"), st_tensor_lt)
                    }
                }
            }
        }
        return new_infer_result(make_type("Tensor"), st)
    }
    if rt == "Tensor" {
        if lt != "<unknown>" {
            if lt != "Int" {
                if lt != "Float" {
                    let st_tensor_rt: SemState = add_error(st, "Operator '" + op + "' not supported for " + lt + " and Tensor", 0, 0)
                    return new_infer_result(make_type("Tensor"), st_tensor_rt)
                }
            }
        }
        return new_infer_result(make_type("Tensor"), st)
    }

    // Non-tensor arithmetic
    if lt != "<unknown>" {
        if lt != "Int" {
            if lt != "Float" {
                if lt != "String" {
                    let st_arith_lt: SemState = add_error(st, "Operator '" + op + "' not supported for types " + lt + " and " + rt, 0, 0)
                    return new_infer_result(unknown_type(), st_arith_lt)
                }
            }
        }
    }
    if rt != "<unknown>" {
        if rt != "Int" {
            if rt != "Float" {
                if rt != "String" {
                    let st_arith_rt: SemState = add_error(st, "Operator '" + op + "' not supported for types " + lt + " and " + rt, 0, 0)
                    return new_infer_result(unknown_type(), st_arith_rt)
                }
            }
        }
    }

    let result_name: String = check_arithmetic_result(lt, rt, op)
    return new_infer_result(make_type(result_name), st)
}

fn check_logical_binary(st: SemState, lt: String, rt: String, op: String) -> InferResult {
    let mut st2: SemState = st
    if lt != "<unknown>" {
        if lt != "Bool" {
            st2 = add_error(st2, "Operator '" + op + "' requires Bool, got " + lt, 0, 0)
        }
    }
    if rt != "<unknown>" {
        if rt != "Bool" {
            st2 = add_error(st2, "Operator '" + op + "' requires Bool, got " + rt, 0, 0)
        }
    }
    return new_infer_result(bool_type(), st2)
}

fn check_matmul_binary(st: SemState, lt: String, rt: String, left_ti: TypeInfo, right_ti: TypeInfo) -> InferResult {
    let mut st2: SemState = st
    if lt != "<unknown>" {
        if lt != "Tensor" {
            st2 = add_error(st2, "Operator '@' requires Tensor, got " + lt, 0, 0)
        }
    }
    if rt != "<unknown>" {
        if rt != "Tensor" {
            st2 = add_error(st2, "Operator '@' requires Tensor, got " + rt, 0, 0)
        }
    }
    let elem: TypeInfo = unknown_type()
    if len(left_ti.args) > 0 {
        let elem2: TypeInfo = left_ti.args[0]
        let args: List<TypeInfo> = []
        // args.push(elem2)
        return new_infer_result(make_generic_type("Tensor", args), st2)
    }
    let args3: List<TypeInfo> = []
    return new_infer_result(make_generic_type("Tensor", args3), st2)
}

// ---------------------------------------------------------------------------
// Unary operators
// ---------------------------------------------------------------------------

fn check_unary_expr(st: SemState, op: String, operand: Expr) -> InferResult {
    let or: InferResult = infer_expr(st, operand)
    let ot: String = or.type_info.name

    if op == "-" {
        if ot != "<unknown>" {
            if ot != "Int" {
                if ot != "Float" {
                    let st_neg: SemState = add_error(or.st, "Unary '-' not supported for type " + ot, 0, 0)
                    return new_infer_result(or.type_info, st_neg)
                }
            }
        }
        return new_infer_result(or.type_info, or.st)
    }

    if op == "!" {
        if ot != "<unknown>" {
            if ot != "Bool" {
                let st_not: SemState = add_error(or.st, "Unary '!' requires Bool, got " + ot, 0, 0)
                return new_infer_result(bool_type(), st_not)
            }
        }
        return new_infer_result(bool_type(), or.st)
    }

    return new_infer_result(unknown_type(), or.st)
}

// ---------------------------------------------------------------------------
// Call expression
// ---------------------------------------------------------------------------

fn check_call_expr(st: SemState, callee: Expr, args: List<Expr>) -> InferResult {
    // Infer argument types
    let mut st2: SemState = st
    let mut arg_types: List<TypeInfo> = []
    let mut i: Int = 0
    for _ in 0..200 {
        if i >= len(args) {
            return check_call_resolved(st2, callee, arg_types)
        }
        let arg: Expr = args[i]
        let ar: InferResult = infer_expr(st2, arg)
        st2 = ar.st
        // arg_types.push(ar.type_info)
        i = i + 1
    }
    return check_call_resolved(st2, callee, arg_types)
}

fn check_call_resolved(st: SemState, callee: Expr, arg_types: List<TypeInfo>) -> InferResult {
    if expr_kind(callee) == "ident" {
        let name: String = expr_ident_name(callee)
        let sym_opt: Option<Symbol> = scope_lookup(st.scope, name)
        match sym_opt {
            Some(sym) => {
                if sym.kind == "function" {
                    if sym.type_info.is_function {
                        match sym.type_info.return_type {
                            Some(ret) => {
                                if len(sym.type_info.param_types) > 0 {
                                    if len(arg_types) != len(sym.type_info.param_types) {
                                        let st_argc: SemState = add_error(st, "Function '" + name + "' argument count mismatch", 0, 0)
                                        return new_infer_result(ret, st_argc)
                                    }
                                }
                                return new_infer_result(ret, st)
                            },
                            _ => { return new_infer_result(unknown_type(), st) }
                        }
                    }
                    return new_infer_result(unknown_type(), st)
                }
                if sym.kind == "agent" {
                    return new_infer_result(make_type(sym.name), st)
                }
                if sym.kind == "struct" {
                    return new_infer_result(make_type(sym.name), st)
                }
                return new_infer_result(unknown_type(), st)
            },
            _ => {
                let st_undef: SemState = add_error(st, "Undefined function '" + name + "'", 0, 0)
                return new_infer_result(unknown_type(), st_undef)
            }
        }
    }
    let cr: InferResult = infer_expr(st, callee)
    return new_infer_result(unknown_type(), cr.st)
}

// ---------------------------------------------------------------------------
// Assignment
// ---------------------------------------------------------------------------

fn check_assign_expr(st: SemState, target: Expr, op: String, value: Expr) -> InferResult {
    let vr: InferResult = infer_expr(st, value)

    if expr_kind(target) == "ident" {
        let name: String = expr_ident_name(target)
        let sym_opt: Option<Symbol> = scope_lookup(vr.st.scope, name)
        match sym_opt {
            Some(sym) => {
                let mut st_assign: SemState = vr.st
                if sym.mutable == false {
                    st_assign = add_error(st_assign, "Cannot assign to immutable variable '" + name + "'", 0, 0)
                }
                if sym.type_info.name != "<unknown>" {
                    if vr.type_info.name != "<unknown>" {
                        if types_compatible(sym.type_info, vr.type_info) == false {
                            st_assign = add_error(st_assign, "Type mismatch in assignment to '" + name + "'", 0, 0)
                        }
                    }
                }
                return new_infer_result(void_type(), st_assign)
            },
            _ => {
                let st_assign_undef: SemState = add_error(vr.st, "Undefined variable '" + name + "'", 0, 0)
                return new_infer_result(void_type(), st_assign_undef)
            }
        }
    }
    // Field or index target — infer both sides
    let tr: InferResult = infer_expr(vr.st, target)
    return new_infer_result(void_type(), tr.st)
}

// ---------------------------------------------------------------------------
// If expression
// ---------------------------------------------------------------------------

fn check_if_expr(st: SemState, cond: Expr, then_block: Block, else_clause: Option<ElseClause>) -> InferResult {
    let cr: InferResult = infer_expr(st, cond)
    let mut st2: SemState = cr.st

    if cr.type_info.name != "<unknown>" {
        if cr.type_info.name != "Bool" {
            st2 = add_error(st2, "If condition must be Bool, got " + cr.type_info.name, 0, 0)
        }
    }

    // Check then block
    let then_st: SemState = push_scope(st2)
    let after_then: SemState = check_block(then_st, then_block)
    st2 = pop_scope(after_then)

    // Check else clause
    match else_clause {
        Some(ec) => {
            st2 = check_else_clause(st2, ec)
        },
        _ => {}
    }

    return new_infer_result(unknown_type(), st2)
}

fn check_else_clause(st: SemState, ec: ElseClause) -> SemState {
    if else_clause_kind(ec) == "else_block" {
        let inner: SemState = push_scope(st)
        let after: SemState = check_block(inner, else_clause_block(ec))
        return pop_scope(after)
    }
    let r: InferResult = check_if_expr(st, else_clause_cond(ec), else_clause_then(ec), else_clause_else(ec))
    return r.st
}

// ---------------------------------------------------------------------------
// Match expression
// ---------------------------------------------------------------------------

fn check_match_expr(st: SemState, subject: Expr, arms: List<MatchArm>) -> InferResult {
    let sr: InferResult = infer_expr(st, subject)
    let mut st2: SemState = sr.st
    let mut i: Int = 0
    for _ in 0..200 {
        if i >= len(arms) { return new_infer_result(unknown_type(), st2) }
        let arm: MatchArm = arms[i]
        let arm_st: SemState = push_scope(st2)
        let bound_st: SemState = bind_pattern(arm_st, arm.pattern)
        let after_arm: SemState = check_match_arm_body(bound_st, arm.body)
        st2 = pop_scope(after_arm)
        i = i + 1
    }
    return new_infer_result(unknown_type(), st2)
}

fn check_match_arm_body(st: SemState, body: MatchArmBody) -> SemState {
    if match_arm_body_kind(body) == "expr" {
        let r: InferResult = infer_expr(st, match_arm_body_expr(body))
        return r.st
    }
    return check_block(st, match_arm_body_block(body))
}

fn bind_pattern(st: SemState, pat: Pattern) -> SemState {
    let pk: String = pattern_kind(pat)
    if pk == "wildcard" { return st }
    if pk == "ident" {
        let name: String = pattern_ident_name(pat)
        let sym: Symbol = new_symbol(name, "variable", unknown_type(), false)
        return define_in_scope(st, name, sym)
    }
    if pk == "literal" { return st }
    if pk == "constructor" {
        let args: List<Pattern> = pattern_ctor_args(pat)
        let mut st2: SemState = st
        let mut i: Int = 0
        for _ in 0..200 {
            if i >= len(args) { return st2 }
            let arg: Pattern = args[i]
            st2 = bind_pattern(st2, arg)
            i = i + 1
        }
        return st2
    }
    return st
}

// ---------------------------------------------------------------------------
// Lambda
// ---------------------------------------------------------------------------

fn check_lambda_expr(st: SemState, params: List<Param>, body: LambdaBody) -> InferResult {
    let inner: SemState = push_scope(st)
    let mut st2: SemState = inner
    let mut param_types: List<TypeInfo> = []
    let mut i: Int = 0

    // Register parameters
    for _ in 0..200 {
        if i >= len(params) {
            // Check body
            let body_result: InferResult = check_lambda_body(st2, body)
            let st3: SemState = pop_scope(body_result.st)
            let fn_ti: TypeInfo = make_fn_type(param_types, body_result.type_info)
            return new_infer_result(fn_ti, st3)
        }
        let p: Param = params[i]
        let pt: TypeInfo = resolve_type_opt(p.type_annotation)
        // param_types.push(pt)
        let sym: Symbol = new_symbol(p.name, "param", pt, false)
        st2 = define_in_scope(st2, p.name, sym)
        i = i + 1
    }

    let st4: SemState = pop_scope(st2)
    return new_infer_result(unknown_type(), st4)
}

fn check_lambda_body(st: SemState, body: LambdaBody) -> InferResult {
    if lambda_body_kind(body) == "expr" { return infer_expr(st, lambda_body_expr(body)) }
    let st2: SemState = check_block(st, lambda_body_block(body))
    return new_infer_result(unknown_type(), st2)
}

// ---------------------------------------------------------------------------
// Spawn / Send
// ---------------------------------------------------------------------------

fn check_spawn_callee(st: SemState, callee: Expr) -> InferResult {
    if expr_kind(callee) == "ident" {
        let name: String = expr_ident_name(callee)
        let sym_opt: Option<Symbol> = scope_lookup(st.scope, name)
        match sym_opt {
            Some(sym) => {
                let mut st2: SemState = st
                if sym.kind != "agent" {
                    if sym.kind != "variable" {
                        st2 = add_error(st2, "'spawn' requires an agent, but '" + name + "' is a " + sym.kind, 0, 0)
                    }
                }
                return new_infer_result(make_type(sym.name), st2)
            },
            _ => {
                let st_err: SemState = add_error(st, "Undefined agent '" + name + "'", 0, 0)
                return new_infer_result(unknown_type(), st_err)
            }
        }
    }
    return new_infer_result(unknown_type(), st)
}

fn check_spawn_expr(st: SemState, callee: Expr, args: List<Expr>) -> InferResult {
    // Infer arguments first
    let mut st2: SemState = st
    let mut i: Int = 0
    for _ in 0..200 {
        if i < len(args) {
            let arg: Expr = args[i]
            let ar: InferResult = infer_expr(st2, arg)
            st2 = ar.st
            i = i + 1
        }
    }
    // Then check callee (no nested match-in-if-in-for)
    return check_spawn_callee(st2, callee)
}

fn check_send_expr(st: SemState, value: Expr, target: Expr) -> SemState {
    let vr: InferResult = infer_expr(st, value)
    let tr: InferResult = infer_expr(vr.st, target)
    return tr.st
}

// ---------------------------------------------------------------------------
// Pipe expression
// ---------------------------------------------------------------------------

fn check_pipe_expr(st: SemState, left: Expr, right: Expr) -> InferResult {
    let lr: InferResult = infer_expr(st, left)
    let st2: SemState = lr.st

    let rk: String = expr_kind(right)
    if rk == "ident" {
        let name: String = expr_ident_name(right)
        let sym_opt: Option<Symbol> = scope_lookup(st2.scope, name)
        match sym_opt {
            Some(sym) => {
                if sym.kind == "function" {
                    if sym.type_info.is_function {
                        if len(sym.type_info.param_types) > 0 {
                            let expected: TypeInfo = sym.type_info.param_types[0]
                            if expected.name != "<unknown>" {
                                if lr.type_info.name != "<unknown>" {
                                    if types_compatible(expected, lr.type_info) == false {
                                        let st3_mismatch: SemState = add_error(st2, "Pipe type mismatch: piped to '" + name + "'", 0, 0)
                                        match sym.type_info.return_type {
                                            Some(ret) => { return new_infer_result(ret, st3_mismatch) },
                                            _ => { return new_infer_result(unknown_type(), st3_mismatch) }
                                        }
                                    }
                                }
                            }
                        }
                        match sym.type_info.return_type {
                            Some(ret) => { return new_infer_result(ret, st2) },
                            _ => { return new_infer_result(unknown_type(), st2) }
                        }
                    }
                }
                if sym.kind == "agent" {
                    return new_infer_result(make_type(sym.name), st2)
                }
                return new_infer_result(unknown_type(), st2)
            },
            _ => {
                let st3_undef: SemState = add_error(st2, "Undefined function '" + name + "'", 0, 0)
                return new_infer_result(unknown_type(), st3_undef)
            }
        }
    }
    if rk == "call" {
        return check_call_expr(st2, expr_call_callee(right), expr_call_args(right))
    }
    let rr: InferResult = infer_expr(st2, right)
    return new_infer_result(unknown_type(), rr.st)
}

// ---------------------------------------------------------------------------
// Block and statement checking
// ---------------------------------------------------------------------------

fn check_block(st: SemState, block: Block) -> SemState {
    let mut st2: SemState = st
    let mut i: Int = 0
    for _ in 0..600 {
        if i >= len(block.stmts) { return st2 }
        let stmt: Stmt = block.stmts[i]
        st2 = check_stmt(st2, stmt)
        i = i + 1
    }
    return st2
}

fn check_stmt(st: SemState, stmt: Stmt) -> SemState {
    let sk: String = stmt_kind(stmt)
    if sk == "let" {
        return check_let_stmt(st, stmt_let_name(stmt), stmt_let_mutable(stmt), stmt_let_type(stmt), stmt_let_value(stmt))
    }
    if sk == "expr_stmt" {
        let r_expr: InferResult = infer_expr(st, stmt_expr(stmt))
        return r_expr.st
    }
    if sk == "return" {
        let value_opt: Option<Expr> = stmt_return_val(stmt)
        match value_opt {
            Some(value) => {
                let r_ret: InferResult = infer_expr(st, value)
                return r_ret.st
            },
            _ => { return st }
        }
    }
    if sk == "for" {
        return check_for_stmt(st, stmt_for_var(stmt), stmt_for_iter(stmt), stmt_for_body(stmt))
    }
    if sk == "signal_decl" {
        return check_signal_decl(st, stmt_signal_name(stmt), stmt_signal_mutable(stmt), stmt_signal_type(stmt), stmt_signal_value(stmt))
    }
    if sk == "stream_decl" {
        return check_stream_decl(st, stmt_stream_name(stmt), stmt_stream_type(stmt), stmt_stream_value(stmt))
    }
    return st
}

// ---------------------------------------------------------------------------
// Let binding
// ---------------------------------------------------------------------------

fn check_let_stmt(st: SemState, name: String, mutable: Bool, type_ann: Option<TypeExpr>, value: Expr) -> SemState {
    let vr: InferResult = infer_expr(st, value)
    let ann_type: TypeInfo = resolve_type_opt(type_ann)
    let mut st2: SemState = vr.st

    // Check annotation matches value type
    if ann_type.name != "<unknown>" {
        if vr.type_info.name != "<unknown>" {
            if types_compatible(ann_type, vr.type_info) == false {
                st2 = add_error(st2, "Type mismatch: declared type " + ann_type.name + " but initial value is " + vr.type_info.name, 0, 0)
            }
        }
    }

    // Use annotation if available, otherwise inferred
    let resolved: TypeInfo = ann_type
    if ann_type.name == "<unknown>" {
        let resolved2: TypeInfo = vr.type_info
        let sym: Symbol = new_symbol(name, "variable", resolved2, mutable)
        return define_in_scope(st2, name, sym)
    }
    let sym2: Symbol = new_symbol(name, "variable", resolved, mutable)
    return define_in_scope(st2, name, sym2)
}

// ---------------------------------------------------------------------------
// For loop
// ---------------------------------------------------------------------------

fn check_for_stmt(st: SemState, var_name: String, iterable: Expr, body: Block) -> SemState {
    let ir: InferResult = infer_expr(st, iterable)
    let inner: SemState = push_scope(ir.st)
    let sym: Symbol = new_symbol(var_name, "variable", unknown_type(), false)
    let bound: SemState = define_in_scope(inner, var_name, sym)
    let after: SemState = check_block(bound, body)
    return pop_scope(after)
}

// ---------------------------------------------------------------------------
// Signal / Stream declarations
// ---------------------------------------------------------------------------

fn check_signal_decl(st: SemState, name: String, mutable: Bool, type_ann: Option<TypeExpr>, value: Expr) -> SemState {
    let vr: InferResult = infer_expr(st, value)
    let ann_type: TypeInfo = resolve_type_opt(type_ann)
    let resolved: TypeInfo = ann_type
    if ann_type.name == "<unknown>" {
        let resolved2: TypeInfo = vr.type_info
        let args: List<TypeInfo> = []
        // args.push(resolved2)
        let sig_type: TypeInfo = make_generic_type("Signal", args)
        let sym: Symbol = new_symbol(name, "variable", sig_type, mutable)
        return define_in_scope(vr.st, name, sym)
    }
    let args2: List<TypeInfo> = []
    // args2.push(resolved)
    let sig_type2: TypeInfo = make_generic_type("Signal", args2)
    let sym2: Symbol = new_symbol(name, "variable", sig_type2, mutable)
    return define_in_scope(vr.st, name, sym2)
}

fn check_stream_decl(st: SemState, name: String, type_ann: Option<TypeExpr>, value: Expr) -> SemState {
    let vr: InferResult = infer_expr(st, value)
    let ann_type: TypeInfo = resolve_type_opt(type_ann)
    let resolved: TypeInfo = ann_type
    if ann_type.name == "<unknown>" {
        let resolved2: TypeInfo = vr.type_info
        let args: List<TypeInfo> = []
        let stream_type: TypeInfo = make_generic_type("Stream", args)
        let sym: Symbol = new_symbol(name, "variable", stream_type, false)
        return define_in_scope(vr.st, name, sym)
    }
    let args2: List<TypeInfo> = []
    let stream_type2: TypeInfo = make_generic_type("Stream", args2)
    let sym2: Symbol = new_symbol(name, "variable", stream_type2, false)
    return define_in_scope(vr.st, name, sym2)
}

// ---------------------------------------------------------------------------
// Definition registration (first pass)
// ---------------------------------------------------------------------------

fn register_definitions(st: SemState, program: Program) -> SemState {
    let mut st2: SemState = st
    let mut i: Int = 0
    for _ in 0..2000 {
        if i >= len(program.definitions) { return st2 }
        let def: Definition = program.definitions[i]
        st2 = register_def(st2, def)
        i = i + 1
    }
    return st2
}

fn register_def(st: SemState, def: Definition) -> SemState {
    let dk: String = def_kind(def)
    if dk == "fn_def" {
        let data: FnDefData = def_fn_data(def)
        let mut params: List<TypeInfo> = []
        let mut pi: Int = 0
        for _ in 0..200 {
            if pi >= len(data.params) {
                let ret: TypeInfo = resolve_type_opt(data.return_type)
                let fn_type: TypeInfo = make_fn_type(params, ret)
                let sym_fn: Symbol = new_symbol(data.name, "function", fn_type, false)
                return define_in_scope(st, data.name, sym_fn)
            }
            let p: Param = data.params[pi]
            let pt: TypeInfo = resolve_type_opt(p.type_annotation)
            pi = pi + 1
        }
        return st
    }
    if dk == "agent_def" {
        let data: AgentDefData = def_agent_data(def)
        let sym_agent: Symbol = new_symbol(data.name, "agent", make_type(data.name), false)
        return define_in_scope(st, data.name, sym_agent)
    }
    if dk == "pipe_def" {
        let sym_pipe: Symbol = new_symbol("pipe", "pipe", unknown_type(), false)
        return define_in_scope(st, "pipe", sym_pipe)
    }
    if dk == "struct_def" {
        let data: StructDefData = def_struct_data(def)
        let sym_struct: Symbol = new_symbol(data.name, "struct", make_type(data.name), false)
        return define_in_scope(st, data.name, sym_struct)
    }
    if dk == "enum_def" {
        let data: EnumDefData = def_enum_data(def)
        let sym_enum: Symbol = new_symbol(data.name, "enum", make_type(data.name), false)
        let mut st2: SemState = define_in_scope(st, data.name, sym_enum)
        let mut vi: Int = 0
        for _ in 0..200 {
            if vi >= len(data.variants) { return st2 }
            let v: EnumVariant = data.variants[vi]
            let variant_type: TypeInfo = make_builtin_fn_type(make_type(data.name))
            let vsym: Symbol = new_symbol(v.name, "function", variant_type, false)
            st2 = define_in_scope(st2, v.name, vsym)
            vi = vi + 1
        }
        return st2
    }
    if dk == "type_alias" {
        let name: String = def_type_alias_name(def)
        let resolved: TypeInfo = resolve_type_expr(def_type_alias_type(def))
        let sym_alias: Symbol = new_symbol(name, "type_alias", resolved, false)
        return define_in_scope(st, name, sym_alias)
    }
    if dk == "import_def" {
        let path: List<String> = def_import_path(def)
        let items: List<String> = def_import_items(def)
        let mut st2: SemState = st
        if len(items) > 0 {
            let mut ii: Int = 0
            for _ in 0..200 {
                if ii >= len(items) { return st2 }
                let item: String = items[ii]
                let sym_item: Symbol = new_symbol(item, "variable", unknown_type(), false)
                st2 = define_in_scope(st2, item, sym_item)
                ii = ii + 1
            }
        } else {
            if len(path) > 0 {
                let mod_name: String = path[len(path) - 1]
                let sym_mod: Symbol = new_symbol(mod_name, "variable", unknown_type(), false)
                st2 = define_in_scope(st2, mod_name, sym_mod)
            }
        }
        return st2
    }
    if dk == "export_def" {
        let inner_def: Option<Definition> = def_export_inner(def)
        match inner_def {
            Some(d) => { return register_def(st, d) },
            _ => { return st }
        }
    }
    // impl_def — methods handled in second pass
    return st
}

// ---------------------------------------------------------------------------
// Definition checking (second pass)
// ---------------------------------------------------------------------------

fn check_definitions(st: SemState, program: Program) -> SemState {
    let mut st2: SemState = st
    let mut i: Int = 0
    for _ in 0..2000 {
        if i >= len(program.definitions) { return st2 }
        let def: Definition = program.definitions[i]
        st2 = check_def(st2, def)
        i = i + 1
    }
    return st2
}

fn check_def(st: SemState, def: Definition) -> SemState {
    let dk: String = def_kind(def)
    if dk == "fn_def" { return check_fn_body(st, def_fn_data(def)) }
    if dk == "agent_def" { return check_agent_body(st, def_agent_data(def)) }
    if dk == "pipe_def" { return check_pipe_stages(st, def_pipe_data(def)) }
    if dk == "impl_def" { return check_impl_body(st, def_impl_target(def), def_impl_methods(def)) }
    if dk == "export_def" {
        let inner_def: Option<Definition> = def_export_inner(def)
        match inner_def {
            Some(d) => { return check_def(st, d) },
            _ => { return st }
        }
    }
    return st
}

// ---------------------------------------------------------------------------
// Function body checking
// ---------------------------------------------------------------------------

fn check_fn_body(st: SemState, data: FnDefData) -> SemState {
    let inner: SemState = push_scope(st)
    let mut st2: SemState = inner

    // Register parameters
    let mut pi: Int = 0
    for _ in 0..200 {
        if pi >= len(data.params) {
            // Check body
            let after: SemState = check_block(st2, data.body)
            return pop_scope(after)
        }
        let p: Param = data.params[pi]
        let pt: TypeInfo = resolve_type_opt(p.type_annotation)
        let sym: Symbol = new_symbol(p.name, "param", pt, false)
        st2 = define_in_scope(st2, p.name, sym)
        pi = pi + 1
    }

    return pop_scope(st2)
}

// ---------------------------------------------------------------------------
// Agent body checking
// ---------------------------------------------------------------------------

fn check_agent_body(st: SemState, data: AgentDefData) -> SemState {
    let inner: SemState = push_scope(st)
    let mut st2: SemState = inner

    // Register self
    let self_sym: Symbol = new_symbol("self", "variable", make_type(data.name), false)
    st2 = define_in_scope(st2, "self", self_sym)

    // Register inputs
    let mut ii: Int = 0
    for _ in 0..200 {
        if ii >= len(data.inputs) {
            // Register outputs
            let mut oi: Int = 0
            for _ in 0..200 {
                if oi >= len(data.outputs) {
                    // Check state bindings
                    let mut si_idx: Int = 0
                    for _ in 0..200 {
                        if si_idx >= len(data.state) {
                            // Check methods
                            let mut mi: Int = 0
                            for _ in 0..200 {
                                if mi >= len(data.methods) {
                                    return pop_scope(st2)
                                }
                                let method: FnDefData = data.methods[mi]
                                st2 = check_fn_body(st2, method)
                                mi = mi + 1
                            }
                            return pop_scope(st2)
                        }
                        let state_stmt: Stmt = data.state[si_idx]
                        st2 = check_stmt(st2, state_stmt)
                        si_idx = si_idx + 1
                    }
                    return pop_scope(st2)
                }
                let out: AgentOutput = data.outputs[oi]
                let out_type: TypeInfo = resolve_type_expr(out.type_annotation)
                let out_sym: Symbol = new_symbol(out.name, "variable", out_type, false)
                st2 = define_in_scope(st2, out.name, out_sym)
                oi = oi + 1
            }
            return pop_scope(st2)
        }
        let inp: AgentInput = data.inputs[ii]
        let inp_type: TypeInfo = resolve_type_expr(inp.type_annotation)
        let inp_sym: Symbol = new_symbol(inp.name, "variable", inp_type, false)
        st2 = define_in_scope(st2, inp.name, inp_sym)
        ii = ii + 1
    }

    return pop_scope(st2)
}

// ---------------------------------------------------------------------------
// Impl block checking
// ---------------------------------------------------------------------------

fn check_impl_body(st: SemState, target: String, methods: List<FnDefData>) -> SemState {
    let sym_opt: Option<Symbol> = scope_lookup(st.scope, target)
    let mut st2: SemState = st
    match sym_opt {
        Some(_) => {},
        _ => {
            st2 = add_error(st2, "Undefined type '" + target + "' in impl block", 0, 0)
        }
    }

    let mut mi: Int = 0
    for _ in 0..200 {
        if mi >= len(methods) { return st2 }
        let method: FnDefData = methods[mi]
        st2 = check_fn_body(st2, method)
        mi = mi + 1
    }
    return st2
}

// ---------------------------------------------------------------------------
// Pipe definition checking
// ---------------------------------------------------------------------------

fn check_pipe_stage_type(st: SemState, stage: Expr, pipe_name: String) -> TypeInfo {
    if expr_kind(stage) == "ident" { return resolve_pipe_ident_type(st, expr_ident_name(stage)) }
    return unknown_type()
}

fn resolve_pipe_ident_type(st: SemState, name: String) -> TypeInfo {
    let sym_opt: Option<Symbol> = scope_lookup(st.scope, name)
    match sym_opt {
        Some(sym) => {
            return resolve_sym_output_type(sym)
        },
        _ => { return unknown_type() }
    }
}

fn resolve_sym_output_type(sym: Symbol) -> TypeInfo {
    if sym.kind != "function" { return unknown_type() }
    if !sym.type_info.is_function { return unknown_type() }
    match sym.type_info.return_type {
        Some(ret) => { return ret },
        _ => { return unknown_type() }
    }
}

fn check_pipe_stage_err(st: SemState, stage: Expr, pipe_name: String) -> SemState {
    if expr_kind(stage) == "ident" {
        let name: String = expr_ident_name(stage)
        let sym_opt: Option<Symbol> = scope_lookup(st.scope, name)
        match sym_opt {
            Some(sym) => { return st },
            _ => { return add_error(st, "Undefined stage '" + name + "' in pipe '" + pipe_name + "'", 0, 0) }
        }
    }
    let sr: InferResult = infer_expr(st, stage)
    return sr.st
}

fn check_pipe_stages(st: SemState, data: PipeDefData) -> SemState {
    if len(data.stages) < 2 { return st }

    let mut st2: SemState = st
    let mut prev_output: TypeInfo = unknown_type()
    let mut si_idx: Int = 0

    for _ in 0..200 {
        if si_idx >= len(data.stages) { return st2 }
        let stage: Expr = data.stages[si_idx]
        prev_output = check_pipe_stage_type(st2, stage, data.name)
        let stage_err: SemState = check_pipe_stage_err(st2, stage, data.name)
        st2 = stage_err
        si_idx = si_idx + 1
    }
    return st2
}

// ---------------------------------------------------------------------------
// Builtin registration
// ---------------------------------------------------------------------------

fn register_builtins(st: SemState) -> SemState {
    let mut st2: SemState = st

    // print, println -> Void
    let print_sym: Symbol = new_symbol("print", "function", make_builtin_fn_type(void_type()), false)
    st2 = define_in_scope(st2, "print", print_sym)
    let println_sym: Symbol = new_symbol("println", "function", make_builtin_fn_type(void_type()), false)
    st2 = define_in_scope(st2, "println", println_sym)

    // len -> Int
    let len_sym: Symbol = new_symbol("len", "function", make_builtin_fn_type(int_type()), false)
    st2 = define_in_scope(st2, "len", len_sym)

    // toString -> String
    let tostr_sym: Symbol = new_symbol("toString", "function", make_builtin_fn_type(string_type()), false)
    st2 = define_in_scope(st2, "toString", tostr_sym)

    // str -> String (alias for toString)
    let str_sym: Symbol = new_symbol("str", "function", make_builtin_fn_type(string_type()), false)
    st2 = define_in_scope(st2, "str", str_sym)

    // int -> Int, float -> Float (type conversions)
    let int_sym: Symbol = new_symbol("int", "function", make_builtin_fn_type(int_type()), false)
    st2 = define_in_scope(st2, "int", int_sym)
    let float_sym: Symbol = new_symbol("float", "function", make_builtin_fn_type(make_type("Float")), false)
    st2 = define_in_scope(st2, "float", float_sym)

    // Some -> Option
    let some_sym: Symbol = new_symbol("Some", "function", make_builtin_fn_type(make_type("Option")), false)
    st2 = define_in_scope(st2, "Some", some_sym)

    // Ok, Err -> Result
    let ok_sym: Symbol = new_symbol("Ok", "function", make_builtin_fn_type(make_type("Result")), false)
    st2 = define_in_scope(st2, "Ok", ok_sym)
    let err_sym: Symbol = new_symbol("Err", "function", make_builtin_fn_type(make_type("Result")), false)
    st2 = define_in_scope(st2, "Err", err_sym)

    // signal -> Signal
    let sig_sym: Symbol = new_symbol("signal", "function", make_builtin_fn_type(make_type("Signal")), false)
    st2 = define_in_scope(st2, "signal", sig_sym)

    // stream -> Stream
    let stream_sym: Symbol = new_symbol("stream", "function", make_builtin_fn_type(make_type("Stream")), false)
    st2 = define_in_scope(st2, "stream", stream_sym)

    // ord -> Int
    let ord_sym: Symbol = new_symbol("ord", "function", make_builtin_fn_type(int_type()), false)
    st2 = define_in_scope(st2, "ord", ord_sym)

    // chr -> String
    let chr_sym: Symbol = new_symbol("chr", "function", make_builtin_fn_type(string_type()), false)
    st2 = define_in_scope(st2, "chr", chr_sym)

    // join -> String
    let join_sym: Symbol = new_symbol("join", "function", make_builtin_fn_type(string_type()), false)
    st2 = define_in_scope(st2, "join", join_sym)

    return st2
}

// ---------------------------------------------------------------------------
// Public API
// ---------------------------------------------------------------------------

pub fn check(program: Program, filename: String) -> List<SemanticError> {
    // Create initial state with builtins
    let mut st: SemState = new_sem_state(filename)
    st = register_builtins(st)

    // Pass 1: register all top-level definitions
    st = register_definitions(st, program)

    // Pass 2: check all definition bodies
    st = check_definitions(st, program)

    return st.errors
}

fn check_or_raise(program: Program, filename: String) -> List<SemanticError> {
    let errors: List<SemanticError> = check(program, filename)
    return errors
}

// ===== mir.mn =====
// mir.mn — MIR (Mid-level Intermediate Representation) data structures.
// Shared by lower.mn, lower_state.mn, and emit_llvm.mn.
//
// Defines all MIR types, values, instructions, basic blocks, functions,
// modules, and associated helper structs/constructors.

// ---------------------------------------------------------------------------
// MIR type representation
// ---------------------------------------------------------------------------

struct MIRType {
    name: String,
    kind: String,
    args: List<MIRType>
}

fn new_mir_type(name: String, kind: String) -> MIRType {
    let args: List<MIRType> = []
    return new MIRType { name: name, kind: kind, args: args }
}

fn new_mir_type_with_args(name: String, kind: String, args: List<MIRType>) -> MIRType {
    return new MIRType { name: name, kind: kind, args: args }
}

fn mir_int() -> MIRType { return new_mir_type("Int", "int") }
fn mir_float() -> MIRType { return new_mir_type("Float", "float") }
fn mir_bool() -> MIRType { return new_mir_type("Bool", "bool") }
fn mir_string() -> MIRType { return new_mir_type("String", "string") }
fn mir_void() -> MIRType { return new_mir_type("Void", "void") }
fn mir_unknown() -> MIRType { return new_mir_type("<unknown>", "unknown") }
fn mir_option() -> MIRType { return new_mir_type("Option", "option") }
fn mir_option_of(inner: MIRType) -> MIRType {
    let mut t: MIRType = new_mir_type("Option", "option")
    t.args.push(inner)
    return t
}
fn mir_result() -> MIRType { return new_mir_type("Result", "result") }
fn mir_list() -> MIRType { return new_mir_type("List", "list") }
fn mir_map() -> MIRType { return new_mir_type("Map", "map") }
fn mir_signal() -> MIRType { return new_mir_type("Signal", "signal") }
fn mir_range() -> MIRType { return new_mir_type("Range", "range") }
fn mir_fn_type() -> MIRType { return new_mir_type("<fn>", "fn") }

fn mir_struct(name: String) -> MIRType {
    return new_mir_type(name, "struct")
}

fn mir_enum(name: String) -> MIRType {
    return new_mir_type(name, "enum")
}

fn mir_agent(name: String) -> MIRType {
    return new_mir_type(name, "agent")
}

// ---------------------------------------------------------------------------
// MIR values — SSA virtual registers
// ---------------------------------------------------------------------------

struct Value {
    name: String,
    ty: MIRType
}

fn new_value(name: String, ty: MIRType) -> Value {
    return new Value { name: name, ty: ty }
}

fn void_value() -> Value {
    return new_value("%void", mir_void())
}

// ---------------------------------------------------------------------------
// MIR instructions — encoded as tagged enum
// ---------------------------------------------------------------------------

enum BinOpKind {
    Add, Sub, Mul, Div, Mod,
    Eq, Ne, Lt, Gt, Le, Ge,
    And, Or
}

enum UnaryOpKind {
    Neg, Not
}

enum StreamOpKind {
    Map, Filter, Fold, Take, Skip, Collect
}

// Field pair for struct init
struct FieldPair {
    name: String,
    val: Value
}

fn new_field_pair(name: String, val: Value) -> FieldPair {
    return new FieldPair { name: name, val: val }
}

// Key-value pair for map init
struct KVPair {
    key: Value,
    val: Value
}

fn new_kv_pair(key: Value, val: Value) -> KVPair {
    return new KVPair { key: key, val: val }
}

// Phi incoming entry
struct PhiEntry {
    block_label: String,
    val: Value
}

fn new_phi_entry(label: String, val: Value) -> PhiEntry {
    return new PhiEntry { block_label: label, val: val }
}

// Switch case entry
struct SwitchCase {
    tag_value: String,
    block_label: String
}

fn new_switch_case(tag: String, label: String) -> SwitchCase {
    return new SwitchCase { tag_value: tag, block_label: label }
}

enum Instruction {
    // Values
    Const(Value, MIRType, String),
    Copy(Value, Value),
    Cast(Value, Value, MIRType),
    // Arithmetic
    BinOp(Value, BinOpKind, Value, Value),
    UnaryOp(Value, UnaryOpKind, Value),
    // Aggregates
    StructInit(Value, MIRType, List<FieldPair>),
    FieldGet(Value, Value, String),
    FieldSet(Value, String, Value),
    ListInit(Value, MIRType, List<Value>),
    IndexGet(Value, Value, Value),
    IndexSet(Value, Value, Value),
    Alloca(Value, MIRType),
    Load(Value, Value),
    Store(Value, Value),
    MapInit(Value, MIRType, MIRType, List<KVPair>),
    // Enum
    EnumInit(Value, MIRType, String, List<Value>),
    EnumTag(Value, Value),
    EnumPayload(Value, Value, String),
    // Option/Result
    WrapSome(Value, Value),
    WrapNone(Value, MIRType),
    WrapOk(Value, Value),
    WrapErr(Value, Value),
    Unwrap(Value, Value),
    // Functions
    Call(Value, String, List<Value>),
    Return(Option<Value>),
    // Control flow
    Jump(String),
    Branch(Value, String, String),
    Switch(Value, List<SwitchCase>, String),
    // Agents
    AgentSpawn(Value, MIRType, List<Value>),
    AgentSend(Value, String, Value),
    AgentSync(Value, Value, String),
    // Signals
    SignalInit(Value, MIRType, Value),
    SignalGet(Value, Value),
    SignalSet(Value, Value),
    // Streams
    StreamOp(Value, StreamOpKind, Value, List<Value>),
    // Strings
    InterpConcat(Value, List<Value>),
    // SSA
    Phi(Value, List<PhiEntry>)
}

// ---------------------------------------------------------------------------
// Basic block
// ---------------------------------------------------------------------------

struct BasicBlock {
    label: String,
    instructions: List<Instruction>
}

fn new_basic_block(label: String) -> BasicBlock {
    let instrs: List<Instruction> = []
    return new BasicBlock { label: label, instructions: instrs }
}

fn is_terminator(inst: Instruction) -> Bool {
    match inst {
        Jump(_) => { return true },
        Branch(_, _, _) => { return true },
        Switch(_, _, _) => { return true },
        Return(_) => { return true },
        _ => { return false }
    }
}

fn block_terminated(bb: BasicBlock) -> Bool {
    if len(bb.instructions) == 0 { return false }
    let last: Instruction = bb.instructions[len(bb.instructions) - 1]
    return is_terminator(last)
}

// ---------------------------------------------------------------------------
// MIR function
// ---------------------------------------------------------------------------

struct MIRParam {
    name: String,
    ty: MIRType
}

fn new_mir_param(name: String, ty: MIRType) -> MIRParam {
    return new MIRParam { name: name, ty: ty }
}

struct MIRFunction {
    name: String,
    params: List<MIRParam>,
    return_type: MIRType,
    blocks: List<BasicBlock>,
    decorators: List<String>,
    is_public: Bool
}

fn new_mir_function(name: String, params: List<MIRParam>, ret: MIRType, decorators: List<String>, is_public: Bool) -> MIRFunction {
    let blocks: List<BasicBlock> = []
    return new MIRFunction { name: name, params: params, return_type: ret, blocks: blocks, decorators: decorators, is_public: is_public }
}

// ---------------------------------------------------------------------------
// MIR module
// ---------------------------------------------------------------------------

struct StructInfo {
    name: String,
    fields: List<FieldPair>
}

fn new_struct_info(name: String, fields: List<FieldPair>) -> StructInfo {
    return new StructInfo { name: name, fields: fields }
}

struct EnumVariantInfo {
    name: String,
    payload_types: List<MIRType>
}

fn new_enum_variant_info(name: String, types: List<MIRType>) -> EnumVariantInfo {
    return new EnumVariantInfo { name: name, payload_types: types }
}

struct EnumInfo {
    name: String,
    variants: List<EnumVariantInfo>
}

fn new_enum_info(name: String, variants: List<EnumVariantInfo>) -> EnumInfo {
    return new EnumInfo { name: name, variants: variants }
}

struct ExternFnInfo {
    abi: String,
    module_name: String,
    fn_name: String,
    param_types: List<MIRType>,
    return_type: MIRType
}

fn new_extern_fn_info(abi: String, module_name: String, fn_name: String, params: List<MIRType>, ret: MIRType) -> ExternFnInfo {
    return new ExternFnInfo { abi: abi, module_name: module_name, fn_name: fn_name, param_types: params, return_type: ret }
}

struct AgentInfo {
    name: String,
    inputs: List<String>,
    outputs: List<String>,
    method_names: List<String>
}

fn new_agent_info(name: String, inputs: List<String>, outputs: List<String>, methods: List<String>) -> AgentInfo {
    return new AgentInfo { name: name, inputs: inputs, outputs: outputs, method_names: methods }
}

struct PipeInfo {
    name: String,
    stages: List<String>
}

fn new_pipe_info(name: String, stages: List<String>) -> PipeInfo {
    return new PipeInfo { name: name, stages: stages }
}

struct ImportInfo {
    path: List<String>,
    items: List<String>
}

fn new_import_info(path: List<String>, items: List<String>) -> ImportInfo {
    return new ImportInfo { path: path, items: items }
}

struct MIRModule {
    name: String,
    functions: List<MIRFunction>,
    structs: List<StructInfo>,
    enums: List<EnumInfo>,
    extern_fns: List<ExternFnInfo>,
    agents: List<AgentInfo>,
    pipes: List<PipeInfo>,
    imports: List<ImportInfo>,
    trait_names: List<String>
}

fn new_mir_module(name: String) -> MIRModule {
    let functions: List<MIRFunction> = []
    let structs: List<StructInfo> = []
    let enums: List<EnumInfo> = []
    let extern_fns: List<ExternFnInfo> = []
    let agents: List<AgentInfo> = []
    let pipes: List<PipeInfo> = []
    let imports: List<ImportInfo> = []
    let trait_names: List<String> = []
    return new MIRModule { name: name, functions: functions, structs: structs, enums: enums, extern_fns: extern_fns, agents: agents, pipes: pipes, imports: imports, trait_names: trait_names }
}

// ---------------------------------------------------------------------------
// Variable tracking
// ---------------------------------------------------------------------------

struct VarInfo {
    name: String,
    current: Value,
    mutable: Bool
}

fn new_var_info(name: String, val: Value, mutable: Bool) -> VarInfo {
    return new VarInfo { name: name, current: val, mutable: mutable }
}

// Impl method mapping: "Type.method" -> "Type_method"
struct ImplEntry {
    key: String,
    mir_name: String
}

fn new_impl_entry(key: String, mir_name: String) -> ImplEntry {
    return new ImplEntry { key: key, mir_name: mir_name }
}

// Struct field names and types mapping
struct StructFieldInfo {
    name: String,
    field_names: List<String>,
    field_types: List<MIRType>
}

fn new_struct_field_info(name: String, fields: List<String>, types: List<MIRType>) -> StructFieldInfo {
    return new StructFieldInfo { name: name, field_names: fields, field_types: types }
}

// Enum variant names mapping
struct EnumVariantNames {
    enum_name: String,
    variant_names: List<String>
}

fn new_enum_variant_names(name: String, variants: List<String>) -> EnumVariantNames {
    return new EnumVariantNames { enum_name: name, variant_names: variants }
}

// Lambda variable mapping
struct LambdaEntry {
    var_name: String,
    fn_name: String
}

fn new_lambda_entry(var_name: String, fn_name: String) -> LambdaEntry {
    return new LambdaEntry { var_name: var_name, fn_name: fn_name }
}

// ---------------------------------------------------------------------------
// Enum-to-string conversion (used by emit_llvm.mn and pretty-printer)
// ---------------------------------------------------------------------------

pub fn binop_kind_to_str(op: BinOpKind) -> String {
    match op {
        Add => { return "add" },
        Sub => { return "sub" },
        Mul => { return "mul" },
        Div => { return "div" },
        Mod => { return "mod" },
        Eq => { return "eq" },
        Ne => { return "ne" },
        Lt => { return "lt" },
        Gt => { return "gt" },
        Le => { return "le" },
        Ge => { return "ge" },
        And => { return "and" },
        Or => { return "or" }
    }
}

pub fn unaryop_kind_to_str(op: UnaryOpKind) -> String {
    match op {
        Neg => { return "neg" },
        Not => { return "not" }
    }
}

pub fn streamop_kind_to_str(op: StreamOpKind) -> String {
    match op {
        Map => { return "map" },
        Filter => { return "filter" },
        Fold => { return "fold" },
        Take => { return "take" },
        Skip => { return "skip" },
        Collect => { return "collect" }
    }
}

// ---------------------------------------------------------------------------
// String-tagged dispatch: instr_kind + field accessors
// These functions use match WITHIN mir.mn (same module as the Instruction
// enum), so enum tags are always correct regardless of which compiler
// produced this binary.  Consumers in other modules (emit_llvm.mn,
// lower.mn) call these instead of matching on Instruction directly.
// ---------------------------------------------------------------------------

pub fn instr_kind(i: Instruction) -> String {
    match i {
        Const(_, _, _) => { return "const" },
        Copy(_, _) => { return "copy" },
        Cast(_, _, _) => { return "cast" },
        BinOp(_, _, _, _) => { return "binop" },
        UnaryOp(_, _, _) => { return "unaryop" },
        StructInit(_, _, _) => { return "struct_init" },
        FieldGet(_, _, _) => { return "field_get" },
        FieldSet(_, _, _) => { return "field_set" },
        ListInit(_, _, _) => { return "list_init" },
        IndexGet(_, _, _) => { return "index_get" },
        IndexSet(_, _, _) => { return "index_set" },
        Alloca(_, _) => { return "alloca" },
        Load(_, _) => { return "load" },
        Store(_, _) => { return "store" },
        MapInit(_, _, _, _) => { return "map_init" },
        EnumInit(_, _, _, _) => { return "enum_init" },
        EnumTag(_, _) => { return "enum_tag" },
        EnumPayload(_, _, _) => { return "enum_payload" },
        WrapSome(_, _) => { return "wrap_some" },
        WrapNone(_, _) => { return "wrap_none" },
        WrapOk(_, _) => { return "wrap_ok" },
        WrapErr(_, _) => { return "wrap_err" },
        Unwrap(_, _) => { return "unwrap" },
        Call(_, _, _) => { return "call" },
        Return(_) => { return "return" },
        Jump(_) => { return "jump" },
        Branch(_, _, _) => { return "branch" },
        Switch(_, _, _) => { return "switch" },
        AgentSpawn(_, _, _) => { return "agent_spawn" },
        AgentSend(_, _, _) => { return "agent_send" },
        AgentSync(_, _, _) => { return "agent_sync" },
        SignalInit(_, _, _) => { return "signal_init" },
        SignalGet(_, _) => { return "signal_get" },
        SignalSet(_, _) => { return "signal_set" },
        StreamOp(_, _, _, _) => { return "stream_op" },
        InterpConcat(_, _) => { return "interp_concat" },
        Phi(_, _) => { return "phi" }
    }
}

// --- Instruction field accessors ---
// Each function extracts one field from a specific variant (or group of
// variants).  The _ => default is never reached when callers check
// instr_kind() first.

pub fn instr_dest(i: Instruction) -> Value {
    match i {
        Const(d, _, _) => { return d },
        Copy(d, _) => { return d },
        Cast(d, _, _) => { return d },
        BinOp(d, _, _, _) => { return d },
        UnaryOp(d, _, _) => { return d },
        StructInit(d, _, _) => { return d },
        FieldGet(d, _, _) => { return d },
        ListInit(d, _, _) => { return d },
        IndexGet(d, _, _) => { return d },
        Alloca(d, _) => { return d },
        Load(d, _) => { return d },
        MapInit(d, _, _, _) => { return d },
        EnumInit(d, _, _, _) => { return d },
        EnumTag(d, _) => { return d },
        EnumPayload(d, _, _) => { return d },
        WrapSome(d, _) => { return d },
        WrapNone(d, _) => { return d },
        WrapOk(d, _) => { return d },
        WrapErr(d, _) => { return d },
        Unwrap(d, _) => { return d },
        Call(d, _, _) => { return d },
        AgentSpawn(d, _, _) => { return d },
        AgentSync(d, _, _) => { return d },
        SignalInit(d, _, _) => { return d },
        SignalGet(d, _) => { return d },
        StreamOp(d, _, _, _) => { return d },
        InterpConcat(d, _) => { return d },
        Phi(d, _) => { return d },
        _ => { return void_value() }
    }
}

