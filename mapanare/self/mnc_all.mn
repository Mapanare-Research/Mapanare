fn make_span(line: Int, column: Int, end_line: Int, end_column: Int) -> Span {
    return new Span { line: line, column: column, end_line: end_line, end_column: end_column }
}

fn start(defs: List<Definition>) -> Program {
    return new Program { span: make_span(1, 0, 1, 0), definitions: defs }
}

