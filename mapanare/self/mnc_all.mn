// Pipe
pub fn expr_pipe_left(e: Expr) -> Expr {
    match e { Pipe(l, _) => { return l }, _ => { return Expr::NoneLit } }
}
pub fn expr_pipe_right(e: Expr) -> Expr {
    match e { Pipe(_, r) => { return r }, _ => { return Expr::NoneLit } }
}

// Range
pub fn expr_range_start(e: Expr) -> Expr {
    match e { Range(s, _, _) => { return s }, _ => { return Expr::NoneLit } }
}
pub fn expr_range_end(e: Expr) -> Expr {
    match e { Range(_, x, _) => { return x }, _ => { return Expr::NoneLit } }
}
pub fn expr_range_inclusive(e: Expr) -> Bool {
    match e { Range(_, _, i) => { return i }, _ => { return false } }
}

// Lambda
pub fn expr_lambda_params(e: Expr) -> List<Param> {
    match e { Lambda(p, _) => { return p }, _ => { let empty: List<Param> = []; return empty } }
}
pub fn expr_lambda_body(e: Expr) -> LambdaBody {
    match e { Lambda(_, b) => { return b }, _ => { let s: List<Stmt> = []; return LambdaBody::BlockBody(new_block(make_span(0,0,0,0), s)) } }
}

// Spawn
pub fn expr_spawn_callee(e: Expr) -> Expr {
    match e { Spawn(c, _) => { return c }, _ => { return Expr::NoneLit } }
}
pub fn expr_spawn_args(e: Expr) -> List<Expr> {
    match e { Spawn(_, a) => { return a }, _ => { let empty: List<Expr> = []; return empty } }
}

// Sync
pub fn expr_sync_inner(e: Expr) -> Expr {
    match e { Sync(x) => { return x }, _ => { return Expr::NoneLit } }
}

// Send
pub fn expr_send_target(e: Expr) -> Expr {
    match e { Send(t, _) => { return t }, _ => { return Expr::NoneLit } }
}
