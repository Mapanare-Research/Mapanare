// ===== lower_state.mn =====
// lower_state.mn — Lowerer state, scope management, lookups, and type resolution.
// Extracted from lower.mn to reduce file size and share lookup utilities.


// ---------------------------------------------------------------------------
// Lowerer state — threaded through all lowering functions
// ---------------------------------------------------------------------------

struct LowerState {
    module: MIRModule,
    current_fn: Option<MIRFunction>,
    current_block_idx: Int,
    tmp_counter: Int,
    block_counter: Int,
    vars: List<VarInfo>,
    scope_stack: List<Int>,
    impl_methods: List<ImplEntry>,
    struct_fields: List<StructFieldInfo>,
    enum_variants: List<EnumVariantNames>,
    lambda_vars: List<LambdaEntry>,
    fn_blocks: List<BasicBlock>,
}

fn new_lower_state(module_name: String) -> LowerState {
    let module: MIRModule = new_mir_module(module_name)
    let vars: List<VarInfo> = []
    let scope_stack: List<Int> = []
    let impl_methods: List<ImplEntry> = []
    let struct_fields: List<StructFieldInfo> = []
    let enum_variants: List<EnumVariantNames> = []
    let lambda_vars: List<LambdaEntry> = []
    let fn_blocks: List<BasicBlock> = []
    return new LowerState { module: module, current_fn: none, current_block_idx: 0, tmp_counter: 0, block_counter: 0, vars: vars, scope_stack: scope_stack, impl_methods: impl_methods, struct_fields: struct_fields, enum_variants: enum_variants, lambda_vars: lambda_vars, fn_blocks: fn_blocks }
}

// Lower result: value + updated state
struct LowerResult {
    value: Value,
    state: LowerState
}

fn new_lower_result(val: Value, st: LowerState) -> LowerResult {
    return new LowerResult { value: val, state: st }
}

// ---------------------------------------------------------------------------
// Name generation
// ---------------------------------------------------------------------------

fn fresh_tmp(st: LowerState, prefix: String) -> LowerResult {
    let name: String = "%" + prefix + toString(st.tmp_counter)
    let mut new_st: LowerState = st
    new_st.tmp_counter = st.tmp_counter + 1
    let val: Value = new_value(name, mir_unknown())
    return new_lower_result(val, new_st)
}

fn fresh_block_label(st: LowerState, prefix: String) -> LowerResult {
    let name: String = prefix + toString(st.block_counter)
    let mut new_st: LowerState = st
    new_st.block_counter = st.block_counter + 1
    let val: Value = new_value(name, mir_unknown())
    return new_lower_result(val, new_st)
}

fn make_value(st: LowerState, ty: MIRType, prefix: String) -> LowerResult {
    let r: LowerResult = fresh_tmp(st, prefix)
    let val: Value = new_value(r.value.name, ty)
    return new_lower_result(val, r.state)
}

// ---------------------------------------------------------------------------
// Block management
// ---------------------------------------------------------------------------

fn add_block(st: LowerState, label: String) -> LowerState {
    let bb: BasicBlock = new_basic_block(label)
    let mut new_st: LowerState = st
    let idx: Int = len(st.fn_blocks)
    let mut blocks: List<BasicBlock> = new_st.fn_blocks
    blocks.push(bb)
    new_st.fn_blocks = blocks
    new_st.current_block_idx = idx
    return new_st
}

fn is_some_fn(opt: Option<MIRFunction>) -> Bool {
    match opt {
        Some(_) => { return true },
        _ => { return false }
    }
}

fn set_block(st: LowerState, idx: Int) -> LowerState {
    let mut new_st: LowerState = st
    new_st.current_block_idx = idx
    return new_st
}

fn emit_instr(st: LowerState, instr: Instruction) -> LowerState {
    // Append instruction to current block using flattened fn_blocks list.
    // Extract → modify → reassign to handle COW write-back correctly.
    let mut new_st: LowerState = st
    let idx: Int = st.current_block_idx
    if idx >= 0 {
        if idx < len(st.fn_blocks) {
            let bb: BasicBlock = st.fn_blocks[idx]
            let mut instrs: List<Instruction> = bb.instructions
            instrs.push(instr)
            let new_bb: BasicBlock = new BasicBlock { label: bb.label, instructions: instrs }
            let mut blocks: List<BasicBlock> = new_st.fn_blocks
            blocks[idx] = new_bb
            new_st.fn_blocks = blocks
        }
    }
    return new_st
}

fn current_block_terminated(st: LowerState) -> Bool {
    let idx: Int = st.current_block_idx
    if idx >= 0 {
        if idx < len(st.fn_blocks) {
            let bb: BasicBlock = st.fn_blocks[idx]
            return block_terminated(bb)
        }
    }
    return true
}

// ---------------------------------------------------------------------------
// Scope management
// ---------------------------------------------------------------------------

fn lower_push_scope(st: LowerState) -> LowerState {
    // Save the current variable count. On pop, truncate vars back to this length.
    let mut new_st: LowerState = st
    let var_count: Int = len(st.vars)
    let mut stack: List<Int> = new_st.scope_stack
    stack.push(var_count)
    new_st.scope_stack = stack
    return new_st
}

fn lower_pop_scope(st: LowerState) -> LowerState {
    let mut new_st: LowerState = st
    if len(st.scope_stack) > 0 {
        let saved_len: Int = st.scope_stack[len(st.scope_stack) - 1]
        // Truncate vars back to the saved length
        // (removes variables defined in the inner scope)
        let mut restored: List<VarInfo> = []
        let mut i: Int = 0
        let nv: Int = len(st.vars)
        for _ in 0..2000 {
            if i < saved_len {
                if i < nv {
                    restored.push(st.vars[i])
                    i = i + 1
                }
            }
        }
        new_st.vars = restored
    }
    return new_st
}

fn define_var(st: LowerState, name: String, val: Value, mutable: Bool) -> LowerState {
    let mut new_st: LowerState = st
    let vi: VarInfo = new_var_info(name, val, mutable)
    let mut vs: List<VarInfo> = new_st.vars
    vs.push(vi)
    new_st.vars = vs
    return new_st
}

fn lookup_var(st: LowerState, name: String) -> Option<Value> {
    let mut i: Int = len(st.vars) - 1
    for _ in 0..2000 {
        if i < 0 { return none }
        let v: VarInfo = st.vars[i]
        if v.name == name { return Some(v.current) }
        i = i - 1
    }
    return none
}

fn update_var(st: LowerState, name: String, val: Value) -> LowerState {
    let mut new_st: LowerState = st
    let mut i: Int = len(st.vars) - 1
    for _ in 0..2000 {
        if i < 0 { return new_st }
        let v: VarInfo = st.vars[i]
        if v.name == name {
            let updated: VarInfo = new_var_info(name, val, v.mutable)
            st.vars[i] = updated
            return new_st
        }
        i = i - 1
    }
    return new_st
}

// ---------------------------------------------------------------------------
// Lookup helpers
// ---------------------------------------------------------------------------

fn find_struct_fields(st: LowerState, name: String) -> Option<List<String>> {
    let mut i: Int = 0
    for _ in 0..2000 {
        if i >= len(st.struct_fields) { return none }
        let sf: StructFieldInfo = st.struct_fields[i]
        if sf.name == name { return Some(sf.field_names) }
        i = i + 1
    }
    return none
}

fn is_struct_name(st: LowerState, name: String) -> Bool {
    let mut i: Int = 0
    for _ in 0..2000 {
        if i >= len(st.struct_fields) { return false }
        let sf: StructFieldInfo = st.struct_fields[i]
        if sf.name == name { return true }
        i = i + 1
    }
    return false
}

fn get_struct_field_names(st: LowerState, name: String) -> List<String> {
    let mut i: Int = 0
    let nsf: Int = len(st.struct_fields)
    for _ in 0..2000 {
        if i < nsf {
            let sf: StructFieldInfo = st.struct_fields[i]
            if sf.name == name { return sf.field_names }
            i = i + 1
        }
    }
    let empty: List<String> = []
    return empty
}

fn find_enum_variants(st: LowerState, name: String) -> Option<List<String>> {
    let mut i: Int = 0
    for _ in 0..2000 {
        if i >= len(st.enum_variants) { return none }
        let ev: EnumVariantNames = st.enum_variants[i]
        if ev.enum_name == name { return Some(ev.variant_names) }
        i = i + 1
    }
    return none
}

fn is_variant_of_enum(st: LowerState, enum_name: String, variant: String) -> Bool {
    let mut i: Int = 0
    let nev0: Int = len(st.enum_variants)
    for _ in 0..2000 {
        if i < nev0 {
            let ev: EnumVariantNames = st.enum_variants[i]
            if ev.enum_name == enum_name {
                let mut j: Int = 0
                let nvn0: Int = len(ev.variant_names)
                for _ in 0..2000 {
                    if j < nvn0 {
                        if ev.variant_names[j] == variant { return true }
                        j = j + 1
                    }
                }
                return false
            }
            i = i + 1
        }
    }
    return false
}

fn is_enum_variant(st: LowerState, name: String) -> Bool {
    let mut i: Int = 0
    let nev: Int = len(st.enum_variants)
    for _ in 0..2000 {
        if i < nev {
            let ev: EnumVariantNames = st.enum_variants[i]
            let mut j: Int = 0
            let nvn: Int = len(ev.variant_names)
            for _ in 0..2000 {
                if j < nvn {
                    let vn: String = ev.variant_names[j]
                    if vn == name { return true }
                    j = j + 1
                }
            }
            i = i + 1
        }
    }
    return false
}

fn variant_index(st: LowerState, variant: String) -> Int {
    let mut i: Int = 0
    let nev2: Int = len(st.enum_variants)
    for _ in 0..2000 {
        if i < nev2 {
            let ev: EnumVariantNames = st.enum_variants[i]
            let mut j: Int = 0
            let nvn2: Int = len(ev.variant_names)
            for _ in 0..2000 {
                if j < nvn2 {
                    if ev.variant_names[j] == variant { return j }
                    j = j + 1
                }
            }
            i = i + 1
        }
    }
    return 0
}

fn enum_name_for_variant(st: LowerState, variant: String) -> String {
    let mut i: Int = 0
    let nev3: Int = len(st.enum_variants)
    for _ in 0..2000 {
        if i < nev3 {
            let ev: EnumVariantNames = st.enum_variants[i]
            let mut j: Int = 0
            let nvn3: Int = len(ev.variant_names)
            for _ in 0..2000 {
                if j < nvn3 {
                    let vn: String = ev.variant_names[j]
                    if vn == variant { return ev.enum_name }
                    j = j + 1
                }
            }
            i = i + 1
        }
    }
    return ""
}

fn find_impl_method(st: LowerState, type_name: String, method: String) -> Option<String> {
    let key: String = type_name + "." + method
    let mut i: Int = 0
    for _ in 0..2000 {
        if i >= len(st.impl_methods) { return none }
        let e: ImplEntry = st.impl_methods[i]
        if e.key == key { return Some(e.mir_name) }
        i = i + 1
    }
    return none
}

fn find_lambda(st: LowerState, name: String) -> Option<String> {
    let mut i: Int = 0
    for _ in 0..2000 {
        if i >= len(st.lambda_vars) { return none }
        let e: LambdaEntry = st.lambda_vars[i]
        if e.var_name == name { return Some(e.fn_name) }
        i = i + 1
    }
    return none
}

// ---------------------------------------------------------------------------
// Type resolution: AST TypeExpr -> MIRType
// ---------------------------------------------------------------------------

fn lower_resolve_type_expr(te: TypeExpr) -> MIRType {
    match te {
        Named(name) => {
            return resolve_type_name(name)
        },
        Generic(name, args) => {
            let mut resolved_args: List<MIRType> = []
            let mut i: Int = 0
            for _ in 0..100 {
                if i >= len(args) {
                    let kind: String = kind_from_name(name)
                    if kind != "unknown" {
                        return new_mir_type_with_args(name, kind, resolved_args)
                    }
                    return new_mir_type_with_args(name, "struct", resolved_args)
                }
                let arg: TypeExpr = args[i]
                let resolved: MIRType = lower_resolve_type_expr(arg)
                resolved_args.push(resolved)
                i = i + 1
            }
            return mir_unknown()
        },
        FnTy(param_types, return_type) => {
            return mir_fn_type()
        },
        _ => { return mir_unknown() }
    }
}

fn resolve_type_name(name: String) -> MIRType {
    if name == "Int" { return mir_int() }
    if name == "Float" { return mir_float() }
    if name == "Bool" { return mir_bool() }
    if name == "String" { return mir_string() }
    if name == "Char" { return mir_string() }
    if name == "Void" { return mir_void() }
    if name == "Option" { return mir_option() }
    if name == "Result" { return mir_result() }
    if name == "List" { return mir_list() }
    if name == "Map" { return mir_map() }
    if name == "Signal" { return mir_signal() }
    return mir_struct(name)
}

// State-aware type resolution: distinguishes structs from enums
fn resolve_type_name_checked(st: LowerState, name: String) -> MIRType {
    if name == "Int" { return mir_int() }
    if name == "Float" { return mir_float() }
    if name == "Bool" { return mir_bool() }
    if name == "String" { return mir_string() }
    if name == "Char" { return mir_string() }
    if name == "Void" { return mir_void() }
    if name == "Option" { return mir_option() }
    if name == "Result" { return mir_result() }
    if name == "List" { return mir_list() }
    if name == "Map" { return mir_map() }
    if name == "Signal" { return mir_signal() }
    // Check if this is a registered enum
    let mut i: Int = 0
    let nev_r: Int = len(st.enum_variants)
    for _ in 0..10000 {
        if i < nev_r {
            if st.enum_variants[i].enum_name == name {
                return mir_enum(name)
            }
            i = i + 1
        }
    }
    return mir_struct(name)
}

fn kind_from_name(name: String) -> String {
    if name == "Int" { return "int" }
    if name == "Float" { return "float" }
    if name == "Bool" { return "bool" }
    if name == "String" { return "string" }
    if name == "Char" { return "string" }
    if name == "Void" { return "void" }
    if name == "Option" { return "option" }
    if name == "Result" { return "result" }
    if name == "List" { return "list" }
    if name == "Map" { return "map" }
    if name == "Signal" { return "signal" }
    if name == "Stream" { return "stream" }
    if name == "Agent" { return "agent" }
    if name == "Tensor" { return "tensor" }
    if name == "Range" { return "range" }
    return "unknown"
}

fn lower_resolve_type_opt(te: Option<TypeExpr>) -> MIRType {
    match te {
        Some(t) => { return lower_resolve_type_expr(t) },
        _ => { return mir_unknown() }
    }
}

fn lower_resolve_type_opt_checked(st: LowerState, te: Option<TypeExpr>) -> MIRType {
    match te {
        Some(t) => { return lower_resolve_type_checked(st, t) },
        _ => { return mir_unknown() }
    }
}

fn resolve_return_type(te: Option<TypeExpr>) -> MIRType {
    match te {
        Some(t) => { return lower_resolve_type_expr(t) },
        _ => { return mir_void() }
    }
}

// State-aware type expression resolver (distinguishes enums from structs)
fn resolve_generic_args_rec(st: LowerState, args: List<TypeExpr>, idx: Int, acc: List<MIRType>) -> List<MIRType> {
    if idx >= len(args) { return acc }
    let arg: TypeExpr = args[idx]
    let resolved: MIRType = lower_resolve_type_checked(st, arg)
    acc.push(resolved)
    return resolve_generic_args_rec(st, args, idx + 1, acc)
}

fn lower_resolve_type_checked(st: LowerState, te: TypeExpr) -> MIRType {
    match te {
        Named(name) => {
            return resolve_type_name_checked(st, name)
        },
        Generic(name, args) => {
            // Use recursion instead of for-loop to avoid the alloca aliasing bug
            let init_args: List<MIRType> = []
            let resolved_args: List<MIRType> = resolve_generic_args_rec(st, args, 0, init_args)
            let kind: String = kind_from_name(name)
            if kind != "unknown" {
                return new_mir_type_with_args(name, kind, resolved_args)
            }
            let checked: MIRType = resolve_type_name_checked(st, name)
            return new_mir_type_with_args(name, checked.kind, resolved_args)
        },
        FnTy(param_types, return_type) => {
            return mir_fn_type()
        },
        _ => { return mir_unknown() }
    }
}

fn resolve_return_type_checked(st: LowerState, te: Option<TypeExpr>) -> MIRType {
    match te {
        Some(t) => { return lower_resolve_type_checked(st, t) },
        _ => { return mir_void() }
    }
}

// ---------------------------------------------------------------------------
// Operator mapping
// ---------------------------------------------------------------------------

fn binop_from_str(op: String) -> Option<BinOpKind> {
    if op == "+" { return Some(BinOpKind::Add) }
    if op == "-" { return Some(BinOpKind::Sub) }
    if op == "*" { return Some(BinOpKind::Mul) }
    if op == "/" { return Some(BinOpKind::Div) }
    if op == "%" { return Some(BinOpKind::Mod) }
    if op == "==" { return Some(BinOpKind::Eq) }
    if op == "!=" { return Some(BinOpKind::Ne) }
    if op == "<" { return Some(BinOpKind::Lt) }
    if op == ">" { return Some(BinOpKind::Gt) }
    if op == "<=" { return Some(BinOpKind::Le) }
    if op == ">=" { return Some(BinOpKind::Ge) }
    if op == "&&" { return Some(BinOpKind::And) }
    if op == "||" { return Some(BinOpKind::Or) }
    return none
}

fn unaryop_from_str(op: String) -> Option<UnaryOpKind> {
    if op == "-" { return Some(UnaryOpKind::Neg) }
    if op == "!" { return Some(UnaryOpKind::Not) }
    return none
}

fn stream_op_from_str(name: String) -> Option<StreamOpKind> {
    if name == "map" { return Some(StreamOpKind::Map) }
    if name == "filter" { return Some(StreamOpKind::Filter) }
    if name == "fold" { return Some(StreamOpKind::Fold) }
    if name == "take" { return Some(StreamOpKind::Take) }
    if name == "skip" { return Some(StreamOpKind::Skip) }
    if name == "collect" { return Some(StreamOpKind::Collect) }
    return none
}

fn is_comparison_binop(op: BinOpKind) -> Bool {
    match op {
        Eq => { return true },
        Ne => { return true },
        Lt => { return true },
        Gt => { return true },
        Le => { return true },
        Ge => { return true },
        And => { return true },
        Or => { return true },
        _ => { return false }
    }
}

// binop_kind_to_str and unaryop_kind_to_str live in mir.mn (near the enums they convert)

// ===== lower.mn =====
// lower.mn — AST → MIR lowering pass for the Mapanare self-hosted compiler.
// Core lowering logic: declaration registration, definition lowering,
// expression/statement lowering, control flow, pretty-printer, verifier.
//
// Data structures (MIRType, Value, Instruction, etc.) are in mir.mn.
// State management (LowerState, lookups, type resolution) is in lower_state.mn.


// ---------------------------------------------------------------------------
// Declaration registration (Pass 1)
// ---------------------------------------------------------------------------

fn register_declarations(st: LowerState, program: Program) -> LowerState {
    let mut s: LowerState = st
    // Pass 1: register enums first so struct field types can distinguish enum vs struct
    s = register_declarations_pass1(s, program)
    // Pass 2: register structs, impls, functions, imports
    s = register_declarations_pass2(s, program)
    return s
}

// Pass 1: register enums. Extracted to helper to use return-based loop exit.
fn register_declarations_pass1(st: LowerState, program: Program) -> LowerState {
    let mut s: LowerState = st
    let mut i: Int = 0
    for _ in 0..2000 {
        if i >= len(program.definitions) { return s }
        let defn: Definition = program.definitions[i]
        // Use register_enum_if_enum to avoid match PHI zeroinitializer bug
        s = register_enum_if_enum(s, defn)
        i = i + 1
    }
    return s
}

// If defn is EnumDef, register it. Otherwise return state unchanged.
fn register_enum_if_enum(st: LowerState, defn: Definition) -> LowerState {
    if def_kind(defn) == "enum_def" { return register_enum(st, def_enum_data(defn)) }
    return st
}

// Pass 2: register non-enum definitions. Extracted for return-based exit.
fn register_declarations_pass2(st: LowerState, program: Program) -> LowerState {
    let mut s: LowerState = st
    let mut i: Int = 0
    for _ in 0..2000 {
        if i >= len(program.definitions) { return s }
        let defn: Definition = program.definitions[i]
        s = register_nonenums(s, defn)
        i = i + 1
    }
    return s
}

// If defn is NOT EnumDef, register it. Otherwise return state unchanged.
fn register_nonenums(st: LowerState, defn: Definition) -> LowerState {
    if def_kind(defn) == "enum_def" { return st }
    return register_definition(st, defn)
}

fn register_definition(st: LowerState, defn: Definition) -> LowerState {
    let dk: String = def_kind(defn)
    if dk == "struct_def" {
        return register_struct(st, def_struct_data(defn))
    }
    if dk == "enum_def" {
        return register_enum(st, def_enum_data(defn))
    }
    if dk == "impl_def" {
        return register_impl(st, def_impl_target(defn), def_impl_methods(defn))
    }
    if dk == "import_def" {
        let info: ImportInfo = new_import_info(def_import_path(defn), def_import_items(defn))
        let mut new_st_imp: LowerState = st
        let mut mod_tmp: MIRModule = new_st_imp.module
        let mut imp_list: List<ImportInfo> = mod_tmp.imports
        imp_list.push(info)
        mod_tmp.imports = imp_list
        new_st_imp.module = mod_tmp
        return new_st_imp
    }
    if dk == "export_def" {
        let inner_opt: Option<Definition> = def_export_inner(defn)
        match inner_opt {
            Some(inner) => { return register_definition(st, inner) },
            _ => { return st }
        }
    }
    if dk == "fn_def" {
        // Register function return type via lambda_vars (top-level list,
        // properly COW-cloned). Using "__ret__fn_name" as the key.
        // This avoids the nested MIRModule.functions COW corruption issue.
        let fd: FnDefData = def_fn_data(defn)
        let ret_ty: MIRType = resolve_return_type_checked(st, fd.return_type)
        let ret_key: String = "__ret__" + fd.name
        let ret_val: String = ret_ty.kind + ":" + ret_ty.name
        let entry: LambdaEntry = new_lambda_entry(ret_key, ret_val)
        let mut new_st_fn: LowerState = st
        let mut lv_fn: List<LambdaEntry> = new_st_fn.lambda_vars
        lv_fn.push(entry)
        new_st_fn.lambda_vars = lv_fn
        return new_st_fn
    }
    if dk == "extern_fn_def" {
        return register_extern_fn(st, defn)
    }
    return st
}

fn register_extern_fn(st: LowerState, defn: Definition) -> LowerState {
    let abi: String = def_extern_abi(defn)
    let fn_name: String = def_extern_name(defn)
    let params: List<Param> = def_extern_params(defn)
    let ret_opt: Option<TypeExpr> = def_extern_return_type(defn)

    // Resolve return type
    let ret_ty: MIRType = resolve_return_type_checked(st, ret_opt)

    // Register function return type in lambda_vars (for call resolution)
    let ret_key: String = "__ret__" + fn_name
    let ret_val: String = ret_ty.kind + ":" + ret_ty.name
    let entry: LambdaEntry = new_lambda_entry(ret_key, ret_val)
    let mut s: LowerState = st
    let mut lv: List<LambdaEntry> = s.lambda_vars
    lv.push(entry)
    s.lambda_vars = lv

    // Resolve parameter types
    let mut param_types: List<MIRType> = []
    let mut i: Int = 0
    for _ in 0..50 {
        if i >= len(params) {
            // Push ExternFnInfo to module.extern_fns
            let info: ExternFnInfo = new_extern_fn_info(abi, "", fn_name, param_types, ret_ty)
            let mut mod_tmp: MIRModule = s.module
            let mut ext_list: List<ExternFnInfo> = mod_tmp.extern_fns
            ext_list.push(info)
            mod_tmp.extern_fns = ext_list
            s.module = mod_tmp
            return s
        }
        let p: Param = params[i]
        match p.type_annotation {
            Some(te) => {
                param_types.push(lower_resolve_type_checked(s, te))
            },
            _ => {
                param_types.push(mir_unknown())
            }
        }
        i = i + 1
    }

    // Fallback: push whatever we have
    let info_fb: ExternFnInfo = new_extern_fn_info(abi, "", fn_name, param_types, ret_ty)
    let mut mod_fb: MIRModule = s.module
    let mut ext_fb: List<ExternFnInfo> = mod_fb.extern_fns
    ext_fb.push(info_fb)
    mod_fb.extern_fns = ext_fb
    s.module = mod_fb
    return s
}

fn register_struct(st: LowerState, data: StructDefData) -> LowerState {
    let mut fields: List<FieldPair> = []
    let mut field_names: List<String> = []
    let mut field_types: List<MIRType> = []
    let mut i: Int = 0
    let mut s: LowerState = st

    for _ in 0..200 {
        if i >= len(data.fields) {
            let info: StructInfo = new_struct_info(data.name, fields)
            s.module = module_push_struct(s.module, info)
            let sfi: StructFieldInfo = new_struct_field_info(data.name, field_names, field_types)
            let mut sf_lst: List<StructFieldInfo> = s.struct_fields
            sf_lst.push(sfi)
            s.struct_fields = sf_lst
            return s
        }
        let field: StructField = data.fields[i]
        let fty: MIRType = lower_resolve_type_checked(s, field.type_annotation)
        let fp: FieldPair = new_field_pair(field.name, new_value("", fty))
        fields.push(fp)
        field_names.push(field.name)
        field_types.push(fty)
        i = i + 1
    }
    return s
}

fn register_enum(st: LowerState, data: EnumDefData) -> LowerState {
    let mut variants: List<EnumVariantInfo> = []
    let mut variant_names: List<String> = []
    let mut i: Int = 0
    let mut s: LowerState = st

    for _ in 0..200 {
        if i >= len(data.variants) {
            let info: EnumInfo = new_enum_info(data.name, variants)
            s.module = module_push_enum(s.module, info)
            let evn: EnumVariantNames = new_enum_variant_names(data.name, variant_names)
            let mut ev_lst: List<EnumVariantNames> = s.enum_variants
            ev_lst.push(evn)
            s.enum_variants = ev_lst
            return s
        }
        let variant: EnumVariant = data.variants[i]
        let mut payload_types: List<MIRType> = []
        let mut j: Int = 0
        for _ in 0..100 {
            if j < len(variant.fields) {
                let fty: MIRType = lower_resolve_type_expr(variant.fields[j])
                payload_types.push(fty)
                j = j + 1
            }
        }
        let vi: EnumVariantInfo = new_enum_variant_info(variant.name, payload_types)
        variants.push(vi)
        variant_names.push(variant.name)
        i = i + 1
    }
    return s
}

fn register_impl(st: LowerState, target: String, methods: List<FnDefData>) -> LowerState {
    let mut s: LowerState = st
    let mut i: Int = 0
    for _ in 0..200 {
        if i >= len(methods) { return s }
        let method: FnDefData = methods[i]
        let key: String = target + "." + method.name
        let mir_name: String = target + "_" + method.name
        let entry: ImplEntry = new_impl_entry(key, mir_name)
        let mut im_lst: List<ImplEntry> = s.impl_methods
        im_lst.push(entry)
        s.impl_methods = im_lst
        i = i + 1
    }
    return s
}

// ---------------------------------------------------------------------------
// Definition lowering (Pass 2)
// ---------------------------------------------------------------------------

fn lower_definitions(st: LowerState, program: Program) -> LowerState {
    let mut s: LowerState = st
    let mut i: Int = 0
    for _ in 0..2000 {
        if i >= len(program.definitions) {
            return s
        }
        let defn: Definition = program.definitions[i]
        let new_s: LowerState = lower_definition(s, defn)
        s = new_s
        i = i + 1
    }
    return s
}

fn lower_definition(st: LowerState, defn: Definition) -> LowerState {
    let dk: String = def_kind(defn)
    if dk == "fn_def" {
        return lower_fn(st, def_fn_data(defn), "")
    }
    if dk == "agent_def" {
        return lower_agent(st, def_agent_data(defn))
    }
    if dk == "impl_def" {
        return lower_impl(st, def_impl_target(defn), def_impl_methods(defn))
    }
    if dk == "export_def" {
        let inner_opt: Option<Definition> = def_export_inner(defn)
        match inner_opt {
            Some(inner) => {
                let s: LowerState = lower_definition(st, inner)
                return s
            },
            _ => { return st }
        }
    }
    return st
}

// ---------------------------------------------------------------------------
// Function lowering
// ---------------------------------------------------------------------------

// Helper: build MIR params from FnDefData.params (avoids break-in-for bug)
fn build_mir_params(st: LowerState, fn_params: List<Param>) -> List<MIRParam> {
    let mut params: List<MIRParam> = []
    let mut pi: Int = 0
    for _ in 0..200 {
        if pi >= len(fn_params) { return params }
        let p: Param = fn_params[pi]
        let pty: MIRType = lower_resolve_type_opt_checked(st, p.type_annotation)
        let mp: MIRParam = new_mir_param(p.name, pty)
        params.push(mp)
        pi = pi + 1
    }
    return params
}

// Helper: collect decorator names (avoids break-in-for bug)
fn collect_decorator_names(decorators: List<Decorator>) -> List<String> {
    let mut names: List<String> = []
    let mut dix: Int = 0
    for _ in 0..100 {
        if dix >= len(decorators) { return names }
        let dec: Decorator = decorators[dix]
        names.push(dec.name)
        dix = dix + 1
    }
    return names
}

// Helper: bind params as variables in entry block (avoids break-in-for bug)
fn bind_fn_params(st: LowerState, fn_params: List<Param>) -> LowerState {
    let mut s: LowerState = st
    let mut bi: Int = 0
    for _ in 0..200 {
        if bi >= len(fn_params) { return s }
        let p: Param = fn_params[bi]
        let pty: MIRType = lower_resolve_type_opt_checked(s, p.type_annotation)
        let addr_name: String = "%" + p.name + ".addr"
        let addr: Value = new_value(addr_name, pty)
        let param_val: Value = new_value("%" + p.name, pty)
        s = emit_instr(s, Instruction::Alloca(addr, pty))
        s = emit_instr(s, Instruction::Store(addr, param_val))
        s = define_var(s, p.name, addr, false)
        bi = bi + 1
    }
    return s
}

fn lower_fn(st: LowerState, fn_def: FnDefData, name_prefix: String) -> LowerState {
    let fn_name: String = name_prefix + fn_def.name

    // Build params and decorators using helpers (avoid break-in-for bug)
    let params: List<MIRParam> = build_mir_params(st, fn_def.params)
    let ret_type: MIRType = resolve_return_type_checked(st, fn_def.return_type)
    let decorators: List<String> = collect_decorator_names(fn_def.decorators)

    let mir_fn: MIRFunction = new_mir_function(fn_name, params, ret_type, decorators, fn_def.public)

    // Save state
    let prev_fn: Option<MIRFunction> = st.current_fn
    let prev_block_idx: Int = st.current_block_idx
    let prev_tmp: Int = st.tmp_counter
    let prev_blk_cnt: Int = st.block_counter
    let prev_vars: List<VarInfo> = st.vars
    let prev_blocks: List<BasicBlock> = st.fn_blocks

    let mut s: LowerState = st
    s.current_fn = Some(mir_fn)
    s.tmp_counter = 0
    s.block_counter = 0
    let fresh_vars: List<VarInfo> = []
    s.vars = fresh_vars
    let fresh_blocks: List<BasicBlock> = []
    s.fn_blocks = fresh_blocks

    // Create entry block
    s = add_block(s, "entry")
    s = set_block(s, 0)

    // Bind params as variables
    let mut bi: Int = 0
    s = bind_fn_params(s, fn_def.params)

    // Lower body
    let body_r: LowerResult = lower_block(s, fn_def.body)
    s = body_r.state

    // Add implicit return if block isn't terminated
    if !current_block_terminated(s) {
        if ret_type.kind == "void" {
            s = emit_instr(s, Instruction::Return(none))
        } else {
            s = emit_instr(s, Instruction::Return(Some(body_r.value)))
        }
    }

    // Copy fn_blocks into MIRFunction and add to module.
    let mut final_fn: MIRFunction = mir_fn
    final_fn.blocks = s.fn_blocks
    s.module = module_push_function(s.module, final_fn)
    __mn_str_eprint(fn_name)
    __mn_str_eprint(toString(len(final_fn.blocks)))
    __mn_str_eprint(toString(len(s.module.functions)))
    __mn_str_eprint("\n")

    // Restore state
    s.current_fn = prev_fn
    s.current_block_idx = prev_block_idx
    s.tmp_counter = prev_tmp
    s.block_counter = prev_blk_cnt
    s.vars = prev_vars
    s.fn_blocks = prev_blocks

    return s
}

fn lower_agent(st: LowerState, data: AgentDefData) -> LowerState {
    let mut s: LowerState = st
    let mut method_names: List<String> = []

    // Lower each method
    let mut i: Int = 0
    for _ in 0..200 {
        if i >= len(data.methods) {
            let inputs: List<String> = extract_agent_input_names(data)
            let outputs: List<String> = extract_agent_output_names(data)
            let info: AgentInfo = new_agent_info(data.name, inputs, outputs, method_names)
            s.module = module_push_agent(s.module, info)
            return s
        }
        let method: FnDefData = data.methods[i]
        s = lower_fn(s, method, data.name + "_")
        let method_mir_name: String = data.name + "_" + method.name
        method_names.push(method_mir_name)
        i = i + 1
    }
    return s
}

fn extract_agent_input_names(data: AgentDefData) -> List<String> {
    let mut names: List<String> = []
    let mut i: Int = 0
    for _ in 0..100 {
        if i >= len(data.inputs) { return names }
        let inp: AgentInput = data.inputs[i]
        names.push(inp.name)
        i = i + 1
    }
    return names
}

fn extract_agent_output_names(data: AgentDefData) -> List<String> {
    let mut names: List<String> = []
    let mut i: Int = 0
    for _ in 0..100 {
        if i >= len(data.outputs) { return names }
        let out: AgentOutput = data.outputs[i]
        names.push(out.name)
        i = i + 1
    }
    return names
}

fn lower_impl(st: LowerState, target: String, methods: List<FnDefData>) -> LowerState {
    let mut s: LowerState = st
    let mut i: Int = 0
    for _ in 0..200 {
        if i >= len(methods) { return s }
        let method: FnDefData = methods[i]
        s = lower_fn(s, method, target + "_")
        i = i + 1
    }
    return s
}

// ---------------------------------------------------------------------------
// Block / statement lowering
// ---------------------------------------------------------------------------

fn lower_block(st: LowerState, block: Block) -> LowerResult {
    let s: LowerState = lower_push_scope(st)
    // Use helper to iterate statements (avoids return-inside-if-inside-for bug)
    let r: LowerResult = lower_block_stmts(s, block.stmts)
    let final_s: LowerState = lower_pop_scope(r.state)
    return new_lower_result(r.value, final_s)
}

// Helper: iterate block statements. Uses return-based exit.
fn lower_block_stmts(st: LowerState, stmts: List<Stmt>) -> LowerResult {
    let mut s: LowerState = st
    let mut last_val: Value = void_value()
    let mut i: Int = 0
    for _ in 0..600 {
        if i >= len(stmts) { return new_lower_result(last_val, s) }
        if current_block_terminated(s) { return new_lower_result(last_val, s) }
        let stmt: Stmt = stmts[i]
        let r: LowerResult = lower_stmt(s, stmt)
        s = r.state
        last_val = r.value
        i = i + 1
    }
    return new_lower_result(last_val, s)
}

fn lower_stmt(st: LowerState, stmt: Stmt) -> LowerResult {
    let sk: String = stmt_kind(stmt)
    if sk == "let" {
        let s_let: LowerState = lower_let(st, stmt_let_name(stmt), stmt_let_mutable(stmt), stmt_let_type(stmt), stmt_let_value(stmt))
        return new_lower_result(void_value(), s_let)
    }
    if sk == "expr_stmt" {
        return lower_expr(st, stmt_expr(stmt))
    }
    if sk == "return" {
        let s_ret: LowerState = lower_return(st, stmt_return_val(stmt))
        return new_lower_result(void_value(), s_ret)
    }
    if sk == "for" {
        let s_for: LowerState = lower_for(st, stmt_for_var(stmt), stmt_for_iter(stmt), stmt_for_body(stmt))
        return new_lower_result(void_value(), s_for)
    }
    if sk == "signal_decl" {
        let s_sig: LowerState = lower_signal_decl(st, stmt_signal_name(stmt), stmt_signal_mutable(stmt), stmt_signal_type(stmt), stmt_signal_value(stmt))
        return new_lower_result(void_value(), s_sig)
    }
    if sk == "stream_decl" {
        let s_strm: LowerState = lower_stream_decl(st, stmt_stream_name(stmt), stmt_stream_value(stmt))
        return new_lower_result(void_value(), s_strm)
    }
    return new_lower_result(void_value(), st)
}

// ---------------------------------------------------------------------------
// Let binding
// ---------------------------------------------------------------------------

fn lower_let(st: LowerState, name: String, mutable: Bool, type_ann: Option<TypeExpr>, value: Expr) -> LowerState {
    // Check if the value expression is a None literal BEFORE lowering.
    // This flag is used later to decide whether to re-wrap with typed WrapNone.
    let mut is_none_literal: Bool = false
    if expr_kind(value) == "none_lit" { is_none_literal = true }
    let r: LowerResult = lower_expr(st, value)
    let mut s: LowerState = r.state

    // Update lambda registration: lower_lambda left var_name empty
    let num_lv: Int = len(s.lambda_vars)
    if num_lv > 0 {
        let last_e: LambdaEntry = s.lambda_vars[num_lv - 1]
        if last_e.var_name == "" {
            let updated: LambdaEntry = new_lambda_entry(name, last_e.fn_name)
            s.lambda_vars[num_lv - 1] = updated
        }
    }

    // Prefer the declared type annotation over the expression's inferred type.
    // This is critical: function calls return mir_unknown(), but the declared
    // type (e.g., `let ch: String = lexer_peek(source)`) carries the real type.
    let mut val_ty: MIRType = r.value.ty
    let mut val: Value = r.value
    match type_ann {
        Some(te) => {
            let declared: MIRType = lower_resolve_type_checked(s, te)
            if declared.kind != "unknown" {
                val_ty = declared
                // Patch the value to carry the declared type (same SSA name, correct type)
                val = new_value(r.value.name, declared)
            }
        },
        _ => {}
    }

    // Find or create alloca for this variable (use counter for uniqueness
    // when the same variable name appears in different branches)
    let addr_name: String = "%" + name + toString(s.tmp_counter) + ".addr"
    s.tmp_counter = s.tmp_counter + 1

    let addr: Value = new_value(addr_name, val_ty)

    // Emit Alloca with the resolved type
    s = emit_instr(s, Instruction::Alloca(addr, val_ty))

    // For None stored to a typed Option alloca: re-emit WrapNone with the
    // declared type so the value and alloca types match.
    // ONLY do this for actual None literals (value name contains "tnone" or
    // is the WrapNone result), NOT for function call results that happen to
    // have untyped Option return. Check: if the expression was NoneLit, the
    // value name starts with "%t" and has no "_val" (it's a direct constant,
    // not a loaded variable or call result).
    if is_none_literal && val_ty.kind == "option" && len(val_ty.args) > 0 {
        let typed_none_r: LowerResult = make_value(s, val_ty, "tnone")
        s = emit_instr(typed_none_r.state, Instruction::WrapNone(typed_none_r.value, val_ty))
        val = typed_none_r.value
    }

    // Store value to alloca
    s = emit_instr(s, Instruction::Store(addr, val))

    // Track the alloca address in our variable map
    s = define_var(s, name, addr, mutable)
    return s
}

// ---------------------------------------------------------------------------
// Return
// ---------------------------------------------------------------------------

fn lower_return(st: LowerState, value_opt: Option<Expr>) -> LowerState {
    match value_opt {
        Some(expr) => {
            let r: LowerResult = lower_expr(st, expr)
            // Return the value directly — no Copy needed.
            // (Avoids `add i64 0, %struct_val` type mismatch for struct returns.)
            return emit_instr(r.state, Instruction::Return(Some(r.value)))
        },
        _ => {
            return emit_instr(st, Instruction::Return(none))
        }
    }
}

// ---------------------------------------------------------------------------
// For loop
// ---------------------------------------------------------------------------

fn lower_for(st: LowerState, var_name: String, iterable: Expr, body: Block) -> LowerState {
    // Lower the iterable (Range expression: start..end)
    let iter_r: LowerResult = lower_expr(st, iterable)
    let mut s: LowerState = iter_r.state

    // Counter-based loop: use __mn_range_start/end to extract bounds.
    // SSA-based iterator can't mutate, so we use alloca counter.
    let counter_addr: Value = new_value("%for_counter" + toString(s.tmp_counter) + ".addr", mir_int())
    s.tmp_counter = s.tmp_counter + 1
    s = emit_instr(s, Instruction::Alloca(counter_addr, mir_int()))

    // Extract start/end from range via runtime calls
    let start_r: LowerResult = make_value(s, mir_int(), "for_start")
    s = start_r.state
    let mut start_args: List<Value> = []
    start_args.push(iter_r.value)
    s = emit_instr(s, Instruction::Call(start_r.value, "__mn_range_start", start_args))
    let end_r: LowerResult = make_value(s, mir_int(), "for_end")
    s = end_r.state
    let mut end_args: List<Value> = []
    end_args.push(iter_r.value)
    s = emit_instr(s, Instruction::Call(end_r.value, "__mn_range_end", end_args))

    // Store start value to counter
    s = emit_instr(s, Instruction::Store(counter_addr, start_r.value))

    // Save current (entry) block index
    let entry_idx: Int = s.current_block_idx

    // Create blocks
    let header_r2: LowerResult = fresh_block_label(s, "for_header")
    s = header_r2.state
    let header_label: String = header_r2.value.name
    s = add_block(s, header_label)
    let header_idx: Int = s.current_block_idx

    let body_r2: LowerResult = fresh_block_label(s, "for_body")
    s = body_r2.state
    let body_label: String = body_r2.value.name
    s = add_block(s, body_label)
    let body_idx: Int = s.current_block_idx

    let exit_r2: LowerResult = fresh_block_label(s, "for_exit")
    s = exit_r2.state
    let exit_label: String = exit_r2.value.name
    s = add_block(s, exit_label)
    let exit_idx: Int = s.current_block_idx

    // Jump from entry block to header
    s = set_block(s, entry_idx)
    if !current_block_terminated(s) {
        s = emit_instr(s, Instruction::Jump(header_label))
    }

    // Header block: load counter, compare < end, branch
    s = set_block(s, header_idx)
    let counter_val: LowerResult = make_value(s, mir_int(), "for_i")
    s = counter_val.state
    s = emit_instr(s, Instruction::Load(counter_val.value, counter_addr))
    let cmp_r: LowerResult = make_value(s, mir_bool(), "for_cmp")
    s = cmp_r.state
    s = emit_instr(s, Instruction::BinOp(cmp_r.value, BinOpKind::Lt, counter_val.value, end_r.value))
    s = emit_instr(s, Instruction::Branch(cmp_r.value, body_label, exit_label))

    // Body block: define loop variable, execute body, increment counter
    s = set_block(s, body_idx)
    let loop_addr_r: LowerResult = make_value(s, mir_int(), var_name + "_addr")
    s = loop_addr_r.state
    s = emit_instr(s, Instruction::Alloca(loop_addr_r.value, mir_int()))
    // Load current counter value for the loop variable
    let cur_i: LowerResult = make_value(s, mir_int(), "cur_i")
    s = cur_i.state
    s = emit_instr(s, Instruction::Load(cur_i.value, counter_addr))
    s = emit_instr(s, Instruction::Store(loop_addr_r.value, cur_i.value))
    s = define_var(s, var_name, loop_addr_r.value, false)

    s = lower_push_scope(s)
    let body_result: LowerResult = lower_block(s, body)
    s = body_result.state
    s = lower_pop_scope(s)

    // Increment counter and jump back to header
    if !current_block_terminated(s) {
        let inc_val: LowerResult = make_value(s, mir_int(), "for_inc")
        s = inc_val.state
        let inc_i: LowerResult = make_value(s, mir_int(), "for_ci")
        s = inc_i.state
        s = emit_instr(s, Instruction::Load(inc_i.value, counter_addr))
        let one_r: LowerResult = make_value(s, mir_int(), "one")
        s = one_r.state
        s = emit_instr(s, Instruction::Const(one_r.value, mir_int(), "1"))
        s = emit_instr(s, Instruction::BinOp(inc_val.value, BinOpKind::Add, inc_i.value, one_r.value))
        s = emit_instr(s, Instruction::Store(counter_addr, inc_val.value))
        s = emit_instr(s, Instruction::Jump(header_label))
    }

    // Exit block
    s = set_block(s, exit_idx)
    return s
}

// ---------------------------------------------------------------------------
// Signal / stream declarations
// ---------------------------------------------------------------------------

fn lower_signal_decl(st: LowerState, name: String, mutable: Bool, type_ann: Option<TypeExpr>, value: Expr) -> LowerState {
    let init_r: LowerResult = lower_expr(st, value)
    let sig_type: MIRType = lower_resolve_type_opt(type_ann)
    let dest_r: LowerResult = make_value(init_r.state, mir_signal(), "sig")
    let mut s: LowerState = emit_instr(dest_r.state, Instruction::SignalInit(dest_r.value, sig_type, init_r.value))
    s = define_var(s, name, dest_r.value, mutable)
    return s
}

fn lower_stream_decl(st: LowerState, name: String, value: Expr) -> LowerState {
    let r: LowerResult = lower_expr(st, value)
    return define_var(r.state, name, r.value, false)
}

// ---------------------------------------------------------------------------
// Expression lowering
// ---------------------------------------------------------------------------

fn lower_expr(st: LowerState, expr: Expr) -> LowerResult {
    let ek: String = expr_kind(expr)
    if ek == "int_lit" {
        let n: Int = expr_int_val(expr)
        let r_int: LowerResult = make_value(st, mir_int(), "t")
        let s_int: LowerState = emit_instr(r_int.state, Instruction::Const(r_int.value, mir_int(), toString(n)))
        return new_lower_result(r_int.value, s_int)
    }
    if ek == "float_lit" {
        let f: Float = expr_float_val(expr)
        let r_flt: LowerResult = make_value(st, mir_float(), "t")
        let s_flt: LowerState = emit_instr(r_flt.state, Instruction::Const(r_flt.value, mir_float(), toString(f)))
        return new_lower_result(r_flt.value, s_flt)
    }
    if ek == "bool_lit" {
        let b: Bool = expr_bool_val(expr)
        let r_bool: LowerResult = make_value(st, mir_bool(), "t")
        let mut val_str: String = "false"
        if b { val_str = "true" }
        let s_bool: LowerState = emit_instr(r_bool.state, Instruction::Const(r_bool.value, mir_bool(), val_str))
        return new_lower_result(r_bool.value, s_bool)
    }
    if ek == "string_lit" {
        let text: String = expr_string_val(expr)
        let r_str: LowerResult = make_value(st, mir_string(), "t")
        let s_str: LowerState = emit_instr(r_str.state, Instruction::Const(r_str.value, mir_string(), text))
        return new_lower_result(r_str.value, s_str)
    }
    if ek == "char_lit" {
        let ch: String = expr_char_val(expr)
        let r_chr: LowerResult = make_value(st, mir_string(), "t")
        let s_chr: LowerState = emit_instr(r_chr.state, Instruction::Const(r_chr.value, mir_string(), ch))
        return new_lower_result(r_chr.value, s_chr)
    }
    if ek == "none_lit" {
        let r_none: LowerResult = make_value(st, mir_option(), "t")
        let s_none: LowerState = emit_instr(r_none.state, Instruction::WrapNone(r_none.value, mir_option()))
        return new_lower_result(r_none.value, s_none)
    }
    if ek == "ident" {
        return lower_identifier(st, expr_ident_name(expr))
    }
    if ek == "binary" {
        return lower_binary(st, expr_binary_left(expr), expr_binary_op(expr), expr_binary_right(expr))
    }
    if ek == "unary" {
        return lower_unary(st, expr_unary_op(expr), expr_unary_operand(expr))
    }
    if ek == "call" {
        return lower_call(st, expr_call_callee(expr), expr_call_args(expr))
    }
    if ek == "method_call" {
        return lower_method_call(st, expr_method_obj(expr), expr_method_name(expr), expr_method_args(expr))
    }
    if ek == "field_access" {
        return lower_field_access(st, expr_field_obj(expr), expr_field_name(expr))
    }
    if ek == "namespace_access" {
        return lower_namespace_access(st, expr_ns_name(expr), expr_ns_member(expr))
    }
    if ek == "index" {
        return lower_index(st, expr_index_obj(expr), expr_index_idx(expr))
    }
    if ek == "pipe" {
        return lower_pipe(st, expr_pipe_left(expr), expr_pipe_right(expr))
    }
    if ek == "range" {
        return lower_range(st, expr_range_start(expr), expr_range_end(expr), expr_range_inclusive(expr))
    }
    if ek == "lambda" {
        return lower_lambda(st, expr_lambda_params(expr), expr_lambda_body(expr))
    }
    if ek == "spawn" {
        return lower_spawn(st, expr_spawn_callee(expr), expr_spawn_args(expr))
    }
    if ek == "sync" {
        return lower_sync(st, expr_sync_inner(expr))
    }
    if ek == "send" {
        return lower_send(st, expr_send_target(expr), expr_send_value(expr))
    }
    if ek == "error_prop" {
        return lower_error_prop(st, expr_errorprop_inner(expr))
    }
    if ek == "list_lit" {
        return lower_list(st, expr_list_elements(expr))
    }
    if ek == "map_lit" {
        return lower_map(st, expr_map_entries(expr))
    }
    if ek == "construct" {
        return lower_construct(st, expr_construct_name(expr), expr_construct_fields(expr))
    }
    if ek == "some_wrap" {
        let inner: Expr = expr_wrap_inner(expr)
        let r_some: LowerResult = lower_expr(st, inner)
        let dr_some: LowerResult = make_value(r_some.state, mir_option(), "t")
        let s_some: LowerState = emit_instr(dr_some.state, Instruction::WrapSome(dr_some.value, r_some.value))
        return new_lower_result(dr_some.value, s_some)
    }
    if ek == "ok_wrap" {
        let inner: Expr = expr_wrap_inner(expr)
        let r_ok: LowerResult = lower_expr(st, inner)
        let dr_ok: LowerResult = make_value(r_ok.state, mir_result(), "t")
        let s_ok: LowerState = emit_instr(dr_ok.state, Instruction::WrapOk(dr_ok.value, r_ok.value))
        return new_lower_result(dr_ok.value, s_ok)
    }
    if ek == "err_wrap" {
        let inner: Expr = expr_wrap_inner(expr)
        let r_err: LowerResult = lower_expr(st, inner)
        let dr_err: LowerResult = make_value(r_err.state, mir_result(), "t")
        let s_err: LowerState = emit_instr(dr_err.state, Instruction::WrapErr(dr_err.value, r_err.value))
        return new_lower_result(dr_err.value, s_err)
    }
    if ek == "signal_val" {
        return lower_signal_expr(st, expr_signal_inner(expr))
    }
    if ek == "assign" {
        return lower_assign(st, expr_assign_target(expr), expr_assign_op(expr), expr_assign_value(expr))
    }
    if ek == "if" {
        return lower_if(st, expr_if_cond(expr), expr_if_then(expr), expr_if_else(expr))
    }
    if ek == "match" {
        return lower_match(st, expr_match_subject(expr), expr_match_arms(expr))
    }
    // Fallback
    let r_fallback: LowerResult = make_value(st, mir_unknown(), "t")
    return new_lower_result(r_fallback.value, r_fallback.state)
}

// ---------------------------------------------------------------------------
// Identifier lowering
// ---------------------------------------------------------------------------

fn lower_identifier(st: LowerState, name: String) -> LowerResult {
    // Check variable scope
    let var_opt: Option<Value> = lookup_var(st, name)
    match var_opt {
        Some(addr) => {
            // var_opt now returns the alloca address. Emit a Load to get the value.
            let r_var: LowerResult = make_value(st, addr.ty, name + "_val")
            let s_var: LowerState = emit_instr(r_var.state, Instruction::Load(r_var.value, addr))
            return new_lower_result(r_var.value, s_var)
        },
        _ => {}
    }

    // Check if it's a bare enum variant (no payload)
    if is_enum_variant(st, name) {
        let enum_name: String = enum_name_for_variant(st, name)
        let enum_ty: MIRType = mir_enum(enum_name)
        let r_enum: LowerResult = make_value(st, enum_ty, "t")
        let empty_payload: List<Value> = []
        let s_enum: LowerState = emit_instr(r_enum.state, Instruction::EnumInit(r_enum.value, enum_ty, name, empty_payload))
        return new_lower_result(r_enum.value, s_enum)
    }

    // Unknown — emit placeholder
    let r_unk: LowerResult = make_value(st, mir_unknown(), name)
    let s_unk: LowerState = emit_instr(r_unk.state, Instruction::Const(r_unk.value, mir_unknown(), ""))
    return new_lower_result(r_unk.value, s_unk)
}

// ---------------------------------------------------------------------------
// Binary expression lowering
// ---------------------------------------------------------------------------

fn lower_binary(st: LowerState, left: Expr, op: String, right: Expr) -> LowerResult {
    // Handle pipe operator
    if op == "|>" {
        return lower_pipe(st, left, right)
    }

    let lhs_r: LowerResult = lower_expr(st, left)
    let rhs_r: LowerResult = lower_expr(lhs_r.state, right)

    // Type coercion: if one operand is unknown and the other is typed,
    // propagate the known type to the unknown operand.
    let mut lhs_val: Value = lhs_r.value
    let mut rhs_val: Value = rhs_r.value
    if lhs_val.ty.kind == "unknown" && rhs_val.ty.kind != "unknown" {
        lhs_val = new_value(lhs_val.name, rhs_val.ty)
    }
    if rhs_val.ty.kind == "unknown" && lhs_val.ty.kind != "unknown" {
        rhs_val = new_value(rhs_val.name, lhs_val.ty)
    }

    let binop_opt: Option<BinOpKind> = binop_from_str(op)
    match binop_opt {
        Some(binop) => {
            // Use string comparison on the operator (not enum match on BinOpKind)
            // because enum match falls through in the compiled binary
            let is_cmp: Bool = op == "==" || op == "!=" || op == "<" || op == ">" || op == "<=" || op == ">=" || op == "and" || op == "or"
            let mut result_ty: MIRType = lhs_val.ty
            if is_cmp { result_ty = mir_bool() }
            let dr_binop: LowerResult = make_value(rhs_r.state, result_ty, "t")
            let s_binop: LowerState = emit_instr(dr_binop.state, Instruction::BinOp(dr_binop.value, binop, lhs_val, rhs_val))
            return new_lower_result(dr_binop.value, s_binop)
        },
        _ => {
            // Unknown operator — emit as call
            let dr_opcall: LowerResult = make_value(rhs_r.state, mir_unknown(), "t")
            let mut args: List<Value> = []
            args.push(lhs_r.value)
            args.push(rhs_r.value)
            let s_opcall: LowerState = emit_instr(dr_opcall.state, Instruction::Call(dr_opcall.value, "__op_" + op, args))
            return new_lower_result(dr_opcall.value, s_opcall)
        }
    }
}

// ---------------------------------------------------------------------------
// Unary expression lowering
// ---------------------------------------------------------------------------

fn resolve_unary_result_type(uop: UnaryOpKind, operand_ty: MIRType) -> MIRType {
    if unaryop_kind_to_str(uop) == "not" { return mir_bool() }
    return operand_ty
}

fn lower_unary(st: LowerState, op: String, operand: Expr) -> LowerResult {
    let op_r: LowerResult = lower_expr(st, operand)
    let uop_opt: Option<UnaryOpKind> = unaryop_from_str(op)
    match uop_opt {
        Some(uop) => {
            let result_ty: MIRType = resolve_unary_result_type(uop, op_r.value.ty)
            let dr_uop: LowerResult = make_value(op_r.state, result_ty, "t")
            let s_uop: LowerState = emit_instr(dr_uop.state, Instruction::UnaryOp(dr_uop.value, uop, op_r.value))
            return new_lower_result(dr_uop.value, s_uop)
        },
        _ => {
            let dr_ucall: LowerResult = make_value(op_r.state, mir_unknown(), "t")
            let mut args: List<Value> = []
            args.push(op_r.value)
            let s_ucall: LowerState = emit_instr(dr_ucall.state, Instruction::Call(dr_ucall.value, "__unary_" + op, args))
            return new_lower_result(dr_ucall.value, s_ucall)
        }
    }
}

// ---------------------------------------------------------------------------
// Call lowering
// ---------------------------------------------------------------------------

fn lower_call(st: LowerState, callee: Expr, arg_exprs: List<Expr>) -> LowerResult {
    // Lower all arguments first (guard pattern avoids break-in-for bug)
    let mut s: LowerState = st
    let mut args: List<Value> = []
    let mut i: Int = 0
    let nae: Int = len(arg_exprs)
    for _ in 0..200 {
        if i < nae {
            let arg_r: LowerResult = lower_expr(s, arg_exprs[i])
            s = arg_r.state
            args.push(arg_r.value)
            i = i + 1
        }
    }

    // Dispatch on callee type
    let ck: String = expr_kind(callee)
    if ck == "ident" {
        return lower_call_by_name(s, expr_ident_name(callee), args)
    }
    if ck == "field_access" {
        // obj.method(args) that parsed as Call(FieldAccess, args)
        let method: String = expr_field_name(callee)
        let obj_r: LowerResult = lower_expr(s, expr_field_obj(callee))
        let dr_meth: LowerResult = make_value(obj_r.state, mir_unknown(), "t")
        let mut all_args: List<Value> = []
        all_args.push(obj_r.value)
        let mut j: Int = 0
        let nargs_fa: Int = len(args)
        for _ in 0..200 {
            if j < nargs_fa {
                all_args.push(args[j])
                j = j + 1
            }
        }
        let ns_meth: LowerState = emit_instr(dr_meth.state, Instruction::Call(dr_meth.value, method, all_args))
        return new_lower_result(dr_meth.value, ns_meth)
    }
    if ck == "namespace_access" {
        let ns: String = expr_ns_name(callee)
        let member: String = expr_ns_member(callee)
        // Check if this is an enum variant constructor: Enum::Variant(...)
        // Directly check if the namespace enum has this variant (avoids
        // returning the wrong enum when variants share names like Return).
        if is_variant_of_enum(s, ns, member) {
            let enum_ty: MIRType = mir_enum(ns)
            let dr_evar: LowerResult = make_value(s, enum_ty, "t")
            let ns_evar: LowerState = emit_instr(dr_evar.state, Instruction::EnumInit(dr_evar.value, enum_ty, member, args))
            return new_lower_result(dr_evar.value, ns_evar)
        }
        // For struct statics like Program::start(defs), try bare function
        // name first (the function is `start`, not `Program_start`).
        return lower_call_by_name(s, member, args)
    }
    // Dynamic call (lambda, etc.)
    let callee_r: LowerResult = lower_expr(s, callee)
    let dr_dyn: LowerResult = make_value(callee_r.state, mir_unknown(), "t")
    let ns_dyn: LowerState = emit_instr(dr_dyn.state, Instruction::Call(dr_dyn.value, callee_r.value.name, args))
    return new_lower_result(dr_dyn.value, ns_dyn)
}

fn lower_call_by_name(st: LowerState, fn_name: String, args: List<Value>) -> LowerResult {
    // Builtin void functions
    if fn_name == "print" {
        let dr_print: LowerResult = make_value(st, mir_void(), "t")
        let s_print: LowerState = emit_instr(dr_print.state, Instruction::Call(dr_print.value, fn_name, args))
        return new_lower_result(dr_print.value, s_print)
    }
    if fn_name == "println" {
        let dr_pln: LowerResult = make_value(st, mir_void(), "t")
        let s_pln: LowerState = emit_instr(dr_pln.state, Instruction::Call(dr_pln.value, fn_name, args))
        return new_lower_result(dr_pln.value, s_pln)
    }
    // Builtin conversion functions — set correct MIR return types
    if fn_name == "int" {
        let dr_int: LowerResult = make_value(st, mir_int(), "t")
        let s_int: LowerState = emit_instr(dr_int.state, Instruction::Call(dr_int.value, fn_name, args))
        return new_lower_result(dr_int.value, s_int)
    }
    if fn_name == "float" {
        let dr_flt: LowerResult = make_value(st, mir_float(), "t")
        let s_flt: LowerState = emit_instr(dr_flt.state, Instruction::Call(dr_flt.value, fn_name, args))
        return new_lower_result(dr_flt.value, s_flt)
    }
    if fn_name == "str" || fn_name == "toString" {
        let dr_str: LowerResult = make_value(st, mir_string(), "t")
        let s_str: LowerState = emit_instr(dr_str.state, Instruction::Call(dr_str.value, fn_name, args))
        return new_lower_result(dr_str.value, s_str)
    }
    if fn_name == "len" {
        let dr_len: LowerResult = make_value(st, mir_int(), "t")
        let s_len: LowerState = emit_instr(dr_len.state, Instruction::Call(dr_len.value, fn_name, args))
        return new_lower_result(dr_len.value, s_len)
    }

    // Runtime: process + file I/O
    if fn_name == "__mn_argc" {
        let dr_argc: LowerResult = make_value(st, mir_int(), "t")
        let s_argc: LowerState = emit_instr(dr_argc.state, Instruction::Call(dr_argc.value, fn_name, args))
        return new_lower_result(dr_argc.value, s_argc)
    }
    if fn_name == "__mn_argv" {
        let dr_argv: LowerResult = make_value(st, mir_string(), "t")
        let s_argv: LowerState = emit_instr(dr_argv.state, Instruction::Call(dr_argv.value, fn_name, args))
        return new_lower_result(dr_argv.value, s_argv)
    }
    if fn_name == "__mn_file_read_or_empty" {
        let dr_fr: LowerResult = make_value(st, mir_string(), "t")
        let s_fr: LowerState = emit_instr(dr_fr.state, Instruction::Call(dr_fr.value, fn_name, args))
        return new_lower_result(dr_fr.value, s_fr)
    }
    if fn_name == "__mn_exit" {
        let dr_exit: LowerResult = make_value(st, mir_void(), "t")
        let s_exit: LowerState = emit_instr(dr_exit.state, Instruction::Call(dr_exit.value, fn_name, args))
        return new_lower_result(dr_exit.value, s_exit)
    }
    if fn_name == "__mn_str_eprint" {
        let dr_epr: LowerResult = make_value(st, mir_void(), "t")
        let s_epr: LowerState = emit_instr(dr_epr.state, Instruction::Call(dr_epr.value, fn_name, args))
        return new_lower_result(dr_epr.value, s_epr)
    }

    // Handle Option/Result builtins
    if fn_name == "Some" {
        if len(args) == 1 {
            let dr_some: LowerResult = make_value(st, mir_option(), "t")
            let s_some: LowerState = emit_instr(dr_some.state, Instruction::WrapSome(dr_some.value, args[0]))
            return new_lower_result(dr_some.value, s_some)
        }
    }
    if fn_name == "Ok" {
        if len(args) == 1 {
            // Use the function's return type (with generic args) if available
            let mut res_ty_ok: MIRType = mir_result()
            match st.current_fn {
                Some(cf) => {
                    if cf.return_type.kind == "result" {
                        res_ty_ok = cf.return_type
                    }
                },
                _ => {}
            }
            let dr_ok: LowerResult = make_value(st, res_ty_ok, "t")
            let s_ok: LowerState = emit_instr(dr_ok.state, Instruction::WrapOk(dr_ok.value, args[0]))
            return new_lower_result(dr_ok.value, s_ok)
        }
    }
    if fn_name == "Err" {
        if len(args) == 1 {
            let mut res_ty_err: MIRType = mir_result()
            match st.current_fn {
                Some(cf) => {
                    if cf.return_type.kind == "result" {
                        res_ty_err = cf.return_type
                    }
                },
                _ => {}
            }
            let dr_err: LowerResult = make_value(st, res_ty_err, "t")
            let s_err: LowerState = emit_instr(dr_err.state, Instruction::WrapErr(dr_err.value, args[0]))
            return new_lower_result(dr_err.value, s_err)
        }
    }

    // Handle __new_StructName calls (from `new StructName { ... }` syntax)
    if fn_name.starts_with("__new_") {
        let struct_name: String = fn_name.substr(6, len(fn_name) - 6)
        if is_struct_name(st, struct_name) {
            let field_names: List<String> = get_struct_field_names(st, struct_name)
            let struct_ty: MIRType = mir_struct(struct_name)
            let mut field_pairs: List<FieldPair> = []
            let mut fi: Int = 0
            let nfn: Int = len(field_names)
            let na: Int = len(args)
            for _ in 0..200 {
                if fi < nfn {
                    if fi < na {
                        let fp: FieldPair = new_field_pair(field_names[fi], args[fi])
                        field_pairs.push(fp)
                        fi = fi + 1
                    }
                }
            }
            let dr_new: LowerResult = make_value(st, struct_ty, "t")
            let s_new: LowerState = emit_instr(dr_new.state, Instruction::StructInit(dr_new.value, struct_ty, field_pairs))
            return new_lower_result(dr_new.value, s_new)
        }
    }

    // Check if it's an enum variant constructor
    if is_enum_variant(st, fn_name) {
        let enum_name: String = enum_name_for_variant(st, fn_name)
        let enum_ty: MIRType = mir_enum(enum_name)
        let dr_enum: LowerResult = make_value(st, enum_ty, "t")
        let s_enum: LowerState = emit_instr(dr_enum.state, Instruction::EnumInit(dr_enum.value, enum_ty, fn_name, args))
        return new_lower_result(dr_enum.value, s_enum)
    }

    // Check if it's a struct constructor (use if instead of match to avoid
    // control flow issues with return-inside-match)
    if is_struct_name(st, fn_name) {
        let field_names: List<String> = get_struct_field_names(st, fn_name)
        let struct_ty: MIRType = mir_struct(fn_name)
        let mut field_pairs: List<FieldPair> = []
        let mut fi: Int = 0
        let nfn: Int = len(field_names)
        let na: Int = len(args)
        for _ in 0..200 {
            if fi < nfn {
                if fi < na {
                    let fp: FieldPair = new_field_pair(field_names[fi], args[fi])
                    field_pairs.push(fp)
                    fi = fi + 1
                }
            }
        }
        let dr_ctor: LowerResult = make_value(st, struct_ty, "t")
        let s_ctor: LowerState = emit_instr(dr_ctor.state, Instruction::StructInit(dr_ctor.value, struct_ty, field_pairs))
        return new_lower_result(dr_ctor.value, s_ctor)
    }

    // Resolve lambda variable names to actual function names
    let resolved: String = unwrap_or_default(find_lambda(st, fn_name), fn_name)

    // For non-lambda calls, emit directly (no state copy needed).
    // Look up function return type from lambda_vars registry (__ret__fn_name).
    if resolved.find(":") < 0 {
        let mut call_ret: MIRType = mir_unknown()
        let ret_key: String = "__ret__" + resolved
        let ret_opt: Option<String> = find_lambda(st, ret_key)
        match ret_opt {
            Some(ret_encoded) => {
                // Decode "kind:name" → MIRType
                let colon: Int = ret_encoded.find(":")
                if colon >= 0 {
                    let kind: String = ret_encoded.substr(0, colon)
                    // substr(start, END) not substr(start, LENGTH)
                    let name: String = ret_encoded.substr(colon + 1, len(ret_encoded))
                    if kind == "struct" { call_ret = mir_struct(name) }
                    if kind == "enum" { call_ret = mir_enum(name) }
                    if kind == "int" { call_ret = mir_int() }
                    if kind == "float" { call_ret = mir_float() }
                    if kind == "string" { call_ret = mir_string() }
                    if kind == "bool" { call_ret = mir_bool() }
                    if kind == "void" { call_ret = mir_void() }
                    if kind == "option" { call_ret = mir_option() }
                    if kind == "result" { call_ret = mir_result() }
                    if kind == "list" { call_ret = mir_list() }
                }
            },
            _ => {}
        }
        let dr_call: LowerResult = make_value(st, call_ret, "t")
        let s_call: LowerState = emit_instr(dr_call.state, Instruction::Call(dr_call.value, resolved, args))
        return new_lower_result(dr_call.value, s_call)
    }

    // Lambda call with captures — decode "lambda1:x,y" and load captured vars.
    // Chain state through make_value/emit_instr (byref, no LowerState copy).
    let actual_fn: String = resolved.substr(0, resolved.find(":"))
    let cp: Int = resolved.find(":")
    let caps_str: String = resolved.substr(cp + 1, len(resolved))
    let cap_parts: List<String> = caps_str.split(",")
    return lower_call_with_captures(st, actual_fn, args, cap_parts, 0)
}

fn lower_call_with_captures(st: LowerState, fn_name: String, args: List<Value>, captures: List<String>, idx: Int) -> LowerResult {
    // Base case: all captures loaded — emit the call
    if idx >= len(captures) {
        let dest_r: LowerResult = make_value(st, mir_unknown(), "t")
        let s: LowerState = emit_instr(dest_r.state, Instruction::Call(dest_r.value, fn_name, args))
        return new_lower_result(dest_r.value, s)
    }

    // Load one captured variable and recurse
    let cap_name: String = captures[idx]
    let var_opt: Option<Value> = lookup_var(st, cap_name)
    match var_opt {
        Some(addr) => {
            let lr: LowerResult = make_value(st, addr.ty, "cap")
            let ns: LowerState = emit_instr(lr.state, Instruction::Load(lr.value, addr))
            args.push(lr.value)
            return lower_call_with_captures(ns, fn_name, args, captures, idx + 1)
        },
        _ => {
            return lower_call_with_captures(st, fn_name, args, captures, idx + 1)
        }
    }
}

// ---------------------------------------------------------------------------
// Method call lowering
// ---------------------------------------------------------------------------

fn str_method_return_type(method: String) -> MIRType {
    if method == "char_at" { return mir_string() }
    if method == "substr" { return mir_string() }
    if method == "to_upper" { return mir_string() }
    if method == "to_lower" { return mir_string() }
    if method == "replace" { return mir_string() }
    if method == "trim" { return mir_string() }
    if method == "trim_start" { return mir_string() }
    if method == "trim_end" { return mir_string() }
    if method == "concat" { return mir_string() }
    if method == "byte_at" { return mir_int() }
    if method == "find" { return mir_int() }
    if method == "starts_with" { return mir_bool() }
    if method == "ends_with" { return mir_bool() }
    if method == "contains" { return mir_bool() }
    if method == "split" { return mir_list() }
    return mir_unknown()
}

fn lower_method_call(st: LowerState, obj: Expr, method: String, arg_exprs: List<Expr>) -> LowerResult {
    let obj_r: LowerResult = lower_expr(st, obj)
    let mut s: LowerState = obj_r.state

    // Special handling for push: pass the list ALLOCA address (not the loaded value)
    // so the emitter can push directly to the alloca, avoiding copy semantics.
    if method == "push" {
        return lower_push_method(s, obj, obj_r, arg_exprs)
    }

    // Build arg list: [obj_value, arg_values...]
    let mut all_args: List<Value> = []
    all_args.push(obj_r.value)
    let nae: Int = len(arg_exprs)
    let mut i: Int = 0
    for _ in 0..200 {
        if i < nae {
            let arg_r: LowerResult = lower_expr(s, arg_exprs[i])
            s = arg_r.state
            all_args.push(arg_r.value)
            i = i + 1
        }
    }

    let mut ret_ty: MIRType = mir_unknown()
    if obj_r.value.ty.kind == "string" {
        ret_ty = str_method_return_type(method)
    }

    let dest_r: LowerResult = make_value(s, ret_ty, "t")
    let new_s: LowerState = emit_instr(dest_r.state, Instruction::Call(dest_r.value, method, all_args))
    return new_lower_result(dest_r.value, new_s)
}

fn lower_push_method(st: LowerState, obj: Expr, obj_r: LowerResult, arg_exprs: List<Expr>) -> LowerResult {
    let mut s: LowerState = st
    // Lower the element
    let arg_r: LowerResult = lower_expr(s, arg_exprs[0])
    s = arg_r.state
    // Find the alloca for the list.
    // For simple Ident: use lookup_var → alloca address
    // For FieldAccess: use the struct alloca + field name
    //   The emitter handles this via the @field: prefix
    let list_ref: Value = find_list_alloca(s, obj, obj_r)
    let mut all_args: List<Value> = []
    all_args.push(list_ref)
    all_args.push(arg_r.value)
    let dest_r: LowerResult = make_value(s, mir_void(), "t")
    let new_s: LowerState = emit_instr(dest_r.state, Instruction::Call(dest_r.value, "push", all_args))
    return new_lower_result(dest_r.value, new_s)
}

fn find_list_alloca(st: LowerState, obj: Expr, obj_r: LowerResult) -> Value {
    let ok: String = expr_kind(obj)
    if ok == "ident" {
        // Simple variable push: use the variable's alloca directly
        let var_opt: Option<Value> = lookup_var(st, expr_ident_name(obj))
        match var_opt {
            Some(addr) => { return addr },
            _ => { return obj_r.value }
        }
    }
    if ok == "field_access" {
        // struct.field.push(): GEP into the struct alloca
        // to get a pointer to the list field
        return find_field_alloca(st, expr_field_obj(obj), expr_field_name(obj), obj_r)
    }
    return obj_r.value
}

fn find_field_alloca(st: LowerState, inner: Expr, field_name: String, obj_r: LowerResult) -> Value {
    if expr_kind(inner) == "ident" {
        let name: String = expr_ident_name(inner)
        let var_opt: Option<Value> = lookup_var(st, name)
        match var_opt {
            Some(addr) => {
                // Encode the field name in the Value's type name
                // so the emitter can find the correct field index.
                // Convention: ty.name = "StructName:field_name"
                let combined: MIRType = new_mir_type(addr.ty.name + ":" + field_name, addr.ty.kind)
                return new_value(addr.name, combined)
            },
            _ => { return obj_r.value }
        }
    }
    return obj_r.value
}

// ---------------------------------------------------------------------------
// Field access lowering
// ---------------------------------------------------------------------------

fn lookup_struct_field_type(st: LowerState, struct_name: String, field_name: String) -> MIRType {
    let mut i: Int = 0
    for _ in 0..10000 {
        if i >= len(st.struct_fields) { return mir_unknown() }
        let info: StructFieldInfo = st.struct_fields[i]
        if info.name == struct_name {
            let mut j: Int = 0
            for _ in 0..200 {
                if j >= len(info.field_names) { return mir_unknown() }
                if info.field_names[j] == field_name {
                    if j < len(info.field_types) {
                        return info.field_types[j]
                    }
                    return mir_unknown()
                }
                j = j + 1
            }
        }
        i = i + 1
    }
    return mir_unknown()
}

fn lower_field_access(st: LowerState, obj: Expr, field_name: String) -> LowerResult {
    let obj_r: LowerResult = lower_expr(st, obj)

    // Only emit SignalGet for actual signal types, not for struct .value fields
    if field_name == "value" && obj_r.value.ty.kind == "signal" {
        let dr_sig: LowerResult = make_value(obj_r.state, mir_unknown(), "t")
        let s_sig: LowerState = emit_instr(dr_sig.state, Instruction::SignalGet(dr_sig.value, obj_r.value))
        return new_lower_result(dr_sig.value, s_sig)
    }

    // Resolve field type from struct registry
    let field_ty: MIRType = lookup_struct_field_type(obj_r.state, obj_r.value.ty.name, field_name)

    let dr_fld: LowerResult = make_value(obj_r.state, field_ty, "t")
    let s_fld: LowerState = emit_instr(dr_fld.state, Instruction::FieldGet(dr_fld.value, obj_r.value, field_name))
    return new_lower_result(dr_fld.value, s_fld)
}

// ---------------------------------------------------------------------------
// Namespace access lowering
// ---------------------------------------------------------------------------

fn is_enum_name(st: LowerState, name: String) -> Bool {
    let mut i: Int = 0
    for _ in 0..600 {
        if i >= len(st.enum_variants) { return false }
        if st.enum_variants[i].enum_name == name { return true }
        i = i + 1
    }
    return false
}

fn lower_namespace_access(st: LowerState, ns: String, member: String) -> LowerResult {
    // Check if namespace is a registered enum → emit EnumInit
    if is_enum_name(st, ns) {
        let enum_ty: MIRType = mir_enum(ns)
        let dr_ns_enum: LowerResult = make_value(st, enum_ty, "t")
        let eargs_enum: List<Value> = []
        let s_ns_enum: LowerState = emit_instr(dr_ns_enum.state, Instruction::EnumInit(dr_ns_enum.value, enum_ty, member, eargs_enum))
        return new_lower_result(dr_ns_enum.value, s_ns_enum)
    }
    // Otherwise: module function call
    let dr_ns_mod: LowerResult = make_value(st, mir_unknown(), "t")
    let fn_name: String = ns + "_" + member
    let eargs_mod: List<Value> = []
    let s_ns_mod: LowerState = emit_instr(dr_ns_mod.state, Instruction::Call(dr_ns_mod.value, fn_name, eargs_mod))
    return new_lower_result(dr_ns_mod.value, s_ns_mod)
}

// ---------------------------------------------------------------------------
// Index lowering
// ---------------------------------------------------------------------------

fn lower_index(st: LowerState, obj: Expr, idx: Expr) -> LowerResult {
    let obj_r: LowerResult = lower_expr(st, obj)
    let idx_r: LowerResult = lower_expr(obj_r.state, idx)

    // For string indexing, result is a string (char_at)
    // For list indexing, result is the element type from List<T>.args[0]
    let mut elem_ty: MIRType = mir_unknown()
    if obj_r.value.ty.kind == "string" {
        elem_ty = mir_string()
    } else if obj_r.value.ty.kind == "list" {
        if len(obj_r.value.ty.args) > 0 {
            elem_ty = obj_r.value.ty.args[0]
        }
    }

    let dest_r: LowerResult = make_value(idx_r.state, elem_ty, "t")
    let s: LowerState = emit_instr(dest_r.state, Instruction::IndexGet(dest_r.value, obj_r.value, idx_r.value))
    return new_lower_result(dest_r.value, s)
}

// ---------------------------------------------------------------------------
// Pipe lowering
// ---------------------------------------------------------------------------

fn lower_pipe_call(arg_r: LowerResult, fn_name: String, extra_exprs: List<Expr>) -> LowerResult {
    let mut s: LowerState = arg_r.state
    let mut args: List<Value> = []
    args.push(arg_r.value)
    let mut i: Int = 0
    let nee: Int = len(extra_exprs)
    for _ in 0..200 {
        if i < nee {
            let extra_r: LowerResult = lower_expr(s, extra_exprs[i])
            s = extra_r.state
            args.push(extra_r.value)
            i = i + 1
        }
    }
    let dest_r: LowerResult = make_value(s, mir_unknown(), "t")
    let new_s: LowerState = emit_instr(dest_r.state, Instruction::Call(dest_r.value, fn_name, args))
    return new_lower_result(dest_r.value, new_s)
}

fn lower_pipe_with_call(arg_r: LowerResult, callee: Expr, extra_arg_exprs: List<Expr>) -> LowerResult {
    if expr_kind(callee) == "ident" {
        return lower_pipe_call(arg_r, expr_ident_name(callee), extra_arg_exprs)
    }
    return new_lower_result(arg_r.value, arg_r.state)
}

fn lower_pipe(st: LowerState, left: Expr, right: Expr) -> LowerResult {
    let arg_r: LowerResult = lower_expr(st, left)

    let rk: String = expr_kind(right)
    if rk == "ident" {
        return lower_pipe_call(arg_r, expr_ident_name(right), [])
    }
    if rk == "call" {
        return lower_pipe_with_call(arg_r, expr_call_callee(right), expr_call_args(right))
    }

    // General case
    let fn_r: LowerResult = lower_expr(arg_r.state, right)
    let dest_r: LowerResult = make_value(fn_r.state, mir_unknown(), "t")
    let mut args: List<Value> = []
    args.push(arg_r.value)
    let s: LowerState = emit_instr(dest_r.state, Instruction::Call(dest_r.value, fn_r.value.name, args))
    return new_lower_result(dest_r.value, s)
}

// ---------------------------------------------------------------------------
// Range lowering
// ---------------------------------------------------------------------------

fn lower_range(st: LowerState, start: Expr, end: Expr, inclusive: Bool) -> LowerResult {
    let start_r: LowerResult = lower_expr(st, start)
    let end_r: LowerResult = lower_expr(start_r.state, end)
    let dest_r: LowerResult = make_value(end_r.state, mir_range(), "t")
    let mut fn_name: String = "__mn_range"
    if inclusive { fn_name = "__mn_range_inclusive" }
    let mut args: List<Value> = []
    args.push(start_r.value)
    args.push(end_r.value)
    let s: LowerState = emit_instr(dest_r.state, Instruction::Call(dest_r.value, fn_name, args))
    return new_lower_result(dest_r.value, s)
}

// ---------------------------------------------------------------------------
// Lambda lowering
// ---------------------------------------------------------------------------

fn find_expr_alloca(st: LowerState, expr: Expr, obj_r: LowerResult) -> Value {
    // For Ident(name), return the variable's alloca address
    if expr_kind(expr) == "ident" {
        let var_opt: Option<Value> = lookup_var(st, expr_ident_name(expr))
        match var_opt {
            Some(addr) => { return addr },
            _ => { return obj_r.value }
        }
    }
    return obj_r.value
}

// Module mutation: extract list to local variable, push, reconstruct.
// This avoids struct field push (GEP index issues) by using the
// 9-field struct init which the parser now supports.
fn module_push_struct(m: MIRModule, info: StructInfo) -> MIRModule {
    let mut lst: List<StructInfo> = m.structs
    lst.push(info)
    return new MIRModule { name: m.name, functions: m.functions, structs: lst, enums: m.enums, extern_fns: m.extern_fns, agents: m.agents, pipes: m.pipes, imports: m.imports, trait_names: m.trait_names }
}

fn module_push_enum(m: MIRModule, info: EnumInfo) -> MIRModule {
    let mut lst: List<EnumInfo> = m.enums
    lst.push(info)
    return new MIRModule { name: m.name, functions: m.functions, structs: m.structs, enums: lst, extern_fns: m.extern_fns, agents: m.agents, pipes: m.pipes, imports: m.imports, trait_names: m.trait_names }
}

fn module_push_function(m: MIRModule, f: MIRFunction) -> MIRModule {
    let mut lst: List<MIRFunction> = m.functions
    lst.push(f)
    return new MIRModule { name: m.name, functions: lst, structs: m.structs, enums: m.enums, extern_fns: m.extern_fns, agents: m.agents, pipes: m.pipes, imports: m.imports, trait_names: m.trait_names }
}

fn module_push_agent(m: MIRModule, info: AgentInfo) -> MIRModule {
    let mut lst: List<AgentInfo> = m.agents
    lst.push(info)
    return new MIRModule { name: m.name, functions: m.functions, structs: m.structs, enums: m.enums, extern_fns: m.extern_fns, agents: lst, pipes: m.pipes, imports: m.imports, trait_names: m.trait_names }
}

fn lower_arm_body(st: LowerState, body: MatchArmBody) -> LowerResult {
    if match_arm_body_kind(body) == "block" { return lower_block(st, match_arm_body_block(body)) }
    return lower_expr(st, match_arm_body_expr(body))
}

fn extract_ident_name(expr: Expr) -> String {
    if expr_kind(expr) == "ident" { return expr_ident_name(expr) }
    return ""
}

fn unwrap_or_default(opt: Option<String>, default: String) -> String {
    match opt {
        Some(val) => { return val },
        _ => { return default }
    }
}

fn lambda_body_to_block(body: LambdaBody) -> Block {
    if lambda_body_kind(body) == "block" { return lambda_body_block(body) }
    let ret_stmt: Stmt = Stmt::Return(Some(lambda_body_expr(body)))
    let stmts: List<Stmt> = []
    stmts.push(ret_stmt)
    let span: Span = new_span(0, 0, 0, 0)
    return new_block(span, stmts)
}

fn lower_lambda(st: LowerState, params: List<Param>, body: LambdaBody) -> LowerResult {
    let name_r: LowerResult = fresh_tmp(st, "lambda")
    let lambda_name: String = "lambda" + toString(st.tmp_counter)

    let body_block: Block = lambda_body_to_block(body)

    // Build extended params: explicit params + captured parent vars
    let parent_vars: List<VarInfo> = name_r.state.vars
    let mut all_params: List<Param> = []
    let mut capture_suffix: String = ""
    let mut pi: Int = 0
    let np: Int = len(params)
    for _ in 0..100 {
        if pi < np {
            all_params.push(params[pi])
            pi = pi + 1
        }
    }
    let mut ci: Int = 0
    let npv: Int = len(parent_vars)
    for _ in 0..200 {
        if ci < npv {
            let pv: VarInfo = parent_vars[ci]
            let cap_param: Param = new Param { span: new_span(0, 0, 0, 0), name: pv.name, type_annotation: none }
            all_params.push(cap_param)
            if ci == 0 {
                capture_suffix = ":" + pv.name
            } else {
                capture_suffix = capture_suffix + "," + pv.name
            }
            ci = ci + 1
        }
    }

    // Create FnDefData with Int return type
    let span: Span = new_span(0, 0, 0, 0)
    let empty_type_params: List<String> = []
    let empty_decorators: List<Decorator> = []
    let int_ret: TypeExpr = make_int_type()
    let fn_def: FnDefData = new_fn_def_data(span, lambda_name, false, empty_type_params, all_params, Some(int_ret), body_block, empty_decorators)

    // Lower as a nested function (lower_fn saves/restores function scope)
    let mut s: LowerState = lower_fn(name_r.state, fn_def, "")

    // Register lambda with capture info
    let encoded_name: String = lambda_name + capture_suffix
    let entry: LambdaEntry = new_lambda_entry("", encoded_name)
    let mut lv_lam: List<LambdaEntry> = s.lambda_vars
    lv_lam.push(entry)
    s.lambda_vars = lv_lam

    // Return a reference to the lambda function
    let dest_r: LowerResult = make_value(s, mir_fn_type(), "t")
    s = emit_instr(dest_r.state, Instruction::Const(dest_r.value, mir_fn_type(), lambda_name))
    return new_lower_result(dest_r.value, s)
}

// ---------------------------------------------------------------------------
// Spawn / Sync / Send lowering
// ---------------------------------------------------------------------------

fn lower_spawn(st: LowerState, callee: Expr, arg_exprs: List<Expr>) -> LowerResult {
    let mut s: LowerState = st
    let mut args: List<Value> = []
    let mut i: Int = 0
    let nae_sp: Int = len(arg_exprs)
    for _ in 0..200 {
        if i < nae_sp {
            let arg_r: LowerResult = lower_expr(s, arg_exprs[i])
            s = arg_r.state
            args.push(arg_r.value)
            i = i + 1
        }
    }

    let agent_name: String = extract_ident_name(callee)

    let agent_ty: MIRType = mir_agent(agent_name)
    let dest_r: LowerResult = make_value(s, agent_ty, "t")
    let new_s: LowerState = emit_instr(dest_r.state, Instruction::AgentSpawn(dest_r.value, agent_ty, args))
    return new_lower_result(dest_r.value, new_s)
}

fn lower_sync(st: LowerState, inner: Expr) -> LowerResult {
    if expr_kind(inner) == "field_access" {
        let obj_r: LowerResult = lower_expr(st, expr_field_obj(inner))
        let dr_sync_fa: LowerResult = make_value(obj_r.state, mir_unknown(), "t")
        let s_sync_fa: LowerState = emit_instr(dr_sync_fa.state, Instruction::AgentSync(dr_sync_fa.value, obj_r.value, expr_field_name(inner)))
        return new_lower_result(dr_sync_fa.value, s_sync_fa)
    }
    let val_r: LowerResult = lower_expr(st, inner)
    let dr_sync_bare: LowerResult = make_value(val_r.state, mir_unknown(), "t")
    let s_sync_bare: LowerState = emit_instr(dr_sync_bare.state, Instruction::AgentSync(dr_sync_bare.value, val_r.value, ""))
    return new_lower_result(dr_sync_bare.value, s_sync_bare)
}

fn lower_send(st: LowerState, target: Expr, value: Expr) -> LowerResult {
    let val_r: LowerResult = lower_expr(st, value)

    if expr_kind(target) == "field_access" {
        let obj_r: LowerResult = lower_expr(val_r.state, expr_field_obj(target))
        let s_field: LowerState = emit_instr(obj_r.state, Instruction::AgentSend(obj_r.value, expr_field_name(target), val_r.value))
        let dr_field: LowerResult = make_value(s_field, mir_void(), "t")
        let s2_field: LowerState = emit_instr(dr_field.state, Instruction::Const(dr_field.value, mir_void(), ""))
        return new_lower_result(dr_field.value, s2_field)
    }
    let target_r: LowerResult = lower_expr(val_r.state, target)
    let s_plain: LowerState = emit_instr(target_r.state, Instruction::AgentSend(target_r.value, "", val_r.value))
    let dr_plain: LowerResult = make_value(s_plain, mir_void(), "t")
    let s2_plain: LowerState = emit_instr(dr_plain.state, Instruction::Const(dr_plain.value, mir_void(), ""))
    return new_lower_result(dr_plain.value, s2_plain)
}

// ---------------------------------------------------------------------------
// Error propagation lowering
// ---------------------------------------------------------------------------

fn lower_error_prop(st: LowerState, inner: Expr) -> LowerResult {
    let val_r: LowerResult = lower_expr(st, inner)
    let mut s: LowerState = val_r.state

    // Extract tag
    let tag_r: LowerResult = make_value(s, mir_bool(), "tag")
    s = emit_instr(tag_r.state, Instruction::EnumTag(tag_r.value, val_r.value))

    // Create blocks
    let ok_label_r: LowerResult = fresh_block_label(s, "prop_ok")
    s = ok_label_r.state
    let ok_label: String = ok_label_r.value.name

    let err_label_r: LowerResult = fresh_block_label(s, "prop_err")
    s = err_label_r.state
    let err_label: String = err_label_r.value.name

    s = add_block(s, ok_label)
    let ok_idx: Int = s.current_block_idx
    s = add_block(s, err_label)
    let err_idx: Int = s.current_block_idx

    // Branch on tag
    s = emit_instr(s, Instruction::Branch(tag_r.value, ok_label, err_label))

    // Error path: return the error
    s = set_block(s, err_idx)
    s = emit_instr(s, Instruction::Return(Some(val_r.value)))

    // Ok path: unwrap
    s = set_block(s, ok_idx)
    let dest_r: LowerResult = make_value(s, mir_unknown(), "t")
    s = emit_instr(dest_r.state, Instruction::Unwrap(dest_r.value, val_r.value))
    return new_lower_result(dest_r.value, s)
}

// ---------------------------------------------------------------------------
// List lowering
// ---------------------------------------------------------------------------

fn lower_list(st: LowerState, elements: List<Expr>) -> LowerResult {
    // Touch st to force materialization before any list operations.
    // Without this, clang -O0 may leave the LowerState in stale registers
    // from the caller's sret return, causing corruption in subsequent ops.
    let mut s: LowerState = st
    let mut vals: List<Value> = []
    let mut i: Int = 0
    let nel: Int = len(elements)
    for _ in 0..600 {
        if i < nel {
            let el_r: LowerResult = lower_expr(s, elements[i])
            s = el_r.state
            vals.push(el_r.value)
            i = i + 1
        }
    }

    let mut elem_type: MIRType = mir_unknown()
    if len(vals) > 0 {
        let first_v: Value = vals[0]
        elem_type = first_v.ty
    }
    let dest_r: LowerResult = make_value(s, mir_list(), "t")
    let new_s: LowerState = emit_instr(dest_r.state, Instruction::ListInit(dest_r.value, elem_type, vals))
    return new_lower_result(dest_r.value, new_s)
}

// ---------------------------------------------------------------------------
// Map lowering
// ---------------------------------------------------------------------------

fn lower_map(st: LowerState, entries: List<MapEntry>) -> LowerResult {
    let mut s: LowerState = st
    let mut pairs: List<KVPair> = []
    let mut i: Int = 0
    let nent: Int = len(entries)
    for _ in 0..600 {
        if i < nent {
            let entry: MapEntry = entries[i]
            let kr: LowerResult = lower_expr(s, entry.key)
            s = kr.state
            let vr: LowerResult = lower_expr(s, entry.value)
            s = vr.state
            pairs.push(new_kv_pair(kr.value, vr.value))
            i = i + 1
        }
    }

    let mut key_ty: MIRType = mir_string()
    let mut val_ty: MIRType = mir_unknown()
    if len(pairs) > 0 {
        key_ty = pairs[0].key.ty
        val_ty = pairs[0].val.ty
    }
    let dest_r: LowerResult = make_value(s, mir_map(), "t")
    let new_s: LowerState = emit_instr(dest_r.state, Instruction::MapInit(dest_r.value, key_ty, val_ty, pairs))
    return new_lower_result(dest_r.value, new_s)
}

// ---------------------------------------------------------------------------
// Construct (struct literal) lowering
// ---------------------------------------------------------------------------

fn lower_construct(st: LowerState, name: String, field_inits: List<FieldInit>) -> LowerResult {
    let mut s: LowerState = st

    // Debug: emit the number of field_inits as a constant to verify the list works
    let nfields: Int = len(field_inits)

    // Lower each field value
    let mut vals: List<Value> = []
    let mut i: Int = 0
    for _ in 0..200 {
        if i < nfields {
            let fi: FieldInit = field_inits[i]
            let val_r: LowerResult = lower_expr(s, fi.value)
            s = val_r.state
            vals.push(val_r.value)
            i = i + 1
        }
    }

    // Emit as Call to "__new_<StructName>" (emitter handles this specially)
    let struct_ty: MIRType = mir_struct(name)
    let dest_r: LowerResult = make_value(s, struct_ty, "t")
    // Debug: emit nfields as a const to see if the field_inits list is intact
    let dbg_r: LowerResult = make_value(dest_r.state, mir_int(), "dbg_nfields")
    s = emit_instr(dbg_r.state, Instruction::Const(dbg_r.value, mir_int(), toString(nfields)))
    s = emit_instr(s, Instruction::Call(dest_r.value, "__new_" + name, vals))
    return new_lower_result(dest_r.value, s)
}

// ---------------------------------------------------------------------------
// Signal expression lowering
// ---------------------------------------------------------------------------

fn lower_signal_expr(st: LowerState, inner: Expr) -> LowerResult {
    let init_r: LowerResult = lower_expr(st, inner)
    let dest_r: LowerResult = make_value(init_r.state, mir_signal(), "t")
    let s: LowerState = emit_instr(dest_r.state, Instruction::SignalInit(dest_r.value, mir_signal(), init_r.value))
    return new_lower_result(dest_r.value, s)
}

// ---------------------------------------------------------------------------
// Assignment lowering
// ---------------------------------------------------------------------------

fn lower_assign(st: LowerState, target: Expr, op: String, value: Expr) -> LowerResult {
    let val_r: LowerResult = lower_expr(st, value)
    let mut s: LowerState = val_r.state

    let tk: String = expr_kind(target)
    if tk == "ident" {
        let name: String = expr_ident_name(target)
        if op != "=" {
            // Compound assignment: x += 1 → x = x + 1
            let old_r: LowerResult = lower_identifier(s, name)
            s = old_r.state
            let op_str: String = strip_assign_op(op)
            let binop_opt: Option<BinOpKind> = binop_from_str(op_str)
            match binop_opt {
                Some(binop) => {
                    let result_r: LowerResult = make_value(s, old_r.value.ty, "t")
                    s = emit_instr(result_r.state, Instruction::BinOp(result_r.value, binop, old_r.value, val_r.value))

                    let var_opt_cmp: Option<Value> = lookup_var(s, name)
                    match var_opt_cmp {
                        Some(addr) => {
                            s = emit_instr(s, Instruction::Store(addr, result_r.value))
                            return new_lower_result(result_r.value, s)
                        },
                        _ => {}
                    }
                },
                _ => {}
            }
        }

        let var_opt_asgn: Option<Value> = lookup_var(s, name)
        match var_opt_asgn {
            Some(addr) => {
                // Update var type if the new value is more specific
                // (e.g. from unknown/i64 to a concrete struct type)
                let mut store_addr: Value = addr
                if addr.ty.kind == "unknown" && val_r.value.ty.kind != "unknown" {
                    store_addr = new_value(addr.name, val_r.value.ty)
                    s = define_var(s, name, store_addr, true)
                }
                s = emit_instr(s, Instruction::Store(store_addr, val_r.value))
                return new_lower_result(val_r.value, s)
            },
            _ => {}
        }
        return new_lower_result(val_r.value, s)
    }
    if tk == "field_access" {
        // Pass the ALLOCA address (not loaded value) so the emitter
        // can GEP+store directly to the struct field.
        let fa_obj: Expr = expr_field_obj(target)
        let obj_r_fa: LowerResult = lower_expr(s, fa_obj)
        let obj_alloca: Value = find_expr_alloca(obj_r_fa.state, fa_obj, obj_r_fa)
        s = emit_instr(obj_r_fa.state, Instruction::FieldSet(obj_alloca, expr_field_name(target), val_r.value))
        return new_lower_result(val_r.value, s)
    }
    if tk == "index" {
        let obj_r_idx: LowerResult = lower_expr(s, expr_index_obj(target))
        let idx_r: LowerResult = lower_expr(obj_r_idx.state, expr_index_idx(target))
        s = emit_instr(idx_r.state, Instruction::IndexSet(obj_r_idx.value, idx_r.value, val_r.value))
        return new_lower_result(val_r.value, s)
    }
    return new_lower_result(val_r.value, s)
}

// Strip the '=' suffix from compound assignment operators: "+=" → "+"
fn strip_assign_op(op: String) -> String {
    if op == "+=" { return "+" }
    if op == "-=" { return "-" }
    if op == "*=" { return "*" }
    if op == "/=" { return "/" }
    if op == "%=" { return "%" }
    return op
}

// ---------------------------------------------------------------------------
// If/else lowering
// ---------------------------------------------------------------------------

fn build_if_phi_entries(then_term: Bool, else_term: Bool, then_val: Value, else_val: Value, then_lbl: String, else_lbl: String) -> List<PhiEntry> {
    let mut result: List<PhiEntry> = []
    // Add then arm if it has a usable value (not terminated, not void)
    let then_ok: Bool = !then_term
    let then_non_void: Bool = then_val.ty.kind != "void"
    if then_ok {
        if then_non_void {
            result.push(new_phi_entry(then_lbl, then_val))
        }
    }
    // Add else arm if it has a usable value
    let else_ok: Bool = !else_term
    let else_non_void: Bool = else_val.ty.kind != "void"
    if else_ok {
        if else_non_void {
            result.push(new_phi_entry(else_lbl, else_val))
        }
    }
    // If one arm has value but other is void, add zeroinitializer for the void arm
    if len(result) == 1 {
        let r0_pe: PhiEntry = result[0]
        let r0_val: Value = r0_pe.val
        let r0_ty: MIRType = r0_val.ty
        if then_ok {
            if !then_non_void {
                let zero_v_then: Value = new_value("zeroinitializer", r0_ty)
                result.push(new_phi_entry(then_lbl, zero_v_then))
            }
        }
        if else_ok {
            if !else_non_void {
                let zero_v_else: Value = new_value("zeroinitializer", r0_ty)
                result.push(new_phi_entry(else_lbl, zero_v_else))
            }
        }
    }
    return result
}

fn infer_variant_payload_type(st: LowerState, subject: Value, variant_name: String, field_idx: Int) -> MIRType {
    // Result types
    if subject.ty.kind == "result" {
        if len(subject.ty.args) >= 2 {
            if variant_name == "Ok" { return subject.ty.args[0] }
            if variant_name == "Err" { return subject.ty.args[1] }
        }
    }
    // Option types
    if subject.ty.kind == "option" {
        if len(subject.ty.args) >= 1 {
            return subject.ty.args[0]
        }
    }
    // Regular enums — look up from module registry
    if subject.ty.kind == "enum" {
        let enum_name: String = subject.ty.name
        let mut ei: Int = 0
        let nei: Int = len(st.module.enums)
        for _ in 0..200 {
            if ei < nei {
                let einfo: EnumInfo = st.module.enums[ei]
                if einfo.name == enum_name {
                    let mut vi: Int = 0
                    let nvi: Int = len(einfo.variants)
                    for _ in 0..200 {
                        if vi < nvi {
                            let vinfo: EnumVariantInfo = einfo.variants[vi]
                            if vinfo.name == variant_name {
                                if field_idx < len(vinfo.payload_types) {
                                    return vinfo.payload_types[field_idx]
                                }
                            }
                            vi = vi + 1
                        }
                    }
                }
                ei = ei + 1
            }
        }
    }
    return mir_unknown()
}

fn is_some_else_clause(clause: Option<ElseClause>) -> Bool {
    match clause {
        Some(c) => { return true },
        _ => { return false }
    }
}

fn lower_else_clause(st: LowerState, clause_opt: Option<ElseClause>) -> LowerResult {
    match clause_opt {
        Some(clause) => {
            return lower_else_clause_inner(st, clause)
        },
        _ => { return new_lower_result(void_value(), st) }
    }
}

fn lower_else_clause_inner(st: LowerState, clause: ElseClause) -> LowerResult {
    if else_clause_kind(clause) == "else_block" {
        return lower_block(st, else_clause_block(clause))
    }
    return lower_if(st, else_clause_cond(clause), else_clause_then(clause), else_clause_else(clause))
}

fn lower_if(st: LowerState, cond: Expr, then_block: Block, else_clause: Option<ElseClause>) -> LowerResult {
    let cond_r: LowerResult = lower_expr(st, cond)
    let mut s: LowerState = cond_r.state

    // Save the current (entry) block index for the branch
    let entry_idx: Int = s.current_block_idx

    // Create blocks
    let then_label_r: LowerResult = fresh_block_label(s, "if_then")
    s = then_label_r.state
    let then_label: String = then_label_r.value.name
    s = add_block(s, then_label)
    let then_idx: Int = s.current_block_idx

    let else_label_r: LowerResult = fresh_block_label(s, "if_else")
    s = else_label_r.state
    let else_label: String = else_label_r.value.name
    s = add_block(s, else_label)
    let else_idx: Int = s.current_block_idx

    let merge_label_r: LowerResult = fresh_block_label(s, "if_merge")
    s = merge_label_r.state
    let merge_label: String = merge_label_r.value.name
    s = add_block(s, merge_label)
    let merge_idx: Int = s.current_block_idx

    // Branch (emitted in the entry block, not the merge block)
    s = set_block(s, entry_idx)
    s = emit_instr(s, Instruction::Branch(cond_r.value, then_label, else_label))

    // Then block
    s = set_block(s, then_idx)
    let then_r: LowerResult = lower_block(s, then_block)
    s = then_r.state
    let then_val: Value = then_r.value
    let then_exit_idx: Int = s.current_block_idx
    let then_terminated: Bool = current_block_terminated(s)
    if !then_terminated {
        s = emit_instr(s, Instruction::Jump(merge_label))
    }

    // Else block
    s = set_block(s, else_idx)
    let mut else_val: Value = void_value()
    let has_else: Bool = is_some_else_clause(else_clause)
    if has_else {
        let else_r: LowerResult = lower_else_clause(s, else_clause)
        s = else_r.state
        else_val = else_r.value
    }
    let else_exit_idx: Int = s.current_block_idx
    let else_terminated: Bool = current_block_terminated(s)
    if !else_terminated {
        s = emit_instr(s, Instruction::Jump(merge_label))
    }

    // Merge block with phi — only include arms that reach the merge block
    s = set_block(s, merge_idx)

    let then_exit_label: String = get_block_label(s, then_exit_idx)
    let else_exit_label: String = get_block_label(s, else_exit_idx)

    // Build Phi directly — no list intermediary to avoid return-by-value bugs.
    // Determine what kind of Phi we need:
    // - Both arms have values → 2-entry Phi
    // - One arm has value, other void → 2-entry Phi with zeroinitializer
    // - Neither has value → void fallback
    let then_ok: Bool = !then_terminated
    let mut then_non_void: Bool = true
    if then_val.ty.kind == "void" { then_non_void = false }
    if then_val.ty.kind == "unknown" { then_non_void = false }
    if then_val.name == "%void" { then_non_void = false }
    let else_ok: Bool = !else_terminated
    let mut else_non_void: Bool = true
    if else_val.ty.kind == "void" { else_non_void = false }
    if else_val.ty.kind == "unknown" { else_non_void = false }
    if else_val.name == "%void" { else_non_void = false }

    // Determine case using simple flags
    let mut both: Bool = false
    let mut only_then: Bool = false
    let mut only_else: Bool = false
    if then_ok {
        if then_non_void {
            if else_ok {
                if else_non_void {
                    both = true
                }
                if !else_non_void {
                    only_then = true
                }
            }
        }
        if !then_non_void {
            if else_ok {
                if else_non_void {
                    only_else = true
                }
            }
        }
    }
    if !then_ok {
        if else_ok {
            if else_non_void {
                only_else = true
            }
        }
    }

    let mut final_val: Value = void_value()
    if both {
        // When both arms produce values, check if types match.
        // Mismatched types (e.g., i64 vs Expr from side-effect if-else) → void fallback.
        let types_match: Bool = then_val.ty.kind == else_val.ty.kind
        if types_match {
            let mut ents_both: List<PhiEntry> = []
            ents_both.push(new_phi_entry(then_exit_label, then_val))
            ents_both.push(new_phi_entry(else_exit_label, else_val))
            let rr_both: LowerResult = make_value(s, then_val.ty, "if_result")
            s = rr_both.state
            s = emit_instr(s, Instruction::Phi(rr_both.value, ents_both))
            final_val = rr_both.value
        }
    }
    if only_then {
        let mut ents_then: List<PhiEntry> = []
        ents_then.push(new_phi_entry(then_exit_label, then_val))
        // Only include else branch if it's not terminated (reaches merge)
        if !else_terminated {
            let zero_v_t: Value = new_value("zeroinitializer", then_val.ty)
            ents_then.push(new_phi_entry(else_exit_label, zero_v_t))
        }
        let rr_then: LowerResult = make_value(s, then_val.ty, "if_result")
        s = rr_then.state
        s = emit_instr(s, Instruction::Phi(rr_then.value, ents_then))
        final_val = rr_then.value
    }
    if only_else {
        let mut ents_else: List<PhiEntry> = []
        // Only include then branch if it's not terminated (reaches merge)
        if !then_terminated {
            let zero_v_e: Value = new_value("zeroinitializer", else_val.ty)
            ents_else.push(new_phi_entry(then_exit_label, zero_v_e))
        }
        ents_else.push(new_phi_entry(else_exit_label, else_val))
        let rr_else: LowerResult = make_value(s, else_val.ty, "if_result")
        s = rr_else.state
        s = emit_instr(s, Instruction::Phi(rr_else.value, ents_else))
        final_val = rr_else.value
    }
    let is_void: Bool = !both && !only_then && !only_else
    if is_void {
        let rr_void: LowerResult = make_value(s, mir_void(), "t")
        s = emit_instr(rr_void.state, Instruction::Const(rr_void.value, mir_void(), ""))
        final_val = rr_void.value
        // Both branches terminated — merge block is unreachable.
        // Emit return terminator AFTER const so current_block_terminated returns true
        // and callers don't emit additional jumps to this block's successors.
        let both_terminated: Bool = then_terminated && else_terminated
        if both_terminated {
            let fn_ret: MIRType = get_current_fn_ret_type(s)
            let dummy_val: Value = new_value("zeroinitializer", fn_ret)
            s = emit_instr(s, Instruction::Return(Some(dummy_val)))
        }
    }
    return new_lower_result(final_val, s)
}

fn get_current_fn_ret_type(st: LowerState) -> MIRType {
    match st.current_fn {
        Some(f) => { return f.return_type },
        _ => { return mir_void() }
    }
}

fn get_block_label(st: LowerState, idx: Int) -> String {
    if idx >= 0 {
        if idx < len(st.fn_blocks) {
            let bb: BasicBlock = st.fn_blocks[idx]
            return bb.label
        }
    }
    return "unknown"
}

// ---------------------------------------------------------------------------
// Match lowering
// ---------------------------------------------------------------------------

struct MatchBuildResult {
    state: LowerState,
    arm_labels: List<String>,
    arm_indices: List<Int>,
    cases: List<SwitchCase>,
    default_label: String
}

fn build_match_arms(st: LowerState, arms: List<MatchArm>, merge_label: String) -> MatchBuildResult {
    let mut labels: List<String> = []
    let mut indices: List<Int> = []
    let mut cases: List<SwitchCase> = []
    let mut default_lbl: String = merge_label
    let mut s: LowerState = st
    let mut i: Int = 0
    let n: Int = len(arms)
    for _ in 0..200 {
        if i < n {
            let label_r: LowerResult = fresh_block_label(s, "match_arm")
            s = label_r.state
            let label: String = label_r.value.name
            s = add_block(s, label)
            labels.push(label)
            indices.push(s.current_block_idx)
            let arm: MatchArm = arms[i]
            let pk_arm: String = pattern_kind(arm.pattern)
            if pk_arm == "constructor" { cases.push(new_switch_case(pattern_ctor_name(arm.pattern), label)) }
            if pk_arm == "literal" { cases.push(new_switch_case(get_literal_value(pattern_literal_expr(arm.pattern)), label)) }
            if pk_arm == "ident" {
                let pn: String = pattern_ident_name(arm.pattern)
                if is_enum_variant(s, pn) {
                    cases.push(new_switch_case(pn, label))
                } else {
                    default_lbl = label
                }
            }
            if pk_arm == "wildcard" { default_lbl = label }
            i = i + 1
        }
    }
    // Build result ONLY after all mutations are done — avoids aliasing
    // the LowerState (which shares fn_blocks buffers with s)
    return new MatchBuildResult { state: s, arm_labels: labels, arm_indices: indices, cases: cases, default_label: default_lbl }
}

fn lower_match(st: LowerState, subject: Expr, arms: List<MatchArm>) -> LowerResult {
    let subject_r: LowerResult = lower_expr(st, subject)
    let mut s: LowerState = subject_r.state

    // Save entry block for switch/branch emission
    let match_entry_idx: Int = s.current_block_idx

    // Create merge block
    let merge_label_r: LowerResult = fresh_block_label(s, "match_merge")
    s = merge_label_r.state
    let merge_label: String = merge_label_r.value.name
    s = add_block(s, merge_label)
    let merge_idx: Int = s.current_block_idx

    // Create arm blocks AND build switch cases.
    // Note: we use build_match_arms which returns accumulated results,
    // avoiding the for-loop local variable aliasing bug in the compiled binary.
    let build_r: MatchBuildResult = build_match_arms(s, arms, merge_label)
    s = build_r.state
    let arm_labels: List<String> = build_r.arm_labels
    let arm_indices: List<Int> = build_r.arm_indices
    let cases: List<SwitchCase> = build_r.cases
    let default_label: String = build_r.default_label

    // Emit switch or branch (in the entry block)
    s = set_block(s, match_entry_idx)
    if len(cases) > 0 {
        let tag_r: LowerResult = make_value(s, subject_r.value.ty, "tag")
        s = tag_r.state
        s = emit_instr(s, Instruction::EnumTag(tag_r.value, subject_r.value))
        s = emit_instr(s, Instruction::Switch(tag_r.value, cases, default_label))
    } else {
        if len(arm_labels) > 0 {
            s = emit_instr(s, Instruction::Jump(arm_labels[0]))
        }
    }

    // Lower each arm
    let mut arm_results: List<PhiEntry> = []
    let mut ai: Int = 0
    let na_match: Int = len(arms)
    for _ in 0..200 {
        if ai < na_match {
            let arm: MatchArm = arms[ai]
            let arm_idx: Int = arm_indices[ai]

            s = set_block(s, arm_idx)
            s = lower_push_scope(s)

            // Bind pattern variables — uses helper + explicit typed temp
            // to preserve LowerState type (avoids emitter type tracking loss)
            let s_bound: LowerState = bind_arm_pattern(s, subject_r.value, arm.pattern)
            s = s_bound

            // Lower arm body
            let arm_val_r: LowerResult = lower_arm_body(s, arm.body)
            s = arm_val_r.state

            let exit_label: String = get_block_label(s, s.current_block_idx)
            let arm_terminated: Bool = current_block_terminated(s)

            // Jump to merge if not terminated
            if !arm_terminated {
                s = emit_instr(s, Instruction::Jump(merge_label))
                // Track arm result for phi (include all arms that reach merge)
                // Use zeroinitializer for void/unknown results to avoid referencing %void
                let arm_kind: String = arm_val_r.value.ty.kind
                if arm_kind == "void" || arm_kind == "unknown" || arm_val_r.value.name == "%void" {
                    let zero_arm: Value = new_value("zeroinitializer", arm_val_r.value.ty)
                    let pe_zero: PhiEntry = new_phi_entry(exit_label, zero_arm)
                    arm_results.push(pe_zero)
                } else {
                    let pe_val: PhiEntry = new_phi_entry(exit_label, arm_val_r.value)
                    arm_results.push(pe_val)
                }
            }
            s = lower_pop_scope(s)
            ai = ai + 1
        }
    }

    // Add zeroinitializer entry for switch default→merge path
    if default_label == merge_label && len(arm_results) > 0 {
        let entry_label: String = get_block_label(s, match_entry_idx)
        let first_pe: PhiEntry = arm_results[0]
        let first_val: Value = first_pe.val
        let zero_ty: MIRType = first_val.ty
        let zero_def: Value = new_value("zeroinitializer", zero_ty)
        let def_pe: PhiEntry = new_phi_entry(entry_label, zero_def)
        arm_results.push(def_pe)
    }

    // Merge block
    s = set_block(s, merge_idx)
    if len(arm_results) > 0 {
        let first_pe2: PhiEntry = arm_results[0]
        let first_val2: Value = first_pe2.val
        let phi_ty: MIRType = first_val2.ty
        let rr_phi: LowerResult = make_value(s, phi_ty, "match_result")
        s = rr_phi.state
        s = emit_instr(s, Instruction::Phi(rr_phi.value, arm_results))
        return new_lower_result(rr_phi.value, s)
    }

    // All arms terminated (all have return/break). Merge block is unreachable
    // but callers may reference the result. Use the function's return type
    // to create a properly-typed dummy value (alloca+load of zeroed memory).
    let fn_ret: MIRType = get_current_fn_ret_type(s)
    let rr_unreach: LowerResult = make_value(s, fn_ret, "match_result")
    s = rr_unreach.state
    let dummy_addr: Value = new_value(rr_unreach.value.name + ".dummy", fn_ret)
    s = emit_instr(s, Instruction::Alloca(dummy_addr, fn_ret))
    s = emit_instr(s, Instruction::Load(rr_unreach.value, dummy_addr))
    return new_lower_result(rr_unreach.value, s)
}

fn get_literal_value(expr: Expr) -> String {
    let ek: String = expr_kind(expr)
    if ek == "int_lit" { return toString(expr_int_val(expr)) }
    if ek == "float_lit" { return toString(expr_float_val(expr)) }
    if ek == "bool_lit" { if expr_bool_val(expr) { return "true" } else { return "false" } }
    if ek == "string_lit" { return expr_string_val(expr) }
    return ""
}

// ---------------------------------------------------------------------------
// Pretty-printer
// ---------------------------------------------------------------------------

// Bind pattern fields for a constructor pattern like Rect(w, h).
// Extracted from inline loop to avoid break-inside-if-inside-for bug.
// Uses return-based iteration (return works, break doesn't).
fn has_non_zero_phi(entries: List<PhiEntry>) -> Bool {
    let mut i: Int = 0
    for _ in 0..200 {
        if i >= len(entries) { return false }
        let pe: PhiEntry = entries[i]
        if pe.val.name != "zeroinitializer" { return true }
        i = i + 1
    }
    return false
}

fn bind_arm_pattern(st: LowerState, subject_val: Value, pat: Pattern) -> LowerState {
    let pk: String = pattern_kind(pat)
    if pk == "constructor" {
        return bind_pattern_fields(st, subject_val, pattern_ctor_name(pat), pattern_ctor_args(pat))
    }
    if pk == "ident" {
        return bind_ident_pattern(st, subject_val, pattern_ident_name(pat))
    }
    return st
}

fn bind_ident_pattern(st: LowerState, subject_val: Value, name: String) -> LowerState {
    if is_enum_variant(st, name) { return st }
    let ident_addr: Value = new_value("%" + name + ".addr", subject_val.ty)
    let mut s: LowerState = emit_instr(st, Instruction::Alloca(ident_addr, subject_val.ty))
    s = emit_instr(s, Instruction::Store(ident_addr, subject_val))
    s = define_var(s, name, ident_addr, false)
    return s
}

fn bind_one_pattern_field(st: LowerState, sub_pat: Pattern, subject: Value, variant_name: String, pi: Int) -> LowerState {
    if pattern_kind(sub_pat) != "ident" { return st }
    let var_name: String = pattern_ident_name(sub_pat)
    let pay_ty: MIRType = infer_variant_payload_type(st, subject, variant_name, pi)
    let payload_r: LowerResult = make_value(st, pay_ty, var_name)
    let mut s: LowerState = payload_r.state
    let indexed_name: String = variant_name + ":" + toString(pi)
    s = emit_instr(s, Instruction::EnumPayload(payload_r.value, subject, indexed_name))
    let payload_addr: Value = new_value("%" + var_name + toString(s.tmp_counter) + ".addr", pay_ty)
    s.tmp_counter = s.tmp_counter + 1
    s = emit_instr(s, Instruction::Alloca(payload_addr, pay_ty))
    s = emit_instr(s, Instruction::Store(payload_addr, payload_r.value))
    s = define_var(s, var_name, payload_addr, false)
    return s
}

fn bind_pattern_fields(st: LowerState, subject: Value, variant_name: String, sub_patterns: List<Pattern>) -> LowerState {
    let mut s: LowerState = st
    let mut pi: Int = 0
    for _ in 0..100 {
        if pi >= len(sub_patterns) { return s }
        let sub_pat: Pattern = sub_patterns[pi]
        let s_next: LowerState = bind_one_pattern_field(s, sub_pat, subject, variant_name, pi)
        s = s_next
        pi = pi + 1
    }
    return s
}

fn format_value(v: Value) -> String {
    return v.name
}

fn format_type(t: MIRType) -> String {
    return t.name
}

fn format_instruction(inst: Instruction) -> String {
    let k: String = instr_kind(inst)
    let d: Value = instr_dest(inst)
    if k == "const" { return d.name + " = const " + format_type(instr_const_type(inst)) + " " + instr_const_val(inst) }
    if k == "copy" { return d.name + " = copy " + instr_copy_src(inst).name }
    if k == "cast" { return d.name + " = cast " + instr_cast_src(inst).name + " to " + format_type(instr_cast_type(inst)) }
    if k == "binop" { return d.name + " = binop " + instr_binop_lhs(inst).name + ", " + instr_binop_rhs(inst).name }
    if k == "unaryop" { return d.name + " = unaryop " + instr_unaryop_operand(inst).name }
    if k == "struct_init" { return d.name + " = struct_init " + format_type(instr_struct_type(inst)) }
    if k == "field_get" { return d.name + " = field_get " + instr_fieldget_obj(inst).name + "." + instr_fieldget_name(inst) }
    if k == "field_set" { return "field_set " + instr_fieldset_obj(inst).name + "." + instr_fieldset_name(inst) + " = " + instr_fieldset_val(inst).name }
    if k == "list_init" { return d.name + " = list_init " + format_type(instr_list_type(inst)) }
    if k == "index_get" { return d.name + " = index_get " + instr_indexget_obj(inst).name + "[" + instr_indexget_idx(inst).name + "]" }
    if k == "index_set" { return "index_set " + instr_indexset_obj(inst).name + "[" + instr_indexset_idx(inst).name + "] = " + instr_indexset_val(inst).name }
    if k == "alloca" { return d.name + " = alloca " + format_type(instr_alloca_type(inst)) }
    if k == "load" { return d.name + " = load " + instr_load_ptr(inst).name }
    if k == "store" { return "store " + instr_store_val(inst).name + " to " + instr_store_ptr(inst).name }
    if k == "map_init" { return "map_init" }
    if k == "enum_init" { return d.name + " = enum_init " + format_type(instr_enum_type(inst)) + "::" + instr_enum_variant(inst) }
    if k == "enum_tag" { return d.name + " = enum_tag " + instr_enumtag_val(inst).name }
    if k == "enum_payload" { return d.name + " = enum_payload " + instr_enumpayload_val(inst).name + "::" + instr_enumpayload_variant(inst) }
    if k == "wrap_some" { return d.name + " = wrap_some " + instr_wrap_val(inst).name }
    if k == "wrap_none" { return d.name + " = wrap_none " + format_type(instr_wrapnone_type(inst)) }
    if k == "wrap_ok" { return d.name + " = wrap_ok " + instr_wrap_val(inst).name }
    if k == "wrap_err" { return d.name + " = wrap_err " + instr_wrap_val(inst).name }
    if k == "unwrap" { return d.name + " = unwrap " + instr_wrap_val(inst).name }
    if k == "call" { return d.name + " = call " + instr_call_fn(inst) + "(...)" }
    if k == "return" {
        let val_opt: Option<Value> = instr_return_val(inst)
        match val_opt {
            Some(v) => { return "ret " + v.name },
            _ => { return "ret void" }
        }
    }
    if k == "jump" { return "jump " + instr_jump_target(inst) }
    if k == "branch" { return "branch " + instr_branch_cond(inst).name + ", " + instr_branch_true(inst) + ", " + instr_branch_false(inst) }
    if k == "switch" { return "switch " + instr_switch_tag(inst).name + " default " + instr_switch_default(inst) }
    if k == "agent_spawn" { return d.name + " = agent_spawn " + format_type(instr_agent_type(inst)) }
    if k == "agent_send" { return "agent_send" }
    if k == "agent_sync" { return "agent_sync" }
    if k == "signal_init" { return d.name + " = signal_init " + format_type(instr_signal_type(inst)) + " " + instr_signal_val(inst).name }
    if k == "signal_get" { return d.name + " = signal_get " + instr_signalget_sig(inst).name }
    if k == "signal_set" { return "signal_set " + instr_signalset_sig(inst).name + " = " + instr_signalset_val(inst).name }
    if k == "stream_op" { return "stream_op" }
    if k == "interp_concat" { return d.name + " = interp_concat [...]" }
    if k == "phi" { return d.name + " = phi [...]" }
    return "<unknown_instruction>"
}

fn pretty_print_block(bb: BasicBlock) -> String {
    let mut result: String = "  " + bb.label + ":\n"
    let mut i: Int = 0
    for _ in 0..600 {
        if i >= len(bb.instructions) { return result }
        let inst: Instruction = bb.instructions[i]
        result = result + "    " + format_instruction(inst) + "\n"
        i = i + 1
    }
    return result
}

fn pretty_print_function(f: MIRFunction) -> String {
    let mut params_str: String = ""
    let mut i: Int = 0
    let nfp: Int = len(f.params)
    for _ in 0..200 {
        if i < nfp {
            let p: MIRParam = f.params[i]
            if i > 0 { params_str = params_str + ", " }
            params_str = params_str + p.name + ": " + format_type(p.ty)
            i = i + 1
        }
    }

    let header: String = "fn " + f.name + "(" + params_str + ") -> " + format_type(f.return_type)
    if len(f.blocks) == 0 { return header + " {}" }

    let mut result: String = header + " {\n"
    let mut bi: Int = 0
    let nfb: Int = len(f.blocks)
    for _ in 0..600 {
        if bi < nfb {
            let bb: BasicBlock = f.blocks[bi]
            result = result + pretty_print_block(bb)
            bi = bi + 1
        }
    }
    result = result + "}"
    return result
}

fn pretty_print_module(module: MIRModule) -> String {
    let mut result: String = ""
    if module.name != "" {
        result = "module " + module.name + "\n\n"
    }

    // Print structs
    let mut si_idx: Int = 0
    let nms: Int = len(module.structs)
    for _ in 0..200 {
        if si_idx < nms {
            let s: StructInfo = module.structs[si_idx]
            result = result + "struct " + s.name + " {...}\n"
            si_idx = si_idx + 1
        }
    }

    // Print enums
    let mut ei: Int = 0
    let nme: Int = len(module.enums)
    for _ in 0..200 {
        if ei < nme {
            let e: EnumInfo = module.enums[ei]
            result = result + "enum " + e.name + " {...}\n"
            ei = ei + 1
        }
    }

    if len(module.structs) > 0 { result = result + "\n" }
    if len(module.enums) > 0 { result = result + "\n" }

    // Print functions
    let mut fi: Int = 0
    let nmf: Int = len(module.functions)
    for _ in 0..600 {
        if fi < nmf {
            let f: MIRFunction = module.functions[fi]
            result = result + pretty_print_function(f) + "\n\n"
            fi = fi + 1
        }
    }

    return result
}

// ---------------------------------------------------------------------------
// MIR verifier
// ---------------------------------------------------------------------------

struct VerifyError {
    fn_name: String,
    block_label: String,
    message: String
}

fn new_verify_error(fn_name: String, block: String, msg: String) -> VerifyError {
    return new VerifyError { fn_name: fn_name, block_label: block, message: msg }
}

fn verify_module(module: MIRModule) -> List<VerifyError> {
    let mut errors: List<VerifyError> = []
    let mut i: Int = 0
    for _ in 0..600 {
        if i >= len(module.functions) { return errors }
        let f: MIRFunction = module.functions[i]
        let fn_errors: List<VerifyError> = verify_function(f)
        let mut j: Int = 0
        let nfe: Int = len(fn_errors)
        for _ in 0..600 {
            if j < nfe {
                errors.push(fn_errors[j])
                j = j + 1
            }
        }
        i = i + 1
    }
    return errors
}

fn verify_function(f: MIRFunction) -> List<VerifyError> {
    let mut errors: List<VerifyError> = []

    if len(f.blocks) == 0 {
        let e: VerifyError = new_verify_error(f.name, "", "function has no basic blocks")
        errors.push(e)
        return errors
    }

    let mut i: Int = 0
    for _ in 0..600 {
        if i >= len(f.blocks) { return errors }
        let bb: BasicBlock = f.blocks[i]
        let bb_errors: List<VerifyError> = verify_block(f.name, bb, f)
        let mut j: Int = 0
        let nbe: Int = len(bb_errors)
        for _ in 0..600 {
            if j < nbe {
                errors.push(bb_errors[j])
                j = j + 1
            }
        }
        i = i + 1
    }
    return errors
}

fn verify_block(fn_name: String, bb: BasicBlock, f: MIRFunction) -> List<VerifyError> {
    let mut errors: List<VerifyError> = []

    if len(bb.instructions) == 0 {
        let e_empty: VerifyError = new_verify_error(fn_name, bb.label, "block has no instructions")
        errors.push(e_empty)
        return errors
    }

    // Check terminator
    let last: Instruction = bb.instructions[len(bb.instructions) - 1]
    if !is_terminator(last) {
        let e_noterm: VerifyError = new_verify_error(fn_name, bb.label, "block does not end with a terminator")
        errors.push(e_noterm)
    }

    // Check no terminators in the middle
    let mut i: Int = 0
    let nbi_m1: Int = len(bb.instructions) - 1
    for _ in 0..600 {
        if i < nbi_m1 {
            let inst_mid: Instruction = bb.instructions[i]
            if is_terminator(inst_mid) {
                let e_midterm: VerifyError = new_verify_error(fn_name, bb.label, "terminator at position " + toString(i) + " (not last)")
                errors.push(e_midterm)
            }
            i = i + 1
        }
    }

    // Check phi nodes are at the start
    let mut seen_non_phi: Bool = false
    let mut phi_i: Int = 0
    let nbi_phi: Int = len(bb.instructions)
    for _ in 0..600 {
        if phi_i < nbi_phi {
            let inst_phi: Instruction = bb.instructions[phi_i]
            if instr_kind(inst_phi) == "phi" {
                if seen_non_phi {
                    let e_phi: VerifyError = new_verify_error(fn_name, bb.label, "phi node after non-phi instruction")
                    errors.push(e_phi)
                }
            } else {
                seen_non_phi = true
            }
            phi_i = phi_i + 1
        }
    }

    return errors
}

// ---------------------------------------------------------------------------
// Public API
// ---------------------------------------------------------------------------

pub fn lower(program: Program, module_name: String) -> MIRModule {
    let mut st: LowerState = new_lower_state(module_name)

    // Pass 1: register declarations
    st = register_declarations(st, program)

    // Pass 2: lower function bodies
    st = lower_definitions(st, program)

    return st.module
}

// Streaming API: lower header only (types, externs), return state for per-function lowering
pub fn lower_header(program: Program, module_name: String) -> LowerState {
    let mut st: LowerState = new_lower_state(module_name)
    st = register_declarations(st, program)
    return st
}

// Lower a single function and return the MIR function + updated state
// The function is NOT added to module.functions (caller handles emission)
pub fn lower_one_fn(st: LowerState, fn_def: FnDefData, prefix: String) -> LowerResult {
    let fn_name: String = prefix + fn_def.name

    // Build params
    let mut params: List<MIRParam> = []
    let mut pi_reg: Int = 0
    let nfdp: Int = len(fn_def.params)
    for _ in 0..200 {
        if pi_reg < nfdp {
            let p_reg: Param = fn_def.params[pi_reg]
            let pty_reg: MIRType = lower_resolve_type_opt_checked(st, p_reg.type_annotation)
            let mp: MIRParam = new_mir_param(p_reg.name, pty_reg)
            params.push(mp)
            pi_reg = pi_reg + 1
        }
    }

    let ret_type: MIRType = resolve_return_type_checked(st, fn_def.return_type)

    let mut decorators: List<String> = []
    let mut dix: Int = 0
    let ndec: Int = len(fn_def.decorators)
    for _ in 0..100 {
        if dix < ndec {
            decorators.push(fn_def.decorators[dix].name)
            dix = dix + 1
        }
    }

    let mir_fn: MIRFunction = new_mir_function(fn_name, params, ret_type, decorators, fn_def.public)

    // Save state
    let prev_fn: Option<MIRFunction> = st.current_fn
    let prev_block_idx: Int = st.current_block_idx
    let prev_tmp: Int = st.tmp_counter
    let prev_blk_cnt: Int = st.block_counter
    let prev_vars: List<VarInfo> = st.vars
    let prev_blocks: List<BasicBlock> = st.fn_blocks

    let mut s: LowerState = st
    s.current_fn = Some(mir_fn)
    s.tmp_counter = 0
    s.block_counter = 0
    let fresh_vars: List<VarInfo> = []
    s.vars = fresh_vars
    let fresh_blocks: List<BasicBlock> = []
    s.fn_blocks = fresh_blocks

    s = add_block(s, "entry")
    s = set_block(s, 0)

    // Bind params
    let mut bi: Int = 0
    for _ in 0..200 {
        if bi < nfdp {
            let p_bind: Param = fn_def.params[bi]
            let pty_bind: MIRType = lower_resolve_type_opt_checked(s, p_bind.type_annotation)
            let addr_name: String = "%" + p_bind.name + ".addr"
            let addr: Value = new_value(addr_name, pty_bind)
            let param_val: Value = new_value("%" + p_bind.name, pty_bind)
            s = emit_instr(s, Instruction::Alloca(addr, pty_bind))
            s = emit_instr(s, Instruction::Store(addr, param_val))
            s = define_var(s, p_bind.name, addr, false)
            bi = bi + 1
        }
    }

    // Lower body
    let body_r: LowerResult = lower_block(s, fn_def.body)
    s = body_r.state

    if !current_block_terminated(s) {
        if ret_type.kind == "void" {
            s = emit_instr(s, Instruction::Return(none))
        } else {
            s = emit_instr(s, Instruction::Return(Some(body_r.value)))
        }
    }

    // Copy fn_blocks into MIRFunction (DO NOT add to module — caller emits it)
    let mut result_fn: MIRFunction = mir_fn
    match s.current_fn {
        Some(f) => { result_fn = f },
        _ => {}
    }
    result_fn.blocks = s.fn_blocks

    // Restore counters/vars but KEEP current_fn so caller can extract it
    s.current_fn = Some(result_fn)
    s.current_block_idx = prev_block_idx
    s.tmp_counter = prev_tmp
    s.block_counter = prev_blk_cnt
    s.vars = prev_vars
    s.fn_blocks = prev_blocks

    let fn_val: Value = new_value(fn_name, mir_void())
    return new_lower_result(fn_val, s)
}

// Get the last-added function from a LowerState's current_fn
pub fn extract_current_fn(st: LowerState) -> MIRFunction {
    match st.current_fn {
        Some(f) => { return f },
        _ => {
            let empty_params: List<MIRParam> = []
            let empty_blocks: List<BasicBlock> = []
            let empty_decorators: List<String> = []
            return new MIRFunction { name: "unknown", params: empty_params, return_type: mir_void(), blocks: empty_blocks, decorators: empty_decorators, is_public: false }
        }
    }
}

// ===== emit_llvm_ir.mn =====
// emit_llvm_ir.mn — LLVM IR type constants and instruction string builders.
// Pure string-producing functions, shared by emit_llvm.mn.


// ---------------------------------------------------------------------------
// LLVM type constants (as string representations)
// ---------------------------------------------------------------------------

fn llvm_int() -> String {
    return "i64"
}

fn llvm_float() -> String {
    return "double"
}

fn llvm_bool() -> String {
    return "i1"
}

fn llvm_char() -> String {
    return "i8"
}

fn llvm_void() -> String {
    return "void"
}

fn llvm_string() -> String {
    return "{ ptr, i64 }"
}

// ---------------------------------------------------------------------------
// Composite type builders
// ---------------------------------------------------------------------------

fn llvm_option_type(inner: String) -> String {
    return "{ i1, " + inner + " }"
}

fn llvm_result_type(ok_ty: String, err_ty: String) -> String {
    return "{ i1, { " + ok_ty + ", " + err_ty + " } }"
}

fn llvm_tensor_type(elem_ty: String) -> String {
    return "{ ptr, i64, ptr, i64 }"
}

fn llvm_list_type(elem_ty: String) -> String {
    return "{ ptr, i64, i64 }"
}

fn llvm_map_type() -> String {
    return "{ ptr, i64 }"
}

fn llvm_ptr() -> String {
    return "ptr"
}

fn llvm_list_rt() -> String {
    return "{ ptr, i64, i64, i64 }"
}

// ---------------------------------------------------------------------------
// MIR type → LLVM type resolution
// ---------------------------------------------------------------------------

fn resolve_mir_type(t: MIRType) -> String {
    if t.kind == "int" { return llvm_int() }
    if t.kind == "float" { return llvm_float() }
    if t.kind == "bool" { return llvm_bool() }
    if t.kind == "string" { return llvm_string() }
    if t.kind == "void" { return llvm_void() }
    if t.kind == "char" { return llvm_char() }
    if t.kind == "list" { return llvm_list_rt() }
    if t.kind == "map" { return llvm_map_type() }
    if t.kind == "option" {
        // Universal type erasure: all Option types use {i1, ptr}.
        // The payload is stored via alloca and accessed through the ptr.
        // This ensures Option types are always consistent between
        // function signatures and match extraction.
        return llvm_option_type(llvm_ptr())
    }
    if t.kind == "result" {
        if len(t.args) >= 2 {
            let ok_ty: String = resolve_mir_type(t.args[0])
            let err_ty: String = resolve_mir_type(t.args[1])
            return llvm_result_type(ok_ty, err_ty)
        }
        return llvm_result_type(llvm_ptr(), llvm_ptr())
    }
    if t.kind == "signal" { return llvm_ptr() }
    if t.kind == "agent" { return llvm_ptr() }
    if t.kind == "struct" { return "%struct." + t.name }
    if t.kind == "enum" { return "%enum." + t.name }
    if t.kind == "range" { return "{ i64, i64 }" }
    if t.kind == "fn" { return llvm_ptr() }
    if t.kind == "unknown" { return llvm_int() }
    return llvm_int()
}

// ---------------------------------------------------------------------------
// LLVM IR instruction builders (string-based)
// ---------------------------------------------------------------------------

fn llvm_alloca(name: String, ty: String) -> String {
    return "  " + name + " =alloca " + ty
}

fn llvm_store(ty: String, value: String, ptr: String) -> String {
    return "  store " + ty + " " + value + ", ptr " + ptr
}

fn llvm_load(name: String, ty: String, ptr: String) -> String {
    return "  " + name + " =load " + ty + ", ptr " + ptr
}

fn emit_add(name: String, ty: String, left: String, right: String) -> String {
    return "  " + name + " =add " + ty + " " + left + ", " + right
}

fn emit_sub(name: String, ty: String, left: String, right: String) -> String {
    return "  " + name + " =sub " + ty + " " + left + ", " + right
}

fn emit_mul(name: String, ty: String, left: String, right: String) -> String {
    return "  " + name + " =mul " + ty + " " + left + ", " + right
}

fn emit_sdiv(name: String, ty: String, left: String, right: String) -> String {
    return "  " + name + " =sdiv " + ty + " " + left + ", " + right
}

fn emit_srem(name: String, ty: String, left: String, right: String) -> String {
    return "  " + name + " =srem " + ty + " " + left + ", " + right
}

fn emit_fadd(name: String, left: String, right: String) -> String {
    return "  " + name + " =fadd double " + left + ", " + right
}

fn emit_fsub(name: String, left: String, right: String) -> String {
    return "  " + name + " =fsub double " + left + ", " + right
}

fn emit_fmul(name: String, left: String, right: String) -> String {
    return "  " + name + " =fmul double " + left + ", " + right
}

fn emit_fdiv(name: String, left: String, right: String) -> String {
    return "  " + name + " =fdiv double " + left + ", " + right
}

fn emit_frem(name: String, left: String, right: String) -> String {
    return "  " + name + " =frem double " + left + ", " + right
}

fn emit_fneg(name: String, operand: String) -> String {
    return "  " + name + " =fneg double " + operand
}

fn emit_neg(name: String, ty: String, operand: String) -> String {
    return "  " + name + " =sub " + ty + " 0, " + operand
}

fn emit_not(name: String, operand: String) -> String {
    return "  " + name + " =xor i1 " + operand + ", true"
}

// ---------------------------------------------------------------------------
// Comparison instruction builders
// ---------------------------------------------------------------------------

fn emit_icmp(name: String, cmp: String, ty: String, left: String, right: String) -> String {
    return "  " + name + " =icmp " + cmp + " " + ty + " " + left + ", " + right
}

fn emit_fcmp(name: String, cmp: String, left: String, right: String) -> String {
    return "  " + name + " =fcmp o" + cmp + " double " + left + ", " + right
}

// ---------------------------------------------------------------------------
// Logical operators
// ---------------------------------------------------------------------------

fn emit_and_instr(name: String, left: String, right: String) -> String {
    return "  " + name + " =and i1 " + left + ", " + right
}

fn emit_or_instr(name: String, left: String, right: String) -> String {
    return "  " + name + " =or i1 " + left + ", " + right
}

// ---------------------------------------------------------------------------
// Control flow
// ---------------------------------------------------------------------------

fn emit_br(label: String) -> String {
    return "  br label %" + label
}

fn emit_cbranch(cond: String, true_label: String, false_label: String) -> String {
    return "  br i1 " + cond + ", label %" + true_label + ", label %" + false_label
}

fn emit_phi_instr(name: String, ty: String, val1: String, bb1: String, val2: String, bb2: String) -> String {
    return "  " + name + " =phi " + ty + " [ " + val1 + ", %" + bb1 + " ], [ " + val2 + ", %" + bb2 + " ]"
}

fn emit_switch_hdr(subject: String, default_label: String) -> String {
    return "  switch i64 " + subject + ", label %" + default_label + " ["
}

fn emit_switch_case(value: String, label: String) -> String {
    return "    i64 " + value + ", label %" + label
}

// ---------------------------------------------------------------------------
// Function / call builders
// ---------------------------------------------------------------------------

fn emit_call_ir(name: String, ret_ty: String, callee: String, args: String) -> String {
    return "  " + name + " =call " + ret_ty + " @" + callee + "(" + args + ")"
}

fn emit_call_void(callee: String, args: String) -> String {
    return "  call void @" + callee + "(" + args + ")"
}

fn emit_ret(ty: String, value: String) -> String {
    return "  ret " + ty + " " + value
}

fn emit_ret_void() -> String {
    return "  ret void"
}

// ---------------------------------------------------------------------------
// GEP / insertvalue / extractvalue builders
// ---------------------------------------------------------------------------

fn emit_gep(name: String, ty: String, ptr: String, idx: String) -> String {
    return "  " + name + " =getelementptr " + ty + ", ptr " + ptr + ", i64 0, i64 " + idx
}

fn emit_insertvalue(name: String, struct_ty: String, agg: String, val: String, val_ty: String, idx: String) -> String {
    return "  " + name + " =insertvalue " + struct_ty + " " + agg + ", " + val_ty + " " + val + ", " + idx
}

fn emit_extractvalue(name: String, struct_ty: String, agg: String, idx: String) -> String {
    return "  " + name + " =extractvalue " + struct_ty + " " + agg + ", " + idx
}

fn emit_bitcast(name: String, src_ty: String, val: String, dst_ty: String) -> String {
    return "  " + name + " =bitcast " + src_ty + " " + val + " to " + dst_ty
}

// ===== emit_llvm.mn =====
// emit_llvm.mn — LLVM IR emitter for the Mapanare self-hosted compiler.
// Consumes MIR (from lower.mn) and produces LLVM IR text (string-based).
//
// Architecture:
//   - emit_mir_module walks MIR structs, enums, extern fns, then functions
//   - emit_mir_function emits function header + basic blocks
//   - emit_mir_basic_block emits block label + instructions
//   - emit_mir_instruction maps each MIR opcode to LLVM IR instructions
//   - A local counter produces unique SSA names (%0, %1, ...)
//
// LLVM type constants and IR string builders are in emit_llvm_ir.mn.


// ---------------------------------------------------------------------------
// Emitter state
// ---------------------------------------------------------------------------

struct StructEntry {
    name: String,
    field_names: List<String>,
    field_types: List<String>,
    llvm_type: String
}

fn new_struct_entry(name: String, fields: List<String>, types: List<String>, ty: String) -> StructEntry {
    return new StructEntry { name: name, field_names: fields, field_types: types, llvm_type: ty }
}

fn lookup_struct_field_types(st: EmitState, name: String) -> List<String> {
    let mut i: Int = 0
    let nstructs: Int = len(st.structs)
    for _ in 0..10000 {
        if i < nstructs {
            let entry: StructEntry = st.structs[i]
            if entry.name == name {
                return entry.field_types
            }
            i = i + 1
        }
    }
    let empty: List<String> = []
    return empty
}

struct FnEntry {
    name: String,
    ret_type: String,
    param_types: List<String>
}

fn new_fn_entry(name: String, ret: String, params: List<String>) -> FnEntry {
    return new FnEntry { name: name, ret_type: ret, param_types: params }
}

struct EmitState {
    lines: List<String>,
    counter: Int,
    functions: List<FnEntry>,
    structs: List<StructEntry>,
    module_name: String,
    str_counter: Int,
    str_globals: List<String>,
    current_ret_type: String,
    enum_names: List<String>,
    enum_infos: List<EnumInfo>
}

fn new_emit_state(module_name: String) -> EmitState {
    let lines: List<String> = []
    let functions: List<FnEntry> = []
    // Build internal struct entries BEFORE constructing EmitState.
    // This avoids the circular dependency: pushing to st.structs needs
    // EmitState field info, but EmitState isn't registered yet.
    let structs: List<StructEntry> = build_internal_struct_list()
    let str_globals: List<String> = []
    let enum_names: List<String> = []
    let enum_infos: List<EnumInfo> = []
    return new EmitState { lines: lines, counter: 0, functions: functions, structs: structs, module_name: module_name, str_counter: 0, str_globals: str_globals, current_ret_type: "void", enum_names: enum_names, enum_infos: enum_infos }
}

fn build_internal_struct_list() -> List<StructEntry> {
    let mut list: List<StructEntry> = []
    // StructEntry MUST be first — make_entry creates StructEntry values,
    // and the emitter needs StructEntry's field info to generate correct
    // insertvalue indices for subsequent make_entry calls.
    list.push(make_entry("StructEntry", ["name", "field_names", "field_types", "llvm_type"]))
    list.push(make_entry("MIRModule", ["name", "functions", "structs", "enums", "extern_fns", "agents", "pipes", "imports", "trait_names"]))
    list.push(make_entry("LowerState", ["module", "current_fn", "current_block_idx", "tmp_counter", "block_counter", "vars", "scope_stack", "impl_methods", "struct_fields", "enum_variants", "lambda_vars", "fn_blocks"]))
    list.push(make_entry("EmitState", ["lines", "counter", "functions", "structs", "module_name", "str_counter", "str_globals", "current_ret_type", "enum_names", "enum_infos"]))
    list.push(make_entry("LowerResult", ["value", "state"]))
    list.push(make_entry("CompileResult", ["success", "ir_text", "errors"]))
    list.push(make_entry("MatchBuildResult", ["state", "arm_labels", "arm_indices", "arm_body_labels", "merge_label"]))
    list.push(make_entry("FnEntry", ["name", "ret_type", "param_types"]))
    // StructEntry already registered first (above)
    list.push(make_entry("VarInfo", ["name", "value", "mutable"]))
    list.push(make_entry("StructFieldInfo", ["struct_name", "field_names", "field_types"]))
    list.push(make_entry("EnumVariantNames", ["name", "variant_names"]))
    list.push(make_entry("LambdaEntry", ["var_name", "body_name"]))
    list.push(make_entry("ExternFnInfo", ["abi", "module_name", "fn_name", "param_types", "return_type"]))
    list.push(make_entry("VerifyError", ["fn_name", "block_name", "message"]))
    list.push(make_entry("ImplEntry", ["key", "method_name"]))
    list.push(make_entry("ImportInfo", ["path", "items"]))
    list.push(make_entry("AgentInfo", ["name", "inputs", "outputs", "state_fields"]))
    list.push(make_entry("PipeInfo", ["name", "stages"]))
    list.push(make_entry("MIRFunction", ["name", "params", "return_type", "blocks", "decorators", "is_public"]))
    list.push(make_entry("BasicBlock", ["label", "instructions"]))
    list.push(make_entry("MIRType", ["kind", "name", "args"]))
    list.push(make_entry("Value", ["name", "ty"]))
    return list
}

fn make_entry(name: String, field_names: List<String>) -> StructEntry {
    let types: List<String> = []
    return new_struct_entry(name, field_names, types, "%struct." + name)
}

// Pre-register internal compiler struct types that may not be in the MIR module.
// Without these, find_field_index returns 0 for all fields (index-0 bug).
fn register_internal_struct(st: EmitState, name: String, fields: List<String>) -> EmitState {
    let types: List<String> = []
    let entry: StructEntry = new_struct_entry(name, fields, types, "%struct." + name)
    st.structs.push(entry)
    return st
}

fn register_all_internal_structs(st: EmitState) -> EmitState {
    let mut s: EmitState = st
    // MIRModule: name, functions, structs, enums, extern_fns, agents, pipes, imports, trait_names
    s = register_internal_struct(s, "MIRModule", ["name", "functions", "structs", "enums", "extern_fns", "agents", "pipes", "imports", "trait_names"])
    // LowerState: module, current_fn, current_block_idx, tmp_counter, block_counter, vars, scope_stack, impl_methods, struct_fields, enum_variants, lambda_vars, fn_blocks
    s = register_internal_struct(s, "LowerState", ["module", "current_fn", "current_block_idx", "tmp_counter", "block_counter", "vars", "scope_stack", "impl_methods", "struct_fields", "enum_variants", "lambda_vars", "fn_blocks"])
    // EmitState: lines, counter, functions, structs, module_name, str_counter, str_globals, current_ret_type, enum_names, enum_infos
    s = register_internal_struct(s, "EmitState", ["lines", "counter", "functions", "structs", "module_name", "str_counter", "str_globals", "current_ret_type", "enum_names", "enum_infos"])
    // LowerResult: value, state
    s = register_internal_struct(s, "LowerResult", ["value", "state"])
    // CompileResult: success, ir_text, errors
    s = register_internal_struct(s, "CompileResult", ["success", "ir_text", "errors"])
    // MatchBuildResult: state, arm_labels, arm_indices, arm_body_labels, merge_label
    s = register_internal_struct(s, "MatchBuildResult", ["state", "arm_labels", "arm_indices", "arm_body_labels", "merge_label"])
    // FnEntry: name, ret_type, param_types
    s = register_internal_struct(s, "FnEntry", ["name", "ret_type", "param_types"])
    // StructEntry: name, field_names, field_types, llvm_type
    s = register_internal_struct(s, "StructEntry", ["name", "field_names", "field_types", "llvm_type"])
    // VarInfo: name, value, mutable
    s = register_internal_struct(s, "VarInfo", ["name", "value", "mutable"])
    // StructFieldInfo: struct_name, field_names, field_types
    s = register_internal_struct(s, "StructFieldInfo", ["struct_name", "field_names", "field_types"])
    // EnumVariantNames: name, variant_names
    s = register_internal_struct(s, "EnumVariantNames", ["name", "variant_names"])
    // LambdaEntry: var_name, body_name
    s = register_internal_struct(s, "LambdaEntry", ["var_name", "body_name"])
    // ExternFnInfo: abi, module_name, fn_name, param_types, return_type
    s = register_internal_struct(s, "ExternFnInfo", ["abi", "module_name", "fn_name", "param_types", "return_type"])
    // VerifyError: fn_name, block_name, message
    s = register_internal_struct(s, "VerifyError", ["fn_name", "block_name", "message"])
    // ImplEntry: key, method_name
    s = register_internal_struct(s, "ImplEntry", ["key", "method_name"])
    // ImportInfo: path, items
    s = register_internal_struct(s, "ImportInfo", ["path", "items"])
    // AgentInfo: name, inputs, outputs, state_fields
    s = register_internal_struct(s, "AgentInfo", ["name", "inputs", "outputs", "state_fields"])
    // PipeInfo: name, stages
    s = register_internal_struct(s, "PipeInfo", ["name", "stages"])
    // MIRFunction: name, params, return_type, blocks, decorators, is_public
    s = register_internal_struct(s, "MIRFunction", ["name", "params", "return_type", "blocks", "decorators", "is_public"])
    // BasicBlock: label, instructions
    s = register_internal_struct(s, "BasicBlock", ["label", "instructions"])
    // MIRType: kind, name, args
    s = register_internal_struct(s, "MIRType", ["kind", "name", "args"])
    // Value: name, ty
    s = register_internal_struct(s, "Value", ["name", "ty"])
    return s
}

fn emit_global(st: EmitState, line: String) -> EmitState {
    st.str_globals.push(line)
    return st
}

fn emit_fresh_tmp(st: EmitState, prefix: String) -> String {
    return prefix + "." + toString(st.counter)
}

// ---------------------------------------------------------------------------
// Line emission
// ---------------------------------------------------------------------------

fn emit_line(st: EmitState, line: String) -> EmitState {
    st.lines.push(line)
    return st
}

fn emit_blank(st: EmitState) -> EmitState {
    return emit_line(st, "")
}

// ---------------------------------------------------------------------------
// Counter helpers
// ---------------------------------------------------------------------------

fn next_ssa(st: EmitState) -> EmitState {
    // Returns state with counter incremented; caller uses st.counter for name
    return st
}

fn ssa_name(st: EmitState) -> String {
    return "%" + toString(st.counter)
}

fn next_str_name(st: EmitState) -> String {
    return "@str." + toString(st.str_counter)
}

// ---------------------------------------------------------------------------
// Lookup helpers
// ---------------------------------------------------------------------------

fn find_function(st: EmitState, name: String) -> Option<FnEntry> {
    let mut i: Int = len(st.functions) - 1
    for _ in 0..600 {
        if i < 0 { return none }
        let f: FnEntry = st.functions[i]
        if f.name == name { return Some(f) }
        i = i - 1
    }
    return none
}

fn find_struct_entry(st: EmitState, name: String) -> Option<StructEntry> {
    let mut i: Int = len(st.structs) - 1
    for _ in 0..600 {
        if i < 0 { return none }
        let s: StructEntry = st.structs[i]
        if s.name == name { return Some(s) }
        i = i - 1
    }
    return none
}

// ---------------------------------------------------------------------------
// State-aware type resolution (corrects struct→enum misclassification)
// ---------------------------------------------------------------------------

fn resolve_type(st: EmitState, ty: MIRType) -> String {
    let resolved: String = resolve_mir_type(ty)
    if resolved.starts_with("%struct.") && is_enum_type(st, ty.name) {
        return "%enum." + ty.name
    }
    return resolved
}

// ---------------------------------------------------------------------------
// Runtime function declarations
// ---------------------------------------------------------------------------

fn declare_runtime_fn(st: EmitState, name: String, ret: String, params: String) -> EmitState {
    let line: String = "declare " + ret + " @" + name + "(" + params + ")"
    return emit_line(st, line)
}

fn declare_all_runtime(st: EmitState) -> EmitState {
    let mut s: EmitState = st

    // String runtime
    s = declare_runtime_fn(s, "__mn_str_concat", llvm_string(), llvm_string() + ", " + llvm_string())
    s = declare_runtime_fn(s, "__mn_str_eq", llvm_int(), llvm_string() + ", " + llvm_string())
    s = declare_runtime_fn(s, "__mn_str_cmp", llvm_int(), llvm_string() + ", " + llvm_string())
    s = declare_runtime_fn(s, "__mn_str_len", llvm_int(), llvm_string())
    s = declare_runtime_fn(s, "__mn_str_char_at", llvm_string(), llvm_string() + ", i64")
    s = declare_runtime_fn(s, "__mn_str_byte_at", llvm_int(), llvm_string() + ", i64")
    s = declare_runtime_fn(s, "__mn_str_substr", llvm_string(), llvm_string() + ", i64, i64")
    s = declare_runtime_fn(s, "__mn_str_from_int", llvm_string(), "i64")
    s = declare_runtime_fn(s, "__mn_str_from_bool", llvm_string(), "i1")
    s = declare_runtime_fn(s, "__mn_str_from_float", llvm_string(), "double")
    s = declare_runtime_fn(s, "__mn_str_to_int", llvm_int(), llvm_string())
    s = declare_runtime_fn(s, "__mn_str_to_float", llvm_float(), llvm_string())
    s = declare_runtime_fn(s, "__mn_str_println", "void", llvm_string())
    s = declare_runtime_fn(s, "__mn_str_print", "void", llvm_string())
    s = declare_runtime_fn(s, "__mn_str_starts_with", llvm_bool(), llvm_string() + ", " + llvm_string())
    s = declare_runtime_fn(s, "__mn_str_ends_with", llvm_bool(), llvm_string() + ", " + llvm_string())
    s = declare_runtime_fn(s, "__mn_str_find", llvm_int(), llvm_string() + ", " + llvm_string())
    s = declare_runtime_fn(s, "__mn_str_join", llvm_string(), llvm_string() + ", ptr")

    // List runtime
    s = declare_runtime_fn(s, "__mn_list_new", llvm_list_rt(), "i64")
    s = declare_runtime_fn(s, "__mn_list_push", "void", "ptr, ptr")
    s = declare_runtime_fn(s, "__mn_list_get", "ptr", "ptr, i64")
    s = declare_runtime_fn(s, "__mn_list_len", "i64", "ptr")
    s = declare_runtime_fn(s, "__mn_list_set", "void", "ptr, i64, ptr")

    // Iterator runtime
    s = declare_runtime_fn(s, "__iter_has_next", llvm_bool(), "{ i64, i64 }")
    s = declare_runtime_fn(s, "__iter_next", llvm_int(), "{ i64, i64 }")
    s = declare_runtime_fn(s, "__mn_range", "{ i64, i64 }", "i64, i64")

    // String methods
    s = declare_runtime_fn(s, "__mn_str_to_upper", llvm_string(), llvm_string())
    s = declare_runtime_fn(s, "__mn_str_to_lower", llvm_string(), llvm_string())
    s = declare_runtime_fn(s, "__mn_str_replace", llvm_string(), llvm_string() + ", " + llvm_string() + ", " + llvm_string())
    s = declare_runtime_fn(s, "__mn_str_split", llvm_list_rt(), llvm_string() + ", " + llvm_string())
    s = declare_runtime_fn(s, "__mn_str_trim", llvm_string(), llvm_string())
    s = declare_runtime_fn(s, "__mn_str_contains", llvm_bool(), llvm_string() + ", " + llvm_string())

    // Panic / process
    s = declare_runtime_fn(s, "__mn_panic", "void", llvm_string())
    s = declare_runtime_fn(s, "__mn_exit", "void", "i64")
    s = declare_runtime_fn(s, "__mn_argc", "i64", "")
    s = declare_runtime_fn(s, "__mn_argv", llvm_string(), "i64")
    s = declare_runtime_fn(s, "__mn_file_read_or_empty", llvm_string(), llvm_string())
    s = declare_runtime_fn(s, "__mn_str_eprint", "void", llvm_string())
    s = declare_runtime_fn(s, "__mn_str_eprintln", "void", llvm_string())

    // Map runtime
    s = declare_runtime_fn(s, "__mn_map_new", "ptr", "i64, i64, i64")
    s = declare_runtime_fn(s, "__mn_map_set", "void", "ptr, ptr, ptr")
    s = declare_runtime_fn(s, "__mn_map_get", "ptr", "ptr, ptr")
    s = declare_runtime_fn(s, "__mn_map_len", "i64", "ptr")
    s = declare_runtime_fn(s, "__mn_map_contains", "i64", "ptr, ptr")

    // Malloc (for enum payload allocation)
    s = declare_runtime_fn(s, "malloc", "ptr", "i64")

    // Printf
    s = declare_runtime_fn(s, "printf", "i32", "ptr, ...")

    // Tensor runtime
    s = declare_runtime_fn(s, "__mapanare_tensor_add", "ptr", "ptr, ptr")
    s = declare_runtime_fn(s, "__mapanare_tensor_sub", "ptr", "ptr, ptr")
    s = declare_runtime_fn(s, "__mapanare_tensor_mul", "ptr", "ptr, ptr")
    s = declare_runtime_fn(s, "__mapanare_tensor_div", "ptr", "ptr, ptr")
    s = declare_runtime_fn(s, "__mapanare_matmul", "ptr", "ptr, ptr")
    s = declare_runtime_fn(s, "__mapanare_tensor_alloc", "ptr", "i64, i64*, i64")
    s = declare_runtime_fn(s, "__mapanare_tensor_free", "void", "ptr")
    s = declare_runtime_fn(s, "__mapanare_tensor_shape_eq", "i1", "ptr, ptr")
    s = declare_runtime_fn(s, "__mapanare_detect_gpus", "ptr", "")

    // Agent runtime
    s = declare_runtime_fn(s, "__mn_agent_spawn", "ptr", "ptr, ptr")
    s = declare_runtime_fn(s, "__mn_agent_send", "void", "ptr, ptr, ptr")
    s = declare_runtime_fn(s, "__mn_agent_sync", "ptr", "ptr, ptr")

    // Signal runtime
    s = declare_runtime_fn(s, "__mn_signal_new", "ptr", "ptr")
    s = declare_runtime_fn(s, "__mn_signal_get", "ptr", "ptr")
    s = declare_runtime_fn(s, "__mn_signal_set", "void", "ptr, ptr")

    return emit_blank(s)
}

// ---------------------------------------------------------------------------
// Struct type registration from MIR
// ---------------------------------------------------------------------------

fn register_mir_struct(st: EmitState, info: StructInfo) -> EmitState {
    let mut field_names: List<String> = []
    let mut field_types: List<String> = []
    let mut llvm_fields: String = ""
    let mut fi: Int = 0

    for _ in 0..200 {
        if fi >= len(info.fields) {
            let ty: String = "{ " + llvm_fields + " }"
            let entry: StructEntry = new_struct_entry(info.name, field_names, field_types, ty)
            st.structs.push(entry)

            // Emit named struct type definition
            let mut s: EmitState = emit_line(st, "%struct." + info.name + " = type " + ty)
            return s
        }
        let fp: FieldPair = info.fields[fi]
        let mut fty: String = resolve_mir_type(fp.val.ty)
        // Detect self-referential fields (e.g. TypeInfo has Option<TypeInfo>).
        // Replace with ptr to avoid infinite recursion in LLVM type layout.
        // Use boundary-aware match: check for exact type name followed by
        // non-alphanumeric (space, comma, }, etc.) to avoid false positives
        // like MatchArm matching MatchArmBody.
        let self_struct: String = "%struct." + info.name + " "
        let self_struct2: String = "%struct." + info.name + "}"
        let self_enum: String = "%enum." + info.name + " "
        let self_enum2: String = "%enum." + info.name + "}"
        if fty.contains(self_struct) || fty.contains(self_struct2) || fty.contains(self_enum) || fty.contains(self_enum2) {
            fty = llvm_ptr()
        }
        field_names.push(fp.name)
        field_types.push(fty)
        if fi > 0 {
            llvm_fields = llvm_fields + ", " + fty
        } else {
            llvm_fields = fty
        }
        fi = fi + 1
    }
    return st
}

// ---------------------------------------------------------------------------
// Enum type registration from MIR
// ---------------------------------------------------------------------------

fn is_enum_type(st: EmitState, name: String) -> Bool {
    let mut i: Int = 0
    for _ in 0..10000 {
        if i >= len(st.enum_names) { return false }
        if st.enum_names[i] == name { return true }
        i = i + 1
    }
    return false
}

fn is_struct_type(st: EmitState, name: String) -> Bool {
    let mut i: Int = 0
    for _ in 0..10000 {
        if i >= len(st.structs) { return false }
        if st.structs[i].name == name { return true }
        i = i + 1
    }
    return false
}

// Compute size of an LLVM type in i64 units (8-byte slots)
fn type_size_in_slots(st: EmitState, ty: MIRType) -> Int {
    let resolved: String = resolve_mir_type(ty)
    if resolved == "i64" { return 1 }
    if resolved == "double" { return 1 }
    if resolved == "i1" { return 1 }
    if resolved == "i8" { return 1 }
    if resolved == "ptr" { return 1 }
    if resolved == "void" { return 0 }
    // String: { ptr, i64 } = 2 slots
    if resolved == "{ ptr, i64 }" { return 2 }
    // List: { ptr, i64, i64, i64 } = 4 slots
    if resolved == "{ ptr, i64, i64, i64 }" { return 4 }
    // Range: { i64, i64 } = 2 slots
    if resolved == "{ i64, i64 }" { return 2 }
    // Option: { i1, T } ≈ 2 slots minimum
    if ty.kind == "option" {
        if len(ty.args) > 0 {
            return 1 + type_size_in_slots(st, ty.args[0])
        }
        return 2
    }
    // Result: { i1, { T, E } }
    if ty.kind == "result" { return 4 }
    // Map: { ptr, i64 } = 2 slots
    if ty.kind == "map" { return 2 }
    // Enum: 1 (tag) + max_payload_slots.
    // If registered, look up; otherwise return 48 (conservative for recursive enums).
    if ty.kind == "enum" {
        let mut ei: Int = 0
        let neinfos: Int = len(st.enum_infos)
        for _ in 0..200 {
            if ei < neinfos {
                let e_info: EnumInfo = st.enum_infos[ei]
                if e_info.name == ty.name {
                    return 1 + variant_payload_slots_max(st, e_info)
                }
                ei = ei + 1
            }
        }
        // Not registered yet (recursive reference or forward ref): use 48 slots.
        // This is conservative: Expr needs ~30, Stmt ~25, Definition ~32.
        return 48
    }
    // Struct: field_count * 4 (average 4 slots per field — covers Span=4, String=2, List=4)
    if ty.kind == "struct" {
        let struct_opt: Option<StructEntry> = find_struct_entry(st, ty.name)
        match struct_opt {
            Some(se) => { return len(se.field_types) * 4 },
            _ => { return 8 }
        }
    }
    // Default: 8 slots (conservative fallback)
    return 8
}

// Compute actual i64 slot count for a variant's payload.
// Extracted to a helper function because return-inside-for works,
// but cross-scope variable assignment after a for loop does not.
fn variant_payload_slots(st: EmitState, variant: EnumVariantInfo) -> Int {
    let mut total: Int = 0
    let mut pi: Int = 0
    for _ in 0..100 {
        if pi >= len(variant.payload_types) { return total }
        total = total + type_size_in_slots(st, variant.payload_types[pi])
        pi = pi + 1
    }
    return total
}

fn max_int(a: Int, b: Int) -> Int {
    if a > b { return a }
    return b
}

// Max payload slots across all variants of an enum.
fn variant_payload_slots_max(st: EmitState, info: EnumInfo) -> Int {
    let mut mx: Int = 0
    let mut vi: Int = 0
    for _ in 0..200 {
        if vi >= len(info.variants) { return mx }
        let count: Int = variant_payload_slots(st, info.variants[vi])
        // Use max_int instead of `if count > mx { mx = count }` because
        // the Python lowerer generates `store i64 0` for conditional
        // assignments inside for loops (cross-scope assignment bug).
        mx = max_int(mx, count)
        vi = vi + 1
    }
    return mx
}

fn register_mir_enum(st: EmitState, info: EnumInfo) -> EmitState {
    // Pointer-based enum: { i64 tag, ptr payload }.
    // Matches the Python text emitter. Payload is heap-allocated.
    // This handles recursive enums (Expr contains Expr) correctly.
    let mut s: EmitState = st
    s.enum_names.push(info.name)
    s.enum_infos.push(info)
    s = emit_line(s, "%enum." + info.name + " = type { i64, ptr }")
    return s
}

// ---------------------------------------------------------------------------
// Extern function declaration from MIR
// ---------------------------------------------------------------------------

fn declare_mir_extern(st: EmitState, info: ExternFnInfo) -> EmitState {
    let ret_ty: String = resolve_mir_type(info.return_type)
    let mut params_str: String = ""
    let mut i: Int = 0
    let nptypes: Int = len(info.param_types)
    for _ in 0..200 {
        if i < nptypes {
            let pty: String = resolve_mir_type(info.param_types[i])
            if i > 0 {
                params_str = params_str + ", " + pty
            } else {
                params_str = pty
            }
            i = i + 1
        }
    }
    return emit_line(st, "declare " + ret_ty + " @" + info.fn_name + "(" + params_str + ")")
}

// ---------------------------------------------------------------------------
// MIR instruction emission → LLVM IR
// ---------------------------------------------------------------------------

fn emit_mir_instruction(st: EmitState, inst: Instruction) -> EmitState {
    // String-tagged dispatch: uses instr_kind() from mir.mn (same module as
    // the Instruction enum) so that enum tags are always correct regardless
    // of which compiler produced this binary.  Dispatches via match-on-string
    // (not match-on-enum) for cross-compilation stability.
    let kind: String = instr_kind(inst)
    return emit_mir_by_kind(st, inst, kind)
}

fn emit_mir_by_kind(st: EmitState, inst: Instruction, kind: String) -> EmitState {
    if kind == "const" { return emit_const(st, instr_dest(inst), instr_const_type(inst), instr_const_val(inst)) }
    if kind == "copy" { return emit_copy(st, instr_dest(inst), instr_copy_src(inst)) }
    if kind == "cast" { return emit_cast(st, instr_dest(inst), instr_cast_src(inst), instr_cast_type(inst)) }
    if kind == "binop" { return emit_binop(st, instr_dest(inst), instr_binop_op(inst), instr_binop_lhs(inst), instr_binop_rhs(inst)) }
    if kind == "unaryop" { return emit_unaryop(st, instr_dest(inst), instr_unaryop_op(inst), instr_unaryop_operand(inst)) }
    if kind == "struct_init" { return emit_struct_init(st, instr_dest(inst), instr_struct_type(inst), instr_struct_fields(inst)) }
    if kind == "field_get" { return emit_field_get(st, instr_dest(inst), instr_fieldget_obj(inst), instr_fieldget_name(inst)) }
    if kind == "field_set" { return emit_field_set(st, instr_fieldset_obj(inst), instr_fieldset_name(inst), instr_fieldset_val(inst)) }
    if kind == "list_init" { return emit_list_init_checked(st, inst) }
    if kind == "index_get" { return emit_index_get(st, instr_dest(inst), instr_indexget_obj(inst), instr_indexget_idx(inst)) }
    if kind == "index_set" { return emit_index_set(st, instr_indexset_obj(inst), instr_indexset_idx(inst), instr_indexset_val(inst)) }
    if kind == "alloca" { return emit_alloca(st, instr_dest(inst), instr_alloca_type(inst)) }
    if kind == "load" { return emit_load(st, instr_dest(inst), instr_load_ptr(inst)) }
    if kind == "store" { return emit_store(st, instr_store_ptr(inst), instr_store_val(inst)) }
    if kind == "map_init" { return emit_map_init(st, instr_dest(inst), instr_map_key_type(inst), instr_map_val_type(inst), instr_map_pairs(inst)) }
    if kind == "enum_init" { return emit_enum_init(st, instr_dest(inst), instr_enum_type(inst), instr_enum_variant(inst), instr_enum_payload(inst)) }
    if kind == "enum_tag" { return emit_enum_tag(st, instr_dest(inst), instr_enumtag_val(inst)) }
    if kind == "enum_payload" { return emit_enum_payload(st, instr_dest(inst), instr_enumpayload_val(inst), instr_enumpayload_variant(inst)) }
    if kind == "wrap_some" { return emit_wrap_some(st, instr_dest(inst), instr_wrap_val(inst)) }
    if kind == "wrap_none" { return emit_wrap_none(st, instr_dest(inst), instr_wrapnone_type(inst)) }
    if kind == "wrap_ok" { return emit_wrap_ok(st, instr_dest(inst), instr_wrap_val(inst)) }
    if kind == "wrap_err" { return emit_wrap_err(st, instr_dest(inst), instr_wrap_val(inst)) }
    if kind == "unwrap" { return emit_unwrap(st, instr_dest(inst), instr_wrap_val(inst)) }
    if kind == "call" { return emit_mir_call(st, instr_dest(inst), instr_call_fn(inst), instr_call_args(inst)) }
    if kind == "return" { return emit_mir_return(st, instr_return_val(inst)) }
    if kind == "jump" { return emit_line(st, emit_br(instr_jump_target(inst))) }
    if kind == "branch" { return emit_mir_branch(st, inst) }
    if kind == "switch" { return emit_mir_switch(st, instr_switch_tag(inst), instr_switch_cases(inst), instr_switch_default(inst)) }
    if kind == "agent_spawn" { return emit_agent_spawn(st, instr_dest(inst), instr_agent_type(inst), instr_agent_args(inst)) }
    if kind == "agent_send" { return emit_agent_send(st, instr_agentsend_agent(inst), instr_agentsend_channel(inst), instr_agentsend_val(inst)) }
    if kind == "agent_sync" { return emit_agent_sync(st, instr_dest(inst), instr_agentsync_agent(inst), instr_agentsync_channel(inst)) }
    if kind == "signal_init" { return emit_signal_init(st, instr_dest(inst), instr_signal_type(inst), instr_signal_val(inst)) }
    if kind == "signal_get" { return emit_signal_get(st, instr_dest(inst), instr_signalget_sig(inst)) }
    if kind == "signal_set" { return emit_signal_set(st, instr_signalset_sig(inst), instr_signalset_val(inst)) }
    if kind == "stream_op" { return emit_stream_op(st, instr_dest(inst), instr_streamop_kind(inst), instr_streamop_source(inst), instr_streamop_args(inst)) }
    if kind == "interp_concat" { return emit_interp_concat(st, instr_dest(inst), instr_concat_parts(inst)) }
    if kind == "phi" { return emit_mir_phi(st, instr_dest(inst), instr_phi_entries(inst)) }
    return st
}

fn emit_mir_branch(st: EmitState, inst: Instruction) -> EmitState {
    let cond: Value = instr_branch_cond(inst)
    return emit_line(st, emit_cbranch(cond.name, instr_branch_true(inst), instr_branch_false(inst)))
}

fn emit_list_init_checked(st: EmitState, inst: Instruction) -> EmitState {
    let dest: Value = instr_dest(inst)
    let elem_ty: MIRType = instr_list_type(inst)
    let elements: List<Value> = instr_list_elements(inst)
    let struct_check: Option<StructEntry> = find_struct_entry(st, dest.ty.name)
    let struct_check2: Option<StructEntry> = find_struct_entry(st, elem_ty.name)
    match struct_check {
        Some(_) => { return emit_struct_init_from_values(st, dest, dest.ty, elements) },
        _ => {}
    }
    match struct_check2 {
        Some(_) => { return emit_struct_init_from_values(st, dest, elem_ty, elements) },
        _ => {}
    }
    return emit_list_init(st, dest, elem_ty, elements)
}

// ---------------------------------------------------------------------------
// Const instruction
// ---------------------------------------------------------------------------

fn emit_const(st: EmitState, dest: Value, ty: MIRType, val: String) -> EmitState {
    let mut s: EmitState = st
    let dn: String = dest.name
    let llvm_ty: String = resolve_mir_type(ty)

    // Void constants are no-ops
    if ty.kind == "void" {
        return s
    }

    // String constant: emit global at module level, build struct inline
    if ty.kind == "string" {
        // Escape special chars for LLVM IR string constants
        let escaped: String = val.replace("\\", "\\5C").replace("\"", "\\22").replace("\n", "\\0A").replace("\t", "\\09").replace("\r", "\\0D")
        let slen: Int = len(val)
        let gname: String = next_str_name(s)
        s.str_counter = s.str_counter + 1
        let arr_ty: String = "[" + toString(slen) + " x i8]"
        s = emit_global(s, gname + " = private constant " + arr_ty + " c\"" + escaped + "\", align 2")
        let ptr_name: String = dn + ".ptr"
        s = emit_line(s, "  " + ptr_name + " = getelementptr inbounds " + arr_ty + ", " + "ptr " + gname + ", i64 0, i64 0")
        let s1_name: String = dn + ".s1"
        s = emit_line(s, emit_insertvalue(s1_name, llvm_string(), "undef", ptr_name, "ptr", "0"))
        s = emit_line(s, emit_insertvalue(dn, llvm_string(), s1_name, toString(slen), "i64", "1"))
        return s
    }

    // Bool constant
    if ty.kind == "bool" {
        let mut bval: String = "0"
        if val == "true" { bval = "1" }
        s = emit_line(s, "  " + dn + " = add i1 0, " + bval)
        return s
    }

    // Int constant: emit `%dest = add i64 0, <val>` to define the SSA value
    if ty.kind == "int" {
        s = emit_line(s, "  " + dn + " = add i64 0, " + val)
        return s
    }

    // Float constant: emit `%dest = fadd double 0.0, <val>`
    // Ensure the value has a decimal point (toString(0.0) may produce "0")
    if ty.kind == "float" {
        let mut fval: String = val
        if !fval.contains(".") { fval = fval + ".0" }
        s = emit_line(s, "  " + dn + " = fadd double 0.0, " + fval)
        return s
    }

    // Struct constant (undef initializer for struct construction)
    if ty.kind == "struct" {
        s = emit_line(s, "  " + dn + " = insertvalue " + llvm_ty + " undef, " + llvm_ty + " undef, 0")
        return s
    }

    // Function constant: emit function pointer reference
    if ty.kind == "fn" {
        s = emit_line(s, "  " + dn + " = bitcast void ()* @" + val + " to ptr")
        return s
    }

    // Unknown type — no-op
    return s
}

// ---------------------------------------------------------------------------
// Copy instruction
// ---------------------------------------------------------------------------

fn emit_copy(st: EmitState, dest: Value, src: Value) -> EmitState {
    let mut s: EmitState = st
    let ty: String = resolve_type(st, dest.ty)
    let src_ty: String = resolve_type(st, src.ty)
    // Use source type when dest is unknown/scalar but source is aggregate.
    // This handles match pattern bindings where the payload type is known
    // from enum info but the pattern variable type is unknown.
    let mut use_ty: String = ty
    if ty == "ptr" {
        use_ty = src_ty
    }
    if ty == "i64" && (src_ty.starts_with("%struct.") || src_ty.starts_with("%enum.") || src_ty.starts_with("{")) {
        use_ty = src_ty
    }

    // Bool: use bitwise identity (and true)
    if ty == "i1" {
        return emit_line(s, "  " + dest.name + " = and i1 " + src.name + ", true")
    }
    // Aggregate types (structs, enums, options, results, lists) cannot use `add`.
    // Use alloca/store/load to copy the value through memory.
    if use_ty.starts_with("%struct.") || use_ty.starts_with("%enum.") || use_ty.starts_with("{") {
        let tmp_a: String = dest.name + ".cpy"
        s = emit_line(s, "  " + tmp_a + " = alloca " + use_ty)
        s = emit_line(s, "  store " + use_ty + " " + src.name + ", " + "ptr " + tmp_a)
        return emit_line(s, "  " + dest.name + " = load " + use_ty + ", " + "ptr " + tmp_a)
    }
    // Scalars (i64, double, ptr, etc.): use add 0 identity
    return emit_line(s, "  " + dest.name + " = add " + use_ty + " 0, " + src.name)
}

// ---------------------------------------------------------------------------
// Cast instruction
// ---------------------------------------------------------------------------

fn emit_cast(st: EmitState, dest: Value, src: Value, target_ty: MIRType) -> EmitState {
    let mut s: EmitState = st
    let sn: String = src.name
    let dn: String = dest.name

    let src_ty: String = resolve_mir_type(src.ty)
    let dst_ty: String = resolve_mir_type(target_ty)

    // Int → Float
    if src.ty.kind == "int" {
        if target_ty.kind == "float" {
            s = emit_line(s, "  " + dn + " =sitofp i64 " + sn + " to double")
            return s
        }
    }
    // Float → Int
    if src.ty.kind == "float" {
        if target_ty.kind == "int" {
            s = emit_line(s, "  " + dn + " =fptosi double " + sn + " to i64")
            return s
        }
    }
    // Fallback: bitcast
    s = emit_line(s, emit_bitcast(dn, src_ty, sn, dst_ty))
    return s
}

// ---------------------------------------------------------------------------
// BinOp instruction
// ---------------------------------------------------------------------------

fn emit_binop(st: EmitState, dest: Value, op: BinOpKind, lhs: Value, rhs: Value) -> EmitState {
    let mut s: EmitState = st
    let ln: String = lhs.name
    let rn: String = rhs.name

    let dn: String = dest.name
    let is_float: Bool = lhs.ty.kind == "float"
    let is_string: Bool = lhs.ty.kind == "string"
    let is_bool: Bool = lhs.ty.kind == "bool"
    let mut cmp_ty: String = llvm_int()
    if is_bool { cmp_ty = "i1" }

    // Use binop_kind_to_str (defined in lower.mn where BinOpKind is local)
    // to convert the enum tag to a string, then dispatch with if/else
    let op_str: String = binop_kind_to_str(op)

    if op_str == "add" {
        if is_string {
            s = emit_line(s, emit_call_ir(dn, llvm_string(), "__mn_str_concat", llvm_string() + " " + ln + ", " + llvm_string() + " " + rn))
        } else {
            if is_float { s = emit_line(s, emit_fadd(dn, ln, rn)) } else { s = emit_line(s, emit_add(dn, llvm_int(), ln, rn)) }
        }
    } else if op_str == "sub" {
        if is_float { s = emit_line(s, emit_fsub(dn, ln, rn)) } else { s = emit_line(s, emit_sub(dn, llvm_int(), ln, rn)) }
    } else if op_str == "mul" {
        if is_float { s = emit_line(s, emit_fmul(dn, ln, rn)) } else { s = emit_line(s, emit_mul(dn, llvm_int(), ln, rn)) }
    } else if op_str == "div" {
        if is_float { s = emit_line(s, emit_fdiv(dn, ln, rn)) } else { s = emit_line(s, emit_sdiv(dn, llvm_int(), ln, rn)) }
    } else if op_str == "mod" {
        if is_float { s = emit_line(s, emit_frem(dn, ln, rn)) } else { s = emit_line(s, emit_srem(dn, llvm_int(), ln, rn)) }
    } else if op_str == "eq" {
        if is_string {
            let eq_raw_eq: String = dn + ".sr"
            s = emit_line(s, emit_call_ir(eq_raw_eq, llvm_int(), "__mn_str_eq", llvm_string() + " " + ln + ", " + llvm_string() + " " + rn))
            s = emit_line(s, emit_icmp(dn, "ne", llvm_int(), eq_raw_eq, "0"))
        } else {
            if is_float { s = emit_line(s, emit_fcmp(dn, "eq", ln, rn)) } else { s = emit_line(s, emit_icmp(dn, "eq", cmp_ty, ln, rn)) }
        }
    } else if op_str == "ne" {
        if is_string {
            let eq_raw_ne: String = dn + ".sr"
            s = emit_line(s, emit_call_ir(eq_raw_ne, llvm_int(), "__mn_str_eq", llvm_string() + " " + ln + ", " + llvm_string() + " " + rn))
            s = emit_line(s, emit_icmp(dn, "eq", llvm_int(), eq_raw_ne, "0"))
        } else {
            if is_float { s = emit_line(s, emit_fcmp(dn, "ne", ln, rn)) } else { s = emit_line(s, emit_icmp(dn, "ne", cmp_ty, ln, rn)) }
        }
    } else if op_str == "lt" {
        if is_string {
            let cmp_r_lt: String = dn + ".sc"
            s = emit_line(s, emit_call_ir(cmp_r_lt, llvm_int(), "__mn_str_cmp", llvm_string() + " " + ln + ", " + llvm_string() + " " + rn))
            s = emit_line(s, emit_icmp(dn, "slt", llvm_int(), cmp_r_lt, "0"))
        } else {
            if is_float { s = emit_line(s, emit_fcmp(dn, "lt", ln, rn)) } else { s = emit_line(s, emit_icmp(dn, "slt", llvm_int(), ln, rn)) }
        }
    } else if op_str == "gt" {
        if is_string {
            let cmp_r_gt: String = dn + ".sc"
            s = emit_line(s, emit_call_ir(cmp_r_gt, llvm_int(), "__mn_str_cmp", llvm_string() + " " + ln + ", " + llvm_string() + " " + rn))
            s = emit_line(s, emit_icmp(dn, "sgt", llvm_int(), cmp_r_gt, "0"))
        } else {
            if is_float { s = emit_line(s, emit_fcmp(dn, "gt", ln, rn)) } else { s = emit_line(s, emit_icmp(dn, "sgt", llvm_int(), ln, rn)) }
        }
    } else if op_str == "le" {
        if is_string {
            let cmp_r_le: String = dn + ".sc"
            s = emit_line(s, emit_call_ir(cmp_r_le, llvm_int(), "__mn_str_cmp", llvm_string() + " " + ln + ", " + llvm_string() + " " + rn))
            s = emit_line(s, emit_icmp(dn, "sle", llvm_int(), cmp_r_le, "0"))
        } else {
            if is_float { s = emit_line(s, emit_fcmp(dn, "le", ln, rn)) } else { s = emit_line(s, emit_icmp(dn, "sle", llvm_int(), ln, rn)) }
        }
    } else if op_str == "ge" {
        if is_string {
            let cmp_r_ge: String = dn + ".sc"
            s = emit_line(s, emit_call_ir(cmp_r_ge, llvm_int(), "__mn_str_cmp", llvm_string() + " " + ln + ", " + llvm_string() + " " + rn))
            s = emit_line(s, emit_icmp(dn, "sge", llvm_int(), cmp_r_ge, "0"))
        } else {
            if is_float { s = emit_line(s, emit_fcmp(dn, "ge", ln, rn)) } else { s = emit_line(s, emit_icmp(dn, "sge", llvm_int(), ln, rn)) }
        }
    } else if op_str == "and" {
        s = emit_line(s, emit_and_instr(dn, ln, rn))
    } else if op_str == "or" {
        s = emit_line(s, emit_or_instr(dn, ln, rn))
    } else {
        // Fallback: add
        s = emit_line(s, emit_add(dn, llvm_int(), ln, rn))
    }

    return s
}

// ---------------------------------------------------------------------------
// UnaryOp instruction
// ---------------------------------------------------------------------------

fn emit_unaryop(st: EmitState, dest: Value, op: UnaryOpKind, operand: Value) -> EmitState {
    let mut s: EmitState = st
    let on: String = operand.name
    let dn: String = dest.name
    let op_str: String = unaryop_kind_to_str(op)

    if op_str == "neg" {
        if operand.ty.kind == "float" {
            s = emit_line(s, emit_fneg(dn, on))
        } else {
            s = emit_line(s, emit_neg(dn, llvm_int(), on))
        }
        return s
    }
    if op_str == "not" {
        s = emit_line(s, emit_not(dn, on))
        return s
    }
    return s
}

// ---------------------------------------------------------------------------
// StructInit instruction
// ---------------------------------------------------------------------------

fn emit_struct_init(st: EmitState, dest: Value, ty: MIRType, fields: List<FieldPair>) -> EmitState {
    let struct_ty: String = resolve_mir_type(ty)
    let mut s: EmitState = st
    let dn: String = dest.name
    let mut agg: String = "undef"
    let mut i: Int = 0

    // Lookup struct field types from the registry (more reliable than MIR types)
    let field_types: List<String> = lookup_struct_field_types(s, ty.name)

    let nfields: Int = len(fields)
    for _ in 0..200 {
        if i < nfields {
            let fp: FieldPair = fields[i]
            let mut fty: String = resolve_mir_type(fp.val.ty)
            let val_name: String = fp.val.name
            // If MIR type is unknown, use the registered struct field type
            if fty == "i64" && fp.val.ty.kind == "unknown" && i < len(field_types) {
                fty = field_types[i]
            }
            let tmp_name: String = dn + ".f" + toString(i)
            s = emit_line(s, emit_insertvalue(tmp_name, struct_ty, agg, val_name, fty, toString(i)))
            agg = tmp_name
            i = i + 1
        }
    }
    // Copy the final insertvalue result to dest via alloca/store/load
    // (aggregate types cannot use `add 0` identity)
    if nfields > 0 {
        let cpy_a: String = dn + ".si"
        s = emit_line(s, "  " + cpy_a + " = alloca " + struct_ty)
        s = emit_line(s, "  store " + struct_ty + " " + agg + ", " + "ptr " + cpy_a)
        s = emit_line(s, "  " + dn + " = load " + struct_ty + ", " + "ptr " + cpy_a)
    }
    return s
}

// ---------------------------------------------------------------------------
// FieldGet instruction
// ---------------------------------------------------------------------------

fn emit_field_get(st: EmitState, dest: Value, obj: Value, field_name: String) -> EmitState {
    let mut s: EmitState = st
    let on: String = obj.name
    let dn: String = dest.name
    let obj_ty: String = resolve_type(st, obj.ty)

    // String .len → extractvalue index 1
    if obj.ty.kind == "string" {
        if field_name == "len" {
            s = emit_line(s, emit_extractvalue(dn, llvm_string(), on, "1"))
            return s
        }
        // String methods (contains, starts_with, etc.) — not struct fields.
        // The actual call is handled by the Call instruction that follows.
        // Just pass the object through as the "method reference".
        return emit_copy(s, dest, obj)
    }

    // List .len
    if obj.ty.kind == "list" {
        if field_name == "len" {
            let lt: String = llvm_list_rt()
            let tmp: String = dn + ".lp"
            s = emit_line(s, "  " + tmp + " = alloca " + lt)
            s = emit_line(s, "  store " + lt + " " + on + ", " + "ptr " + tmp)
            s = emit_line(s, emit_call_ir(dn, llvm_int(), "__mn_list_len", "ptr " + tmp))
            return s
        }
        // List methods (push, etc.) — pass object through
        return emit_copy(s, dest, obj)
    }

    // Look up field index: try hardcoded first (internal types), then registry
    let hc_idx: Int = hardcoded_field_index(obj.ty.name, field_name)
    if hc_idx > 0 {
        // Hardcoded match — use it (overrides potentially broken registry)
        s = emit_line(s, emit_extractvalue(dn, obj_ty, on, toString(hc_idx)))
        return s
    }
    // Fall back to registered structs
    let struct_opt: Option<StructEntry> = find_struct_entry(s, obj.ty.name)
    match struct_opt {
        Some(se) => {
            let idx: Int = find_field_index(se.field_names, field_name)
            s = emit_line(s, emit_extractvalue(dn, obj_ty, on, toString(idx)))
            return s
        },
        _ => {
            // Last resort: hardcoded (returns 0 for unknown)
            s = emit_line(s, emit_extractvalue(dn, obj_ty, on, toString(hc_idx)))
            return s
        }
    }
}

// Hardcoded field indices for the 18 internal compiler struct types.
// These are not in the MIR module's struct list due to a state accumulation
// bug, so find_struct_entry returns None. This function provides the correct
// indices as a workaround.
fn hardcoded_field_index(struct_name: String, field_name: String) -> Int {
    // LowerState: module(0) current_fn(1) current_block_idx(2) tmp_counter(3) block_counter(4) vars(5) scope_stack(6) impl_methods(7) struct_fields(8) enum_variants(9) lambda_vars(10) fn_blocks(11)
    if struct_name == "LowerState" {
        if field_name == "module" { return 0 }
        if field_name == "current_fn" { return 1 }
        if field_name == "current_block_idx" { return 2 }
        if field_name == "tmp_counter" { return 3 }
        if field_name == "block_counter" { return 4 }
        if field_name == "vars" { return 5 }
        if field_name == "scope_stack" { return 6 }
        if field_name == "impl_methods" { return 7 }
        if field_name == "struct_fields" { return 8 }
        if field_name == "enum_variants" { return 9 }
        if field_name == "lambda_vars" { return 10 }
        if field_name == "fn_blocks" { return 11 }
    }
    // EmitState: lines(0) counter(1) functions(2) structs(3) module_name(4) str_counter(5) str_globals(6) current_ret_type(7) enum_names(8) enum_infos(9)
    if struct_name == "EmitState" {
        if field_name == "lines" { return 0 }
        if field_name == "counter" { return 1 }
        if field_name == "functions" { return 2 }
        if field_name == "structs" { return 3 }
        if field_name == "module_name" { return 4 }
        if field_name == "str_counter" { return 5 }
        if field_name == "str_globals" { return 6 }
        if field_name == "current_ret_type" { return 7 }
        if field_name == "enum_names" { return 8 }
        if field_name == "enum_infos" { return 9 }
    }
    // MIRModule: name(0) functions(1) structs(2) enums(3) extern_fns(4) agents(5) pipes(6) imports(7) trait_names(8)
    if struct_name == "MIRModule" {
        if field_name == "name" { return 0 }
        if field_name == "functions" { return 1 }
        if field_name == "structs" { return 2 }
        if field_name == "enums" { return 3 }
        if field_name == "extern_fns" { return 4 }
        if field_name == "agents" { return 5 }
        if field_name == "pipes" { return 6 }
        if field_name == "imports" { return 7 }
        if field_name == "trait_names" { return 8 }
    }
    // LowerResult: value(0) state(1)
    if struct_name == "LowerResult" {
        if field_name == "value" { return 0 }
        if field_name == "state" { return 1 }
    }
    // VarInfo: name(0) current(1) mutable(2)
    if struct_name == "VarInfo" {
        if field_name == "name" { return 0 }
        if field_name == "current" { return 1 }
        if field_name == "mutable" { return 2 }
    }
    // CompileResult: success(0) ir_text(1) errors(2)
    if struct_name == "CompileResult" {
        if field_name == "success" { return 0 }
        if field_name == "ir_text" { return 1 }
        if field_name == "errors" { return 2 }
    }
    // MatchBuildResult: state(0) arm_labels(1) arm_indices(2) cases(3) default_label(4)
    if struct_name == "MatchBuildResult" {
        if field_name == "state" { return 0 }
        if field_name == "arm_labels" { return 1 }
        if field_name == "arm_indices" { return 2 }
        if field_name == "cases" { return 3 }
        if field_name == "default_label" { return 4 }
    }
    // FnEntry: name(0) ret_type(1) param_types(2)
    if struct_name == "FnEntry" {
        if field_name == "name" { return 0 }
        if field_name == "ret_type" { return 1 }
        if field_name == "param_types" { return 2 }
    }
    // StructEntry: name(0) field_names(1) field_types(2) llvm_type(3)
    if struct_name == "StructEntry" {
        if field_name == "name" { return 0 }
        if field_name == "field_names" { return 1 }
        if field_name == "field_types" { return 2 }
        if field_name == "llvm_type" { return 3 }
    }
    // StructFieldInfo: name(0) field_names(1) field_types(2)
    if struct_name == "StructFieldInfo" {
        if field_name == "name" { return 0 }
        if field_name == "field_names" { return 1 }
        if field_name == "field_types" { return 2 }
    }
    // EnumVariantNames: enum_name(0) variant_names(1)
    if struct_name == "EnumVariantNames" {
        if field_name == "enum_name" { return 0 }
        if field_name == "variant_names" { return 1 }
    }
    // LambdaEntry: var_name(0) fn_name(1)
    if struct_name == "LambdaEntry" {
        if field_name == "var_name" { return 0 }
        if field_name == "fn_name" { return 1 }
    }
    // ExternFnInfo: abi(0) module_name(1) fn_name(2) param_types(3) return_type(4)
    if struct_name == "ExternFnInfo" {
        if field_name == "abi" { return 0 }
        if field_name == "module_name" { return 1 }
        if field_name == "fn_name" { return 2 }
        if field_name == "param_types" { return 3 }
        if field_name == "return_type" { return 4 }
    }
    // VerifyError: fn_name(0) block_label(1) message(2)
    if struct_name == "VerifyError" {
        if field_name == "fn_name" { return 0 }
        if field_name == "block_label" { return 1 }
        if field_name == "message" { return 2 }
    }
    // ImplEntry: key(0) mir_name(1)
    if struct_name == "ImplEntry" {
        if field_name == "key" { return 0 }
        if field_name == "mir_name" { return 1 }
    }
    // ImportInfo: path(0) items(1)
    if struct_name == "ImportInfo" {
        if field_name == "path" { return 0 }
        if field_name == "items" { return 1 }
    }
    // AgentInfo: name(0) inputs(1) outputs(2) method_names(3)
    if struct_name == "AgentInfo" {
        if field_name == "name" { return 0 }
        if field_name == "inputs" { return 1 }
        if field_name == "outputs" { return 2 }
        if field_name == "method_names" { return 3 }
    }
    // PipeInfo: name(0) stages(1)
    if struct_name == "PipeInfo" {
        if field_name == "name" { return 0 }
        if field_name == "stages" { return 1 }
    }
    // MIRFunction: name(0) params(1) return_type(2) blocks(3) decorators(4) is_public(5)
    if struct_name == "MIRFunction" {
        if field_name == "name" { return 0 }
        if field_name == "params" { return 1 }
        if field_name == "return_type" { return 2 }
        if field_name == "blocks" { return 3 }
        if field_name == "decorators" { return 4 }
        if field_name == "is_public" { return 5 }
    }
    // BasicBlock: label(0) instructions(1)
    if struct_name == "BasicBlock" {
        if field_name == "label" { return 0 }
        if field_name == "instructions" { return 1 }
    }
    // MIRType: name(0) kind(1) args(2)
    if struct_name == "MIRType" {
        if field_name == "name" { return 0 }
        if field_name == "kind" { return 1 }
        if field_name == "args" { return 2 }
    }
    // Value: name(0) ty(1)
    if struct_name == "Value" {
        if field_name == "name" { return 0 }
        if field_name == "ty" { return 1 }
    }
    return 0
}

fn find_field_index(fields: List<String>, name: String) -> Int {
    let mut i: Int = 0
    for _ in 0..200 {
        if i >= len(fields) { return 0 }
        if fields[i] == name { return i }
        i = i + 1
    }
    return 0
}

// ---------------------------------------------------------------------------
// FieldSet instruction
// ---------------------------------------------------------------------------

fn emit_field_set(st: EmitState, obj: Value, field_name: String, val: Value) -> EmitState {
    let mut s: EmitState = st

    let val_ty: String = resolve_mir_type(val.ty)

    // Try hardcoded index first (for internal types with broken registry)
    let hc_idx: Int = hardcoded_field_index(obj.ty.name, field_name)
    let struct_opt: Option<StructEntry> = find_struct_entry(s, obj.ty.name)
    let mut idx: Int = hc_idx
    match struct_opt {
        Some(se) => {
            if hc_idx == 0 {
                // Only use registry if hardcoded didn't find it (hc=0 might be field 0 OR unknown)
                idx = find_field_index(se.field_names, field_name)
            }
        },
        _ => {}
    }
    let struct_ty: String = resolve_type(s, obj.ty)
    if obj.name.contains(".addr") {
        let gep: String = "%" + strip_percent(obj.name) + "_fp" + toString(s.counter)
        s.counter = s.counter + 1
        s = emit_line(s, "  " + gep + " = getelementptr inbounds " + struct_ty + ", ptr " + obj.name + ", i32 0, i32 " + toString(idx))
        s = emit_line(s, "  store " + val_ty + " " + val.name + ", ptr " + gep)
    } else {
        let tmp_name: String = "%" + strip_percent(obj.name) + "_set" + toString(s.counter)
        s.counter = s.counter + 1
        s = emit_line(s, emit_insertvalue(tmp_name, struct_ty, obj.name, val.name, val_ty, toString(idx)))
    }
    return s
}

// ---------------------------------------------------------------------------
// ListInit instruction
// ---------------------------------------------------------------------------

fn strip_percent(name: String) -> String {
    // Strip leading % from name (avoid if-expression — PHI zeroinit bug)
    let starts: Bool = name.starts_with("%")
    let mut result: String = name
    if starts { result = name.substr(1, len(name) - 1) }
    return result
}

fn has_struct(st: EmitState, name: String) -> Bool {
    let opt: Option<StructEntry> = find_struct_entry(st, name)
    match opt {
        Some(_) => { return true },
        _ => { return false }
    }
}

fn try_emit_struct_construct(st: EmitState, dest: Value, fn_name: String, args: List<Value>) -> EmitState {
    // Check if fn_name is "__new_<StructName>" and emit struct construction.
    // Uses ternary expressions to avoid early returns inside if/match.
    let is_new: Bool = len(fn_name) > 6
    let mut prefix: String = ""
    if is_new { prefix = fn_name.substr(0, 6) }
    let mut struct_name: String = ""
    if prefix == "__new_" { struct_name = fn_name.substr(6, len(fn_name) - 6) }
    let mut found: Bool = false
    if struct_name != "" { found = has_struct(st, struct_name) }
    let mut result: EmitState = st
    if found { result = emit_struct_init_from_values(st, dest, dest.ty, args) }
    return result
}

fn emit_struct_init_from_values(st: EmitState, dest: Value, ty: MIRType, values: List<Value>) -> EmitState {
    // Build struct from a list of values (field order matches struct definition)
    let struct_ty: String = resolve_mir_type(ty)
    let mut s: EmitState = st
    let dn: String = dest.name
    let mut agg: String = "undef"
    let nfields: Int = len(values)

    // Lookup registered field types for this struct
    let field_types: List<String> = lookup_struct_field_types(s, ty.name)

    let mut i: Int = 0
    for _ in 0..200 {
        if i < nfields {
            let v: Value = values[i]
            let mut fty: String = resolve_type(st, v.ty)
            let vname: String = v.name
            // Always prefer registered field types for struct construction.
            // MIR value types are often wrong (unknown/empty name) due to
            // COW corruption in nested lists. The emitter's struct registry
            // (from type definitions) is authoritative.
            if i < len(field_types) {
                let rft: String = field_types[i]
                if len(rft) > 2 && rft != "i64" {
                    fty = rft
                }
            }
            let tmp_name: String = dn + ".f" + toString(i)
            s = emit_line(s, emit_insertvalue(tmp_name, struct_ty, agg, vname, fty, toString(i)))
            agg = tmp_name
            i = i + 1
        }
    }
    // Copy the final insertvalue result to dest
    if nfields > 0 {
        let cpy_a: String = dn + ".si"
        s = emit_line(s, "  " + cpy_a + " = alloca " + struct_ty)
        s = emit_line(s, "  store " + struct_ty + " " + agg + ", " + "ptr " + cpy_a)
        s = emit_line(s, "  " + dn + " = load " + struct_ty + ", " + "ptr " + cpy_a)
    }
    return s
}

fn find_list_field_index(st: EmitState, struct_name: String, dest: Value) -> String {
    // The struct_name may be "StructName:field_name" (encoded by lowerer)
    let colon_pos: Int = struct_name.find(":")
    if colon_pos > 0 {
        // Use char-by-char builders to avoid C runtime substr bug
        let base: String = strip_colon_suffix(struct_name)
        let field: String = extract_after_colon(struct_name, colon_pos)
        let opt: Option<StructEntry> = find_struct_entry(st, base)
        match opt {
            Some(se) => {
                let idx: Int = find_field_index(se.field_names, field)
                return toString(idx)
            },
            _ => { return "0" }
        }
    }
    return "0"
}

fn find_alloca_by_search(lines: List<String>, value_name: String) -> String {
    // Search FORWARD for "value_name =load TYPE, ptr %alloca"
    // Use the LAST match (most recent load of this value)
    let search_pat: String = value_name + " =load"
    let n: Int = len(lines)
    let mut result: String = ""
    let mut i: Int = 0
    for _ in 0..600 {
        if i >= n { return result }
        let line: String = lines[i]
        if line.contains(search_pat) {
            let pp: Int = line.find(", ptr ")
            if pp > 0 {
                result = line.substr(pp + 6, len(line) - pp - 6)
            }
        }
        i = i + 1
    }
    return result
}

fn is_name_in_byref(byref_names: List<String>, name: String) -> Bool {
    // Check if alloca name matches a byref param EXACTLY.
    // Alloca names: "%{param_name}.addr" (params have no counter suffix).
    // Local vars: "%{name}{counter}.addr" — these should NOT match.
    let mut i: Int = 0
    for _ in 0..100 {
        if i >= len(byref_names) { return false }
        let bn: String = byref_names[i]
        // Exact match: the alloca is %{param_name}.addr
        let expected: String = "%" + bn + ".addr"
        if name == expected { return true }
        i = i + 1
    }
    return false
}

fn is_byref_type(ty: String) -> Bool {
    // Large types (> 64 bytes) should use byref/sret passing.
    // This prevents ABI issues with large struct copies.
    if ty.starts_with("%struct.") {
        // All structs > 64 bytes use byref. Use llvm_type_size heuristic.
        let sz_st: Int = llvm_type_size(ty)
        if sz_st > 64 { return true }
        return false
    }
    if ty.starts_with("{") {
        let sz_lit: Int = llvm_type_size(ty)
        if sz_lit > 64 { return true }
    }
    return false
}

fn find_alloca_for_value(st: EmitState, value_name: String) -> String {
    // Scan backward through emitted lines to find:
    //   %value_name =load TYPE, ptr %ALLOCA
    // Return %ALLOCA name so FieldSet can store back.
    let search: String = value_name + " ="
    let n: Int = len(st.lines)
    let mut i: Int = n - 1
    for _ in 0..10000 {
        if i < 0 { return "" }
        let line: String = st.lines[i]
        if line.contains(search) {
            if line.contains("load") {
                let ptr_pos: Int = line.find(", ptr ")
                if ptr_pos > 0 {
                    let after: String = line.substr(ptr_pos + 6, len(line) - ptr_pos - 6)
                    return after
                }
            }
            return ""
        }
        i = i - 1
    }
    return ""
}

fn llvm_type_size(ty: String) -> Int {
    if ty == "i1" { return 1 }
    if ty == "i8" { return 1 }
    if ty == "i32" { return 4 }
    if ty == "i64" { return 8 }
    if ty == "double" { return 8 }
    if ty == "ptr" { return 8 }
    if ty == "void" { return 0 }
    // String = {ptr, i64} = 16
    if ty == llvm_string() { return 16 }
    // List = {ptr, i64, i64, i64} = 32
    if ty == llvm_list_rt() { return 32 }
    // Enums: now always {i64, ptr} = 16 bytes
    if ty.starts_with("%enum.") { return 16 }
    // Structs: use field_count * 32 as safe upper bound.
    // This is used for malloc allocation, so must be >= actual size.
    if ty.starts_with("%struct.") { return 256 }
    // Aggregate types: count fields
    if ty.starts_with("{") { return llvm_aggregate_size(ty) }
    return 8
}

fn llvm_aggregate_size(ty: String) -> Int {
    // Count comma-separated fields, each assumed 8 bytes
    let inner: String = ty.substr(1, len(ty) - 2)
    let parts: List<String> = inner.split(",")
    return len(parts) * 8
}

fn emit_list_push_call(st: EmitState, dest: Value, args: List<Value>) -> EmitState {
    let mut s: EmitState = st
    if len(args) >= 2 {
        let list_ref: String = args[0].name
        let list_ty_kind: String = args[0].ty.kind
        let elem_name: String = args[1].name
        let mut elem_ty: String = resolve_type(st, args[1].ty)
        if elem_ty == "i64" { elem_ty = resolve_mir_type(args[1].ty) }
        // If type is still i64 but the MIR type has a struct/enum name,
        // use the named type. This handles struct-in-list push where the
        // lowerer's type info doesn't propagate through method dispatch.
        if elem_ty == "i64" {
            if len(args[1].ty.name) > 0 {
                if is_struct_type(st, args[1].ty.name) {
                    elem_ty = "%struct." + args[1].ty.name
                }
                if is_enum_type(st, args[1].ty.name) {
                    elem_ty = "%enum." + args[1].ty.name
                }
            }
        }
        let cnt: String = toString(s.counter)
        s.counter = s.counter + 1

        // Alloca element
        let ea: String = "%push_ea" + cnt
        s = emit_line(s, "  " + ea + " = alloca " + elem_ty)
        s = emit_line(s, "  store " + elem_ty + " " + elem_name + ", ptr " + ea)

        if list_ref.contains(".addr") && list_ty_kind == "struct" {
            // Struct field push: GEP to field, load list to temp, push to temp,
            // WRITE BACK to struct field (matches Python text emitter pattern).
            let type_name: String = args[0].ty.name
            let cp: Int = type_name.find(":")
            let mut base_name: String = type_name
            if cp > 0 { base_name = type_name.substr(0, cp) }
            let struct_ty: String = "%struct." + base_name
            let field_idx: String = find_list_field_index(st, type_name, dest)
            let gep: String = "%push_gep" + cnt
            s = emit_line(s, "  " + gep + " = getelementptr inbounds " + struct_ty + ", ptr " + list_ref + ", i32 0, i32 " + field_idx)
            // Load list to temp alloca
            let tmp_sf: String = "%push_tmp" + cnt
            s = emit_line(s, "  " + tmp_sf + " = alloca " + llvm_list_rt())
            let ld_sf: String = "%push_ld" + cnt
            s = emit_line(s, "  " + ld_sf + " = load " + llvm_list_rt() + ", ptr " + gep)
            s = emit_line(s, "  store " + llvm_list_rt() + " " + ld_sf + ", ptr " + tmp_sf)
            // Push to temp
            s = emit_line(s, emit_call_void("__mn_list_push", "ptr " + tmp_sf + ", ptr " + ea))
            // Write back to struct field
            let wb_sf: String = "%push_wb" + cnt
            s = emit_line(s, "  " + wb_sf + " = load " + llvm_list_rt() + ", ptr " + tmp_sf)
            s = emit_line(s, "  store " + llvm_list_rt() + " " + wb_sf + ", ptr " + gep)
        } else if list_ref.contains(".addr") {
            // Simple alloca push: same temp+writeback pattern
            let tmp_sa: String = "%push_tmp" + cnt
            s = emit_line(s, "  " + tmp_sa + " = alloca " + llvm_list_rt())
            let ld_sa: String = "%push_ld" + cnt
            s = emit_line(s, "  " + ld_sa + " = load " + llvm_list_rt() + ", ptr " + list_ref)
            s = emit_line(s, "  store " + llvm_list_rt() + " " + ld_sa + ", ptr " + tmp_sa)
            s = emit_line(s, emit_call_void("__mn_list_push", "ptr " + tmp_sa + ", ptr " + ea))
            let wb_sa: String = "%push_wb" + cnt
            s = emit_line(s, "  " + wb_sa + " = load " + llvm_list_rt() + ", ptr " + tmp_sa)
            s = emit_line(s, "  store " + llvm_list_rt() + " " + wb_sa + ", ptr " + list_ref)
        } else {
            // Loaded list value — create temp alloca
            let la: String = "%push_la" + cnt
            s = emit_line(s, "  " + la + " = alloca " + llvm_list_rt())
            s = emit_line(s, "  store " + llvm_list_rt() + " " + list_ref + ", ptr " + la)
            s = emit_line(s, emit_call_void("__mn_list_push", "ptr " + la + ", ptr " + ea))
        }
    }
    return s
}

fn emit_list_init(st: EmitState, dest: Value, elem_ty: MIRType, elements: List<Value>) -> EmitState {
    let mut s: EmitState = st
    let dn: String = dest.name

    // Create empty list. Use 64 bytes as default element size — this covers
    // all types (i64=8, String=16, List=32, structs≤64). The C runtime
    // uses elem_size for memcpy in push; oversizing wastes memory but
    // prevents truncation crashes.
    let list_name: String = dn + ".new"
    let elem_llvm_ty: String = resolve_mir_type(elem_ty)
    let mut elem_sz: Int = llvm_type_size(elem_llvm_ty)
    // Minimum 384: covers all enums (max: Definition≈264) and structs (max: ~256).
    // Empty lists default to unknown (i64, size 8) — the floor ensures they
    // still work correctly when populated with large elements later.
    if elem_sz < 384 { elem_sz = 384 }
    s = emit_line(s, emit_call_ir(list_name, llvm_list_rt(), "__mn_list_new", "i64 " + toString(elem_sz)))

    // Alloca for push
    let alloca_name: String = dn + ".addr"
    s = emit_line(s, llvm_alloca(alloca_name, llvm_list_rt()))
    s = emit_line(s, llvm_store(llvm_list_rt(), list_name, alloca_name))

    // Push each element
    let mut i: Int = 0
    for _ in 0..600 {
        if i >= len(elements) {
            // Load final list
            let final_list: String = dest.name
            s = emit_line(s, llvm_load(final_list, llvm_list_rt(), alloca_name))
            return s
        }
        let elem: Value = elements[i]
        let ety: String = resolve_mir_type(elem.ty)
        let elem_alloca: String = dn + ".e" + toString(i)
        s = emit_line(s, llvm_alloca(elem_alloca, ety))
        s = emit_line(s, llvm_store(ety, elem.name, elem_alloca))
        let cast_name: String = dn + ".c" + toString(i)
        s = emit_line(s, emit_bitcast(cast_name, ety + "*", elem_alloca, "ptr"))
        s = emit_line(s, emit_call_void("__mn_list_push", "ptr " + alloca_name + ", ptr " + cast_name))
        i = i + 1
    }
    return s
}

// ---------------------------------------------------------------------------
// IndexGet instruction
// ---------------------------------------------------------------------------

fn emit_index_get(st: EmitState, dest: Value, obj: Value, idx: Value) -> EmitState {
    let mut s: EmitState = st
    let dn: String = dest.name

    // String indexing → char_at
    if obj.ty.kind == "string" {
        s = emit_line(s, emit_call_ir(dn, llvm_string(), "__mn_str_char_at", llvm_string() + " " + obj.name + ", i64 " + idx.name))
        return s
    }

    // List indexing → list_get (needs pointer; alloca+store the list value)
    let lt: String = llvm_list_rt()
    let tmp: String = dn + ".lp"
    s = emit_line(s, "  " + tmp + " = alloca " + lt)
    s = emit_line(s, "  store " + lt + " " + obj.name + ", " + "ptr " + tmp)

    // If dest type is known, load from the ptr returned by list_get
    let dest_ty: String = resolve_type(st, dest.ty)
    if dest_ty != llvm_int() && dest_ty != "ptr" && dest_ty != "void" {
        let raw: String = dn + ".raw"
        s = emit_line(s, emit_call_ir(raw, "ptr", "__mn_list_get", "ptr " + tmp + ", i64 " + idx.name))
        // Opaque pointers: load directly from ptr, no bitcast needed
        s = emit_line(s, "  " + dn + " = load " + dest_ty + ", ptr " + raw)
    } else {
        // list_get returns ptr to element. Load the element value.
        let raw2: String = dn + ".raw"
        s = emit_line(s, emit_call_ir(raw2, "ptr", "__mn_list_get", "ptr " + tmp + ", i64 " + idx.name))
        s = emit_line(s, "  " + dn + " = load i64, ptr " + raw2)
    }
    return s
}

// ---------------------------------------------------------------------------
// IndexSet instruction
// ---------------------------------------------------------------------------

fn emit_index_set(st: EmitState, obj: Value, idx: Value, val: Value) -> EmitState {
    let mut s: EmitState = st
    let list_ref: String = obj.name
    let idx_name: String = idx.name
    let elem_name: String = val.name
    let elem_ty: String = resolve_type(st, val.ty)
    let cnt: String = toString(s.counter)
    s.counter = s.counter + 1

    // Map index set: entries[key] = value → __mn_map_set
    if obj.ty.kind == "map" {
        let idx_ty: String = resolve_type(st, idx.ty)
        // Alloca key
        let ka: String = "%set_ka" + cnt
        s = emit_line(s, "  " + ka + " = alloca " + idx_ty)
        s = emit_line(s, "  store " + idx_ty + " " + idx_name + ", ptr " + ka)
        // Alloca value
        let va: String = "%set_va" + cnt
        s = emit_line(s, "  " + va + " = alloca " + elem_ty)
        s = emit_line(s, "  store " + elem_ty + " " + elem_name + ", ptr " + va)
        // Load map pointer from alloca or value
        if list_ref.contains(".addr") {
            let map_ld: String = "%set_mld" + cnt
            s = emit_line(s, "  " + map_ld + " = load " + llvm_map_type() + ", ptr " + list_ref)
            let map_ptr: String = "%set_mptr" + cnt
            s = emit_line(s, "  " + map_ptr + " = extractvalue " + llvm_map_type() + " " + map_ld + ", 0")
            s = emit_line(s, emit_call_void("__mn_map_set", "ptr " + map_ptr + ", ptr " + ka + ", ptr " + va))
        } else {
            let map_ptr: String = "%set_mptr" + cnt
            s = emit_line(s, "  " + map_ptr + " = extractvalue " + llvm_map_type() + " " + list_ref + ", 0")
            s = emit_line(s, emit_call_void("__mn_map_set", "ptr " + map_ptr + ", ptr " + ka + ", ptr " + va))
        }
        return s
    }

    // List index set (original path)
    // Alloca element, store value
    let ea: String = "%set_ea" + cnt
    s = emit_line(s, "  " + ea + " = alloca " + elem_ty)
    s = emit_line(s, "  store " + elem_ty + " " + elem_name + ", ptr " + ea)

    if list_ref.contains(".addr") {
        // obj is an alloca pointer — load, call, write back
        let tmp_addr: String = "%set_tmp" + cnt
        s = emit_line(s, "  " + tmp_addr + " = alloca " + llvm_list_rt())
        let ld: String = "%set_ld" + cnt
        s = emit_line(s, "  " + ld + " = load " + llvm_list_rt() + ", ptr " + list_ref)
        s = emit_line(s, "  store " + llvm_list_rt() + " " + ld + ", ptr " + tmp_addr)
        s = emit_line(s, emit_call_void("__mn_list_set", "ptr " + tmp_addr + ", i64 " + idx_name + ", ptr " + ea))
        let wb: String = "%set_wb" + cnt
        s = emit_line(s, "  " + wb + " = load " + llvm_list_rt() + ", ptr " + tmp_addr)
        s = emit_line(s, "  store " + llvm_list_rt() + " " + wb + ", ptr " + list_ref)
    } else {
        // obj is a loaded value — store to temp alloca first
        let tmp_val: String = "%set_tmp" + cnt
        s = emit_line(s, "  " + tmp_val + " = alloca " + llvm_list_rt())
        s = emit_line(s, "  store " + llvm_list_rt() + " " + list_ref + ", ptr " + tmp_val)
        s = emit_line(s, emit_call_void("__mn_list_set", "ptr " + tmp_val + ", i64 " + idx_name + ", ptr " + ea))
    }
    return s
}

// ---------------------------------------------------------------------------
// Alloca/Load/Store instructions
// ---------------------------------------------------------------------------

fn emit_alloca(st: EmitState, dest: Value, ty: MIRType) -> EmitState {
    return emit_line(st, llvm_alloca(dest.name, resolve_type(st, ty)))
}

fn emit_load(st: EmitState, dest: Value, ptr: Value) -> EmitState {
    return emit_line(st, llvm_load(dest.name, resolve_type(st, dest.ty), ptr.name))
}

fn emit_store(st: EmitState, ptr: Value, val: Value) -> EmitState {
    let val_ty: String = resolve_type(st, val.ty)
    let ptr_ty: String = resolve_type(st, ptr.ty)
    // When storing a generic None ({i1, ptr}) to a specific Option alloca
    // ({i1, %enum.T}), use zeroinitializer with the alloca's type instead.
    // None has tag=0 and null payload — zeroinitializer is equivalent.
    if val.ty.kind == "option" && ptr_ty != val_ty && ptr_ty.starts_with("{") {
        return emit_line(st, "  store " + ptr_ty + " zeroinitializer, " + "ptr " + ptr.name)
    }
    return emit_line(st, llvm_store(val_ty, val.name, ptr.name))
}

// ---------------------------------------------------------------------------
// MapInit instruction
// ---------------------------------------------------------------------------

fn emit_map_init(st: EmitState, dest: Value, key_ty: MIRType, val_ty: MIRType, pairs: List<KVPair>) -> EmitState {
    let mut s: EmitState = st
    let dn: String = dest.name
    let cnt: String = toString(s.counter)
    s.counter = s.counter + 1

    // Determine key type tag: 0=int, 1=str, 2=float
    let mut key_tag: String = "1"
    if key_ty.kind == "int" { key_tag = "0" }
    if key_ty.kind == "float" { key_tag = "2" }

    // Key/val sizes: strings are 16 bytes ({ptr,i64}), ints are 8 bytes
    let mut key_size: String = "16"
    let mut val_size: String = "8"
    if key_ty.kind == "int" { key_size = "8" }
    if key_ty.kind == "float" { key_size = "8" }
    if val_ty.kind == "string" { val_size = "16" }
    if val_ty.kind == "struct" { val_size = "64" }
    if val_ty.kind == "enum" { val_size = "64" }

    // Call __mn_map_new(key_size, val_size, key_type)
    let map_ptr: String = dn + ".mp"
    s = emit_line(s, "  " + map_ptr + " =call ptr @__mn_map_new(i64 " + key_size + ", i64 " + val_size + ", i64 " + key_tag + ")")

    // Insert each pair
    let npairs: Int = len(pairs)
    let mut i: Int = 0
    for _ in 0..1000 {
        if i >= npairs {
            // Store map pointer into result: { ptr, i64 } with ptr=map, i64=0
            s = emit_line(s, "  " + dn + ".s0 =insertvalue { ptr, i64 } undef, ptr " + map_ptr + ", 0")
            s = emit_line(s, "  " + dn + " =insertvalue { ptr, i64 } " + dn + ".s0, i64 0, 1")
            return s
        }
        let pair: KVPair = pairs[i]
        let pi: String = toString(i)
        let k_ty: String = resolve_mir_type(pair.key.ty)
        let v_ty: String = resolve_mir_type(pair.val.ty)
        // Alloca key, store, bitcast to ptr
        let ka: String = dn + ".k" + pi
        s = emit_line(s, "  " + ka + " =alloca " + k_ty)
        s = emit_line(s, "  store " + k_ty + " " + pair.key.name + ", ptr " + ka)
        // Alloca val, store, bitcast to ptr
        let va: String = dn + ".v" + pi
        s = emit_line(s, "  " + va + " =alloca " + v_ty)
        s = emit_line(s, "  store " + v_ty + " " + pair.val.name + ", ptr " + va)
        // Call __mn_map_set(map, key_ptr, val_ptr)
        s = emit_line(s, emit_call_void("__mn_map_set", "ptr " + map_ptr + ", ptr " + ka + ", ptr " + va))
        i = i + 1
    }

    // Fallback: return empty map
    s = emit_line(s, "  " + dn + ".s0 =insertvalue { ptr, i64 } undef, ptr " + map_ptr + ", 0")
    s = emit_line(s, "  " + dn + " =insertvalue { ptr, i64 } " + dn + ".s0, i64 0, 1")
    return s
}

// ---------------------------------------------------------------------------
// EnumInit instruction
// ---------------------------------------------------------------------------

fn emit_enum_init(st: EmitState, dest: Value, ty: MIRType, variant: String, payload: List<Value>) -> EmitState {
    let mut s: EmitState = st
    let dn: String = dest.name

    // Resolve variant tag index
    let tag_val: String = toString(resolve_variant_index(s, ty.name, variant))

    // Pointer-based enum: { i64 tag, ptr payload }.
    // 1. Malloc payload struct, store each field via GEP.
    // 2. Build {i64, ptr} with insertvalue.
    // Use named type (%enum.X) for insertvalue, not inline { i64, ptr }
    let enum_ty: String = resolve_mir_type(ty)
    if len(payload) > 0 {
        // Compute payload allocation size: sum field sizes
        let alloc_size: String = toString(compute_payload_alloc_size(s, payload))
        let ep: String = dn + ".ep"
        s = emit_line(s, "  " + ep + " = call ptr @malloc(i64 " + alloc_size + ")")
        // Store each payload field via byte-offset GEP
        let mut i: Int = 0
        let npayload: Int = len(payload)
        for _ in 0..100 {
            if i < npayload {
                let p: Value = payload[i]
                let pty: String = resolve_mir_type(p.ty)
                let ef: String = dn + ".ef" + toString(i)
                let offset: String = toString(compute_field_offset(s, payload, i))
                s = emit_line(s, "  " + ef + " = getelementptr inbounds i8, ptr " + ep + ", i64 " + offset)
                s = emit_line(s, "  store " + pty + " " + p.name + ", ptr " + ef)
                i = i + 1
            }
        }
        // Build enum value using named type
        let ei1_pay: String = dn + ".ei1"
        s = emit_line(s, "  " + ei1_pay + " = insertvalue " + enum_ty + " undef, i64 " + tag_val + ", 0")
        s = emit_line(s, "  " + dn + " = insertvalue " + enum_ty + " " + ei1_pay + ", ptr " + ep + ", 1")
    } else {
        // No payload: null pointer
        let ei1_bare: String = dn + ".ei1"
        s = emit_line(s, "  " + ei1_bare + " = insertvalue " + enum_ty + " undef, i64 " + tag_val + ", 0")
        s = emit_line(s, "  " + dn + " = insertvalue " + enum_ty + " " + ei1_bare + ", ptr null, 1")
    }
    return s
}

fn compute_payload_alloc_size(st: EmitState, payload: List<Value>) -> Int {
    let mut total: Int = 0
    let mut i: Int = 0
    for _ in 0..100 {
        if i >= len(payload) { return total }
        let pty: String = resolve_mir_type(payload[i].ty)
        total = total + llvm_type_size(pty)
        i = i + 1
    }
    return total
}

fn compute_field_offset(st: EmitState, payload: List<Value>, field_idx: Int) -> Int {
    let mut offset: Int = 0
    let mut i: Int = 0
    for _ in 0..100 {
        if i >= field_idx { return offset }
        let mut pty: String = resolve_mir_type(payload[i].ty)
        // Fix struct→enum misclassification
        if pty.starts_with("%struct.") {
            if is_enum_type(st, payload[i].ty.name) {
                pty = "%enum." + payload[i].ty.name
            }
        }
        offset = offset + llvm_type_size(pty)
        i = i + 1
    }
    return offset
}

fn resolve_variant_index(st: EmitState, enum_name: String, variant: String) -> Int {
    // Strip ":N" suffix if present (from indexed payload extraction)
    let mut vname: String = variant
    let colon: Int = variant.find(":")
    if colon >= 0 {
        vname = variant.substr(0, colon)
    }
    let mut i: Int = 0
    let neinfos2: Int = len(st.enum_infos)
    for _ in 0..200 {
        if i < neinfos2 {
            let info: EnumInfo = st.enum_infos[i]
            if info.name == enum_name {
                let mut vi: Int = 0
                let nvariants: Int = len(info.variants)
                for _ in 0..200 {
                    if vi < nvariants {
                        if info.variants[vi].name == vname {
                            return vi
                        }
                        vi = vi + 1
                    }
                }
            }
            i = i + 1
        }
    }
    return 0
}

// Parse field index from "Variant:N" format. Returns N (0 if no colon).
// Uses return instead of conditional assignment (Python lowerer drops if-assignments).
fn parse_field_index(variant: String) -> Int {
    let colon_pos: Int = variant.find(":")
    if colon_pos < 0 { return 0 }
    // Use char_at instead of substr — substr has a C runtime bug for short substrings
    let idx_char: String = variant.char_at(colon_pos + 1)
    return int(idx_char)
}

// Strip ":N" suffix from "Variant:N". Uses char_at loop to avoid buggy substr.
fn strip_colon_suffix(s: String) -> String {
    let colon_pos: Int = s.find(":")
    if colon_pos < 0 { return s }
    // Build result char by char (substr is buggy for non-zero start)
    let mut result: String = ""
    let mut i: Int = 0
    for _ in 0..200 {
        if i >= colon_pos { return result }
        result = result + s.char_at(i)
        i = i + 1
    }
    return result
}

// Extract everything after ":" — char-by-char to avoid substr bug.
fn extract_after_colon(s: String, colon_pos: Int) -> String {
    let mut result: String = ""
    let slen: Int = len(s)
    let mut i: Int = colon_pos + 1
    for _ in 0..200 {
        if i >= slen { return result }
        result = result + s.char_at(i)
        i = i + 1
    }
    return result
}

// Compute byte offset to field_idx within a variant's payload.
// Sums llvm_type_size of fields 0..field_idx-1.
fn compute_payload_offset(st: EmitState, enum_name: String, variant_name: String, field_idx: Int) -> Int {
    let mut ei: Int = 0
    for _ in 0..200 {
        if ei >= len(st.enum_infos) { return 0 }
        let info: EnumInfo = st.enum_infos[ei]
        if info.name == enum_name {
            let mut vi: Int = 0
            for _ in 0..200 {
                if vi >= len(info.variants) { return 0 }
                if info.variants[vi].name == variant_name {
                    return sum_field_sizes(st, info.variants[vi].payload_types, field_idx)
                }
                vi = vi + 1
            }
        }
        ei = ei + 1
    }
    return 0
}

// Sum llvm_type_size for fields 0..count-1
fn sum_field_sizes(st: EmitState, types: List<MIRType>, count: Int) -> Int {
    let mut total: Int = 0
    let mut i: Int = 0
    for _ in 0..100 {
        if i >= count { return total }
        let mut pty: String = resolve_mir_type(types[i])
        // Fix struct→enum misclassification: MIR may have kind:"struct" for enums
        if pty.starts_with("%struct.") {
            let tname: String = types[i].name
            if is_enum_type(st, tname) {
                pty = "%enum." + tname
            }
        }
        total = total + llvm_type_size(pty)
        i = i + 1
    }
    return total
}

// Parse "Variant:N" → compute byte offset to field N within the variant's payload.
// Uses llvm_type_size for each prior field to sum the offset.
fn compute_variant_field_offset(st: EmitState, enum_name: String, variant_with_idx: String) -> Int {
    // Parse index from "Variant:N"
    let colon_pos: Int = variant_with_idx.find(":")
    if colon_pos < 0 { return 0 }
    let idx_str: String = variant_with_idx.substr(colon_pos + 1, len(variant_with_idx) - colon_pos - 1)
    let field_idx: Int = int(idx_str)
    if field_idx == 0 { return 0 }

    // Look up variant's payload types
    let variant_name: String = variant_with_idx.substr(0, colon_pos)
    let mut ei: Int = 0
    for _ in 0..200 {
        if ei >= len(st.enum_infos) { return 0 }
        let info: EnumInfo = st.enum_infos[ei]
        if info.name == enum_name {
            let mut vi: Int = 0
            for _ in 0..200 {
                if vi >= len(info.variants) { return 0 }
                if info.variants[vi].name == variant_name {
                    // Sum sizes of fields 0..field_idx-1
                    let mut offset: Int = 0
                    let mut fi: Int = 0
                    for _ in 0..100 {
                        if fi >= field_idx { return offset }
                        if fi >= len(info.variants[vi].payload_types) { return offset }
                        let fty: String = resolve_mir_type(info.variants[vi].payload_types[fi])
                        offset = offset + llvm_type_size(fty)
                        fi = fi + 1
                    }
                    return offset
                }
                vi = vi + 1
            }
        }
        ei = ei + 1
    }
    return 0
}

// ---------------------------------------------------------------------------
// EnumTag instruction
// ---------------------------------------------------------------------------

fn emit_enum_tag(st: EmitState, dest: Value, val: Value) -> EmitState {
    let mut s: EmitState = st
    let enum_ty: String = resolve_type(st, val.ty)
    let dn: String = dest.name
    // For Result/Option the tag field is i1; for enums it's i64.
    // Extract field 0 and zext to i64 if needed.
    if val.ty.kind == "result" || val.ty.kind == "option" {
        let raw_tag: String = dn + ".raw"
        s = emit_line(s, emit_extractvalue(raw_tag, enum_ty, val.name, "0"))
        s = emit_line(s, "  " + dn + " = zext i1 " + raw_tag + " to i64")
    } else {
        s = emit_line(s, emit_extractvalue(dn, enum_ty, val.name, "0"))
    }
    return s
}

// ---------------------------------------------------------------------------
// EnumPayload instruction
// ---------------------------------------------------------------------------

fn emit_enum_payload(st: EmitState, dest: Value, val: Value, variant: String) -> EmitState {
    let mut s: EmitState = st
    let enum_ty: String = resolve_type(st, val.ty)
    let dn: String = dest.name

    // For Result/Option: use extractvalue on the inner struct
    if val.ty.kind == "result" {
        // Result = {i1, {ok_ty, err_ty}}. Extract inner struct, then payload.
        let inner_r: String = dn + ".inner"
        s = emit_line(s, "  " + inner_r + " = extractvalue " + enum_ty + " " + val.name + ", 1")
        // Ok payload at index 0, Err payload at index 1
        let mut ok_ty: String = llvm_ptr()
        let mut err_ty: String = llvm_ptr()
        if len(val.ty.args) >= 2 {
            ok_ty = resolve_mir_type(val.ty.args[0])
            err_ty = resolve_mir_type(val.ty.args[1])
        }
        let inner_ty_res: String = "{ " + ok_ty + ", " + err_ty + " }"
        // Strip ":N" suffix from variant name (lowerer passes "Ok:0", "Err:0")
        let base_variant: String = strip_colon_suffix(variant)
        if base_variant == "Ok" {
            s = emit_line(s, "  " + dn + " = extractvalue " + inner_ty_res + " " + inner_r + ", 0")
        } else {
            s = emit_line(s, "  " + dn + " = extractvalue " + inner_ty_res + " " + inner_r + ", 1")
        }
        return s
    }
    if val.ty.kind == "option" {
        // Universal erasure: Option = {i1, ptr}. Extract ptr, then load.
        let ptr_name: String = dn + ".ptr"
        s = emit_line(s, "  " + ptr_name + " = extractvalue " + enum_ty + " " + val.name + ", 1")
        // Use destination type for load — avoids struct/enum name mismatches
        let inner_ty_opt: String = resolve_type(st, dest.ty)
        s = emit_line(s, "  " + dn + " = load " + inner_ty_opt + ", ptr " + ptr_name)
        return s
    }

    // Pointer-based enum: { i64 tag, ptr payload }.
    // Extract payload pointer using the named enum type.
    let pr: String = dn + ".pr"
    s = emit_line(s, "  " + pr + " = extractvalue " + enum_ty + " " + val.name + ", 1")

    // Determine the dest type
    let mut dest_ty: String = resolve_mir_type(dest.ty)
    // Correct struct→enum misclassification
    if dest_ty.starts_with("%struct.") {
        let payload_name: String = dest.ty.name
        if is_enum_type(s, payload_name) {
            dest_ty = "%enum." + payload_name
        }
    }

    // Parse field index from "Variant:N" suffix.
    let field_idx: Int = parse_field_index(variant)

    if field_idx > 0 {
        // Compute byte offset: look up variant's payload types and sum sizes
        // of fields 0..field_idx-1. Pass parsed values to avoid substr bug.
        let stripped_name: String = strip_colon_suffix(variant)
        let offset: Int = compute_payload_offset(s, val.ty.name, stripped_name, field_idx)
        let pf: String = dn + ".pf"
        s = emit_line(s, "  " + pf + " = getelementptr inbounds i8, ptr " + pr + ", i64 " + toString(offset))
        s = emit_line(s, "  " + dn + " = load " + dest_ty + ", ptr " + pf)
    } else {
        s = emit_line(s, "  " + dn + " = load " + dest_ty + ", ptr " + pr)
    }
    return s
}

// ---------------------------------------------------------------------------
// Option/Result wrapping
// ---------------------------------------------------------------------------

fn emit_wrap_some(st: EmitState, dest: Value, val: Value) -> EmitState {
    let mut s: EmitState = st
    let val_ty: String = resolve_type(st, val.ty)
    let dn: String = dest.name

    // Heap-allocate the payload via malloc so the pointer survives function returns.
    // Stack alloca would be destroyed when the current function returns, leaving
    // a dangling pointer in the {i1, ptr} Option representation.
    let ea: String = dn + ".ea"
    let sz: String = dn + ".sz"
    s = emit_line(s, "  " + sz + " = ptrtoint ptr getelementptr (" + val_ty + ", ptr null, i32 1) to i64")
    s = emit_line(s, "  " + ea + " = call ptr @malloc(i64 " + sz + ")")
    s = emit_line(s, "  store " + val_ty + " " + val.name + ", ptr " + ea)
    let opt_ty: String = llvm_option_type(llvm_ptr())
    let tag_name: String = dn + ".tag"
    s = emit_line(s, emit_insertvalue(tag_name, opt_ty, "undef", "1", "i1", "0"))
    s = emit_line(s, emit_insertvalue(dn, opt_ty, tag_name, ea, llvm_ptr(), "1"))
    return s
}

fn emit_wrap_none(st: EmitState, dest: Value, ty: MIRType) -> EmitState {
    // Universal erasure: all Option types are {i1, ptr}. None = {i1=0, null}.
    let opt_ty: String = llvm_option_type(llvm_ptr())
    let dn: String = dest.name
    let s: EmitState = emit_line(st, emit_insertvalue(dn, opt_ty, "undef", "0", "i1", "0"))
    return s
}

fn emit_wrap_ok(st: EmitState, dest: Value, val: Value) -> EmitState {
    let mut s: EmitState = st
    // Use dest's Result type args for correct ok/err layout
    let res_ty: String = resolve_mir_type(dest.ty)
    let val_ty: String = resolve_mir_type(val.ty)
    let mut ok_ty: String = val_ty
    let mut err_ty: String = llvm_ptr()
    if len(dest.ty.args) >= 2 {
        ok_ty = resolve_mir_type(dest.ty.args[0])
        err_ty = resolve_mir_type(dest.ty.args[1])
    }
    let inner_ty: String = "{ " + ok_ty + ", " + err_ty + " }"
    let dn: String = dest.name

    let tag_name: String = dn + ".tag"
    s = emit_line(s, emit_insertvalue(tag_name, res_ty, "undef", "1", "i1", "0"))
    let inner_name: String = dn + ".inner"
    s = emit_line(s, emit_insertvalue(inner_name, inner_ty, "undef", val.name, ok_ty, "0"))
    s = emit_line(s, emit_insertvalue(dn, res_ty, tag_name, inner_name, inner_ty, "1"))
    return s
}

fn emit_wrap_err(st: EmitState, dest: Value, val: Value) -> EmitState {
    let mut s: EmitState = st
    let res_ty: String = resolve_mir_type(dest.ty)
    let val_ty: String = resolve_mir_type(val.ty)
    let mut ok_ty: String = llvm_ptr()
    let mut err_ty: String = val_ty
    if len(dest.ty.args) >= 2 {
        ok_ty = resolve_mir_type(dest.ty.args[0])
        err_ty = resolve_mir_type(dest.ty.args[1])
    }
    let inner_ty: String = "{ " + ok_ty + ", " + err_ty + " }"
    let dn: String = dest.name

    let tag_name: String = dn + ".tag"
    s = emit_line(s, emit_insertvalue(tag_name, res_ty, "undef", "0", "i1", "0"))
    let inner_name: String = dn + ".inner"
    s = emit_line(s, emit_insertvalue(inner_name, inner_ty, "undef", val.name, err_ty, "1"))
    s = emit_line(s, emit_insertvalue(dn, res_ty, tag_name, inner_name, inner_ty, "1"))
    return s
}

// ---------------------------------------------------------------------------
// Unwrap instruction
// ---------------------------------------------------------------------------

fn emit_unwrap(st: EmitState, dest: Value, val: Value) -> EmitState {
    let mut s: EmitState = st
    let val_ty: String = resolve_mir_type(val.ty)
    let dn: String = dest.name
    if val.ty.kind == "option" {
        // Universal erasure: Option is {i1, ptr}. Extract ptr, then load.
        let ptr_name: String = dn + ".ptr"
        s = emit_line(s, emit_extractvalue(ptr_name, val_ty, val.name, "1"))
        // Use destination type for the load — avoids struct/enum name mismatches
        let inner_ty: String = resolve_type(st, dest.ty)
        s = emit_line(s, "  " + dn + " = load " + inner_ty + ", ptr " + ptr_name)
    } else {
        // Non-option: direct extractvalue
        s = emit_line(s, emit_extractvalue(dn, val_ty, val.name, "1"))
    }
    return s
}

// ---------------------------------------------------------------------------
// Call instruction
// ---------------------------------------------------------------------------

fn emit_mir_call(st: EmitState, dest: Value, fn_name: String, args: List<Value>) -> EmitState {
    let dn: String = dest.name

    // Built-in: print / println
    if fn_name == "print" {
        return emit_builtin_print(st, args)
    }
    if fn_name == "println" {
        return emit_builtin_println(st, args)
    }
    if fn_name == "len" {
        return emit_builtin_len(st, dest, args)
    }
    if fn_name == "toString" {
        return emit_builtin_tostring(st, dest, args)
    }
    if fn_name == "str" {
        return emit_builtin_tostring(st, dest, args)
    }
    if fn_name == "int" {
        return emit_builtin_int(st, dest, args)
    }
    if fn_name == "float" {
        return emit_builtin_float(st, dest, args)
    }

    // Runtime: process + file I/O
    if fn_name == "__mn_argc" {
        return emit_line(st, emit_call_ir(dn, "i64", "__mn_argc", ""))
    }
    if fn_name == "__mn_argv" {
        let as_argv: String = "i64 " + args[0].name
        return emit_line(st, emit_call_ir(dn, llvm_string(), "__mn_argv", as_argv))
    }
    if fn_name == "__mn_file_read_or_empty" {
        let as_fr: String = llvm_string() + " " + args[0].name
        return emit_line(st, emit_call_ir(dn, llvm_string(), "__mn_file_read_or_empty", as_fr))
    }
    if fn_name == "__mn_exit" {
        return emit_line(st, emit_call_void("__mn_exit", "i64 " + args[0].name))
    }
    if fn_name == "__mn_str_eprint" {
        let as_epr: String = llvm_string() + " " + args[0].name
        return emit_line(st, emit_call_void("__mn_str_eprint", as_epr))
    }

    // BinOp fallback: when enum tag mismatch causes BinOp to reach Call dispatch,
    // the fn_name is "__op_<operator>". Convert to inline LLVM arithmetic.
    if fn_name.starts_with("__op_") {
        let op_ch: String = fn_name.replace("__op_", "")
        let an: String = args[0].name
        let bn: String = args[1].name
        if op_ch == "+" { return emit_line(st, emit_add(dn, llvm_int(), an, bn)) }
        if op_ch == "-" { return emit_line(st, emit_sub(dn, llvm_int(), an, bn)) }
        if op_ch == "*" { return emit_line(st, emit_mul(dn, llvm_int(), an, bn)) }
        if op_ch == "/" { return emit_line(st, emit_sdiv(dn, llvm_int(), an, bn)) }
        if op_ch == "%" { return emit_line(st, emit_srem(dn, llvm_int(), an, bn)) }
        if op_ch == "==" { return emit_line(st, emit_icmp(dn, "eq", llvm_int(), an, bn)) }
        if op_ch == "!=" { return emit_line(st, emit_icmp(dn, "ne", llvm_int(), an, bn)) }
        if op_ch == "<" { return emit_line(st, emit_icmp(dn, "slt", llvm_int(), an, bn)) }
        if op_ch == ">" { return emit_line(st, emit_icmp(dn, "sgt", llvm_int(), an, bn)) }
        if op_ch == "<=" { return emit_line(st, emit_icmp(dn, "sle", llvm_int(), an, bn)) }
        if op_ch == ">=" { return emit_line(st, emit_icmp(dn, "sge", llvm_int(), an, bn)) }
        if op_ch == "&&" { return emit_line(st, emit_and_instr(dn, an, bn)) }
        if op_ch == "||" { return emit_line(st, emit_or_instr(dn, an, bn)) }
        // Fallback for unknown operator
        return emit_line(st, emit_add(dn, llvm_int(), an, bn))
    }

    // Range construction — inline to avoid ABI mismatch with C runtime
    // C runtime __mn_range returns void* (ptr), but self-hosted expects {i64, i64}.
    // Fix: construct the {i64, i64} directly instead of calling the C function.
    if fn_name == "__mn_range" {
        let mut s_rng: EmitState = st
        let tmp_rng: String = dn + ".tmp"
        s_rng = emit_line(s_rng, "  " + tmp_rng + " = insertvalue { i64, i64 } undef, i64 " + args[0].name + ", 0")
        s_rng = emit_line(s_rng, "  " + dn + " = insertvalue { i64, i64 } " + tmp_rng + ", i64 " + args[1].name + ", 1")
        return s_rng
    }
    if fn_name == "__mn_range_inclusive" {
        let mut s_rngi: EmitState = st
        let inc: String = dn + ".inc"
        let tmp_rngi: String = dn + ".tmp"
        s_rngi = emit_line(s_rngi, "  " + inc + " = add i64 " + args[1].name + ", 1")
        s_rngi = emit_line(s_rngi, "  " + tmp_rngi + " = insertvalue { i64, i64 } undef, i64 " + args[0].name + ", 0")
        s_rngi = emit_line(s_rngi, "  " + dn + " = insertvalue { i64, i64 } " + tmp_rngi + ", i64 " + inc + ", 1")
        return s_rngi
    }

    // Range field extraction (counter-based for-loops)
    if fn_name == "__mn_range_start" {
        let mut s_rs: EmitState = st
        s_rs = emit_line(s_rs, "  " + dn + " = extractvalue { i64, i64 } " + args[0].name + ", 0")
        return s_rs
    }
    if fn_name == "__mn_range_end" {
        let mut s_re: EmitState = st
        s_re = emit_line(s_re, "  " + dn + " = extractvalue { i64, i64 } " + args[0].name + ", 1")
        return s_re
    }

    // String builtins
    if fn_name == "split" {
        let mut s_split: EmitState = st
        let as_split: String = llvm_string() + " " + args[0].name + ", " + llvm_string() + " " + args[1].name
        s_split = emit_line(s_split, emit_call_ir(dn, llvm_list_rt(), "__mn_str_split", as_split))
        return s_split
    }
    if fn_name == "contains" {
        let mut s_cont: EmitState = st
        let as_cont: String = llvm_string() + " " + args[0].name + ", " + llvm_string() + " " + args[1].name
        s_cont = emit_line(s_cont, emit_call_ir(dn, llvm_bool(), "__mn_str_contains", as_cont))
        return s_cont
    }
    if fn_name == "replace" {
        let mut s_repl: EmitState = st
        let as_repl: String = llvm_string() + " " + args[0].name + ", " + llvm_string() + " " + args[1].name + ", " + llvm_string() + " " + args[2].name
        s_repl = emit_line(s_repl, emit_call_ir(dn, llvm_string(), "__mn_str_replace", as_repl))
        return s_repl
    }
    if fn_name == "byte_at" {
        let mut s_ba: EmitState = st
        let as_ba: String = llvm_string() + " " + args[0].name + ", i64 " + args[1].name
        s_ba = emit_line(s_ba, emit_call_ir(dn, llvm_int(), "__mn_str_byte_at", as_ba))
        return s_ba
    }
    // join(sep, list) → String via C runtime. List passed by pointer.
    if fn_name == "join" {
        let mut s_join: EmitState = st
        // Alloca the list and pass pointer (C runtime expects MnList*)
        let la: String = "%" + strip_percent(dn) + ".la"
        s_join = emit_line(s_join, "  " + la + " = alloca " + llvm_list_rt())
        s_join = emit_line(s_join, "  store " + llvm_list_rt() + " " + args[1].name + ", ptr " + la)
        let as_join: String = llvm_string() + " " + args[0].name + ", ptr " + la
        s_join = emit_line(s_join, emit_call_ir(dn, llvm_string(), "__mn_str_join", as_join))
        return s_join
    }

    // List push: extract to helper to avoid return-inside-if bug
    if fn_name == "push" {
        return emit_list_push_call(st, dest, args)
    }

    // Synthetic struct constructor: __new_<StructName>(field_values...)
    // Use replace to remove the "__new_" prefix instead of substr
    // (substr has off-by-one issues in the compiled binary)
    if fn_name.contains("__new_") {
        let struct_name: String = fn_name.replace("__new_", "")
        let struct_ty: MIRType = mir_struct(struct_name)
        return emit_struct_init_from_values(st, dest, struct_ty, args)
    }

    // Resolve operands for all other calls
    let mut s: EmitState = st

    // String methods: dispatched to __mn_str_<method> runtime functions
    if len(args) >= 1 {
        let first_arg: Value = args[0]
        if first_arg.ty.kind == "string" {
            let s0: String = first_arg.name
            if fn_name == "contains" {
                s = emit_line(s, emit_call_ir(dn, llvm_bool(), "__mn_str_contains", llvm_string() + " " + s0 + ", " + llvm_string() + " " + args[1].name))
                return s
            }
            if fn_name == "starts_with" {
                s = emit_line(s, emit_call_ir(dn, llvm_bool(), "__mn_str_starts_with", llvm_string() + " " + s0 + ", " + llvm_string() + " " + args[1].name))
                return s
            }
            if fn_name == "ends_with" {
                s = emit_line(s, emit_call_ir(dn, llvm_bool(), "__mn_str_ends_with", llvm_string() + " " + s0 + ", " + llvm_string() + " " + args[1].name))
                return s
            }
            if fn_name == "find" {
                s = emit_line(s, emit_call_ir(dn, llvm_int(), "__mn_str_find", llvm_string() + " " + s0 + ", " + llvm_string() + " " + args[1].name))
                return s
            }
            if fn_name == "char_at" {
                s = emit_line(s, emit_call_ir(dn, llvm_string(), "__mn_str_char_at", llvm_string() + " " + s0 + ", i64 " + args[1].name))
                return s
            }
            if fn_name == "substr" {
                if len(args) >= 3 {
                    s = emit_line(s, emit_call_ir(dn, llvm_string(), "__mn_str_substr", llvm_string() + " " + s0 + ", i64 " + args[1].name + ", i64 " + args[2].name))
                    return s
                }
            }
            if fn_name == "to_upper" {
                s = emit_line(s, emit_call_ir(dn, llvm_string(), "__mn_str_to_upper", llvm_string() + " " + s0))
                return s
            }
            if fn_name == "to_lower" {
                s = emit_line(s, emit_call_ir(dn, llvm_string(), "__mn_str_to_lower", llvm_string() + " " + s0))
                return s
            }
            if fn_name == "replace" {
                if len(args) >= 3 {
                    s = emit_line(s, emit_call_ir(dn, llvm_string(), "__mn_str_replace", llvm_string() + " " + s0 + ", " + llvm_string() + " " + args[1].name + ", " + llvm_string() + " " + args[2].name))
                    return s
                }
            }
        }
    }

    // Look up registered function parameter types (more reliable than MIR)
    let fn_opt_pre: Option<FnEntry> = find_function(s, fn_name)
    let mut reg_param_types: List<String> = []
    match fn_opt_pre {
        Some(fe) => { reg_param_types = fe.param_types },
        _ => {}
    }

    // Build args with byref: large struct args → alloca + pass pointer
    let mut args_str: String = ""
    let mut j: Int = 0
    let nargs: Int = len(args)
    for _ in 0..200 {
        if j < nargs {
            let mut aty: String = resolve_mir_type(args[j].ty)
            let mut an: String = args[j].name
            // Use registered param type when available.
            // Enum reinterpret: alloca+store+load for layout-compatible enums.
            // NEVER set an=zeroinitializer (that was the bug causing empty args).
            if j < len(reg_param_types) {
                let rpt: String = reg_param_types[j]
                if rpt != aty && rpt != "i64" {
                    // Enum type mismatch: reinterpret through memory
                    if aty.starts_with("%enum.") && rpt.starts_with("%enum.") && aty != rpt {
                        let rc_a: String = "%ecast" + toString(s.counter)
                        s.counter = s.counter + 1
                        s = emit_line(s, "  " + rc_a + " = alloca " + rpt)
                        s = emit_line(s, "  store " + aty + " " + an + ", ptr " + rc_a)
                        let rc_ld: String = "%ecast_ld" + toString(s.counter)
                        s.counter = s.counter + 1
                        s = emit_line(s, "  " + rc_ld + " = load " + rpt + ", ptr " + rc_a)
                        an = rc_ld
                    }
                    aty = rpt
                }
            }
            // Byref: large struct args → store to alloca, pass pointer
            let mut pass_ty: String = aty
            let mut pass_name: String = an
            if is_byref_type(aty) {
                let ba: String = "%barg" + toString(s.counter)
                s.counter = s.counter + 1
                s = emit_line(s, "  " + ba + " = alloca " + aty)
                s = emit_line(s, "  store " + aty + " " + an + ", ptr " + ba)
                pass_ty = "ptr"
                pass_name = ba
            }
            if j > 0 {
                args_str = args_str + ", " + pass_ty + " " + pass_name
            } else {
                args_str = pass_ty + " " + pass_name
            }
            j = j + 1
        }
    }

    // Look up return type and handle sret for large struct returns
    let fn_opt: Option<FnEntry> = find_function(s, fn_name)
    match fn_opt {
        Some(fe) => {
            if fe.ret_type == "void" {
                return emit_line(s, emit_call_void(fn_name, args_str))
            }
            // sret: large struct returns via hidden pointer
            if is_byref_type(fe.ret_type) {
                let sret_a: String = "%sret" + toString(s.counter)
                s.counter = s.counter + 1
                s = emit_line(s, "  " + sret_a + " = alloca " + fe.ret_type)
                s = emit_line(s, "  store " + fe.ret_type + " zeroinitializer, ptr " + sret_a)
                let sret_arg: String = "ptr sret(" + fe.ret_type + ") " + sret_a
                let mut full_args: String = sret_arg
                if len(args_str) > 0 { full_args = sret_arg + ", " + args_str }
                s = emit_line(s, "  call void @" + fn_name + "(" + full_args + ")")
                s = emit_line(s, "  " + dn + " = load " + fe.ret_type + ", ptr " + sret_a)
                return s
            }
            s = emit_line(s, emit_call_ir(dn, fe.ret_type, fn_name, args_str))
            return s
        },
        _ => {
            let ret_ty: String = resolve_mir_type(dest.ty)
            if ret_ty == "void" {
                return emit_line(s, emit_call_void(fn_name, args_str))
            }
            // sret for unregistered functions with large struct returns
            if is_byref_type(ret_ty) {
                let sret_b: String = "%sret" + toString(s.counter)
                s.counter = s.counter + 1
                s = emit_line(s, "  " + sret_b + " = alloca " + ret_ty)
                s = emit_line(s, "  store " + ret_ty + " zeroinitializer, ptr " + sret_b)
                let sret_arg_b: String = "ptr sret(" + ret_ty + ") " + sret_b
                let mut full_args_b: String = sret_arg_b
                if len(args_str) > 0 { full_args_b = sret_arg_b + ", " + args_str }
                s = emit_line(s, "  call void @" + fn_name + "(" + full_args_b + ")")
                s = emit_line(s, "  " + dn + " = load " + ret_ty + ", ptr " + sret_b)
                return s
            }
            s = emit_line(s, emit_call_ir(dn, ret_ty, fn_name, args_str))
            return s
        }
    }
}

// ---------------------------------------------------------------------------
// Built-in function emission
// ---------------------------------------------------------------------------

fn emit_builtin_print(st: EmitState, args: List<Value>) -> EmitState {
    // print() in Mapanare adds a newline (like Python's print)
    if len(args) == 0 {
        return emit_line(st, emit_call_void("printf", "ptr @.newline"))
    }
    let arg: Value = args[0]
    let mut s: EmitState = st
    let an: String = arg.name

    if arg.ty.kind == "string" {
        return emit_line(s, emit_call_void("__mn_str_println", llvm_string() + " " + an))
    }
    if arg.ty.kind == "float" {
        return emit_line(s, "  call i32 (ptr, ...) @printf(ptr @.fmt_float_nl, double " + an + ")")
    }
    if arg.ty.kind == "int" {
        return emit_line(s, "  call i32 (ptr, ...) @printf(ptr @.fmt_int_nl, i64 " + an + ")")
    }
    if arg.ty.kind == "bool" {
        return emit_line(s, "  call i32 (ptr, ...) @printf(ptr @.fmt_int_nl, i64 " + an + ")")
    }
    // Unknown type: assume string
    return emit_line(s, emit_call_void("__mn_str_println", llvm_string() + " " + an))
}

fn emit_builtin_println(st: EmitState, args: List<Value>) -> EmitState {
    if len(args) == 0 {
        return emit_line(st, emit_call_void("printf", "ptr @.newline"))
    }
    let arg: Value = args[0]
    let mut s: EmitState = st
    let an: String = arg.name

    if arg.ty.kind == "string" {
        return emit_line(s, emit_call_void("__mn_str_println", llvm_string() + " " + an))
    }
    if arg.ty.kind == "float" {
        return emit_line(s, "  call i32 (ptr, ...) @printf(ptr @.fmt_float_nl, double " + an + ")")
    }
    if arg.ty.kind == "int" {
        return emit_line(s, "  call i32 (ptr, ...) @printf(ptr @.fmt_int_nl, i64 " + an + ")")
    }
    if arg.ty.kind == "bool" {
        return emit_line(s, "  call i32 (ptr, ...) @printf(ptr @.fmt_int_nl, i64 " + an + ")")
    }
    // Unknown type: assume string (common from str()/toString() calls)
    return emit_line(s, emit_call_void("__mn_str_println", llvm_string() + " " + an))
}

fn emit_builtin_len(st: EmitState, dest: Value, args: List<Value>) -> EmitState {
    if len(args) == 0 { return st }
    let mut s: EmitState = st
    let an: String = args[0].name
    let dn: String = dest.name

    if args[0].ty.kind == "string" {
        s = emit_line(s, emit_call_ir(dn, llvm_int(), "__mn_str_len", llvm_string() + " " + an))
    } else {
        // __mn_list_len expects a pointer; alloca+store the list value first
        let tmp: String = dn + ".lp"
        let lt: String = llvm_list_rt()
        s = emit_line(s, "  " + tmp + " = alloca " + lt)
        s = emit_line(s, "  store " + lt + " " + an + ", " + "ptr " + tmp)
        s = emit_line(s, emit_call_ir(dn, llvm_int(), "__mn_list_len", "ptr " + tmp))
    }
    return s
}

fn emit_builtin_tostring(st: EmitState, dest: Value, args: List<Value>) -> EmitState {
    if len(args) == 0 { return st }
    let mut s: EmitState = st
    let an: String = args[0].name
    let dn: String = dest.name

    if args[0].ty.kind == "string" {
        return emit_copy(s, dest, args[0])
    }
    if args[0].ty.kind == "bool" {
        s = emit_line(s, emit_call_ir(dn, llvm_string(), "__mn_str_from_bool", "i1 " + an))
    } else {
    if args[0].ty.kind == "float" {
        s = emit_line(s, emit_call_ir(dn, llvm_string(), "__mn_str_from_float", "double " + an))
    } else {
        s = emit_line(s, emit_call_ir(dn, llvm_string(), "__mn_str_from_int", "i64 " + an))
    }}
    return s
}

fn emit_builtin_int(st: EmitState, dest: Value, args: List<Value>) -> EmitState {
    if len(args) == 0 { return st }
    let mut s: EmitState = st
    let an: String = args[0].name
    let dn: String = dest.name

    if args[0].ty.kind == "float" {
        s = emit_line(s, "  " + dn + " =fptosi double " + an + " to i64")
    } else {
    if args[0].ty.kind == "int" {
        return emit_copy(s, dest, args[0])
    } else {
        s = emit_line(s, emit_call_ir(dn, llvm_int(), "__mn_str_to_int", llvm_string() + " " + an))
    }}
    return s
}

fn emit_builtin_float(st: EmitState, dest: Value, args: List<Value>) -> EmitState {
    if len(args) == 0 { return st }
    let mut s: EmitState = st
    let an: String = args[0].name
    let dn: String = dest.name

    if args[0].ty.kind == "int" {
        s = emit_line(s, "  " + dn + " =sitofp i64 " + an + " to double")
    } else {
    if args[0].ty.kind == "float" {
        return emit_copy(s, dest, args[0])
    } else {
        s = emit_line(s, emit_call_ir(dn, llvm_float(), "__mn_str_to_float", llvm_string() + " " + an))
    }}
    return s
}

// ---------------------------------------------------------------------------
// Return instruction
// ---------------------------------------------------------------------------

fn emit_mir_return(st: EmitState, val_opt: Option<Value>) -> EmitState {
    match val_opt {
        Some(val) => {
            let ty: String = st.current_ret_type
            if ty == "void" {
                return emit_line(st, emit_ret_void())
            }
            // If using sret (large struct return), store to sret pointer and ret void
            if is_byref_type(ty) {
                let mut s: EmitState = emit_line(st, "  store " + ty + " " + val.name + ", ptr %__sret__")
                return emit_line(s, emit_ret_void())
            }
            return emit_line(st, emit_ret(ty, val.name))
        },
        _ => {
            // For non-void functions, emit zeroinitializer return (dead code from
            // match arms that all terminate). For void functions, emit ret void.
            let ret_ty: String = st.current_ret_type
            if ret_ty != "void" {
                return emit_line(st, "  ret " + ret_ty + " zeroinitializer")
            }
            return emit_line(st, emit_ret_void())
        }
    }
}

// ---------------------------------------------------------------------------
// Switch instruction
// ---------------------------------------------------------------------------

fn emit_mir_switch(st: EmitState, tag: Value, cases: List<SwitchCase>, default_bb: String) -> EmitState {
    let mut s: EmitState = emit_line(st, emit_switch_hdr(tag.name, default_bb))
    // Resolve the enum name from the tag value's type for variant index lookup
    let enum_name: String = tag.ty.name

    let mut i: Int = 0
    for _ in 0..200 {
        if i >= len(cases) {
            s = emit_line(s, "  ]")
            return s
        }
        let c: SwitchCase = cases[i]
        // If the case value is a variant name (not a number), resolve to integer index
        // This mirrors the Python emitter's _vtag() method
        let mut case_val: String = c.tag_value
        if len(case_val) > 0 {
            let first_ch: Int = c.tag_value.byte_at(0)
            // If not a digit (0-9) and not '-', it's a variant name → resolve to index
            if first_ch < 48 || first_ch > 57 {
                if first_ch != 45 {
                    // Hardcoded indices for Result/Option builtins
                    if case_val == "Ok" || case_val == "Some" {
                        case_val = "1"
                    } else if case_val == "Err" || case_val == "None" {
                        case_val = "0"
                    } else {
                        case_val = toString(resolve_variant_index(s, enum_name, case_val))
                    }
                }
            }
        }
        s = emit_line(s, emit_switch_case(case_val, c.block_label))
        i = i + 1
    }
    s = emit_line(s, "  ]")
    return s
}

// ---------------------------------------------------------------------------
// Agent instructions
// ---------------------------------------------------------------------------

fn emit_agent_spawn(st: EmitState, dest: Value, ty: MIRType, args: List<Value>) -> EmitState {
    let dn: String = dest.name
    let mut s: EmitState = st
    // Call agent spawn runtime function
    s = emit_line(s, emit_call_ir(dn, "ptr", "__mn_agent_spawn", "ptr null, ptr null"))
    return s
}

fn emit_agent_send(st: EmitState, ag: Value, channel: String, val: Value) -> EmitState {
    return emit_line(st, emit_call_void("__mn_agent_send", "ptr " + ag.name + ", ptr null, ptr null"))
}

fn emit_agent_sync(st: EmitState, dest: Value, ag: Value, channel: String) -> EmitState {
    let dn: String = dest.name
    let s2: EmitState = emit_line(st, emit_call_ir(dn, "ptr", "__mn_agent_sync", "ptr " + ag.name + ", ptr null"))
    return s2
}

// ---------------------------------------------------------------------------
// Signal instructions
// ---------------------------------------------------------------------------

fn emit_signal_init(st: EmitState, dest: Value, ty: MIRType, val: Value) -> EmitState {
    let dn: String = dest.name
    let s2: EmitState = emit_line(st, emit_call_ir(dn, "ptr", "__mn_signal_new", "ptr null"))
    return s2
}

fn emit_signal_get(st: EmitState, dest: Value, sig: Value) -> EmitState {
    let dn: String = dest.name
    let s2: EmitState = emit_line(st, emit_call_ir(dn, "ptr", "__mn_signal_get", "ptr " + sig.name))
    return s2
}

fn emit_signal_set(st: EmitState, sig: Value, val: Value) -> EmitState {
    return emit_line(st, emit_call_void("__mn_signal_set", "ptr " + sig.name + ", ptr null"))
}

// ---------------------------------------------------------------------------
// StreamOp instruction
// ---------------------------------------------------------------------------

fn emit_stream_op(st: EmitState, dest: Value, kind: StreamOpKind, source: Value, args: List<Value>) -> EmitState {
    let mut s: EmitState = st
    let dn: String = dest.name
    // Stream operations are runtime-dispatched; minimal LLVM lowering
    let s2: EmitState = emit_line(s, "  " + dn + " =bitcast ptr " + source.name + " to ptr")
    return s2
}

// ---------------------------------------------------------------------------
// InterpConcat instruction
// ---------------------------------------------------------------------------

fn emit_interp_concat(st: EmitState, dest: Value, parts: List<Value>) -> EmitState {
    if len(parts) == 0 {
        return emit_const(st, dest, mir_string(), "")
    }
    if len(parts) == 1 {
        return emit_copy(st, dest, parts[0])
    }

    // Concatenate parts left-to-right using __mn_str_concat
    let mut s: EmitState = st
    let dn: String = dest.name

    let mut acc: String = parts[0].name

    let mut i: Int = 1
    let nparts: Int = len(parts)
    for _ in 0..200 {
        if i < nparts {
            let tmp: String = dn + ".c" + toString(i)
            s = emit_line(s, emit_call_ir(tmp, llvm_string(), "__mn_str_concat", llvm_string() + " " + acc + ", " + llvm_string() + " " + parts[i].name))
            acc = tmp
            i = i + 1
        }
    }
    return s
}

// ---------------------------------------------------------------------------
// Phi instruction
// ---------------------------------------------------------------------------

fn emit_mir_phi(st: EmitState, dest: Value, incoming: List<PhiEntry>) -> EmitState {
    let mut ty: String = resolve_type(st, dest.ty)
    let dn: String = dest.name

    let mut s: EmitState = st
    let mut skip: Bool = false
    if len(incoming) == 0 { skip = true }
    if ty == "void" { skip = true }
    // For Phis with i64 type (unresolved or unknown): recover the actual type
    // from the incoming values. Any struct/enum type in incoming is better than
    // the default i64 that resolve_mir_type assigns to unknown types.
    if len(incoming) > 0 {
        let mut found: Bool = false
        let mut ci: Int = 0
        for _ in 0..100 {
            if ci >= len(incoming) { ci = 999 }
            if !found && ci < len(incoming) {
                let inc_ty: String = resolve_type(st, incoming[ci].val.ty)
                if inc_ty != "i64" && inc_ty != "void" {
                    if ty == "i64" {
                        ty = inc_ty
                        found = true
                    }
                }
            }
            ci = ci + 1
        }
    }

    if !skip {
        let mut phi_str: String = "  " + dn + " = phi " + ty + " "
        let mut i: Int = 0
        let nincoming: Int = len(incoming)
        for _ in 0..200 {
            if i < nincoming {
                let e: PhiEntry = incoming[i]
                if i > 0 {
                    phi_str = phi_str + ", "
                }
                phi_str = phi_str + "[ " + e.val.name + ", %" + e.block_label + " ]"
                i = i + 1
            }
        }
        s = emit_line(s, phi_str)
    }
    return s
}

// ---------------------------------------------------------------------------
// MIR basic block emission
// ---------------------------------------------------------------------------

fn emit_mir_basic_block(st: EmitState, bb: BasicBlock) -> EmitState {
    let mut s: EmitState = emit_line(st, bb.label + ":")
    let mut i: Int = 0
    for _ in 0..600 {
        if i >= len(bb.instructions) { return s }
        let inst: Instruction = bb.instructions[i]
        s = emit_mir_instruction(s, inst)
        i = i + 1
    }
    return s
}

// ---------------------------------------------------------------------------
// MIR function emission
// ---------------------------------------------------------------------------

fn emit_mir_function(st: EmitState, f: MIRFunction) -> EmitState {
    // Resolve return type
    let mut ret_ty: String = resolve_mir_type(f.return_type)
    if ret_ty.starts_with("%struct.") {
        let ret_name: String = f.return_type.name
        if is_enum_type(st, ret_name) {
            ret_ty = "%enum." + ret_name
        }
    }

    // Determine byref/sret: large structs passed by pointer
    let use_sret: Bool = is_byref_type(ret_ty) && f.name != "main"

    // Build parameter list with byref adjustments
    let mut params_str: String = ""
    let mut param_types: List<String> = []
    // If sret, first param is the return pointer
    if use_sret {
        params_str = "ptr sret(" + ret_ty + ") %__sret__"
    }
    let mut pi: Int = 0
    let nfparams: Int = len(f.params)
    for _ in 0..200 {
        if pi < nfparams {
            let p_sig: MIRParam = f.params[pi]
            let pty_sig: String = resolve_mir_type(p_sig.ty)
            param_types.push(pty_sig)
            let need_sep: Bool = pi > 0 || use_sret
            let mut sep: String = ""
            if need_sep { sep = ", " }
            if is_byref_type(pty_sig) {
                // Large param: pass by pointer
                params_str = params_str + sep + "ptr %" + p_sig.name + ".byref"
            } else {
                params_str = params_str + sep + pty_sig + " %" + p_sig.name
            }
            pi = pi + 1
        }
    }

    // Register function (with original types for caller resolution)
    let entry: FnEntry = new_fn_entry(f.name, ret_ty, param_types)
    let mut s: EmitState = st
    s.functions.push(entry)

    // Track current function's return type and sret flag
    // main() uses i32 return (C ABI) for clean exit codes
    if f.name == "main" {
        s.current_ret_type = "i32"
    } else {
        s.current_ret_type = ret_ty
    }

    // Emit function header
    let fn_name: String = strip_percent(f.name)
    let is_lambda: Bool = fn_name != f.name
    // Avoid if-expression (PHI zeroinitializer bug in stage2)
    let mut visibility: String = "define"
    if is_lambda { visibility = "define internal" }
    let mut abi_ret: String = ret_ty
    if use_sret { abi_ret = "void" }
    // main() returns i32 (C ABI) instead of void for clean exit codes
    if fn_name == "main" { abi_ret = "i32" }
    s = emit_line(s, visibility + " " + abi_ret + " @" + fn_name + "(" + params_str + ") {")

    // Emit basic blocks — entry block gets byref param fixup.
    // Extracted from single loop to avoid return-in-for and else-branch bugs.
    let nblks: Int = len(f.blocks)

    // Entry block (index 0): emit byref param loads, then instructions
    if nblks > 0 {
        let bb0: BasicBlock = f.blocks[0]
        s = emit_line(s, bb0.label + ":")
        // Emit byref loads: for each byref param, alloca + load from ptr + store
        let mut pi3: Int = 0
        let nfparams3: Int = len(f.params)
        for _ in 0..100 {
            if pi3 < nfparams3 {
                let p_byref: MIRParam = f.params[pi3]
                let pty_byref: String = resolve_mir_type(p_byref.ty)
                if is_byref_type(pty_byref) {
                    s = emit_line(s, "  %" + p_byref.name + ".addr = alloca " + pty_byref)
                    s = emit_line(s, "  %" + p_byref.name + ".bp = load " + pty_byref + ", ptr %" + p_byref.name + ".byref")
                    s = emit_line(s, "  store " + pty_byref + " %" + p_byref.name + ".bp, ptr %" + p_byref.name + ".addr")
                }
                pi3 = pi3 + 1
            }
        }
        // Build set of byref param names for skip detection
        let mut byref_names: List<String> = []
        let mut pn: Int = 0
        let nfparamsn: Int = len(f.params)
        for _ in 0..100 {
            if pn < nfparamsn {
                let pp: MIRParam = f.params[pn]
                let ppty: String = resolve_mir_type(pp.ty)
                if is_byref_type(ppty) {
                    byref_names.push(pp.name)
                }
                pn = pn + 1
            }
        }
        // Emit block instructions, skipping Alloca+Store ONLY for byref params
        let mut ii: Int = 0
        let ninsts: Int = len(bb0.instructions)
        for _ in 0..600 {
            if ii < ninsts {
                let inst: Instruction = bb0.instructions[ii]
                let mut should_skip: Bool = false
                let ik: String = instr_kind(inst)
                if ik == "alloca" {
                    should_skip = is_name_in_byref(byref_names, instr_dest(inst).name)
                }
                if ik == "store" {
                    should_skip = is_name_in_byref(byref_names, instr_store_ptr(inst).name)
                }
                if !should_skip {
                    s = emit_mir_instruction(s, inst)
                }
                ii = ii + 1
            }
        }
    }

    // Remaining blocks (index 1..nblks-1)
    let mut bi: Int = 1
    for _ in 0..600 {
        if bi < nblks {
            let bb: BasicBlock = f.blocks[bi]
            s = emit_mir_basic_block(s, bb)
            bi = bi + 1
        }
    }

    s = emit_line(s, "}")
    return emit_blank(s)
}

// ---------------------------------------------------------------------------
// Format constants (printf format strings)
// ---------------------------------------------------------------------------

fn emit_format_constants(st: EmitState) -> EmitState {
    let mut s: EmitState = st
    s = emit_line(s, "@.newline = private constant [2 x i8] c\"\\0A\\00\", align 2")
    s = emit_line(s, "@.fmt_int = private constant [4 x i8] c\"%ld\\00\", align 2")
    s = emit_line(s, "@.fmt_int_nl = private constant [5 x i8] c\"%ld\\0A\\00\", align 2")
    s = emit_line(s, "@.fmt_float = private constant [4 x i8] c\"%lf\\00\", align 2")
    s = emit_line(s, "@.fmt_float_nl = private constant [5 x i8] c\"%lf\\0A\\00\", align 2")
    return emit_blank(s)
}

// ---------------------------------------------------------------------------
// Public API: emit_mir_module
// ---------------------------------------------------------------------------

fn str_join(sep: String, parts: List<String>) -> String {
    return join(sep, parts)
}

pub fn emit_mir_module(module: MIRModule, module_name: String) -> String {
    let mut st: EmitState = new_emit_state(module_name)

    // Module header
    st = emit_line(st, "; ModuleID = '" + module_name + "'")
    st = emit_line(st, "source_filename = \"" + module_name + "\"")
    st = emit_blank(st)

    // Format string constants
    st = emit_format_constants(st)

    // Runtime declarations
    st = declare_all_runtime(st)

    // Register struct types
    let mut si_idx: Int = 0
    let nmodstructs: Int = len(module.structs)
    for _ in 0..200 {
        if si_idx < nmodstructs {
            st = register_mir_struct(st, module.structs[si_idx])
            si_idx = si_idx + 1
        }
    }

    // Register enum types
    let mut ei: Int = 0
    let nmodenums: Int = len(module.enums)
    for _ in 0..200 {
        if ei < nmodenums {
            st = register_mir_enum(st, module.enums[ei])
            ei = ei + 1
        }
    }

    if len(module.structs) > 0 { st = emit_blank(st) }
    if len(module.enums) > 0 { st = emit_blank(st) }

    // Declare extern functions
    let mut xi: Int = 0
    let nmodexterns: Int = len(module.extern_fns)
    for _ in 0..200 {
        if xi < nmodexterns {
            st = declare_mir_extern(st, module.extern_fns[xi])
            xi = xi + 1
        }
    }
    if len(module.extern_fns) > 0 { st = emit_blank(st) }

    // Forward-declare all functions (for mutual recursion)
    let mut dix: Int = 0
    let nmodfns: Int = len(module.functions)
    for _ in 0..2000 {
        if dix < nmodfns {
            let f_decl: MIRFunction = module.functions[dix]
            let ret_ty: String = resolve_mir_type(f_decl.return_type)
            let mut fparams: String = ""
            let mut fpi: Int = 0
            let nfwdparams: Int = len(f_decl.params)
            for _ in 0..200 {
                if fpi < nfwdparams {
                    let fp: MIRParam = f_decl.params[fpi]
                    let fpty: String = resolve_mir_type(fp.ty)
                    if fpi > 0 {
                        fparams = fparams + ", " + fpty
                    } else {
                        fparams = fpty
                    }
                    fpi = fpi + 1
                }
            }
            let mut fn_types: List<String> = []
            let mut fti: Int = 0
            for _ in 0..200 {
                if fti < nfwdparams {
                    fn_types.push(resolve_mir_type(f_decl.params[fti].ty))
                    fti = fti + 1
                }
            }
            let fe: FnEntry = new_fn_entry(f_decl.name, ret_ty, fn_types)
            st.functions.push(fe)
            dix = dix + 1
        }
    }

    // Emit function bodies
    let total_fns: Int = len(module.functions)
    let mut fi: Int = 0
    for _ in 0..2000 {
        if fi < total_fns {
            let f_emit: MIRFunction = module.functions[fi]
            if len(f_emit.blocks) > 0 {
                st = emit_mir_function(st, f_emit)
            }
            fi = fi + 1
        }
    }

    // Append string globals
    let mut gi: Int = 0
    let nstrglobals: Int = len(st.str_globals)
    for _ in 0..1000000 {
        if gi < nstrglobals {
            st = emit_line(st, st.str_globals[gi])
            gi = gi + 1
        }
    }
    // Print all lines directly to stdout
    let nlines: Int = len(st.lines)
    let mut li: Int = 0
    for _ in 0..1000000 {
        if li < nlines {
            print(st.lines[li])
            li = li + 1
        }
    }
    return ""
}

// ---------------------------------------------------------------------------
// Streaming API: emit module header, then individual functions
// ---------------------------------------------------------------------------

pub fn emit_header(module: MIRModule, module_name: String) -> EmitState {
    let mut st: EmitState = new_emit_state(module_name)
    st = emit_line(st, "; ModuleID = '" + module_name + "'")
    st = emit_line(st, "source_filename = \"" + module_name + "\"")
    st = emit_blank(st)
    st = emit_format_constants(st)
    st = declare_all_runtime(st)

    let mut si_idx: Int = 0
    let nhstructs: Int = len(module.structs)
    for _ in 0..200 {
        if si_idx < nhstructs {
            st = register_mir_struct(st, module.structs[si_idx])
            si_idx = si_idx + 1
        }
    }
    let mut ei: Int = 0
    let nhenums: Int = len(module.enums)
    for _ in 0..200 {
        if ei < nhenums {
            st = register_mir_enum(st, module.enums[ei])
            ei = ei + 1
        }
    }
    if len(module.structs) > 0 { st = emit_blank(st) }
    if len(module.enums) > 0 { st = emit_blank(st) }

    let mut xi: Int = 0
    let nhexterns: Int = len(module.extern_fns)
    for _ in 0..200 {
        if xi < nhexterns {
            st = declare_mir_extern(st, module.extern_fns[xi])
            xi = xi + 1
        }
    }
    if len(module.extern_fns) > 0 { st = emit_blank(st) }

    return st
}

pub fn register_fn_sig(st: EmitState, f: MIRFunction) -> EmitState {
    let mut ret_ty: String = resolve_mir_type(f.return_type)
    if ret_ty.starts_with("%struct.") {
        if is_enum_type(st, f.return_type.name) {
            ret_ty = "%enum." + f.return_type.name
        }
    }
    let fn_types: List<String> = []
    let fe: FnEntry = new_fn_entry(f.name, ret_ty, fn_types)
    let mut s: EmitState = st
    s.functions.push(fe)
    return s
}

pub fn emit_one_fn(st: EmitState, f: MIRFunction) -> EmitState {
    return emit_mir_function(st, f)
}

pub fn emit_finalize(st: EmitState) -> String {
    let nlines: Int = len(st.lines)
    let mut result: String = ""
    let mut li: Int = 0
    for _ in 0..1000000 {
        if li < nlines {
            result = result + st.lines[li] + "\n"
            li = li + 1
        }
    }
    let mut gi: Int = 0
    let nfinalglobals: Int = len(st.str_globals)
    for _ in 0..1000000 {
        if gi < nfinalglobals {
            result = result + st.str_globals[gi] + "\n"
            gi = gi + 1
        }
    }
    return result
}

// ===== main.mn =====
// main.mn — Compiler driver for the Mapanare self-hosted compiler.
// Wires the pipeline: source -> parse -> resolve imports -> lower -> emit_llvm -> LLVM IR.


// ---------------------------------------------------------------------------
// Compilation result
// ---------------------------------------------------------------------------

struct CompileResult {
    success: Bool,
    ir_text: String,
    errors: List<SemanticError>
}

fn new_compile_result(success: Bool, ir_text: String, errors: List<SemanticError>) -> CompileResult {
    return new CompileResult { success: success, ir_text: ir_text, errors: errors }
}

// ---------------------------------------------------------------------------
// version — return the compiler version string
// ---------------------------------------------------------------------------

fn version() -> String {
    return "mapanare 3.4.0"
}

// ---------------------------------------------------------------------------
// Path helpers for module resolution
// ---------------------------------------------------------------------------

// Extract directory part of a path: "/foo/bar/baz.mn" -> "/foo/bar/"
// Returns "" if no directory separator found.
// Scans from end to find last separator (avoids nested-assign MIR bug).
fn dir_of_path(path: String) -> String {
    let slen: Int = len(path)
    if slen == 0 { return "" }
    let mut i: Int = slen - 1
    for _ in 0..4096 {
        if i < 0 { return "" }
        let ch: String = path.substr(i, 1)
        if ch == "/" {
            return path.substr(0, i + 1)
        }
        i = i - 1
    }
    return ""
}

// Join import path segments with "/": ["stdlib", "math"] -> "stdlib/math"
fn join_import_path(segments: List<String>) -> String {
    let mut result: String = ""
    let mut i: Int = 0
    let n: Int = len(segments)
    for _ in 0..20 {
        if i >= n { return result }
        if i > 0 {
            result = result + "/" + segments[i]
        } else {
            result = segments[i]
        }
        i = i + 1
    }
    return result
}

// Try a single directory + relative path combination.
fn try_resolve(dir: String, rel: String) -> String {
    let c1: String = dir + rel + ".mn"
    let r1: String = __mn_file_read_or_empty(c1)
    if len(r1) > 0 { return c1 }
    let c2: String = dir + rel + "/mod.mn"
    let r2: String = __mn_file_read_or_empty(c2)
    if len(r2) > 0 { return c2 }
    return ""
}

// Resolve an import path to a file path, reading to check existence.
// Search order: source_dir, parent dirs of source_dir, then CWD.
// Returns "" if not found.
fn resolve_import_file(segments: List<String>, source_dir: String) -> String {
    let rel: String = join_import_path(segments)
    // Try relative to source directory and each parent up to root
    let mut dir: String = source_dir
    for _ in 0..20 {
        if len(dir) == 0 {
            // Try CWD-relative (empty prefix)
            let cwd_result: String = try_resolve("", rel)
            if len(cwd_result) > 0 { return cwd_result }
            return ""
        }
        let result: String = try_resolve(dir, rel)
        if len(result) > 0 { return result }
        // Climb to parent: strip trailing slash, then find last slash
        let trimmed: String = dir.substr(0, len(dir) - 1)
        dir = dir_of_path(trimmed)
    }
    return ""
}

// ---------------------------------------------------------------------------
// Import resolution — read imported files, parse, merge definitions
// ---------------------------------------------------------------------------

// Resolve all imports in a program. Reads imported files, parses them,
// and prepends their definitions to the program.
// visited tracks already-resolved files to prevent circular imports.
fn resolve_imports(program: Program, filename: String, visited: List<String>) -> Program {
    let source_dir: String = dir_of_path(filename)
    let mut all_defs: List<Definition> = []
    let mut vis: List<String> = visited
    vis.push(filename)

    // First pass: find and resolve import definitions
    let mut i: Int = 0
    let ndefs: Int = len(program.definitions)
    for _ in 0..2000 {
        if i >= ndefs {
            // Append the original non-import definitions
            let mut j: Int = 0
            for _ in 0..10000 {
                if j >= ndefs { return start(all_defs) }
                let defn_j: Definition = program.definitions[j]
                if def_kind(defn_j) != "import_def" {
                    all_defs.push(defn_j)
                }
                j = j + 1
            }
            return start(all_defs)
        }
        let defn: Definition = program.definitions[i]
        if def_kind(defn) == "import_def" {
            let imp_path: List<String> = def_import_path(defn)
            if len(imp_path) > 0 {
                let resolved_file: String = resolve_import_file(imp_path, source_dir)
                if len(resolved_file) > 0 {
                    // Check if already visited (circular import guard)
                    if is_visited(vis, resolved_file) == false {
                        vis.push(resolved_file)
                        let imp_source: String = __mn_file_read_or_empty(resolved_file)
                        if len(imp_source) > 0 {
                            let imp_program: Program = parse(imp_source, resolved_file)
                            // Recursively resolve imports in the imported module
                            let resolved_imp: Program = resolve_imports(imp_program, resolved_file, vis)
                            // Prepend imported definitions (skip import defs themselves)
                            let mut k: Int = 0
                            let nimp: Int = len(resolved_imp.definitions)
                            for _ in 0..10000 {
                                if k >= nimp { k = nimp + 1 }
                                if k < nimp {
                                    all_defs.push(resolved_imp.definitions[k])
                                    k = k + 1
                                }
                            }
                        }
                    }
                }
            }
        }
        i = i + 1
    }
    return start(all_defs)
}

fn is_visited(visited: List<String>, path: String) -> Bool {
    let mut i: Int = 0
    let n: Int = len(visited)
    for _ in 0..100 {
        if i >= n { return false }
        if visited[i] == path { return true }
        i = i + 1
    }
    return false
}

// ---------------------------------------------------------------------------
// compile — run the full pipeline on a source string
// ---------------------------------------------------------------------------

fn compile(source: String, filename: String) -> CompileResult {
    // Stage 1: parse
    let program: Program = parse(source, filename)

    // Stage 2: resolve imports — read imported files, parse, merge definitions
    let visited: List<String> = []
    let resolved: Program = resolve_imports(program, filename, visited)

    // Stage 3: lower AST to MIR
    let mir_module: MIRModule = lower(resolved, filename)

    // Stage 4: emit LLVM IR from MIR
    let ir_text: String = emit_mir_module(mir_module, filename)
    let no_errors: List<SemanticError> = []
    return new_compile_result(true, ir_text, no_errors)
}

// ---------------------------------------------------------------------------
// format_error — format a SemanticError for display
// ---------------------------------------------------------------------------

fn format_error(err: SemanticError) -> String {
    return err.filename + ":" + toString(err.line) + ":" + toString(err.column) + ": error: " + err.message
}

// ---------------------------------------------------------------------------
// compile_and_print — compile and print result or errors
// ---------------------------------------------------------------------------

fn compile_and_print(source: String, filename: String) -> CompileResult {
    let cr: CompileResult = compile(source, filename)

    if cr.success {
        print(cr.ir_text)
    } else {
        for i in 0..len(cr.errors) {
            let err: SemanticError = cr.errors[i]
            print(format_error(err))
        }
    }
    return cr
}

// ---------------------------------------------------------------------------
// mn_main — native compiler entry point (called from C shim)
//
// Reads source file from argv[1], compiles to LLVM IR, prints to stdout.
// Errors go to stderr. Returns exit code via __mn_exit.
// ---------------------------------------------------------------------------

fn mn_main() {
    if __mn_argc() < 2 {
        __mn_str_eprint("usage: mnc <file.mn>\n")
        __mn_exit(1)
    }
    let filename: String = __mn_argv(1)
    let source: String = __mn_file_read_or_empty(filename)
    if len(source) < 0 {
        __mn_str_eprint("error: cannot read file '")
        __mn_str_eprint(filename)
        __mn_str_eprint("'\n")
        __mn_exit(1)
    }
    let cr: CompileResult = compile(source, filename)
    if cr.success {
        print(cr.ir_text)
    } else {
        for i in 0..len(cr.errors) {
            let err: SemanticError = cr.errors[i]
            __mn_str_eprint(format_error(err))
            __mn_str_eprint("\n")
        }
        __mn_exit(1)
    }
}
