// Auto-generated: all self-hosted compiler modules concatenated.
// Do not edit — regenerate with: python scripts/concat_self.py

// ===== ast.mn =====
// ast.mn — AST node definitions for the Mapanare self-hosted compiler.
// Port of mapa/ast_nodes.py to native Mapanare.

// ---------------------------------------------------------------------------
// Base
// ---------------------------------------------------------------------------

struct Span {
    line: Int,
    column: Int,
    end_line: Int,
    end_column: Int
}

struct ASTNode {
    span: Span
}

// ---------------------------------------------------------------------------
// Program (root)
// ---------------------------------------------------------------------------

struct Program {
    span: Span,
    definitions: List<Definition>
}

fn make_span(line: Int, column: Int, end_line: Int, end_column: Int) -> Span {
    return new Span { line: line, column: column, end_line: end_line, end_column: end_column }
}

fn start(defs: List<Definition>) -> Program {
    return new Program { span: make_span(1, 0, 1, 0), definitions: defs }
}

// ---------------------------------------------------------------------------
// Type annotations
// ---------------------------------------------------------------------------

enum TypeExpr {
    Named(String),
    Generic(String, List<TypeExpr>),
    TensorTy(TypeExpr, List<Expr>),
    FnTy(List<TypeExpr>, TypeExpr)
}

// ---------------------------------------------------------------------------
// Expressions
// ---------------------------------------------------------------------------

enum LambdaBody {
    ExprBody(Expr),
    BlockBody(Block)
}

enum ElseClause {
    ElseBlock(Block),
    ElseIf(Expr, Block, Option<ElseClause>)
}

struct MapEntry {
    key: Expr,
    value: Expr
}

enum Expr {
    IntLit(Int),
    FloatLit(Float),
    StringLit(String),
    CharLit(String),
    BoolLit(Bool),
    NoneLit,
    Ident(String),
    Binary(Expr, String, Expr),
    Unary(String, Expr),
    Call(Expr, List<Expr>),
    MethodCall(Expr, String, List<Expr>),
    FieldAccess(Expr, String),
    NamespaceAccess(String, String),
    Index(Expr, Expr),
    Pipe(Expr, Expr),
    Range(Expr, Expr, Bool),
    Lambda(List<Param>, LambdaBody),
    Spawn(Expr, List<Expr>),
    Sync(Expr),
    Send(Expr, Expr),
    ErrorProp(Expr),
    ListLit(List<Expr>),
    MapLit(List<MapEntry>),
    Construct(String, List<FieldInit>),
    SomeWrap(Expr),
    OkWrap(Expr),
    ErrWrap(Expr),
    SignalVal(Expr, Bool),
    Assign(Expr, String, Expr),
    If(Expr, Block, Option<ElseClause>),
    Match(Expr, List<MatchArm>)
}

// ---------------------------------------------------------------------------
// Statements
// ---------------------------------------------------------------------------

enum Stmt {
    Let(String, Bool, Option<TypeExpr>, Expr),
    ExprStmt(Expr),
    Return(Option<Expr>),
    For(String, Expr, Block),
    SignalDecl(String, Bool, Option<TypeExpr>, Expr, Bool),
    StreamDecl(String, Option<TypeExpr>, Expr)
}

struct Block {
    span: Span,
    stmts: List<Stmt>
}

// ---------------------------------------------------------------------------
// Patterns (for match)
// ---------------------------------------------------------------------------

enum Pattern {
    Wildcard,
    IdentPat(String),
    LiteralPat(Expr),
    ConstructorPat(String, List<Pattern>)
}

struct MatchArm {
    span: Span,
    pattern: Pattern,
    body: MatchArmBody
}

enum MatchArmBody {
    ExprBody(Expr),
    BlockBody(Block)
}

// ---------------------------------------------------------------------------
// Definitions
// ---------------------------------------------------------------------------

struct Decorator {
    span: Span,
    name: String,
    args: List<Expr>
}

struct Param {
    span: Span,
    name: String,
    type_annotation: Option<TypeExpr>
}

struct FieldInit {
    span: Span,
    name: String,
    value: Expr
}

struct FnDefData {
    span: Span,
    name: String,
    public: Bool,
    type_params: List<String>,
    params: List<Param>,
    return_type: Option<TypeExpr>,
    body: Block,
    decorators: List<Decorator>
}

struct AgentInput {
    span: Span,
    name: String,
    type_annotation: TypeExpr
}

struct AgentOutput {
    span: Span,
    name: String,
    type_annotation: TypeExpr
}

struct AgentDefData {
    span: Span,
    name: String,
    public: Bool,
    inputs: List<AgentInput>,
    outputs: List<AgentOutput>,
    state: List<Stmt>,
    methods: List<FnDefData>,
    decorators: List<Decorator>
}

struct PipeDefData {
    span: Span,
    name: String,
    public: Bool,
    stages: List<Expr>
}

struct StructField {
    span: Span,
    name: String,
    type_annotation: TypeExpr
}

struct StructDefData {
    span: Span,
    name: String,
    public: Bool,
    type_params: List<String>,
    fields: List<StructField>
}

struct EnumVariant {
    span: Span,
    name: String,
    fields: List<TypeExpr>
}

struct EnumDefData {
    span: Span,
    name: String,
    public: Bool,
    type_params: List<String>,
    variants: List<EnumVariant>
}

enum Definition {
    FnDef(FnDefData),
    AgentDef(AgentDefData),
    PipeDef(PipeDefData),
    StructDef(StructDefData),
    EnumDef(EnumDefData),
    TypeAlias(String, TypeExpr),
    ImplDef(String, List<FnDefData>),
    ImportDef(List<String>, List<String>),
    ExportDef(Option<Definition>, List<String>),
    ExternFnDef(String, String, List<Param>, Option<TypeExpr>)
}

// ---------------------------------------------------------------------------
// Helper constructors
// ---------------------------------------------------------------------------

fn make_named_type(name: String) -> TypeExpr {
    return TypeExpr::Named(name)
}

fn make_void_type() -> TypeExpr {
    return TypeExpr::Named("Void")
}

fn make_int_type() -> TypeExpr {
    return TypeExpr::Named("Int")
}

fn make_float_type() -> TypeExpr {
    return TypeExpr::Named("Float")
}

fn make_bool_type() -> TypeExpr {
    return TypeExpr::Named("Bool")
}

fn make_string_type() -> TypeExpr {
    return TypeExpr::Named("String")
}

// Shared AST constructors (used by parser.mn and lower.mn)

fn new_span(line: Int, col: Int, end_line: Int, end_col: Int) -> Span {
    return new Span { line: line, column: col, end_line: end_line, end_column: end_col }
}

fn new_block(span: Span, stmts: List<Stmt>) -> Block {
    return new Block { span: span, stmts: stmts }
}

fn new_fn_def_data(span: Span, name: String, public: Bool, type_params: List<String>, params: List<Param>, return_type: Option<TypeExpr>, body: Block, decorators: List<Decorator>) -> FnDefData {
    return new FnDefData { span: span, name: name, public: public, type_params: type_params, params: params, return_type: return_type, body: body, decorators: decorators }
}

// ---------------------------------------------------------------------------
// String-tagged dispatch: kind functions + field accessors
// These functions use match WITHIN ast.mn (same module as the enum defs),
// so enum tags are always correct.  Consumers in other modules call these
// instead of matching on Expr/Stmt/Definition directly.
// ---------------------------------------------------------------------------

// ---- Expr kind + accessors ------------------------------------------------

pub fn expr_kind(e: Expr) -> String {
    match e {
        IntLit(_) => { return "int_lit" },
        FloatLit(_) => { return "float_lit" },
        StringLit(_) => { return "string_lit" },
        CharLit(_) => { return "char_lit" },
        BoolLit(_) => { return "bool_lit" },
        NoneLit => { return "none_lit" },
        Ident(_) => { return "ident" },
        Binary(_, _, _) => { return "binary" },
        Unary(_, _) => { return "unary" },
        Call(_, _) => { return "call" },
        MethodCall(_, _, _) => { return "method_call" },
        FieldAccess(_, _) => { return "field_access" },
        NamespaceAccess(_, _) => { return "namespace_access" },
        Index(_, _) => { return "index" },
        Pipe(_, _) => { return "pipe" },
        Range(_, _, _) => { return "range" },
        Lambda(_, _) => { return "lambda" },
        Spawn(_, _) => { return "spawn" },
        Sync(_) => { return "sync" },
        Send(_, _) => { return "send" },
        ErrorProp(_) => { return "error_prop" },
        ListLit(_) => { return "list_lit" },
        MapLit(_) => { return "map_lit" },
        Construct(_, _) => { return "construct" },
        SomeWrap(_) => { return "some_wrap" },
        OkWrap(_) => { return "ok_wrap" },
        ErrWrap(_) => { return "err_wrap" },
        SignalVal(_, _) => { return "signal_val" },
        Assign(_, _, _) => { return "assign" },
        If(_, _, _) => { return "if" },
        Match(_, _) => { return "match" }
    }
}

// Literal accessors
pub fn expr_int_val(e: Expr) -> Int {
    match e { IntLit(n) => { return n }, _ => { return 0 } }
}
pub fn expr_float_val(e: Expr) -> Float {
    match e { FloatLit(f) => { return f }, _ => { return 0.0 } }
}
pub fn expr_string_val(e: Expr) -> String {
    match e { StringLit(s) => { return s }, _ => { return "" } }
}
pub fn expr_char_val(e: Expr) -> String {
    match e { CharLit(c) => { return c }, _ => { return "" } }
}
pub fn expr_bool_val(e: Expr) -> Bool {
    match e { BoolLit(b) => { return b }, _ => { return false } }
}

// Ident
pub fn expr_ident_name(e: Expr) -> String {
    match e { Ident(n) => { return n }, _ => { return "" } }
}

// Binary
pub fn expr_binary_left(e: Expr) -> Expr {
    match e { Binary(l, _, _) => { return l }, _ => { return Expr::NoneLit } }
}
pub fn expr_binary_op(e: Expr) -> String {
    match e { Binary(_, o, _) => { return o }, _ => { return "" } }
}
pub fn expr_binary_right(e: Expr) -> Expr {
    match e { Binary(_, _, r) => { return r }, _ => { return Expr::NoneLit } }
}

// Unary
pub fn expr_unary_op(e: Expr) -> String {
    match e { Unary(o, _) => { return o }, _ => { return "" } }
}
pub fn expr_unary_operand(e: Expr) -> Expr {
    match e { Unary(_, x) => { return x }, _ => { return Expr::NoneLit } }
}

// Call
pub fn expr_call_callee(e: Expr) -> Expr {
    match e { Call(c, _) => { return c }, _ => { return Expr::NoneLit } }
}
pub fn expr_call_args(e: Expr) -> List<Expr> {
    match e { Call(_, a) => { return a }, _ => { let empty: List<Expr> = []; return empty } }
}

// MethodCall
pub fn expr_method_obj(e: Expr) -> Expr {
    match e { MethodCall(o, _, _) => { return o }, _ => { return Expr::NoneLit } }
}
pub fn expr_method_name(e: Expr) -> String {
    match e { MethodCall(_, n, _) => { return n }, _ => { return "" } }
}
pub fn expr_method_args(e: Expr) -> List<Expr> {
    match e { MethodCall(_, _, a) => { return a }, _ => { let empty: List<Expr> = []; return empty } }
}

// FieldAccess
pub fn expr_field_obj(e: Expr) -> Expr {
    match e { FieldAccess(o, _) => { return o }, _ => { return Expr::NoneLit } }
}
pub fn expr_field_name(e: Expr) -> String {
    match e { FieldAccess(_, n) => { return n }, _ => { return "" } }
}

// NamespaceAccess
pub fn expr_ns_name(e: Expr) -> String {
    match e { NamespaceAccess(n, _) => { return n }, _ => { return "" } }
}
pub fn expr_ns_member(e: Expr) -> String {
    match e { NamespaceAccess(_, m) => { return m }, _ => { return "" } }
}

// Index
pub fn expr_index_obj(e: Expr) -> Expr {
    match e { Index(o, _) => { return o }, _ => { return Expr::NoneLit } }
}
pub fn expr_index_idx(e: Expr) -> Expr {
    match e { Index(_, x) => { return x }, _ => { return Expr::NoneLit } }
