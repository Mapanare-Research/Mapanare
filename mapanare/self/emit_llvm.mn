// emit_llvm.mn — LLVM IR emitter for the Mapanare self-hosted compiler.
// Consumes MIR (from lower.mn) and produces LLVM IR text (string-based).
//
// Architecture:
//   - emit_mir_module walks MIR structs, enums, extern fns, then functions
//   - emit_mir_function emits function header + basic blocks
//   - emit_mir_basic_block emits block label + instructions
//   - emit_mir_instruction maps each MIR opcode to LLVM IR instructions
//   - A local counter produces unique SSA names (%0, %1, ...)
//
// LLVM type constants and IR string builders are in emit_llvm_ir.mn.

import self::mir
import self::emit_llvm_ir

// ---------------------------------------------------------------------------
// Emitter state
// ---------------------------------------------------------------------------

struct StructEntry {
    name: String,
    field_names: List<String>,
    field_types: List<String>,
    llvm_type: String
}

fn new_struct_entry(name: String, fields: List<String>, types: List<String>, ty: String) -> StructEntry {
    return new StructEntry { name: name, field_names: fields, field_types: types, llvm_type: ty }
}

fn lookup_struct_field_types(st: EmitState, name: String) -> List<String> {
    let mut i: Int = 0
    let nstructs: Int = len(st.structs)
    for _ in 0..10000 {
        if i < nstructs {
            let entry: StructEntry = st.structs[i]
            if entry.name == name {
                return entry.field_types
            }
            i = i + 1
        }
    }
    let empty: List<String> = []
    return empty
}

struct FnEntry {
    name: String,
    ret_type: String,
    param_types: List<String>
}

fn new_fn_entry(name: String, ret: String, params: List<String>) -> FnEntry {
    return new FnEntry { name: name, ret_type: ret, param_types: params }
}

struct EmitState {
    lines: List<String>,
    counter: Int,
    functions: List<FnEntry>,
    structs: List<StructEntry>,
    module_name: String,
    str_counter: Int,
    str_globals: List<String>,
    current_ret_type: String,
    enum_names: List<String>,
    enum_infos: List<EnumInfo>
}

fn new_emit_state(module_name: String) -> EmitState {
    let lines: List<String> = []
    let functions: List<FnEntry> = []
    // Build internal struct entries BEFORE constructing EmitState.
    // This avoids the circular dependency: pushing to st.structs needs
    // EmitState field info, but EmitState isn't registered yet.
    let structs: List<StructEntry> = build_internal_struct_list()
    let str_globals: List<String> = []
    let enum_names: List<String> = []
    let enum_infos: List<EnumInfo> = []
    return new EmitState { lines: lines, counter: 0, functions: functions, structs: structs, module_name: module_name, str_counter: 0, str_globals: str_globals, current_ret_type: "void", enum_names: enum_names, enum_infos: enum_infos }
}

fn build_internal_struct_list() -> List<StructEntry> {
    let mut list: List<StructEntry> = []
    // StructEntry MUST be first — make_entry creates StructEntry values,
    // and the emitter needs StructEntry's field info to generate correct
    // insertvalue indices for subsequent make_entry calls.
    list.push(make_entry("StructEntry", ["name", "field_names", "field_types", "llvm_type"]))
    list.push(make_entry("MIRModule", ["name", "functions", "structs", "enums", "extern_fns", "agents", "pipes", "imports", "trait_names"]))
    list.push(make_entry("LowerState", ["module", "current_fn", "current_block_idx", "tmp_counter", "block_counter", "vars", "scope_stack", "impl_methods", "struct_fields", "enum_variants", "lambda_vars"]))
    list.push(make_entry("EmitState", ["lines", "counter", "functions", "structs", "module_name", "str_counter", "str_globals", "current_ret_type", "enum_names", "enum_infos"]))
    list.push(make_entry("LowerResult", ["value", "state"]))
    list.push(make_entry("CompileResult", ["success", "ir_text", "errors"]))
    list.push(make_entry("MatchBuildResult", ["state", "arm_labels", "arm_indices", "arm_body_labels", "merge_label"]))
    list.push(make_entry("FnEntry", ["name", "ret_type", "param_types"]))
    // StructEntry already registered first (above)
    list.push(make_entry("VarInfo", ["name", "value", "mutable"]))
    list.push(make_entry("StructFieldInfo", ["struct_name", "field_names", "field_types"]))
    list.push(make_entry("EnumVariantNames", ["name", "variant_names"]))
    list.push(make_entry("LambdaEntry", ["var_name", "body_name"]))
    list.push(make_entry("ExternFnInfo", ["abi", "module_name", "fn_name", "param_types", "return_type"]))
    list.push(make_entry("VerifyError", ["fn_name", "block_name", "message"]))
    list.push(make_entry("ImplEntry", ["key", "method_name"]))
    list.push(make_entry("ImportInfo", ["path", "items"]))
    list.push(make_entry("AgentInfo", ["name", "inputs", "outputs", "state_fields"]))
    list.push(make_entry("PipeInfo", ["name", "stages"]))
    list.push(make_entry("MIRFunction", ["name", "params", "return_type", "blocks", "decorators", "is_public"]))
    list.push(make_entry("BasicBlock", ["label", "instructions"]))
    list.push(make_entry("MIRType", ["kind", "name", "args"]))
    list.push(make_entry("Value", ["name", "ty"]))
    return list
}

fn make_entry(name: String, field_names: List<String>) -> StructEntry {
    let types: List<String> = []
    return new_struct_entry(name, field_names, types, "%struct." + name)
}

// Pre-register internal compiler struct types that may not be in the MIR module.
// Without these, find_field_index returns 0 for all fields (index-0 bug).
fn register_internal_struct(st: EmitState, name: String, fields: List<String>) -> EmitState {
    let types: List<String> = []
    let entry: StructEntry = new_struct_entry(name, fields, types, "%struct." + name)
    st.structs.push(entry)
    return st
}

fn register_all_internal_structs(st: EmitState) -> EmitState {
    let mut s: EmitState = st
    // MIRModule: name, functions, structs, enums, extern_fns, agents, pipes, imports, trait_names
    s = register_internal_struct(s, "MIRModule", ["name", "functions", "structs", "enums", "extern_fns", "agents", "pipes", "imports", "trait_names"])
    // LowerState: module, current_fn, current_block_idx, tmp_counter, block_counter, vars, scope_stack, impl_methods, struct_fields, enum_variants, lambda_vars
    s = register_internal_struct(s, "LowerState", ["module", "current_fn", "current_block_idx", "tmp_counter", "block_counter", "vars", "scope_stack", "impl_methods", "struct_fields", "enum_variants", "lambda_vars"])
    // EmitState: lines, counter, functions, structs, module_name, str_counter, str_globals, current_ret_type, enum_names, enum_infos
    s = register_internal_struct(s, "EmitState", ["lines", "counter", "functions", "structs", "module_name", "str_counter", "str_globals", "current_ret_type", "enum_names", "enum_infos"])
    // LowerResult: value, state
    s = register_internal_struct(s, "LowerResult", ["value", "state"])
    // CompileResult: success, ir_text, errors
    s = register_internal_struct(s, "CompileResult", ["success", "ir_text", "errors"])
    // MatchBuildResult: state, arm_labels, arm_indices, arm_body_labels, merge_label
    s = register_internal_struct(s, "MatchBuildResult", ["state", "arm_labels", "arm_indices", "arm_body_labels", "merge_label"])
    // FnEntry: name, ret_type, param_types
    s = register_internal_struct(s, "FnEntry", ["name", "ret_type", "param_types"])
    // StructEntry: name, field_names, field_types, llvm_type
    s = register_internal_struct(s, "StructEntry", ["name", "field_names", "field_types", "llvm_type"])
    // VarInfo: name, value, mutable
    s = register_internal_struct(s, "VarInfo", ["name", "value", "mutable"])
    // StructFieldInfo: struct_name, field_names, field_types
    s = register_internal_struct(s, "StructFieldInfo", ["struct_name", "field_names", "field_types"])
    // EnumVariantNames: name, variant_names
    s = register_internal_struct(s, "EnumVariantNames", ["name", "variant_names"])
    // LambdaEntry: var_name, body_name
    s = register_internal_struct(s, "LambdaEntry", ["var_name", "body_name"])
    // ExternFnInfo: abi, module_name, fn_name, param_types, return_type
    s = register_internal_struct(s, "ExternFnInfo", ["abi", "module_name", "fn_name", "param_types", "return_type"])
    // VerifyError: fn_name, block_name, message
    s = register_internal_struct(s, "VerifyError", ["fn_name", "block_name", "message"])
    // ImplEntry: key, method_name
    s = register_internal_struct(s, "ImplEntry", ["key", "method_name"])
    // ImportInfo: path, items
    s = register_internal_struct(s, "ImportInfo", ["path", "items"])
    // AgentInfo: name, inputs, outputs, state_fields
    s = register_internal_struct(s, "AgentInfo", ["name", "inputs", "outputs", "state_fields"])
    // PipeInfo: name, stages
    s = register_internal_struct(s, "PipeInfo", ["name", "stages"])
    // MIRFunction: name, params, return_type, blocks, decorators, is_public
    s = register_internal_struct(s, "MIRFunction", ["name", "params", "return_type", "blocks", "decorators", "is_public"])
    // BasicBlock: label, instructions
    s = register_internal_struct(s, "BasicBlock", ["label", "instructions"])
    // MIRType: kind, name, args
    s = register_internal_struct(s, "MIRType", ["kind", "name", "args"])
    // Value: name, ty
    s = register_internal_struct(s, "Value", ["name", "ty"])
    return s
}

fn emit_global(st: EmitState, line: String) -> EmitState {
    st.str_globals.push(line)
    return st
}

fn emit_fresh_tmp(st: EmitState, prefix: String) -> String {
    return prefix + "." + toString(st.counter)
}

// ---------------------------------------------------------------------------
// Line emission
// ---------------------------------------------------------------------------

fn emit_line(st: EmitState, line: String) -> EmitState {
    st.lines.push(line)
    return st
}

fn emit_blank(st: EmitState) -> EmitState {
    return emit_line(st, "")
}

// ---------------------------------------------------------------------------
// Counter helpers
// ---------------------------------------------------------------------------

fn next_ssa(st: EmitState) -> EmitState {
    // Returns state with counter incremented; caller uses st.counter for name
    return st
}

fn ssa_name(st: EmitState) -> String {
    return "%" + toString(st.counter)
}

fn next_str_name(st: EmitState) -> String {
    return "@str." + toString(st.str_counter)
}

// ---------------------------------------------------------------------------
// Lookup helpers
// ---------------------------------------------------------------------------

fn find_function(st: EmitState, name: String) -> Option<FnEntry> {
    let mut i: Int = len(st.functions) - 1
    for _ in 0..600 {
        if i < 0 { return none }
        let f: FnEntry = st.functions[i]
        if f.name == name { return Some(f) }
        i = i - 1
    }
    return none
}

fn find_struct_entry(st: EmitState, name: String) -> Option<StructEntry> {
    let mut i: Int = len(st.structs) - 1
    for _ in 0..600 {
        if i < 0 { return none }
        let s: StructEntry = st.structs[i]
        if s.name == name { return Some(s) }
        i = i - 1
    }
    return none
}

// ---------------------------------------------------------------------------
// State-aware type resolution (corrects struct→enum misclassification)
// ---------------------------------------------------------------------------

fn resolve_type(st: EmitState, ty: MIRType) -> String {
    let resolved: String = resolve_mir_type(ty)
    if resolved.starts_with("%struct.") && is_enum_type(st, ty.name) {
        return "%enum." + ty.name
    }
    return resolved
}

// ---------------------------------------------------------------------------
// Runtime function declarations
// ---------------------------------------------------------------------------

fn declare_runtime_fn(st: EmitState, name: String, ret: String, params: String) -> EmitState {
    let line: String = "declare " + ret + " @" + name + "(" + params + ")"
    return emit_line(st, line)
}

fn declare_all_runtime(st: EmitState) -> EmitState {
    let mut s: EmitState = st

    // String runtime
    s = declare_runtime_fn(s, "__mn_str_concat", llvm_string(), llvm_string() + ", " + llvm_string())
    s = declare_runtime_fn(s, "__mn_str_eq", llvm_int(), llvm_string() + ", " + llvm_string())
    s = declare_runtime_fn(s, "__mn_str_cmp", llvm_int(), llvm_string() + ", " + llvm_string())
    s = declare_runtime_fn(s, "__mn_str_len", llvm_int(), llvm_string())
    s = declare_runtime_fn(s, "__mn_str_char_at", llvm_string(), llvm_string() + ", i64")
    s = declare_runtime_fn(s, "__mn_str_byte_at", llvm_int(), llvm_string() + ", i64")
    s = declare_runtime_fn(s, "__mn_str_substr", llvm_string(), llvm_string() + ", i64, i64")
    s = declare_runtime_fn(s, "__mn_str_from_int", llvm_string(), "i64")
    s = declare_runtime_fn(s, "__mn_str_from_bool", llvm_string(), "i1")
    s = declare_runtime_fn(s, "__mn_str_from_float", llvm_string(), "double")
    s = declare_runtime_fn(s, "__mn_str_to_int", llvm_int(), llvm_string())
    s = declare_runtime_fn(s, "__mn_str_to_float", llvm_float(), llvm_string())
    s = declare_runtime_fn(s, "__mn_str_println", "void", llvm_string())
    s = declare_runtime_fn(s, "__mn_str_print", "void", llvm_string())
    s = declare_runtime_fn(s, "__mn_str_starts_with", llvm_bool(), llvm_string() + ", " + llvm_string())
    s = declare_runtime_fn(s, "__mn_str_ends_with", llvm_bool(), llvm_string() + ", " + llvm_string())
    s = declare_runtime_fn(s, "__mn_str_find", llvm_int(), llvm_string() + ", " + llvm_string())
    s = declare_runtime_fn(s, "__mn_str_join", llvm_string(), llvm_string() + ", ptr")

    // List runtime
    s = declare_runtime_fn(s, "__mn_list_new", llvm_list_rt(), "i64")
    s = declare_runtime_fn(s, "__mn_list_push", "void", "ptr, ptr")
    s = declare_runtime_fn(s, "__mn_list_get", "ptr", "ptr, i64")
    s = declare_runtime_fn(s, "__mn_list_len", "i64", "ptr")
    s = declare_runtime_fn(s, "__mn_list_set", "void", "ptr, i64, ptr")

    // Iterator runtime
    s = declare_runtime_fn(s, "__iter_has_next", llvm_bool(), "{ i64, i64 }")
    s = declare_runtime_fn(s, "__iter_next", llvm_int(), "{ i64, i64 }")
    s = declare_runtime_fn(s, "__mn_range", "{ i64, i64 }", "i64, i64")

    // String methods
    s = declare_runtime_fn(s, "__mn_str_to_upper", llvm_string(), llvm_string())
    s = declare_runtime_fn(s, "__mn_str_to_lower", llvm_string(), llvm_string())
    s = declare_runtime_fn(s, "__mn_str_replace", llvm_string(), llvm_string() + ", " + llvm_string() + ", " + llvm_string())
    s = declare_runtime_fn(s, "__mn_str_split", llvm_list_rt(), llvm_string() + ", " + llvm_string())
    s = declare_runtime_fn(s, "__mn_str_trim", llvm_string(), llvm_string())
    s = declare_runtime_fn(s, "__mn_str_contains", llvm_bool(), llvm_string() + ", " + llvm_string())

    // Panic
    s = declare_runtime_fn(s, "__mn_panic", "void", llvm_string())

    // Malloc (for enum payload allocation)
    s = declare_runtime_fn(s, "malloc", "ptr", "i64")

    // Printf
    s = declare_runtime_fn(s, "printf", "i32", "ptr, ...")

    // Tensor runtime
    s = declare_runtime_fn(s, "__mapanare_tensor_add", "ptr", "ptr, ptr")
    s = declare_runtime_fn(s, "__mapanare_tensor_sub", "ptr", "ptr, ptr")
    s = declare_runtime_fn(s, "__mapanare_tensor_mul", "ptr", "ptr, ptr")
    s = declare_runtime_fn(s, "__mapanare_tensor_div", "ptr", "ptr, ptr")
    s = declare_runtime_fn(s, "__mapanare_matmul", "ptr", "ptr, ptr")
    s = declare_runtime_fn(s, "__mapanare_tensor_alloc", "ptr", "i64, i64*, i64")
    s = declare_runtime_fn(s, "__mapanare_tensor_free", "void", "ptr")
    s = declare_runtime_fn(s, "__mapanare_tensor_shape_eq", "i1", "ptr, ptr")
    s = declare_runtime_fn(s, "__mapanare_detect_gpus", "ptr", "")

    // Agent runtime
    s = declare_runtime_fn(s, "__mn_agent_spawn", "ptr", "ptr, ptr")
    s = declare_runtime_fn(s, "__mn_agent_send", "void", "ptr, ptr, ptr")
    s = declare_runtime_fn(s, "__mn_agent_sync", "ptr", "ptr, ptr")

    // Signal runtime
    s = declare_runtime_fn(s, "__mn_signal_new", "ptr", "ptr")
    s = declare_runtime_fn(s, "__mn_signal_get", "ptr", "ptr")
    s = declare_runtime_fn(s, "__mn_signal_set", "void", "ptr, ptr")

    return emit_blank(s)
}

// ---------------------------------------------------------------------------
// Struct type registration from MIR
// ---------------------------------------------------------------------------

fn register_mir_struct(st: EmitState, info: StructInfo) -> EmitState {
    let mut field_names: List<String> = []
    let mut field_types: List<String> = []
    let mut llvm_fields: String = ""
    let mut fi: Int = 0

    for _ in 0..50 {
        if fi >= len(info.fields) {
            let ty: String = "{ " + llvm_fields + " }"
            let entry: StructEntry = new_struct_entry(info.name, field_names, field_types, ty)
            st.structs.push(entry)

            // Emit named struct type definition
            let mut s: EmitState = emit_line(st, "%struct." + info.name + " = type " + ty)
            return s
        }
        let fp: FieldPair = info.fields[fi]
        let mut fty: String = resolve_mir_type(fp.val.ty)
        // Detect self-referential fields (e.g. TypeInfo has Option<TypeInfo>).
        // Replace with ptr to avoid infinite recursion in LLVM type layout.
        // Use boundary-aware match: check for exact type name followed by
        // non-alphanumeric (space, comma, }, etc.) to avoid false positives
        // like MatchArm matching MatchArmBody.
        let self_struct: String = "%struct." + info.name + " "
        let self_struct2: String = "%struct." + info.name + "}"
        let self_enum: String = "%enum." + info.name + " "
        let self_enum2: String = "%enum." + info.name + "}"
        if fty.contains(self_struct) || fty.contains(self_struct2) || fty.contains(self_enum) || fty.contains(self_enum2) {
            fty = llvm_ptr()
        }
        field_names.push(fp.name)
        field_types.push(fty)
        if fi > 0 {
            llvm_fields = llvm_fields + ", " + fty
        } else {
            llvm_fields = fty
        }
        fi = fi + 1
    }
    return st
}

// ---------------------------------------------------------------------------
// Enum type registration from MIR
// ---------------------------------------------------------------------------

fn is_enum_type(st: EmitState, name: String) -> Bool {
    let mut i: Int = 0
    for _ in 0..10000 {
        if i >= len(st.enum_names) { return false }
        if st.enum_names[i] == name { return true }
        i = i + 1
    }
    return false
}

// Compute size of an LLVM type in i64 units (8-byte slots)
fn type_size_in_slots(st: EmitState, ty: MIRType) -> Int {
    let resolved: String = resolve_mir_type(ty)
    if resolved == "i64" { return 1 }
    if resolved == "double" { return 1 }
    if resolved == "i1" { return 1 }
    if resolved == "i8" { return 1 }
    if resolved == "ptr" { return 1 }
    if resolved == "void" { return 0 }
    // String: { ptr, i64 } = 2 slots
    if resolved == "{ ptr, i64 }" { return 2 }
    // List: { ptr, i64, i64, i64 } = 4 slots
    if resolved == "{ ptr, i64, i64, i64 }" { return 4 }
    // Range: { i64, i64 } = 2 slots
    if resolved == "{ i64, i64 }" { return 2 }
    // Option: { i1, T } ≈ 2 slots minimum
    if ty.kind == "option" {
        if len(ty.args) > 0 {
            return 1 + type_size_in_slots(st, ty.args[0])
        }
        return 2
    }
    // Result: { i1, { T, E } }
    if ty.kind == "result" { return 4 }
    // Map: { ptr, i64 } = 2 slots
    if ty.kind == "map" { return 2 }
    // Enum: 1 (tag) + max_payload_slots.
    // If registered, look up; otherwise return 48 (conservative for recursive enums).
    if ty.kind == "enum" {
        let mut ei: Int = 0
        let neinfos: Int = len(st.enum_infos)
        for _ in 0..50 {
            if ei < neinfos {
                let e_info: EnumInfo = st.enum_infos[ei]
                if e_info.name == ty.name {
                    return 1 + variant_payload_slots_max(st, e_info)
                }
                ei = ei + 1
            }
        }
        // Not registered yet (recursive reference or forward ref): use 48 slots.
        // This is conservative: Expr needs ~30, Stmt ~25, Definition ~32.
        return 48
    }
    // Struct: field_count * 4 (average 4 slots per field — covers Span=4, String=2, List=4)
    if ty.kind == "struct" {
        let struct_opt: Option<StructEntry> = find_struct_entry(st, ty.name)
        match struct_opt {
            Some(se) => { return len(se.field_types) * 4 },
            _ => { return 8 }
        }
    }
    // Default: 8 slots (conservative fallback)
    return 8
}

// Compute actual i64 slot count for a variant's payload.
// Extracted to a helper function because return-inside-for works,
// but cross-scope variable assignment after a for loop does not.
fn variant_payload_slots(st: EmitState, variant: EnumVariantInfo) -> Int {
    let mut total: Int = 0
    let mut pi: Int = 0
    for _ in 0..100 {
        if pi >= len(variant.payload_types) { return total }
        total = total + type_size_in_slots(st, variant.payload_types[pi])
        pi = pi + 1
    }
    return total
}

fn max_int(a: Int, b: Int) -> Int {
    if a > b { return a }
    return b
}

// Max payload slots across all variants of an enum.
fn variant_payload_slots_max(st: EmitState, info: EnumInfo) -> Int {
    let mut mx: Int = 0
    let mut vi: Int = 0
    for _ in 0..50 {
        if vi >= len(info.variants) { return mx }
        let count: Int = variant_payload_slots(st, info.variants[vi])
        // Use max_int instead of `if count > mx { mx = count }` because
        // the Python lowerer generates `store i64 0` for conditional
        // assignments inside for loops (cross-scope assignment bug).
        mx = max_int(mx, count)
        vi = vi + 1
    }
    return mx
}

fn register_mir_enum(st: EmitState, info: EnumInfo) -> EmitState {
    // Pointer-based enum: { i64 tag, ptr payload }.
    // Matches the Python text emitter. Payload is heap-allocated.
    // This handles recursive enums (Expr contains Expr) correctly.
    let mut s: EmitState = st
    s.enum_names.push(info.name)
    s.enum_infos.push(info)
    s = emit_line(s, "%enum." + info.name + " = type { i64, ptr }")
    return s
}

// ---------------------------------------------------------------------------
// Extern function declaration from MIR
// ---------------------------------------------------------------------------

fn declare_mir_extern(st: EmitState, info: ExternFnInfo) -> EmitState {
    let ret_ty: String = resolve_mir_type(info.return_type)
    let mut params_str: String = ""
    let mut i: Int = 0
    let nptypes: Int = len(info.param_types)
    for _ in 0..50 {
        if i < nptypes {
            let pty: String = resolve_mir_type(info.param_types[i])
            if i > 0 {
                params_str = params_str + ", " + pty
            } else {
                params_str = pty
            }
            i = i + 1
        }
    }
    return emit_line(st, "declare " + ret_ty + " @" + info.fn_name + "(" + params_str + ")")
}

// ---------------------------------------------------------------------------
// MIR instruction emission → LLVM IR
// ---------------------------------------------------------------------------

fn emit_mir_instruction(st: EmitState, inst: Instruction) -> EmitState {
    match inst {
        Const(dest, ty, val) => {
            return emit_const(st, dest, ty, val)
        },
        Copy(dest, src) => {
            return emit_copy(st, dest, src)
        },
        Cast(dest, src, target_ty) => {
            return emit_cast(st, dest, src, target_ty)
        },
        BinOp(dest, op, lhs, rhs) => {
            return emit_binop(st, dest, op, lhs, rhs)
        },
        UnaryOp(dest, op, operand) => {
            return emit_unaryop(st, dest, op, operand)
        },
        StructInit(dest, ty, fields) => {
            return emit_struct_init(st, dest, ty, fields)
        },
        FieldGet(dest, obj, field_name) => {
            return emit_field_get(st, dest, obj, field_name)
        },
        FieldSet(obj, field_name, val) => {
            return emit_field_set(st, obj, field_name, val)
        },
        ListInit(dest, elem_ty, elements) => {
            // Check if this is a struct init by looking up dest type name
            // in the struct registry. Enum payload types get corrupted, so
            // we check elem_ty.name and dest.ty.name against known structs.
            let struct_check: Option<StructEntry> = find_struct_entry(st, dest.ty.name)
            let struct_check2: Option<StructEntry> = find_struct_entry(st, elem_ty.name)
            match struct_check {
                Some(_) => {
                    return emit_struct_init_from_values(st, dest, dest.ty, elements)
                },
                _ => {}
            }
            match struct_check2 {
                Some(_) => {
                    return emit_struct_init_from_values(st, dest, elem_ty, elements)
                },
                _ => {}
            }
            return emit_list_init(st, dest, elem_ty, elements)
        },
        IndexGet(dest, obj, idx) => {
            return emit_index_get(st, dest, obj, idx)
        },
        IndexSet(obj, idx, val) => {
            return emit_index_set(st, obj, idx, val)
        },
        Alloca(dest, ty) => {
            return emit_alloca(st, dest, ty)
        },
        Load(dest, ptr) => {
            return emit_load(st, dest, ptr)
        },
        Store(ptr, val) => {
            return emit_store(st, ptr, val)
        },
        MapInit(dest, key_ty, val_ty, pairs) => {
            return emit_map_init(st, dest, key_ty, val_ty, pairs)
        },
        EnumInit(dest, ty, variant, payload) => {
            return emit_enum_init(st, dest, ty, variant, payload)
        },
        EnumTag(dest, val) => {
            return emit_enum_tag(st, dest, val)
        },
        EnumPayload(dest, val, variant) => {
            return emit_enum_payload(st, dest, val, variant)
        },
        WrapSome(dest, val) => {
            return emit_wrap_some(st, dest, val)
        },
        WrapNone(dest, ty) => {
            return emit_wrap_none(st, dest, ty)
        },
        WrapOk(dest, val) => {
            return emit_wrap_ok(st, dest, val)
        },
        WrapErr(dest, val) => {
            return emit_wrap_err(st, dest, val)
        },
        Unwrap(dest, val) => {
            return emit_unwrap(st, dest, val)
        },
        Call(dest, fn_name, args) => {
            return emit_mir_call(st, dest, fn_name, args)
        },
        Return(val_opt) => {
            return emit_mir_return(st, val_opt)
        },
        Jump(target) => {
            return emit_line(st, emit_br(target))
        },
        Branch(cond, true_bb, false_bb) => {
            return emit_line(st, emit_cbranch(cond.name, true_bb, false_bb))
        },
        Switch(tag, cases, default_bb) => {
            return emit_mir_switch(st, tag, cases, default_bb)
        },
        AgentSpawn(dest, ty, args) => {
            return emit_agent_spawn(st, dest, ty, args)
        },
        AgentSend(ag, channel, val) => {
            return emit_agent_send(st, ag, channel, val)
        },
        AgentSync(dest, ag, channel) => {
            return emit_agent_sync(st, dest, ag, channel)
        },
        SignalInit(dest, ty, val) => {
            return emit_signal_init(st, dest, ty, val)
        },
        SignalGet(dest, sig) => {
            return emit_signal_get(st, dest, sig)
        },
        SignalSet(sig, val) => {
            return emit_signal_set(st, sig, val)
        },
        StreamOp(dest, kind, source, args) => {
            return emit_stream_op(st, dest, kind, source, args)
        },
        InterpConcat(dest, parts) => {
            return emit_interp_concat(st, dest, parts)
        },
        Phi(dest, incoming) => {
            return emit_mir_phi(st, dest, incoming)
        }
    }
}

// ---------------------------------------------------------------------------
// Const instruction
// ---------------------------------------------------------------------------

fn emit_const(st: EmitState, dest: Value, ty: MIRType, val: String) -> EmitState {
    let mut s: EmitState = st
    let dn: String = dest.name
    let llvm_ty: String = resolve_mir_type(ty)

    // Void constants are no-ops
    if ty.kind == "void" {
        return s
    }

    // String constant: emit global at module level, build struct inline
    if ty.kind == "string" {
        // Escape special chars for LLVM IR string constants
        let escaped: String = val.replace("\\", "\\5C").replace("\"", "\\22").replace("\n", "\\0A")
        let slen: Int = len(val)
        let gname: String = next_str_name(s)
        s.str_counter = s.str_counter + 1
        let arr_ty: String = "[" + toString(slen) + " x i8]"
        s = emit_global(s, gname + " = private constant " + arr_ty + " c\"" + escaped + "\", align 2")
        let ptr_name: String = dn + ".ptr"
        s = emit_line(s, "  " + ptr_name + " = getelementptr inbounds " + arr_ty + ", " + "ptr " + gname + ", i64 0, i64 0")
        let s1_name: String = dn + ".s1"
        s = emit_line(s, emit_insertvalue(s1_name, llvm_string(), "undef", ptr_name, "ptr", "0"))
        s = emit_line(s, emit_insertvalue(dn, llvm_string(), s1_name, toString(slen), "i64", "1"))
        return s
    }

    // Bool constant
    if ty.kind == "bool" {
        let mut bval: String = "0"
        if val == "true" { bval = "1" }
        s = emit_line(s, "  " + dn + " = add i1 0, " + bval)
        return s
    }

    // Int constant: emit `%dest = add i64 0, <val>` to define the SSA value
    if ty.kind == "int" {
        s = emit_line(s, "  " + dn + " = add i64 0, " + val)
        return s
    }

    // Float constant: emit `%dest = fadd double 0.0, <val>`
    if ty.kind == "float" {
        s = emit_line(s, "  " + dn + " = fadd double 0.0, " + val)
        return s
    }

    // Struct constant (undef initializer for struct construction)
    if ty.kind == "struct" {
        s = emit_line(s, "  " + dn + " = insertvalue " + llvm_ty + " undef, " + llvm_ty + " undef, 0")
        return s
    }

    // Function constant: emit function pointer reference
    if ty.kind == "fn" {
        s = emit_line(s, "  " + dn + " = bitcast void ()* @" + val + " to ptr")
        return s
    }

    // Unknown type — no-op
    return s
}

// ---------------------------------------------------------------------------
// Copy instruction
// ---------------------------------------------------------------------------

fn emit_copy(st: EmitState, dest: Value, src: Value) -> EmitState {
    let mut s: EmitState = st
    let ty: String = resolve_type(st, dest.ty)
    let src_ty: String = resolve_type(st, src.ty)
    // Use source type when dest is unknown/scalar but source is aggregate.
    // This handles match pattern bindings where the payload type is known
    // from enum info but the pattern variable type is unknown.
    let mut use_ty: String = ty
    if ty == "ptr" {
        use_ty = src_ty
    }
    if ty == "i64" && (src_ty.starts_with("%struct.") || src_ty.starts_with("%enum.") || src_ty.starts_with("{")) {
        use_ty = src_ty
    }

    // Bool: use bitwise identity (and true)
    if ty == "i1" {
        return emit_line(s, "  " + dest.name + " = and i1 " + src.name + ", true")
    }
    // Aggregate types (structs, enums, options, results, lists) cannot use `add`.
    // Use alloca/store/load to copy the value through memory.
    if use_ty.starts_with("%struct.") || use_ty.starts_with("%enum.") || use_ty.starts_with("{") {
        let tmp_a: String = dest.name + ".cpy"
        s = emit_line(s, "  " + tmp_a + " = alloca " + use_ty)
        s = emit_line(s, "  store " + use_ty + " " + src.name + ", " + "ptr " + tmp_a)
        return emit_line(s, "  " + dest.name + " = load " + use_ty + ", " + "ptr " + tmp_a)
    }
    // Scalars (i64, double, ptr, etc.): use add 0 identity
    return emit_line(s, "  " + dest.name + " = add " + use_ty + " 0, " + src.name)
}

// ---------------------------------------------------------------------------
// Cast instruction
// ---------------------------------------------------------------------------

fn emit_cast(st: EmitState, dest: Value, src: Value, target_ty: MIRType) -> EmitState {
    let mut s: EmitState = st
    let sn: String = src.name
    let dn: String = dest.name

    let src_ty: String = resolve_mir_type(src.ty)
    let dst_ty: String = resolve_mir_type(target_ty)

    // Int → Float
    if src.ty.kind == "int" {
        if target_ty.kind == "float" {
            s = emit_line(s, "  " + dn + " =sitofp i64 " + sn + " to double")
            return s
        }
    }
    // Float → Int
    if src.ty.kind == "float" {
        if target_ty.kind == "int" {
            s = emit_line(s, "  " + dn + " =fptosi double " + sn + " to i64")
            return s
        }
    }
    // Fallback: bitcast
    s = emit_line(s, emit_bitcast(dn, src_ty, sn, dst_ty))
    return s
}

// ---------------------------------------------------------------------------
// BinOp instruction
// ---------------------------------------------------------------------------

fn emit_binop(st: EmitState, dest: Value, op: BinOpKind, lhs: Value, rhs: Value) -> EmitState {
    let mut s: EmitState = st
    let ln: String = lhs.name
    let rn: String = rhs.name

    let dn: String = dest.name
    let is_float: Bool = lhs.ty.kind == "float"
    let is_string: Bool = lhs.ty.kind == "string"
    let is_bool: Bool = lhs.ty.kind == "bool"
    let mut cmp_ty: String = llvm_int()
    if is_bool { cmp_ty = "i1" }

    // Use binop_kind_to_str (defined in lower.mn where BinOpKind is local)
    // to convert the enum tag to a string, then dispatch with if/else
    let op_str: String = binop_kind_to_str(op)

    if op_str == "add" {
        if is_string {
            s = emit_line(s, emit_call_ir(dn, llvm_string(), "__mn_str_concat", llvm_string() + " " + ln + ", " + llvm_string() + " " + rn))
        } else {
            if is_float { s = emit_line(s, emit_fadd(dn, ln, rn)) } else { s = emit_line(s, emit_add(dn, llvm_int(), ln, rn)) }
        }
    } else if op_str == "sub" {
        if is_float { s = emit_line(s, emit_fsub(dn, ln, rn)) } else { s = emit_line(s, emit_sub(dn, llvm_int(), ln, rn)) }
    } else if op_str == "mul" {
        if is_float { s = emit_line(s, emit_fmul(dn, ln, rn)) } else { s = emit_line(s, emit_mul(dn, llvm_int(), ln, rn)) }
    } else if op_str == "div" {
        if is_float { s = emit_line(s, emit_fdiv(dn, ln, rn)) } else { s = emit_line(s, emit_sdiv(dn, llvm_int(), ln, rn)) }
    } else if op_str == "mod" {
        if is_float { s = emit_line(s, emit_frem(dn, ln, rn)) } else { s = emit_line(s, emit_srem(dn, llvm_int(), ln, rn)) }
    } else if op_str == "eq" {
        if is_string {
            let eq_raw: String = dn + ".sr"
            s = emit_line(s, emit_call_ir(eq_raw, llvm_int(), "__mn_str_eq", llvm_string() + " " + ln + ", " + llvm_string() + " " + rn))
            s = emit_line(s, emit_icmp(dn, "ne", llvm_int(), eq_raw, "0"))
        } else {
            if is_float { s = emit_line(s, emit_fcmp(dn, "eq", ln, rn)) } else { s = emit_line(s, emit_icmp(dn, "eq", cmp_ty, ln, rn)) }
        }
    } else if op_str == "ne" {
        if is_string {
            let eq_raw: String = dn + ".sr"
            s = emit_line(s, emit_call_ir(eq_raw, llvm_int(), "__mn_str_eq", llvm_string() + " " + ln + ", " + llvm_string() + " " + rn))
            s = emit_line(s, emit_icmp(dn, "eq", llvm_int(), eq_raw, "0"))
        } else {
            if is_float { s = emit_line(s, emit_fcmp(dn, "ne", ln, rn)) } else { s = emit_line(s, emit_icmp(dn, "ne", cmp_ty, ln, rn)) }
        }
    } else if op_str == "lt" {
        if is_string {
            let cmp_r: String = dn + ".sc"
            s = emit_line(s, emit_call_ir(cmp_r, llvm_int(), "__mn_str_cmp", llvm_string() + " " + ln + ", " + llvm_string() + " " + rn))
            s = emit_line(s, emit_icmp(dn, "slt", llvm_int(), cmp_r, "0"))
        } else {
            if is_float { s = emit_line(s, emit_fcmp(dn, "lt", ln, rn)) } else { s = emit_line(s, emit_icmp(dn, "slt", llvm_int(), ln, rn)) }
        }
    } else if op_str == "gt" {
        if is_string {
            let cmp_r: String = dn + ".sc"
            s = emit_line(s, emit_call_ir(cmp_r, llvm_int(), "__mn_str_cmp", llvm_string() + " " + ln + ", " + llvm_string() + " " + rn))
            s = emit_line(s, emit_icmp(dn, "sgt", llvm_int(), cmp_r, "0"))
        } else {
            if is_float { s = emit_line(s, emit_fcmp(dn, "gt", ln, rn)) } else { s = emit_line(s, emit_icmp(dn, "sgt", llvm_int(), ln, rn)) }
        }
    } else if op_str == "le" {
        if is_string {
            let cmp_r: String = dn + ".sc"
            s = emit_line(s, emit_call_ir(cmp_r, llvm_int(), "__mn_str_cmp", llvm_string() + " " + ln + ", " + llvm_string() + " " + rn))
            s = emit_line(s, emit_icmp(dn, "sle", llvm_int(), cmp_r, "0"))
        } else {
            if is_float { s = emit_line(s, emit_fcmp(dn, "le", ln, rn)) } else { s = emit_line(s, emit_icmp(dn, "sle", llvm_int(), ln, rn)) }
        }
    } else if op_str == "ge" {
        if is_string {
            let cmp_r: String = dn + ".sc"
            s = emit_line(s, emit_call_ir(cmp_r, llvm_int(), "__mn_str_cmp", llvm_string() + " " + ln + ", " + llvm_string() + " " + rn))
            s = emit_line(s, emit_icmp(dn, "sge", llvm_int(), cmp_r, "0"))
        } else {
            if is_float { s = emit_line(s, emit_fcmp(dn, "ge", ln, rn)) } else { s = emit_line(s, emit_icmp(dn, "sge", llvm_int(), ln, rn)) }
        }
    } else if op_str == "and" {
        s = emit_line(s, emit_and_instr(dn, ln, rn))
    } else if op_str == "or" {
        s = emit_line(s, emit_or_instr(dn, ln, rn))
    } else {
        // Fallback: add
        s = emit_line(s, emit_add(dn, llvm_int(), ln, rn))
    }

    return s
}

// ---------------------------------------------------------------------------
// UnaryOp instruction
// ---------------------------------------------------------------------------

fn emit_unaryop(st: EmitState, dest: Value, op: UnaryOpKind, operand: Value) -> EmitState {
    let mut s: EmitState = st
    let on: String = operand.name
    let dn: String = dest.name
    let op_str: String = unaryop_kind_to_str(op)

    if op_str == "neg" {
        if operand.ty.kind == "float" {
            s = emit_line(s, emit_fneg(dn, on))
        } else {
            s = emit_line(s, emit_neg(dn, llvm_int(), on))
        }
        return s
    }
    if op_str == "not" {
        s = emit_line(s, emit_not(dn, on))
        return s
    }
    return s
}

// ---------------------------------------------------------------------------
// StructInit instruction
// ---------------------------------------------------------------------------

fn emit_struct_init(st: EmitState, dest: Value, ty: MIRType, fields: List<FieldPair>) -> EmitState {
    let struct_ty: String = resolve_mir_type(ty)
    let mut s: EmitState = st
    let dn: String = dest.name
    let mut agg: String = "undef"
    let mut i: Int = 0

    // Lookup struct field types from the registry (more reliable than MIR types)
    let field_types: List<String> = lookup_struct_field_types(s, ty.name)

    let nfields: Int = len(fields)
    for _ in 0..50 {
        if i < nfields {
            let fp: FieldPair = fields[i]
            let mut fty: String = resolve_mir_type(fp.val.ty)
            let val_name: String = fp.val.name
            // If MIR type is unknown, use the registered struct field type
            if fty == "i64" && fp.val.ty.kind == "unknown" && i < len(field_types) {
                fty = field_types[i]
            }
            let tmp_name: String = dn + ".f" + toString(i)
            s = emit_line(s, emit_insertvalue(tmp_name, struct_ty, agg, val_name, fty, toString(i)))
            agg = tmp_name
            i = i + 1
        }
    }
    // Copy the final insertvalue result to dest via alloca/store/load
    // (aggregate types cannot use `add 0` identity)
    if nfields > 0 {
        let cpy_a: String = dn + ".si"
        s = emit_line(s, "  " + cpy_a + " = alloca " + struct_ty)
        s = emit_line(s, "  store " + struct_ty + " " + agg + ", " + "ptr " + cpy_a)
        s = emit_line(s, "  " + dn + " = load " + struct_ty + ", " + "ptr " + cpy_a)
    }
    return s
}

// ---------------------------------------------------------------------------
// FieldGet instruction
// ---------------------------------------------------------------------------

fn emit_field_get(st: EmitState, dest: Value, obj: Value, field_name: String) -> EmitState {
    let mut s: EmitState = st
    let on: String = obj.name
    let dn: String = dest.name
    let obj_ty: String = resolve_type(st, obj.ty)

    // String .len → extractvalue index 1
    if obj.ty.kind == "string" {
        if field_name == "len" {
            s = emit_line(s, emit_extractvalue(dn, llvm_string(), on, "1"))
            return s
        }
        // String methods (contains, starts_with, etc.) — not struct fields.
        // The actual call is handled by the Call instruction that follows.
        // Just pass the object through as the "method reference".
        return emit_copy(s, dest, obj)
    }

    // List .len
    if obj.ty.kind == "list" {
        if field_name == "len" {
            let lt: String = llvm_list_rt()
            let tmp: String = dn + ".lp"
            s = emit_line(s, "  " + tmp + " = alloca " + lt)
            s = emit_line(s, "  store " + lt + " " + on + ", " + "ptr " + tmp)
            s = emit_line(s, emit_call_ir(dn, llvm_int(), "__mn_list_len", "ptr " + tmp))
            return s
        }
        // List methods (push, etc.) — pass object through
        return emit_copy(s, dest, obj)
    }

    // Look up field index: try hardcoded first (internal types), then registry
    let hc_idx: Int = hardcoded_field_index(obj.ty.name, field_name)
    if hc_idx > 0 {
        // Hardcoded match — use it (overrides potentially broken registry)
        s = emit_line(s, emit_extractvalue(dn, obj_ty, on, toString(hc_idx)))
        return s
    }
    // Fall back to registered structs
    let struct_opt: Option<StructEntry> = find_struct_entry(s, obj.ty.name)
    match struct_opt {
        Some(se) => {
            let idx: Int = find_field_index(se.field_names, field_name)
            s = emit_line(s, emit_extractvalue(dn, obj_ty, on, toString(idx)))
            return s
        },
        _ => {
            // Last resort: hardcoded (returns 0 for unknown)
            s = emit_line(s, emit_extractvalue(dn, obj_ty, on, toString(hc_idx)))
            return s
        }
    }
}

// Hardcoded field indices for the 18 internal compiler struct types.
// These are not in the MIR module's struct list due to a state accumulation
// bug, so find_struct_entry returns None. This function provides the correct
// indices as a workaround.
fn hardcoded_field_index(struct_name: String, field_name: String) -> Int {
    // LowerState: module(0) current_fn(1) current_block_idx(2) tmp_counter(3) block_counter(4) vars(5) scope_stack(6) impl_methods(7) struct_fields(8) enum_variants(9) lambda_vars(10)
    if struct_name == "LowerState" {
        if field_name == "module" { return 0 }
        if field_name == "current_fn" { return 1 }
        if field_name == "current_block_idx" { return 2 }
        if field_name == "tmp_counter" { return 3 }
        if field_name == "block_counter" { return 4 }
        if field_name == "vars" { return 5 }
        if field_name == "scope_stack" { return 6 }
        if field_name == "impl_methods" { return 7 }
        if field_name == "struct_fields" { return 8 }
        if field_name == "enum_variants" { return 9 }
        if field_name == "lambda_vars" { return 10 }
    }
    // EmitState: lines(0) counter(1) functions(2) structs(3) module_name(4) str_counter(5) str_globals(6) current_ret_type(7) enum_names(8) enum_infos(9)
    if struct_name == "EmitState" {
        if field_name == "lines" { return 0 }
        if field_name == "counter" { return 1 }
        if field_name == "functions" { return 2 }
        if field_name == "structs" { return 3 }
        if field_name == "module_name" { return 4 }
        if field_name == "str_counter" { return 5 }
        if field_name == "str_globals" { return 6 }
        if field_name == "current_ret_type" { return 7 }
        if field_name == "enum_names" { return 8 }
        if field_name == "enum_infos" { return 9 }
    }
    // MIRModule: name(0) functions(1) structs(2) enums(3) extern_fns(4) agents(5) pipes(6) imports(7) trait_names(8)
    if struct_name == "MIRModule" {
        if field_name == "name" { return 0 }
        if field_name == "functions" { return 1 }
        if field_name == "structs" { return 2 }
        if field_name == "enums" { return 3 }
        if field_name == "extern_fns" { return 4 }
        if field_name == "agents" { return 5 }
        if field_name == "pipes" { return 6 }
        if field_name == "imports" { return 7 }
        if field_name == "trait_names" { return 8 }
    }
    // LowerResult: value(0) state(1)
    if struct_name == "LowerResult" {
        if field_name == "value" { return 0 }
        if field_name == "state" { return 1 }
    }
    // VarInfo: name(0) current(1) mutable(2)
    if struct_name == "VarInfo" {
        if field_name == "name" { return 0 }
        if field_name == "current" { return 1 }
        if field_name == "mutable" { return 2 }
    }
    // CompileResult: success(0) ir_text(1) errors(2)
    if struct_name == "CompileResult" {
        if field_name == "success" { return 0 }
        if field_name == "ir_text" { return 1 }
        if field_name == "errors" { return 2 }
    }
    // MatchBuildResult: state(0) arm_labels(1) arm_indices(2) cases(3) default_label(4)
    if struct_name == "MatchBuildResult" {
        if field_name == "state" { return 0 }
        if field_name == "arm_labels" { return 1 }
        if field_name == "arm_indices" { return 2 }
        if field_name == "cases" { return 3 }
        if field_name == "default_label" { return 4 }
    }
    // FnEntry: name(0) ret_type(1) param_types(2)
    if struct_name == "FnEntry" {
        if field_name == "name" { return 0 }
        if field_name == "ret_type" { return 1 }
        if field_name == "param_types" { return 2 }
    }
    // StructEntry: name(0) field_names(1) field_types(2) llvm_type(3)
    if struct_name == "StructEntry" {
        if field_name == "name" { return 0 }
        if field_name == "field_names" { return 1 }
        if field_name == "field_types" { return 2 }
        if field_name == "llvm_type" { return 3 }
    }
    // StructFieldInfo: name(0) field_names(1) field_types(2)
    if struct_name == "StructFieldInfo" {
        if field_name == "name" { return 0 }
        if field_name == "field_names" { return 1 }
        if field_name == "field_types" { return 2 }
    }
    // EnumVariantNames: enum_name(0) variant_names(1)
    if struct_name == "EnumVariantNames" {
        if field_name == "enum_name" { return 0 }
        if field_name == "variant_names" { return 1 }
    }
    // LambdaEntry: var_name(0) fn_name(1)
    if struct_name == "LambdaEntry" {
        if field_name == "var_name" { return 0 }
        if field_name == "fn_name" { return 1 }
    }
    // ExternFnInfo: abi(0) module_name(1) fn_name(2) param_types(3) return_type(4)
    if struct_name == "ExternFnInfo" {
        if field_name == "abi" { return 0 }
        if field_name == "module_name" { return 1 }
        if field_name == "fn_name" { return 2 }
        if field_name == "param_types" { return 3 }
        if field_name == "return_type" { return 4 }
    }
    // VerifyError: fn_name(0) block_label(1) message(2)
    if struct_name == "VerifyError" {
        if field_name == "fn_name" { return 0 }
        if field_name == "block_label" { return 1 }
        if field_name == "message" { return 2 }
    }
    // ImplEntry: key(0) mir_name(1)
    if struct_name == "ImplEntry" {
        if field_name == "key" { return 0 }
        if field_name == "mir_name" { return 1 }
    }
    // ImportInfo: path(0) items(1)
    if struct_name == "ImportInfo" {
        if field_name == "path" { return 0 }
        if field_name == "items" { return 1 }
    }
    // AgentInfo: name(0) inputs(1) outputs(2) method_names(3)
    if struct_name == "AgentInfo" {
        if field_name == "name" { return 0 }
        if field_name == "inputs" { return 1 }
        if field_name == "outputs" { return 2 }
        if field_name == "method_names" { return 3 }
    }
    // PipeInfo: name(0) stages(1)
    if struct_name == "PipeInfo" {
        if field_name == "name" { return 0 }
        if field_name == "stages" { return 1 }
    }
    // MIRFunction: name(0) params(1) return_type(2) blocks(3) decorators(4) is_public(5)
    if struct_name == "MIRFunction" {
        if field_name == "name" { return 0 }
        if field_name == "params" { return 1 }
        if field_name == "return_type" { return 2 }
        if field_name == "blocks" { return 3 }
        if field_name == "decorators" { return 4 }
        if field_name == "is_public" { return 5 }
    }
    // BasicBlock: label(0) instructions(1)
    if struct_name == "BasicBlock" {
        if field_name == "label" { return 0 }
        if field_name == "instructions" { return 1 }
    }
    // MIRType: kind(0) name(1) args(2)
    if struct_name == "MIRType" {
        if field_name == "kind" { return 0 }
        if field_name == "name" { return 1 }
        if field_name == "args" { return 2 }
    }
    // Value: name(0) ty(1)
    if struct_name == "Value" {
        if field_name == "name" { return 0 }
        if field_name == "ty" { return 1 }
    }
    return 0
}

fn find_field_index(fields: List<String>, name: String) -> Int {
    let mut i: Int = 0
    for _ in 0..50 {
        if i >= len(fields) { return 0 }
        if fields[i] == name { return i }
        i = i + 1
    }
    return 0
}

// ---------------------------------------------------------------------------
// FieldSet instruction
// ---------------------------------------------------------------------------

fn emit_field_set(st: EmitState, obj: Value, field_name: String, val: Value) -> EmitState {
    let mut s: EmitState = st

    let val_ty: String = resolve_mir_type(val.ty)

    // Try hardcoded index first (for internal types with broken registry)
    let hc_idx: Int = hardcoded_field_index(obj.ty.name, field_name)
    let struct_opt: Option<StructEntry> = find_struct_entry(s, obj.ty.name)
    let mut idx: Int = hc_idx
    match struct_opt {
        Some(se) => {
            if hc_idx == 0 {
                // Only use registry if hardcoded didn't find it (hc=0 might be field 0 OR unknown)
                idx = find_field_index(se.field_names, field_name)
            }
        },
        _ => {}
    }
    let struct_ty: String = resolve_type(s, obj.ty)
    if obj.name.contains(".addr") {
        let gep: String = "%" + strip_percent(obj.name) + "_fp" + toString(s.counter)
        s.counter = s.counter + 1
        s = emit_line(s, "  " + gep + " = getelementptr inbounds " + struct_ty + ", ptr " + obj.name + ", i32 0, i32 " + toString(idx))
        s = emit_line(s, "  store " + val_ty + " " + val.name + ", ptr " + gep)
    } else {
        let tmp_name: String = "%" + strip_percent(obj.name) + "_set" + toString(s.counter)
        s.counter = s.counter + 1
        s = emit_line(s, emit_insertvalue(tmp_name, struct_ty, obj.name, val.name, val_ty, toString(idx)))
    }
    return s
}

// ---------------------------------------------------------------------------
// ListInit instruction
// ---------------------------------------------------------------------------

fn strip_percent(name: String) -> String {
    // Strip leading % from name (avoid if-expression — PHI zeroinit bug)
    let starts: Bool = name.starts_with("%")
    let mut result: String = name
    if starts { result = name.substr(1, len(name) - 1) }
    return result
}

fn has_struct(st: EmitState, name: String) -> Bool {
    let opt: Option<StructEntry> = find_struct_entry(st, name)
    match opt {
        Some(_) => { return true },
        _ => { return false }
    }
}

fn try_emit_struct_construct(st: EmitState, dest: Value, fn_name: String, args: List<Value>) -> EmitState {
    // Check if fn_name is "__new_<StructName>" and emit struct construction.
    // Uses ternary expressions to avoid early returns inside if/match.
    let is_new: Bool = len(fn_name) > 6
    let mut prefix: String = ""
    if is_new { prefix = fn_name.substr(0, 6) }
    let mut struct_name: String = ""
    if prefix == "__new_" { struct_name = fn_name.substr(6, len(fn_name) - 6) }
    let mut found: Bool = false
    if struct_name != "" { found = has_struct(st, struct_name) }
    let mut result: EmitState = st
    if found { result = emit_struct_init_from_values(st, dest, dest.ty, args) }
    return result
}

fn emit_struct_init_from_values(st: EmitState, dest: Value, ty: MIRType, values: List<Value>) -> EmitState {
    // Build struct from a list of values (field order matches struct definition)
    let struct_ty: String = resolve_mir_type(ty)
    let mut s: EmitState = st
    let dn: String = dest.name
    let mut agg: String = "undef"
    let nfields: Int = len(values)

    // Lookup registered field types for this struct
    let field_types: List<String> = lookup_struct_field_types(s, ty.name)

    let mut i: Int = 0
    for _ in 0..50 {
        if i < nfields {
            let v: Value = values[i]
            let mut fty: String = resolve_type(st, v.ty)
            let vname: String = v.name
            // Always prefer registered field types for struct construction.
            // MIR value types are often wrong (unknown/empty name) due to
            // COW corruption in nested lists. The emitter's struct registry
            // (from type definitions) is authoritative.
            if i < len(field_types) {
                let rft: String = field_types[i]
                if len(rft) > 2 && rft != "i64" {
                    fty = rft
                }
            }
            let tmp_name: String = dn + ".f" + toString(i)
            s = emit_line(s, emit_insertvalue(tmp_name, struct_ty, agg, vname, fty, toString(i)))
            agg = tmp_name
            i = i + 1
        }
    }
    // Copy the final insertvalue result to dest
    if nfields > 0 {
        let cpy_a: String = dn + ".si"
        s = emit_line(s, "  " + cpy_a + " = alloca " + struct_ty)
        s = emit_line(s, "  store " + struct_ty + " " + agg + ", " + "ptr " + cpy_a)
        s = emit_line(s, "  " + dn + " = load " + struct_ty + ", " + "ptr " + cpy_a)
    }
    return s
}

fn find_list_field_index(st: EmitState, struct_name: String, dest: Value) -> String {
    // The struct_name may be "StructName:field_name" (encoded by lowerer)
    let colon_pos: Int = struct_name.find(":")
    if colon_pos > 0 {
        // Use char-by-char builders to avoid C runtime substr bug
        let base: String = strip_colon_suffix(struct_name)
        let field: String = extract_after_colon(struct_name, colon_pos)
        let opt: Option<StructEntry> = find_struct_entry(st, base)
        match opt {
            Some(se) => {
                let idx: Int = find_field_index(se.field_names, field)
                return toString(idx)
            },
            _ => { return "0" }
        }
    }
    return "0"
}

fn find_alloca_by_search(lines: List<String>, value_name: String) -> String {
    // Search FORWARD for "value_name =load TYPE, ptr %alloca"
    // Use the LAST match (most recent load of this value)
    let search_pat: String = value_name + " =load"
    let n: Int = len(lines)
    let mut result: String = ""
    let mut i: Int = 0
    for _ in 0..600 {
        if i >= n { return result }
        let line: String = lines[i]
        if line.contains(search_pat) {
            let pp: Int = line.find(", ptr ")
            if pp > 0 {
                result = line.substr(pp + 6, len(line) - pp - 6)
            }
        }
        i = i + 1
    }
    return result
}

fn is_name_in_byref(byref_names: List<String>, name: String) -> Bool {
    // Check if alloca name matches a byref param EXACTLY.
    // Alloca names: "%{param_name}.addr" (params have no counter suffix).
    // Local vars: "%{name}{counter}.addr" — these should NOT match.
    let mut i: Int = 0
    for _ in 0..100 {
        if i >= len(byref_names) { return false }
        let bn: String = byref_names[i]
        // Exact match: the alloca is %{param_name}.addr
        let expected: String = "%" + bn + ".addr"
        if name == expected { return true }
        i = i + 1
    }
    return false
}

fn is_byref_type(ty: String) -> Bool {
    // Large types (> 64 bytes) should use byref/sret passing.
    // This prevents ABI issues with large struct copies.
    if ty.starts_with("%struct.") {
        // All structs > 64 bytes use byref. Use llvm_type_size heuristic.
        let sz: Int = llvm_type_size(ty)
        if sz > 64 { return true }
        return false
    }
    if ty.starts_with("{") {
        let sz: Int = llvm_type_size(ty)
        if sz > 64 { return true }
    }
    return false
}

fn find_alloca_for_value(st: EmitState, value_name: String) -> String {
    // Scan backward through emitted lines to find:
    //   %value_name =load TYPE, ptr %ALLOCA
    // Return %ALLOCA name so FieldSet can store back.
    let search: String = value_name + " ="
    let n: Int = len(st.lines)
    let mut i: Int = n - 1
    for _ in 0..10000 {
        if i < 0 { return "" }
        let line: String = st.lines[i]
        if line.contains(search) {
            if line.contains("load") {
                let ptr_pos: Int = line.find(", ptr ")
                if ptr_pos > 0 {
                    let after: String = line.substr(ptr_pos + 6, len(line) - ptr_pos - 6)
                    return after
                }
            }
            return ""
        }
        i = i - 1
    }
    return ""
}

fn llvm_type_size(ty: String) -> Int {
    if ty == "i1" { return 1 }
    if ty == "i8" { return 1 }
    if ty == "i32" { return 4 }
    if ty == "i64" { return 8 }
    if ty == "double" { return 8 }
    if ty == "ptr" { return 8 }
    if ty == "void" { return 0 }
    // String = {ptr, i64} = 16
    if ty == llvm_string() { return 16 }
    // List = {ptr, i64, i64, i64} = 32
    if ty == llvm_list_rt() { return 32 }
    // Enums: now always {i64, ptr} = 16 bytes
    if ty.starts_with("%enum.") { return 16 }
    // Structs: use field_count * 32 as safe upper bound.
    // This is used for malloc allocation, so must be >= actual size.
    if ty.starts_with("%struct.") { return 256 }
    // Aggregate types: count fields
    if ty.starts_with("{") { return llvm_aggregate_size(ty) }
    return 8
}

fn llvm_aggregate_size(ty: String) -> Int {
    // Count comma-separated fields, each assumed 8 bytes
    let inner: String = ty.substr(1, len(ty) - 2)
    let parts: List<String> = inner.split(",")
    return len(parts) * 8
}

fn emit_list_push_call(st: EmitState, dest: Value, args: List<Value>) -> EmitState {
    let mut s: EmitState = st
    if len(args) >= 2 {
        let list_ref: String = args[0].name
        let list_ty_kind: String = args[0].ty.kind
        let elem_name: String = args[1].name
        let mut elem_ty: String = resolve_type(st, args[1].ty)
        if elem_ty == "i64" { elem_ty = resolve_mir_type(args[1].ty) }
        let cnt: String = toString(s.counter)
        s.counter = s.counter + 1

        // Alloca element
        let ea: String = "%push_ea" + cnt
        s = emit_line(s, "  " + ea + " = alloca " + elem_ty)
        s = emit_line(s, "  store " + elem_ty + " " + elem_name + ", ptr " + ea)

        if list_ref.contains(".addr") && list_ty_kind == "struct" {
            // Struct field push: GEP to field, load list to temp, push to temp,
            // WRITE BACK to struct field (matches Python text emitter pattern).
            let type_name: String = args[0].ty.name
            let cp: Int = type_name.find(":")
            let mut base_name: String = type_name
            if cp > 0 { base_name = type_name.substr(0, cp) }
            let struct_ty: String = "%struct." + base_name
            let field_idx: String = find_list_field_index(st, type_name, dest)
            let gep: String = "%push_gep" + cnt
            s = emit_line(s, "  " + gep + " = getelementptr inbounds " + struct_ty + ", ptr " + list_ref + ", i32 0, i32 " + field_idx)
            // Load list to temp alloca
            let tmp: String = "%push_tmp" + cnt
            s = emit_line(s, "  " + tmp + " = alloca " + llvm_list_rt())
            let ld: String = "%push_ld" + cnt
            s = emit_line(s, "  " + ld + " = load " + llvm_list_rt() + ", ptr " + gep)
            s = emit_line(s, "  store " + llvm_list_rt() + " " + ld + ", ptr " + tmp)
            // Push to temp
            s = emit_line(s, emit_call_void("__mn_list_push", "ptr " + tmp + ", ptr " + ea))
            // Write back to struct field
            let wb: String = "%push_wb" + cnt
            s = emit_line(s, "  " + wb + " = load " + llvm_list_rt() + ", ptr " + tmp)
            s = emit_line(s, "  store " + llvm_list_rt() + " " + wb + ", ptr " + gep)
        } else if list_ref.contains(".addr") {
            // Simple alloca push: same temp+writeback pattern
            let tmp: String = "%push_tmp" + cnt
            s = emit_line(s, "  " + tmp + " = alloca " + llvm_list_rt())
            let ld: String = "%push_ld" + cnt
            s = emit_line(s, "  " + ld + " = load " + llvm_list_rt() + ", ptr " + list_ref)
            s = emit_line(s, "  store " + llvm_list_rt() + " " + ld + ", ptr " + tmp)
            s = emit_line(s, emit_call_void("__mn_list_push", "ptr " + tmp + ", ptr " + ea))
            let wb: String = "%push_wb" + cnt
            s = emit_line(s, "  " + wb + " = load " + llvm_list_rt() + ", ptr " + tmp)
            s = emit_line(s, "  store " + llvm_list_rt() + " " + wb + ", ptr " + list_ref)
        } else {
            // Loaded list value — create temp alloca
            let la: String = "%push_la" + cnt
            s = emit_line(s, "  " + la + " = alloca " + llvm_list_rt())
            s = emit_line(s, "  store " + llvm_list_rt() + " " + list_ref + ", ptr " + la)
            s = emit_line(s, emit_call_void("__mn_list_push", "ptr " + la + ", ptr " + ea))
        }
    }
    return s
}

fn emit_list_init(st: EmitState, dest: Value, elem_ty: MIRType, elements: List<Value>) -> EmitState {
    let mut s: EmitState = st
    let dn: String = dest.name

    // Create empty list. Use 64 bytes as default element size — this covers
    // all types (i64=8, String=16, List=32, structs≤64). The C runtime
    // uses elem_size for memcpy in push; oversizing wastes memory but
    // prevents truncation crashes.
    let list_name: String = dn + ".new"
    let elem_llvm_ty: String = resolve_mir_type(elem_ty)
    let mut elem_sz: Int = llvm_type_size(elem_llvm_ty)
    // Minimum 384: covers all enums (max: Definition≈264) and structs (max: ~256).
    // Empty lists default to unknown (i64, size 8) — the floor ensures they
    // still work correctly when populated with large elements later.
    if elem_sz < 384 { elem_sz = 384 }
    s = emit_line(s, emit_call_ir(list_name, llvm_list_rt(), "__mn_list_new", "i64 " + toString(elem_sz)))

    // Alloca for push
    let alloca_name: String = dn + ".addr"
    s = emit_line(s, llvm_alloca(alloca_name, llvm_list_rt()))
    s = emit_line(s, llvm_store(llvm_list_rt(), list_name, alloca_name))

    // Push each element
    let mut i: Int = 0
    for _ in 0..600 {
        if i >= len(elements) {
            // Load final list
            let final_list: String = dest.name
            s = emit_line(s, llvm_load(final_list, llvm_list_rt(), alloca_name))
            return s
        }
        let elem: Value = elements[i]
        let ety: String = resolve_mir_type(elem.ty)
        let elem_alloca: String = dn + ".e" + toString(i)
        s = emit_line(s, llvm_alloca(elem_alloca, ety))
        s = emit_line(s, llvm_store(ety, elem.name, elem_alloca))
        let cast_name: String = dn + ".c" + toString(i)
        s = emit_line(s, emit_bitcast(cast_name, ety + "*", elem_alloca, "ptr"))
        s = emit_line(s, emit_call_void("__mn_list_push", "ptr " + alloca_name + ", ptr " + cast_name))
        i = i + 1
    }
    return s
}

// ---------------------------------------------------------------------------
// IndexGet instruction
// ---------------------------------------------------------------------------

fn emit_index_get(st: EmitState, dest: Value, obj: Value, idx: Value) -> EmitState {
    let mut s: EmitState = st
    let dn: String = dest.name

    // String indexing → char_at
    if obj.ty.kind == "string" {
        s = emit_line(s, emit_call_ir(dn, llvm_string(), "__mn_str_char_at", llvm_string() + " " + obj.name + ", i64 " + idx.name))
        return s
    }

    // List indexing → list_get (needs pointer; alloca+store the list value)
    let lt: String = llvm_list_rt()
    let tmp: String = dn + ".lp"
    s = emit_line(s, "  " + tmp + " = alloca " + lt)
    s = emit_line(s, "  store " + lt + " " + obj.name + ", " + "ptr " + tmp)

    // If dest type is known, load from the ptr returned by list_get
    let dest_ty: String = resolve_type(st, dest.ty)
    if dest_ty != llvm_int() && dest_ty != "ptr" && dest_ty != "void" {
        let raw: String = dn + ".raw"
        s = emit_line(s, emit_call_ir(raw, "ptr", "__mn_list_get", "ptr " + tmp + ", i64 " + idx.name))
        // Opaque pointers: load directly from ptr, no bitcast needed
        s = emit_line(s, "  " + dn + " = load " + dest_ty + ", ptr " + raw)
    } else {
        // list_get returns ptr to element. Load the element value.
        let raw2: String = dn + ".raw"
        s = emit_line(s, emit_call_ir(raw2, "ptr", "__mn_list_get", "ptr " + tmp + ", i64 " + idx.name))
        s = emit_line(s, "  " + dn + " = load i64, ptr " + raw2)
    }
    return s
}

// ---------------------------------------------------------------------------
// IndexSet instruction
// ---------------------------------------------------------------------------

fn emit_index_set(st: EmitState, obj: Value, idx: Value, val: Value) -> EmitState {
    // Stub: indexed list store not yet working in stage2
    // (any non-trivial implementation triggers layout-sensitive binary corruption)
    return st
}

// ---------------------------------------------------------------------------
// Alloca/Load/Store instructions
// ---------------------------------------------------------------------------

fn emit_alloca(st: EmitState, dest: Value, ty: MIRType) -> EmitState {
    return emit_line(st, llvm_alloca(dest.name, resolve_type(st, ty)))
}

fn emit_load(st: EmitState, dest: Value, ptr: Value) -> EmitState {
    return emit_line(st, llvm_load(dest.name, resolve_type(st, dest.ty), ptr.name))
}

fn emit_store(st: EmitState, ptr: Value, val: Value) -> EmitState {
    let val_ty: String = resolve_type(st, val.ty)
    let ptr_ty: String = resolve_type(st, ptr.ty)
    // When storing a generic None ({i1, ptr}) to a specific Option alloca
    // ({i1, %enum.T}), use zeroinitializer with the alloca's type instead.
    // None has tag=0 and null payload — zeroinitializer is equivalent.
    if val.ty.kind == "option" && ptr_ty != val_ty && ptr_ty.starts_with("{") {
        return emit_line(st, "  store " + ptr_ty + " zeroinitializer, " + "ptr " + ptr.name)
    }
    return emit_line(st, llvm_store(val_ty, val.name, ptr.name))
}

// ---------------------------------------------------------------------------
// MapInit instruction
// ---------------------------------------------------------------------------

fn emit_map_init(st: EmitState, dest: Value, key_ty: MIRType, val_ty: MIRType, pairs: List<KVPair>) -> EmitState {
    let mut s: EmitState = st
    let dn: String = dest.name
    // Maps are pointer-based; minimal implementation
    s = emit_line(s, "  " + dn + " =insertvalue " + llvm_map_type() + " undef, ptr null, 0")
    return s
}

// ---------------------------------------------------------------------------
// EnumInit instruction
// ---------------------------------------------------------------------------

fn emit_enum_init(st: EmitState, dest: Value, ty: MIRType, variant: String, payload: List<Value>) -> EmitState {
    let mut s: EmitState = st
    let dn: String = dest.name

    // Resolve variant tag index
    let tag_val: String = toString(resolve_variant_index(s, ty.name, variant))

    // Pointer-based enum: { i64 tag, ptr payload }.
    // 1. Malloc payload struct, store each field via GEP.
    // 2. Build {i64, ptr} with insertvalue.
    // Use named type (%enum.X) for insertvalue, not inline { i64, ptr }
    let enum_ty: String = resolve_mir_type(ty)
    if len(payload) > 0 {
        // Compute payload allocation size: sum field sizes
        let alloc_size: String = toString(compute_payload_alloc_size(s, payload))
        let ep: String = dn + ".ep"
        s = emit_line(s, "  " + ep + " = call ptr @malloc(i64 " + alloc_size + ")")
        // Store each payload field via byte-offset GEP
        let mut i: Int = 0
        let npayload: Int = len(payload)
        for _ in 0..100 {
            if i < npayload {
                let p: Value = payload[i]
                let pty: String = resolve_mir_type(p.ty)
                let ef: String = dn + ".ef" + toString(i)
                let offset: String = toString(compute_field_offset(s, payload, i))
                s = emit_line(s, "  " + ef + " = getelementptr inbounds i8, ptr " + ep + ", i64 " + offset)
                s = emit_line(s, "  store " + pty + " " + p.name + ", ptr " + ef)
                i = i + 1
            }
        }
        // Build enum value using named type
        let ei1: String = dn + ".ei1"
        s = emit_line(s, "  " + ei1 + " = insertvalue " + enum_ty + " undef, i64 " + tag_val + ", 0")
        s = emit_line(s, "  " + dn + " = insertvalue " + enum_ty + " " + ei1 + ", ptr " + ep + ", 1")
    } else {
        // No payload: null pointer
        let ei1: String = dn + ".ei1"
        s = emit_line(s, "  " + ei1 + " = insertvalue " + enum_ty + " undef, i64 " + tag_val + ", 0")
        s = emit_line(s, "  " + dn + " = insertvalue " + enum_ty + " " + ei1 + ", ptr null, 1")
    }
    return s
}

fn compute_payload_alloc_size(st: EmitState, payload: List<Value>) -> Int {
    let mut total: Int = 0
    let mut i: Int = 0
    for _ in 0..100 {
        if i >= len(payload) { return total }
        let pty: String = resolve_mir_type(payload[i].ty)
        total = total + llvm_type_size(pty)
        i = i + 1
    }
    return total
}

fn compute_field_offset(st: EmitState, payload: List<Value>, field_idx: Int) -> Int {
    let mut offset: Int = 0
    let mut i: Int = 0
    for _ in 0..100 {
        if i >= field_idx { return offset }
        let mut pty: String = resolve_mir_type(payload[i].ty)
        // Fix struct→enum misclassification
        if pty.starts_with("%struct.") {
            if is_enum_type(st, payload[i].ty.name) {
                pty = "%enum." + payload[i].ty.name
            }
        }
        offset = offset + llvm_type_size(pty)
        i = i + 1
    }
    return offset
}

fn resolve_variant_index(st: EmitState, enum_name: String, variant: String) -> Int {
    // Strip ":N" suffix if present (from indexed payload extraction)
    let mut vname: String = variant
    let colon: Int = variant.find(":")
    if colon >= 0 {
        vname = variant.substr(0, colon)
    }
    let mut i: Int = 0
    let neinfos2: Int = len(st.enum_infos)
    for _ in 0..50 {
        if i < neinfos2 {
            let info: EnumInfo = st.enum_infos[i]
            if info.name == enum_name {
                let mut vi: Int = 0
                let nvariants: Int = len(info.variants)
                for _ in 0..50 {
                    if vi < nvariants {
                        if info.variants[vi].name == vname {
                            return vi
                        }
                        vi = vi + 1
                    }
                }
            }
            i = i + 1
        }
    }
    return 0
}

// Parse field index from "Variant:N" format. Returns N (0 if no colon).
// Uses return instead of conditional assignment (Python lowerer drops if-assignments).
fn parse_field_index(variant: String) -> Int {
    let colon_pos: Int = variant.find(":")
    if colon_pos < 0 { return 0 }
    // Use char_at instead of substr — substr has a C runtime bug for short substrings
    let idx_char: String = variant.char_at(colon_pos + 1)
    return int(idx_char)
}

// Strip ":N" suffix from "Variant:N". Uses char_at loop to avoid buggy substr.
fn strip_colon_suffix(s: String) -> String {
    let colon_pos: Int = s.find(":")
    if colon_pos < 0 { return s }
    // Build result char by char (substr is buggy for non-zero start)
    let mut result: String = ""
    let mut i: Int = 0
    for _ in 0..50 {
        if i >= colon_pos { return result }
        result = result + s.char_at(i)
        i = i + 1
    }
    return result
}

// Extract everything after ":" — char-by-char to avoid substr bug.
fn extract_after_colon(s: String, colon_pos: Int) -> String {
    let mut result: String = ""
    let slen: Int = len(s)
    let mut i: Int = colon_pos + 1
    for _ in 0..200 {
        if i >= slen { return result }
        result = result + s.char_at(i)
        i = i + 1
    }
    return result
}

// Compute byte offset to field_idx within a variant's payload.
// Sums llvm_type_size of fields 0..field_idx-1.
fn compute_payload_offset(st: EmitState, enum_name: String, variant_name: String, field_idx: Int) -> Int {
    let mut ei: Int = 0
    for _ in 0..50 {
        if ei >= len(st.enum_infos) { return 0 }
        let info: EnumInfo = st.enum_infos[ei]
        if info.name == enum_name {
            let mut vi: Int = 0
            for _ in 0..50 {
                if vi >= len(info.variants) { return 0 }
                if info.variants[vi].name == variant_name {
                    return sum_field_sizes(st, info.variants[vi].payload_types, field_idx)
                }
                vi = vi + 1
            }
        }
        ei = ei + 1
    }
    return 0
}

// Sum llvm_type_size for fields 0..count-1
fn sum_field_sizes(st: EmitState, types: List<MIRType>, count: Int) -> Int {
    let mut total: Int = 0
    let mut i: Int = 0
    for _ in 0..100 {
        if i >= count { return total }
        let mut pty: String = resolve_mir_type(types[i])
        // Fix struct→enum misclassification: MIR may have kind:"struct" for enums
        if pty.starts_with("%struct.") {
            let tname: String = types[i].name
            if is_enum_type(st, tname) {
                pty = "%enum." + tname
            }
        }
        total = total + llvm_type_size(pty)
        i = i + 1
    }
    return total
}

// Parse "Variant:N" → compute byte offset to field N within the variant's payload.
// Uses llvm_type_size for each prior field to sum the offset.
fn compute_variant_field_offset(st: EmitState, enum_name: String, variant_with_idx: String) -> Int {
    // Parse index from "Variant:N"
    let colon_pos: Int = variant_with_idx.find(":")
    if colon_pos < 0 { return 0 }
    let idx_str: String = variant_with_idx.substr(colon_pos + 1, len(variant_with_idx) - colon_pos - 1)
    let field_idx: Int = int(idx_str)
    if field_idx == 0 { return 0 }

    // Look up variant's payload types
    let variant_name: String = variant_with_idx.substr(0, colon_pos)
    let mut ei: Int = 0
    for _ in 0..50 {
        if ei >= len(st.enum_infos) { return 0 }
        let info: EnumInfo = st.enum_infos[ei]
        if info.name == enum_name {
            let mut vi: Int = 0
            for _ in 0..50 {
                if vi >= len(info.variants) { return 0 }
                if info.variants[vi].name == variant_name {
                    // Sum sizes of fields 0..field_idx-1
                    let mut offset: Int = 0
                    let mut fi: Int = 0
                    for _ in 0..100 {
                        if fi >= field_idx { return offset }
                        if fi >= len(info.variants[vi].payload_types) { return offset }
                        let fty: String = resolve_mir_type(info.variants[vi].payload_types[fi])
                        offset = offset + llvm_type_size(fty)
                        fi = fi + 1
                    }
                    return offset
                }
                vi = vi + 1
            }
        }
        ei = ei + 1
    }
    return 0
}

// ---------------------------------------------------------------------------
// EnumTag instruction
// ---------------------------------------------------------------------------

fn emit_enum_tag(st: EmitState, dest: Value, val: Value) -> EmitState {
    let mut s: EmitState = st
    let enum_ty: String = resolve_type(st, val.ty)
    let dn: String = dest.name
    // For Result/Option the tag field is i1; for enums it's i64.
    // Extract field 0 and zext to i64 if needed.
    if val.ty.kind == "result" || val.ty.kind == "option" {
        let raw_tag: String = dn + ".raw"
        s = emit_line(s, emit_extractvalue(raw_tag, enum_ty, val.name, "0"))
        s = emit_line(s, "  " + dn + " = zext i1 " + raw_tag + " to i64")
    } else {
        s = emit_line(s, emit_extractvalue(dn, enum_ty, val.name, "0"))
    }
    return s
}

// ---------------------------------------------------------------------------
// EnumPayload instruction
// ---------------------------------------------------------------------------

fn emit_enum_payload(st: EmitState, dest: Value, val: Value, variant: String) -> EmitState {
    let mut s: EmitState = st
    let enum_ty: String = resolve_type(st, val.ty)
    let dn: String = dest.name

    // For Result/Option: use extractvalue on the inner struct
    if val.ty.kind == "result" {
        // Result = {i1, {ok_ty, err_ty}}. Extract inner struct, then payload.
        let inner_r: String = dn + ".inner"
        s = emit_line(s, "  " + inner_r + " = extractvalue " + enum_ty + " " + val.name + ", 1")
        // Ok payload at index 0, Err payload at index 1
        let mut ok_ty: String = llvm_ptr()
        let mut err_ty: String = llvm_ptr()
        if len(val.ty.args) >= 2 {
            ok_ty = resolve_mir_type(val.ty.args[0])
            err_ty = resolve_mir_type(val.ty.args[1])
        }
        let inner_ty: String = "{ " + ok_ty + ", " + err_ty + " }"
        if variant == "Ok" {
            s = emit_line(s, "  " + dn + " = extractvalue " + inner_ty + " " + inner_r + ", 0")
        } else {
            s = emit_line(s, "  " + dn + " = extractvalue " + inner_ty + " " + inner_r + ", 1")
        }
        return s
    }
    if val.ty.kind == "option" {
        // Universal erasure: Option = {i1, ptr}. Extract ptr, then load.
        let ptr_name: String = dn + ".ptr"
        s = emit_line(s, "  " + ptr_name + " = extractvalue " + enum_ty + " " + val.name + ", 1")
        // Use destination type for load — avoids struct/enum name mismatches
        let inner_ty: String = resolve_type(st, dest.ty)
        s = emit_line(s, "  " + dn + " = load " + inner_ty + ", ptr " + ptr_name)
        return s
    }

    // Pointer-based enum: { i64 tag, ptr payload }.
    // Extract payload pointer using the named enum type.
    let pr: String = dn + ".pr"
    s = emit_line(s, "  " + pr + " = extractvalue " + enum_ty + " " + val.name + ", 1")

    // Determine the dest type
    let mut dest_ty: String = resolve_mir_type(dest.ty)
    // Correct struct→enum misclassification
    if dest_ty.starts_with("%struct.") {
        let payload_name: String = dest.ty.name
        if is_enum_type(s, payload_name) {
            dest_ty = "%enum." + payload_name
        }
    }

    // Parse field index from "Variant:N" suffix.
    let field_idx: Int = parse_field_index(variant)

    if field_idx > 0 {
        // Compute byte offset: look up variant's payload types and sum sizes
        // of fields 0..field_idx-1. Pass parsed values to avoid substr bug.
        let stripped_name: String = strip_colon_suffix(variant)
        let offset: Int = compute_payload_offset(s, val.ty.name, stripped_name, field_idx)
        let pf: String = dn + ".pf"
        s = emit_line(s, "  " + pf + " = getelementptr inbounds i8, ptr " + pr + ", i64 " + toString(offset))
        s = emit_line(s, "  " + dn + " = load " + dest_ty + ", ptr " + pf)
    } else {
        s = emit_line(s, "  " + dn + " = load " + dest_ty + ", ptr " + pr)
    }
    return s
}

// ---------------------------------------------------------------------------
// Option/Result wrapping
// ---------------------------------------------------------------------------

fn emit_wrap_some(st: EmitState, dest: Value, val: Value) -> EmitState {
    let mut s: EmitState = st
    let val_ty: String = resolve_type(st, val.ty)
    let dn: String = dest.name

    // Heap-allocate the payload via malloc so the pointer survives function returns.
    // Stack alloca would be destroyed when the current function returns, leaving
    // a dangling pointer in the {i1, ptr} Option representation.
    let ea: String = dn + ".ea"
    let sz: String = dn + ".sz"
    s = emit_line(s, "  " + sz + " = ptrtoint ptr getelementptr (" + val_ty + ", ptr null, i32 1) to i64")
    s = emit_line(s, "  " + ea + " = call ptr @malloc(i64 " + sz + ")")
    s = emit_line(s, "  store " + val_ty + " " + val.name + ", ptr " + ea)
    let opt_ty: String = llvm_option_type(llvm_ptr())
    let tag_name: String = dn + ".tag"
    s = emit_line(s, emit_insertvalue(tag_name, opt_ty, "undef", "1", "i1", "0"))
    s = emit_line(s, emit_insertvalue(dn, opt_ty, tag_name, ea, llvm_ptr(), "1"))
    return s
}

fn emit_wrap_none(st: EmitState, dest: Value, ty: MIRType) -> EmitState {
    // Universal erasure: all Option types are {i1, ptr}. None = {i1=0, null}.
    let opt_ty: String = llvm_option_type(llvm_ptr())
    let dn: String = dest.name
    let s: EmitState = emit_line(st, emit_insertvalue(dn, opt_ty, "undef", "0", "i1", "0"))
    return s
}

fn emit_wrap_ok(st: EmitState, dest: Value, val: Value) -> EmitState {
    let mut s: EmitState = st
    // Use dest's Result type args for correct ok/err layout
    let res_ty: String = resolve_mir_type(dest.ty)
    let val_ty: String = resolve_mir_type(val.ty)
    let mut ok_ty: String = val_ty
    let mut err_ty: String = llvm_ptr()
    if len(dest.ty.args) >= 2 {
        ok_ty = resolve_mir_type(dest.ty.args[0])
        err_ty = resolve_mir_type(dest.ty.args[1])
    }
    let inner_ty: String = "{ " + ok_ty + ", " + err_ty + " }"
    let dn: String = dest.name

    let tag_name: String = dn + ".tag"
    s = emit_line(s, emit_insertvalue(tag_name, res_ty, "undef", "1", "i1", "0"))
    let inner_name: String = dn + ".inner"
    s = emit_line(s, emit_insertvalue(inner_name, inner_ty, "undef", val.name, ok_ty, "0"))
    s = emit_line(s, emit_insertvalue(dn, res_ty, tag_name, inner_name, inner_ty, "1"))
    return s
}

fn emit_wrap_err(st: EmitState, dest: Value, val: Value) -> EmitState {
    let mut s: EmitState = st
    let res_ty: String = resolve_mir_type(dest.ty)
    let val_ty: String = resolve_mir_type(val.ty)
    let mut ok_ty: String = llvm_ptr()
    let mut err_ty: String = val_ty
    if len(dest.ty.args) >= 2 {
        ok_ty = resolve_mir_type(dest.ty.args[0])
        err_ty = resolve_mir_type(dest.ty.args[1])
    }
    let inner_ty: String = "{ " + ok_ty + ", " + err_ty + " }"
    let dn: String = dest.name

    let tag_name: String = dn + ".tag"
    s = emit_line(s, emit_insertvalue(tag_name, res_ty, "undef", "0", "i1", "0"))
    let inner_name: String = dn + ".inner"
    s = emit_line(s, emit_insertvalue(inner_name, inner_ty, "undef", val.name, err_ty, "1"))
    s = emit_line(s, emit_insertvalue(dn, res_ty, tag_name, inner_name, inner_ty, "1"))
    return s
}

// ---------------------------------------------------------------------------
// Unwrap instruction
// ---------------------------------------------------------------------------

fn emit_unwrap(st: EmitState, dest: Value, val: Value) -> EmitState {
    let mut s: EmitState = st
    let val_ty: String = resolve_mir_type(val.ty)
    let dn: String = dest.name
    if val.ty.kind == "option" {
        // Universal erasure: Option is {i1, ptr}. Extract ptr, then load.
        let ptr_name: String = dn + ".ptr"
        s = emit_line(s, emit_extractvalue(ptr_name, val_ty, val.name, "1"))
        // Use destination type for the load — avoids struct/enum name mismatches
        let inner_ty: String = resolve_type(st, dest.ty)
        s = emit_line(s, "  " + dn + " = load " + inner_ty + ", ptr " + ptr_name)
    } else {
        // Non-option: direct extractvalue
        s = emit_line(s, emit_extractvalue(dn, val_ty, val.name, "1"))
    }
    return s
}

// ---------------------------------------------------------------------------
// Call instruction
// ---------------------------------------------------------------------------

fn emit_mir_call(st: EmitState, dest: Value, fn_name: String, args: List<Value>) -> EmitState {
    let dn: String = dest.name

    // Built-in: print / println
    if fn_name == "print" {
        return emit_builtin_print(st, args)
    }
    if fn_name == "println" {
        return emit_builtin_println(st, args)
    }
    if fn_name == "len" {
        return emit_builtin_len(st, dest, args)
    }
    if fn_name == "toString" {
        return emit_builtin_tostring(st, dest, args)
    }
    if fn_name == "str" {
        return emit_builtin_tostring(st, dest, args)
    }
    if fn_name == "int" {
        return emit_builtin_int(st, dest, args)
    }
    if fn_name == "float" {
        return emit_builtin_float(st, dest, args)
    }

    // Range construction — inline to avoid ABI mismatch with C runtime
    // C runtime __mn_range returns void* (ptr), but self-hosted expects {i64, i64}.
    // Fix: construct the {i64, i64} directly instead of calling the C function.
    if fn_name == "__mn_range" {
        let mut s: EmitState = st
        let tmp: String = dn + ".tmp"
        s = emit_line(s, "  " + tmp + " = insertvalue { i64, i64 } undef, i64 " + args[0].name + ", 0")
        s = emit_line(s, "  " + dn + " = insertvalue { i64, i64 } " + tmp + ", i64 " + args[1].name + ", 1")
        return s
    }
    if fn_name == "__mn_range_inclusive" {
        let mut s: EmitState = st
        let inc: String = dn + ".inc"
        let tmp: String = dn + ".tmp"
        s = emit_line(s, "  " + inc + " = add i64 " + args[1].name + ", 1")
        s = emit_line(s, "  " + tmp + " = insertvalue { i64, i64 } undef, i64 " + args[0].name + ", 0")
        s = emit_line(s, "  " + dn + " = insertvalue { i64, i64 } " + tmp + ", i64 " + inc + ", 1")
        return s
    }

    // Range field extraction (counter-based for-loops)
    if fn_name == "__mn_range_start" {
        let mut s: EmitState = st
        s = emit_line(s, "  " + dn + " = extractvalue { i64, i64 } " + args[0].name + ", 0")
        return s
    }
    if fn_name == "__mn_range_end" {
        let mut s: EmitState = st
        s = emit_line(s, "  " + dn + " = extractvalue { i64, i64 } " + args[0].name + ", 1")
        return s
    }

    // String builtins
    if fn_name == "split" {
        let mut s: EmitState = st
        let arg_str: String = llvm_string() + " " + args[0].name + ", " + llvm_string() + " " + args[1].name
        s = emit_line(s, emit_call_ir(dn, llvm_list_rt(), "__mn_str_split", arg_str))
        return s
    }
    if fn_name == "contains" {
        let mut s: EmitState = st
        let arg_str: String = llvm_string() + " " + args[0].name + ", " + llvm_string() + " " + args[1].name
        s = emit_line(s, emit_call_ir(dn, llvm_bool(), "__mn_str_contains", arg_str))
        return s
    }
    if fn_name == "replace" {
        let mut s: EmitState = st
        let arg_str: String = llvm_string() + " " + args[0].name + ", " + llvm_string() + " " + args[1].name + ", " + llvm_string() + " " + args[2].name
        s = emit_line(s, emit_call_ir(dn, llvm_string(), "__mn_str_replace", arg_str))
        return s
    }
    if fn_name == "byte_at" {
        let mut s: EmitState = st
        let arg_str: String = llvm_string() + " " + args[0].name + ", i64 " + args[1].name
        s = emit_line(s, emit_call_ir(dn, llvm_int(), "__mn_str_byte_at", arg_str))
        return s
    }
    // join(sep, list) → String via C runtime. List passed by pointer.
    if fn_name == "join" {
        let mut s: EmitState = st
        // Alloca the list and pass pointer (C runtime expects MnList*)
        let la: String = "%" + strip_percent(dn) + ".la"
        s = emit_line(s, "  " + la + " = alloca " + llvm_list_rt())
        s = emit_line(s, "  store " + llvm_list_rt() + " " + args[1].name + ", ptr " + la)
        let arg_str: String = llvm_string() + " " + args[0].name + ", ptr " + la
        s = emit_line(s, emit_call_ir(dn, llvm_string(), "__mn_str_join", arg_str))
        return s
    }

    // List push: extract to helper to avoid return-inside-if bug
    if fn_name == "push" {
        return emit_list_push_call(st, dest, args)
    }

    // Synthetic struct constructor: __new_<StructName>(field_values...)
    // Use replace to remove the "__new_" prefix instead of substr
    // (substr has off-by-one issues in the compiled binary)
    if fn_name.contains("__new_") {
        let struct_name: String = fn_name.replace("__new_", "")
        let struct_ty: MIRType = mir_struct(struct_name)
        return emit_struct_init_from_values(st, dest, struct_ty, args)
    }

    // Resolve operands for all other calls
    let mut s: EmitState = st

    // String methods: dispatched to __mn_str_<method> runtime functions
    if len(args) >= 1 {
        let first_arg: Value = args[0]
        if first_arg.ty.kind == "string" {
            let s0: String = first_arg.name
            if fn_name == "contains" {
                s = emit_line(s, emit_call_ir(dn, llvm_bool(), "__mn_str_contains", llvm_string() + " " + s0 + ", " + llvm_string() + " " + args[1].name))
                return s
            }
            if fn_name == "starts_with" {
                s = emit_line(s, emit_call_ir(dn, llvm_bool(), "__mn_str_starts_with", llvm_string() + " " + s0 + ", " + llvm_string() + " " + args[1].name))
                return s
            }
            if fn_name == "ends_with" {
                s = emit_line(s, emit_call_ir(dn, llvm_bool(), "__mn_str_ends_with", llvm_string() + " " + s0 + ", " + llvm_string() + " " + args[1].name))
                return s
            }
            if fn_name == "find" {
                s = emit_line(s, emit_call_ir(dn, llvm_int(), "__mn_str_find", llvm_string() + " " + s0 + ", " + llvm_string() + " " + args[1].name))
                return s
            }
            if fn_name == "char_at" {
                s = emit_line(s, emit_call_ir(dn, llvm_string(), "__mn_str_char_at", llvm_string() + " " + s0 + ", i64 " + args[1].name))
                return s
            }
            if fn_name == "substr" {
                if len(args) >= 3 {
                    s = emit_line(s, emit_call_ir(dn, llvm_string(), "__mn_str_substr", llvm_string() + " " + s0 + ", i64 " + args[1].name + ", i64 " + args[2].name))
                    return s
                }
            }
            if fn_name == "to_upper" {
                s = emit_line(s, emit_call_ir(dn, llvm_string(), "__mn_str_to_upper", llvm_string() + " " + s0))
                return s
            }
            if fn_name == "to_lower" {
                s = emit_line(s, emit_call_ir(dn, llvm_string(), "__mn_str_to_lower", llvm_string() + " " + s0))
                return s
            }
            if fn_name == "replace" {
                if len(args) >= 3 {
                    s = emit_line(s, emit_call_ir(dn, llvm_string(), "__mn_str_replace", llvm_string() + " " + s0 + ", " + llvm_string() + " " + args[1].name + ", " + llvm_string() + " " + args[2].name))
                    return s
                }
            }
        }
    }

    // Look up registered function parameter types (more reliable than MIR)
    let fn_opt_pre: Option<FnEntry> = find_function(s, fn_name)
    let mut reg_param_types: List<String> = []
    match fn_opt_pre {
        Some(fe) => { reg_param_types = fe.param_types },
        _ => {}
    }

    // Build args with byref: large struct args → alloca + pass pointer
    let mut args_str: String = ""
    let mut j: Int = 0
    let nargs: Int = len(args)
    for _ in 0..50 {
        if j < nargs {
            let mut aty: String = resolve_mir_type(args[j].ty)
            let mut an: String = args[j].name
            // Use registered param type when available.
            // Enum reinterpret: alloca+store+load for layout-compatible enums.
            // NEVER set an=zeroinitializer (that was the bug causing empty args).
            if j < len(reg_param_types) {
                let rpt: String = reg_param_types[j]
                if rpt != aty && rpt != "i64" {
                    // Enum type mismatch: reinterpret through memory
                    if aty.starts_with("%enum.") && rpt.starts_with("%enum.") && aty != rpt {
                        let rc_a: String = "%ecast" + toString(s.counter)
                        s.counter = s.counter + 1
                        s = emit_line(s, "  " + rc_a + " = alloca " + rpt)
                        s = emit_line(s, "  store " + aty + " " + an + ", ptr " + rc_a)
                        let rc_ld: String = "%ecast_ld" + toString(s.counter)
                        s.counter = s.counter + 1
                        s = emit_line(s, "  " + rc_ld + " = load " + rpt + ", ptr " + rc_a)
                        an = rc_ld
                    }
                    aty = rpt
                }
            }
            // Byref: large struct args → store to alloca, pass pointer
            let mut pass_ty: String = aty
            let mut pass_name: String = an
            if is_byref_type(aty) {
                let ba: String = "%barg" + toString(s.counter)
                s.counter = s.counter + 1
                s = emit_line(s, "  " + ba + " = alloca " + aty)
                s = emit_line(s, "  store " + aty + " " + an + ", ptr " + ba)
                pass_ty = "ptr"
                pass_name = ba
            }
            if j > 0 {
                args_str = args_str + ", " + pass_ty + " " + pass_name
            } else {
                args_str = pass_ty + " " + pass_name
            }
            j = j + 1
        }
    }

    // Look up return type and handle sret for large struct returns
    let fn_opt: Option<FnEntry> = find_function(s, fn_name)
    match fn_opt {
        Some(fe) => {
            if fe.ret_type == "void" {
                return emit_line(s, emit_call_void(fn_name, args_str))
            }
            // sret: large struct returns via hidden pointer
            if is_byref_type(fe.ret_type) {
                let sret_a: String = "%sret" + toString(s.counter)
                s.counter = s.counter + 1
                s = emit_line(s, "  " + sret_a + " = alloca " + fe.ret_type)
                s = emit_line(s, "  store " + fe.ret_type + " zeroinitializer, ptr " + sret_a)
                let sret_arg: String = "ptr sret(" + fe.ret_type + ") " + sret_a
                let mut full_args: String = sret_arg
                if len(args_str) > 0 { full_args = sret_arg + ", " + args_str }
                s = emit_line(s, "  call void @" + fn_name + "(" + full_args + ")")
                s = emit_line(s, "  " + dn + " = load " + fe.ret_type + ", ptr " + sret_a)
                return s
            }
            s = emit_line(s, emit_call_ir(dn, fe.ret_type, fn_name, args_str))
            return s
        },
        _ => {
            let ret_ty: String = resolve_mir_type(dest.ty)
            if ret_ty == "void" {
                return emit_line(s, emit_call_void(fn_name, args_str))
            }
            s = emit_line(s, emit_call_ir(dn, ret_ty, fn_name, args_str))
            return s
        }
    }
}

// ---------------------------------------------------------------------------
// Built-in function emission
// ---------------------------------------------------------------------------

fn emit_builtin_print(st: EmitState, args: List<Value>) -> EmitState {
    // print() in Mapanare adds a newline (like Python's print)
    if len(args) == 0 {
        return emit_line(st, emit_call_void("printf", "ptr @.newline"))
    }
    let arg: Value = args[0]
    let mut s: EmitState = st
    let an: String = arg.name

    if arg.ty.kind == "string" {
        return emit_line(s, emit_call_void("__mn_str_println", llvm_string() + " " + an))
    }
    if arg.ty.kind == "float" {
        return emit_line(s, "  call i32 (ptr, ...) @printf(ptr @.fmt_float_nl, double " + an + ")")
    }
    if arg.ty.kind == "int" {
        return emit_line(s, "  call i32 (ptr, ...) @printf(ptr @.fmt_int_nl, i64 " + an + ")")
    }
    if arg.ty.kind == "bool" {
        return emit_line(s, "  call i32 (ptr, ...) @printf(ptr @.fmt_int_nl, i64 " + an + ")")
    }
    // Unknown type: assume string
    return emit_line(s, emit_call_void("__mn_str_println", llvm_string() + " " + an))
}

fn emit_builtin_println(st: EmitState, args: List<Value>) -> EmitState {
    if len(args) == 0 {
        return emit_line(st, emit_call_void("printf", "ptr @.newline"))
    }
    let arg: Value = args[0]
    let mut s: EmitState = st
    let an: String = arg.name

    if arg.ty.kind == "string" {
        return emit_line(s, emit_call_void("__mn_str_println", llvm_string() + " " + an))
    }
    if arg.ty.kind == "float" {
        return emit_line(s, "  call i32 (ptr, ...) @printf(ptr @.fmt_float_nl, double " + an + ")")
    }
    if arg.ty.kind == "int" {
        return emit_line(s, "  call i32 (ptr, ...) @printf(ptr @.fmt_int_nl, i64 " + an + ")")
    }
    if arg.ty.kind == "bool" {
        return emit_line(s, "  call i32 (ptr, ...) @printf(ptr @.fmt_int_nl, i64 " + an + ")")
    }
    // Unknown type: assume string (common from str()/toString() calls)
    return emit_line(s, emit_call_void("__mn_str_println", llvm_string() + " " + an))
}

fn emit_builtin_len(st: EmitState, dest: Value, args: List<Value>) -> EmitState {
    if len(args) == 0 { return st }
    let mut s: EmitState = st
    let an: String = args[0].name
    let dn: String = dest.name

    if args[0].ty.kind == "string" {
        s = emit_line(s, emit_call_ir(dn, llvm_int(), "__mn_str_len", llvm_string() + " " + an))
    } else {
        // __mn_list_len expects a pointer; alloca+store the list value first
        let tmp: String = dn + ".lp"
        let lt: String = llvm_list_rt()
        s = emit_line(s, "  " + tmp + " = alloca " + lt)
        s = emit_line(s, "  store " + lt + " " + an + ", " + "ptr " + tmp)
        s = emit_line(s, emit_call_ir(dn, llvm_int(), "__mn_list_len", "ptr " + tmp))
    }
    return s
}

fn emit_builtin_tostring(st: EmitState, dest: Value, args: List<Value>) -> EmitState {
    if len(args) == 0 { return st }
    let mut s: EmitState = st
    let an: String = args[0].name
    let dn: String = dest.name

    if args[0].ty.kind == "string" {
        return emit_copy(s, dest, args[0])
    }
    if args[0].ty.kind == "bool" {
        s = emit_line(s, emit_call_ir(dn, llvm_string(), "__mn_str_from_bool", "i1 " + an))
    } else {
    if args[0].ty.kind == "float" {
        s = emit_line(s, emit_call_ir(dn, llvm_string(), "__mn_str_from_float", "double " + an))
    } else {
        s = emit_line(s, emit_call_ir(dn, llvm_string(), "__mn_str_from_int", "i64 " + an))
    }}
    return s
}

fn emit_builtin_int(st: EmitState, dest: Value, args: List<Value>) -> EmitState {
    if len(args) == 0 { return st }
    let mut s: EmitState = st
    let an: String = args[0].name
    let dn: String = dest.name

    if args[0].ty.kind == "float" {
        s = emit_line(s, "  " + dn + " =fptosi double " + an + " to i64")
    } else {
    if args[0].ty.kind == "int" {
        return emit_copy(s, dest, args[0])
    } else {
        s = emit_line(s, emit_call_ir(dn, llvm_int(), "__mn_str_to_int", llvm_string() + " " + an))
    }}
    return s
}

fn emit_builtin_float(st: EmitState, dest: Value, args: List<Value>) -> EmitState {
    if len(args) == 0 { return st }
    let mut s: EmitState = st
    let an: String = args[0].name
    let dn: String = dest.name

    if args[0].ty.kind == "int" {
        s = emit_line(s, "  " + dn + " =sitofp i64 " + an + " to double")
    } else {
    if args[0].ty.kind == "float" {
        return emit_copy(s, dest, args[0])
    } else {
        s = emit_line(s, emit_call_ir(dn, llvm_float(), "__mn_str_to_float", llvm_string() + " " + an))
    }}
    return s
}

// ---------------------------------------------------------------------------
// Return instruction
// ---------------------------------------------------------------------------

fn emit_mir_return(st: EmitState, val_opt: Option<Value>) -> EmitState {
    match val_opt {
        Some(val) => {
            let ty: String = st.current_ret_type
            if ty == "void" {
                return emit_line(st, emit_ret_void())
            }
            // If using sret (large struct return), store to sret pointer and ret void
            if is_byref_type(ty) {
                let mut s: EmitState = emit_line(st, "  store " + ty + " " + val.name + ", ptr %__sret__")
                return emit_line(s, emit_ret_void())
            }
            return emit_line(st, emit_ret(ty, val.name))
        },
        _ => {
            // For non-void functions, emit zeroinitializer return (dead code from
            // match arms that all terminate). For void functions, emit ret void.
            let ret_ty: String = st.current_ret_type
            if ret_ty != "void" {
                return emit_line(st, "  ret " + ret_ty + " zeroinitializer")
            }
            return emit_line(st, emit_ret_void())
        }
    }
}

// ---------------------------------------------------------------------------
// Switch instruction
// ---------------------------------------------------------------------------

fn emit_mir_switch(st: EmitState, tag: Value, cases: List<SwitchCase>, default_bb: String) -> EmitState {
    let mut s: EmitState = emit_line(st, emit_switch_hdr(tag.name, default_bb))
    // Resolve the enum name from the tag value's type for variant index lookup
    let enum_name: String = tag.ty.name

    let mut i: Int = 0
    for _ in 0..50 {
        if i >= len(cases) {
            s = emit_line(s, "  ]")
            return s
        }
        let c: SwitchCase = cases[i]
        // If the case value is a variant name (not a number), resolve to integer index
        // This mirrors the Python emitter's _vtag() method
        let mut case_val: String = c.tag_value
        if len(case_val) > 0 {
            let first_ch: Int = c.tag_value.byte_at(0)
            // If not a digit (0-9) and not '-', it's a variant name → resolve to index
            if first_ch < 48 || first_ch > 57 {
                if first_ch != 45 {
                    // Hardcoded indices for Result/Option builtins
                    if case_val == "Ok" || case_val == "Some" {
                        case_val = "1"
                    } else if case_val == "Err" || case_val == "None" {
                        case_val = "0"
                    } else {
                        case_val = toString(resolve_variant_index(s, enum_name, case_val))
                    }
                }
            }
        }
        s = emit_line(s, emit_switch_case(case_val, c.block_label))
        i = i + 1
    }
    s = emit_line(s, "  ]")
    return s
}

// ---------------------------------------------------------------------------
// Agent instructions
// ---------------------------------------------------------------------------

fn emit_agent_spawn(st: EmitState, dest: Value, ty: MIRType, args: List<Value>) -> EmitState {
    let dn: String = dest.name
    let mut s: EmitState = st
    // Call agent spawn runtime function
    s = emit_line(s, emit_call_ir(dn, "ptr", "__mn_agent_spawn", "ptr null, ptr null"))
    return s
}

fn emit_agent_send(st: EmitState, ag: Value, channel: String, val: Value) -> EmitState {
    return emit_line(st, emit_call_void("__mn_agent_send", "ptr " + ag.name + ", ptr null, ptr null"))
}

fn emit_agent_sync(st: EmitState, dest: Value, ag: Value, channel: String) -> EmitState {
    let dn: String = dest.name
    let s2: EmitState = emit_line(st, emit_call_ir(dn, "ptr", "__mn_agent_sync", "ptr " + ag.name + ", ptr null"))
    return s2
}

// ---------------------------------------------------------------------------
// Signal instructions
// ---------------------------------------------------------------------------

fn emit_signal_init(st: EmitState, dest: Value, ty: MIRType, val: Value) -> EmitState {
    let dn: String = dest.name
    let s2: EmitState = emit_line(st, emit_call_ir(dn, "ptr", "__mn_signal_new", "ptr null"))
    return s2
}

fn emit_signal_get(st: EmitState, dest: Value, sig: Value) -> EmitState {
    let dn: String = dest.name
    let s2: EmitState = emit_line(st, emit_call_ir(dn, "ptr", "__mn_signal_get", "ptr " + sig.name))
    return s2
}

fn emit_signal_set(st: EmitState, sig: Value, val: Value) -> EmitState {
    return emit_line(st, emit_call_void("__mn_signal_set", "ptr " + sig.name + ", ptr null"))
}

// ---------------------------------------------------------------------------
// StreamOp instruction
// ---------------------------------------------------------------------------

fn emit_stream_op(st: EmitState, dest: Value, kind: StreamOpKind, source: Value, args: List<Value>) -> EmitState {
    let mut s: EmitState = st
    let dn: String = dest.name
    // Stream operations are runtime-dispatched; minimal LLVM lowering
    let s2: EmitState = emit_line(s, "  " + dn + " =bitcast ptr " + source.name + " to ptr")
    return s2
}

// ---------------------------------------------------------------------------
// InterpConcat instruction
// ---------------------------------------------------------------------------

fn emit_interp_concat(st: EmitState, dest: Value, parts: List<Value>) -> EmitState {
    if len(parts) == 0 {
        return emit_const(st, dest, mir_string(), "")
    }
    if len(parts) == 1 {
        return emit_copy(st, dest, parts[0])
    }

    // Concatenate parts left-to-right using __mn_str_concat
    let mut s: EmitState = st
    let dn: String = dest.name

    let mut acc: String = parts[0].name

    let mut i: Int = 1
    let nparts: Int = len(parts)
    for _ in 0..50 {
        if i < nparts {
            let tmp: String = dn + ".c" + toString(i)
            s = emit_line(s, emit_call_ir(tmp, llvm_string(), "__mn_str_concat", llvm_string() + " " + acc + ", " + llvm_string() + " " + parts[i].name))
            acc = tmp
            i = i + 1
        }
    }
    return s
}

// ---------------------------------------------------------------------------
// Phi instruction
// ---------------------------------------------------------------------------

fn emit_mir_phi(st: EmitState, dest: Value, incoming: List<PhiEntry>) -> EmitState {
    let mut ty: String = resolve_type(st, dest.ty)
    let dn: String = dest.name

    let mut s: EmitState = st
    let mut skip: Bool = false
    if len(incoming) == 0 { skip = true }
    if ty == "void" { skip = true }
    // For Phis with i64 type (unresolved): recover the actual type from
    // the incoming values. Uses a flag instead of break to avoid the
    // Python lowerer's control flow bug that swallows break-inside-if.
    if ty == "i64" && len(incoming) > 0 {
        let mut found: Bool = false
        let mut ci: Int = 0
        for _ in 0..100 {
            if ci >= len(incoming) { ci = 999 }
            if !found && ci < len(incoming) {
                let inc_ty: String = resolve_type(st, incoming[ci].val.ty)
                if inc_ty != "i64" && inc_ty != "void" {
                    ty = inc_ty
                    found = true
                }
            }
            ci = ci + 1
        }
    }

    if !skip {
        let mut phi_str: String = "  " + dn + " = phi " + ty + " "
        let mut i: Int = 0
        let nincoming: Int = len(incoming)
        for _ in 0..50 {
            if i < nincoming {
                let e: PhiEntry = incoming[i]
                if i > 0 {
                    phi_str = phi_str + ", "
                }
                phi_str = phi_str + "[ " + e.val.name + ", %" + e.block_label + " ]"
                i = i + 1
            }
        }
        s = emit_line(s, phi_str)
    }
    return s
}

// ---------------------------------------------------------------------------
// MIR basic block emission
// ---------------------------------------------------------------------------

fn emit_mir_basic_block(st: EmitState, bb: BasicBlock) -> EmitState {
    let mut s: EmitState = emit_line(st, bb.label + ":")
    let mut i: Int = 0
    for _ in 0..600 {
        if i >= len(bb.instructions) { return s }
        let inst: Instruction = bb.instructions[i]
        s = emit_mir_instruction(s, inst)
        i = i + 1
    }
    return s
}

// ---------------------------------------------------------------------------
// MIR function emission
// ---------------------------------------------------------------------------

fn emit_mir_function(st: EmitState, f: MIRFunction) -> EmitState {
    // Resolve return type
    let mut ret_ty: String = resolve_mir_type(f.return_type)
    if ret_ty.starts_with("%struct.") {
        let ret_name: String = f.return_type.name
        if is_enum_type(st, ret_name) {
            ret_ty = "%enum." + ret_name
        }
    }

    // Determine byref/sret: large structs passed by pointer
    let use_sret: Bool = is_byref_type(ret_ty) && f.name != "main"

    // Build parameter list with byref adjustments
    let mut params_str: String = ""
    let mut param_types: List<String> = []
    // If sret, first param is the return pointer
    if use_sret {
        params_str = "ptr sret(" + ret_ty + ") %__sret__"
    }
    let mut pi: Int = 0
    let nfparams: Int = len(f.params)
    for _ in 0..50 {
        if pi < nfparams {
            let p: MIRParam = f.params[pi]
            let pty: String = resolve_mir_type(p.ty)
            param_types.push(pty)
            let need_sep: Bool = pi > 0 || use_sret
            let mut sep: String = ""
            if need_sep { sep = ", " }
            if is_byref_type(pty) {
                // Large param: pass by pointer
                params_str = params_str + sep + "ptr %" + p.name + ".byref"
            } else {
                params_str = params_str + sep + pty + " %" + p.name
            }
            pi = pi + 1
        }
    }

    // Register function (with original types for caller resolution)
    let entry: FnEntry = new_fn_entry(f.name, ret_ty, param_types)
    let mut s: EmitState = st
    s.functions.push(entry)

    // Track current function's return type and sret flag
    s.current_ret_type = ret_ty

    // Emit function header
    let fn_name: String = strip_percent(f.name)
    let is_lambda: Bool = fn_name != f.name
    // Avoid if-expression (PHI zeroinitializer bug in stage2)
    let mut visibility: String = "define"
    if is_lambda { visibility = "define internal" }
    let mut abi_ret: String = ret_ty
    if use_sret { abi_ret = "void" }
    s = emit_line(s, visibility + " " + abi_ret + " @" + fn_name + "(" + params_str + ") {")

    // Emit basic blocks — entry block gets byref param fixup.
    // Extracted from single loop to avoid return-in-for and else-branch bugs.
    let nblks: Int = len(f.blocks)

    // Entry block (index 0): emit byref param loads, then instructions
    if nblks > 0 {
        let bb0: BasicBlock = f.blocks[0]
        s = emit_line(s, bb0.label + ":")
        // Emit byref loads: for each byref param, alloca + load from ptr + store
        let mut pi3: Int = 0
        let nfparams3: Int = len(f.params)
        for _ in 0..100 {
            if pi3 < nfparams3 {
                let p: MIRParam = f.params[pi3]
                let pty: String = resolve_mir_type(p.ty)
                if is_byref_type(pty) {
                    s = emit_line(s, "  %" + p.name + ".addr = alloca " + pty)
                    s = emit_line(s, "  %" + p.name + ".bp = load " + pty + ", ptr %" + p.name + ".byref")
                    s = emit_line(s, "  store " + pty + " %" + p.name + ".bp, ptr %" + p.name + ".addr")
                }
                pi3 = pi3 + 1
            }
        }
        // Build set of byref param names for skip detection
        let mut byref_names: List<String> = []
        let mut pn: Int = 0
        let nfparamsn: Int = len(f.params)
        for _ in 0..100 {
            if pn < nfparamsn {
                let pp: MIRParam = f.params[pn]
                let ppty: String = resolve_mir_type(pp.ty)
                if is_byref_type(ppty) {
                    byref_names.push(pp.name)
                }
                pn = pn + 1
            }
        }
        // Emit block instructions, skipping Alloca+Store ONLY for byref params
        let mut ii: Int = 0
        let ninsts: Int = len(bb0.instructions)
        for _ in 0..600 {
            if ii < ninsts {
                let inst: Instruction = bb0.instructions[ii]
                let mut should_skip: Bool = false
                match inst {
                    Alloca(dest, ty) => {
                        should_skip = is_name_in_byref(byref_names, dest.name)
                    },
                    Store(ptr, val) => {
                        should_skip = is_name_in_byref(byref_names, ptr.name)
                    },
                    _ => {}
                }
                if !should_skip {
                    s = emit_mir_instruction(s, inst)
                }
                ii = ii + 1
            }
        }
    }

    // Remaining blocks (index 1..nblks-1)
    let mut bi: Int = 1
    for _ in 0..600 {
        if bi < nblks {
            let bb: BasicBlock = f.blocks[bi]
            s = emit_mir_basic_block(s, bb)
            bi = bi + 1
        }
    }

    s = emit_line(s, "}")
    return emit_blank(s)
}

// ---------------------------------------------------------------------------
// Format constants (printf format strings)
// ---------------------------------------------------------------------------

fn emit_format_constants(st: EmitState) -> EmitState {
    let mut s: EmitState = st
    s = emit_line(s, "@.newline = private constant [2 x i8] c\"\\0A\\00\", align 2")
    s = emit_line(s, "@.fmt_int = private constant [4 x i8] c\"%ld\\00\", align 2")
    s = emit_line(s, "@.fmt_int_nl = private constant [5 x i8] c\"%ld\\0A\\00\", align 2")
    s = emit_line(s, "@.fmt_float = private constant [4 x i8] c\"%lf\\00\", align 2")
    s = emit_line(s, "@.fmt_float_nl = private constant [5 x i8] c\"%lf\\0A\\00\", align 2")
    return emit_blank(s)
}

// ---------------------------------------------------------------------------
// Public API: emit_mir_module
// ---------------------------------------------------------------------------

fn str_join(sep: String, parts: List<String>) -> String {
    return join(sep, parts)
}

pub fn emit_mir_module(module: MIRModule, module_name: String) -> String {
    let mut st: EmitState = new_emit_state(module_name)

    // Module header
    st = emit_line(st, "; ModuleID = '" + module_name + "'")
    st = emit_line(st, "source_filename = \"" + module_name + "\"")
    st = emit_blank(st)

    // Format string constants
    st = emit_format_constants(st)

    // Runtime declarations
    st = declare_all_runtime(st)

    // Register struct types
    let mut si: Int = 0
    let nmodstructs: Int = len(module.structs)
    for _ in 0..50 {
        if si < nmodstructs {
            st = register_mir_struct(st, module.structs[si])
            si = si + 1
        }
    }

    // Register enum types
    let mut ei: Int = 0
    let nmodenums: Int = len(module.enums)
    for _ in 0..50 {
        if ei < nmodenums {
            st = register_mir_enum(st, module.enums[ei])
            ei = ei + 1
        }
    }

    if len(module.structs) > 0 { st = emit_blank(st) }
    if len(module.enums) > 0 { st = emit_blank(st) }

    // Declare extern functions
    let mut xi: Int = 0
    let nmodexterns: Int = len(module.extern_fns)
    for _ in 0..50 {
        if xi < nmodexterns {
            st = declare_mir_extern(st, module.extern_fns[xi])
            xi = xi + 1
        }
    }
    if len(module.extern_fns) > 0 { st = emit_blank(st) }

    // Forward-declare all functions (for mutual recursion)
    let mut di: Int = 0
    let nmodfns: Int = len(module.functions)
    for _ in 0..600 {
        if di < nmodfns {
            let f: MIRFunction = module.functions[di]
            let ret_ty: String = resolve_mir_type(f.return_type)
            let mut fparams: String = ""
            let mut fpi: Int = 0
            let nfwdparams: Int = len(f.params)
            for _ in 0..50 {
                if fpi < nfwdparams {
                    let fp: MIRParam = f.params[fpi]
                    let fpty: String = resolve_mir_type(fp.ty)
                    if fpi > 0 {
                        fparams = fparams + ", " + fpty
                    } else {
                        fparams = fpty
                    }
                    fpi = fpi + 1
                }
            }
            let mut fn_types: List<String> = []
            let mut fti: Int = 0
            for _ in 0..50 {
                if fti < nfwdparams {
                    fn_types.push(resolve_mir_type(f.params[fti].ty))
                    fti = fti + 1
                }
            }
            let fe: FnEntry = new_fn_entry(f.name, ret_ty, fn_types)
            st.functions.push(fe)
            di = di + 1
        }
    }

    // Emit function bodies
    let total_fns: Int = len(module.functions)
    let mut fi: Int = 0
    for _ in 0..600 {
        if fi < total_fns {
            let f: MIRFunction = module.functions[fi]
            if len(f.blocks) > 0 {
                st = emit_mir_function(st, f)
            }
            fi = fi + 1
        }
    }

    // Append string globals
    let mut gi: Int = 0
    let nstrglobals: Int = len(st.str_globals)
    for _ in 0..1000000 {
        if gi < nstrglobals {
            st = emit_line(st, st.str_globals[gi])
            gi = gi + 1
        }
    }
    // Print all lines directly to stdout
    let nlines: Int = len(st.lines)
    let mut li: Int = 0
    for _ in 0..1000000 {
        if li < nlines {
            print(st.lines[li])
            li = li + 1
        }
    }
    return ""
}

// ---------------------------------------------------------------------------
// Streaming API: emit module header, then individual functions
// ---------------------------------------------------------------------------

pub fn emit_header(module: MIRModule, module_name: String) -> EmitState {
    let mut st: EmitState = new_emit_state(module_name)
    st = emit_line(st, "; ModuleID = '" + module_name + "'")
    st = emit_line(st, "source_filename = \"" + module_name + "\"")
    st = emit_blank(st)
    st = emit_format_constants(st)
    st = declare_all_runtime(st)

    let mut si: Int = 0
    let nhstructs: Int = len(module.structs)
    for _ in 0..50 {
        if si < nhstructs {
            st = register_mir_struct(st, module.structs[si])
            si = si + 1
        }
    }
    let mut ei: Int = 0
    let nhenums: Int = len(module.enums)
    for _ in 0..50 {
        if ei < nhenums {
            st = register_mir_enum(st, module.enums[ei])
            ei = ei + 1
        }
    }
    if len(module.structs) > 0 { st = emit_blank(st) }
    if len(module.enums) > 0 { st = emit_blank(st) }

    let mut xi: Int = 0
    let nhexterns: Int = len(module.extern_fns)
    for _ in 0..50 {
        if xi < nhexterns {
            st = declare_mir_extern(st, module.extern_fns[xi])
            xi = xi + 1
        }
    }
    if len(module.extern_fns) > 0 { st = emit_blank(st) }

    return st
}

pub fn register_fn_sig(st: EmitState, f: MIRFunction) -> EmitState {
    let mut ret_ty: String = resolve_mir_type(f.return_type)
    if ret_ty.starts_with("%struct.") {
        if is_enum_type(st, f.return_type.name) {
            ret_ty = "%enum." + f.return_type.name
        }
    }
    let fn_types: List<String> = []
    let fe: FnEntry = new_fn_entry(f.name, ret_ty, fn_types)
    let mut s: EmitState = st
    s.functions.push(fe)
    return s
}

pub fn emit_one_fn(st: EmitState, f: MIRFunction) -> EmitState {
    return emit_mir_function(st, f)
}

pub fn emit_finalize(st: EmitState) -> String {
    let nlines: Int = len(st.lines)
    let mut result: String = ""
    let mut li: Int = 0
    for _ in 0..1000000 {
        if li < nlines {
            result = result + st.lines[li] + "\n"
            li = li + 1
        }
    }
    let mut gi: Int = 0
    let nfinalglobals: Int = len(st.str_globals)
    for _ in 0..1000000 {
        if gi < nfinalglobals {
            result = result + st.str_globals[gi] + "\n"
            gi = gi + 1
        }
    }
    return result
}
