enum Color {
    Red,
    Green,
    Blue
}

fn color_name(c: Color) -> String {
    match c {
        Red => { return "red" },
        Green => { return "green" },
        Blue => { return "blue" }
    }
}

fn main() {
    let c1: Color = Red
    let c2: Color = Blue
    print(color_name(c1))
    print(color_name(c2))
}
