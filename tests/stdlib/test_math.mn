// test_math.mn — Tests for stdlib/math.mn
//
// Self-contained: functions defined inline so the JIT test runner
// can compile and execute without cross-module imports.

// ---------------------------------------------------------------------------
// Constants
// ---------------------------------------------------------------------------

fn pi() -> Float { return 3.141592653589793 }
fn e() -> Float { return 2.718281828459045 }
fn tau() -> Float { return 6.283185307179586 }

// ---------------------------------------------------------------------------
// Basic numeric functions
// ---------------------------------------------------------------------------

fn abs_int(x: Int) -> Int {
    if x < 0 { return 0 - x }
    return x
}

fn mn_abs(x: Float) -> Float {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn clamp(x: Float, lo: Float, hi: Float) -> Float {
    if x < lo { return lo }
    if x > hi { return hi }
    return x
}

fn clamp_int(x: Int, lo: Int, hi: Int) -> Int {
    if x < lo { return lo }
    if x > hi { return hi }
    return x
}

fn lerp(a: Float, b: Float, t: Float) -> Float {
    return a + (b - a) * t
}

fn remap(x: Float, in_lo: Float, in_hi: Float, out_lo: Float, out_hi: Float) -> Float {
    let t: Float = (x - in_lo) / (in_hi - in_lo)
    return out_lo + (out_hi - out_lo) * t
}

fn min_float(a: Float, b: Float) -> Float {
    if a < b { return a }
    return b
}

fn max_float(a: Float, b: Float) -> Float {
    if a > b { return a }
    return b
}

fn min_int(a: Int, b: Int) -> Int {
    if a < b { return a }
    return b
}

fn max_int(a: Int, b: Int) -> Int {
    if a > b { return a }
    return b
}

fn sign(x: Float) -> Float {
    if x > 0.0 { return 1.0 }
    if x < 0.0 { return -1.0 }
    return 0.0
}

fn sign_int(x: Int) -> Int {
    if x > 0 { return 1 }
    if x < 0 { return -1 }
    return 0
}

// ---------------------------------------------------------------------------
// Angle conversion
// ---------------------------------------------------------------------------

fn degrees(rad: Float) -> Float {
    return rad * 180.0 / pi()
}

fn radians(deg: Float) -> Float {
    return deg * pi() / 180.0
}

// ---------------------------------------------------------------------------
// Rounding
// ---------------------------------------------------------------------------

fn mn_floor(x: Float) -> Int {
    let i: Int = int(x)
    let f: Float = float(i)
    if x < f { return i - 1 }
    return i
}

fn mn_ceil(x: Float) -> Int {
    let i: Int = int(x)
    let f: Float = float(i)
    if x > f { return i + 1 }
    return i
}

fn round_to(x: Float, decimals: Int) -> Float {
    let mut factor: Float = 1.0
    let mut i: Int = 0
    while i < decimals {
        factor = factor * 10.0
        i = i + 1
    }
    let shifted: Float = x * factor + 0.5
    let floored: Int = int(shifted)
    return float(floored) / factor
}

// ---------------------------------------------------------------------------
// Statistics helpers
// NOTE: List<Float> has a known LLVM codegen bug (bitcast i8* to double).
// These functions are correct but cannot be JIT-tested until the bug is fixed.
// They are included commented-out for reference and future enablement.
// ---------------------------------------------------------------------------

// fn sum(values: List<Float>) -> Float { ... }
// fn mean(values: List<Float>) -> Float { ... }
// fn median(values: List<Float>) -> Float { ... }
// fn min_val(values: List<Float>) -> Float { ... }
// fn max_val(values: List<Float>) -> Float { ... }
// fn variance(values: List<Float>, population: Bool) -> Float { ... }

// ---------------------------------------------------------------------------
// Duration helpers
// ---------------------------------------------------------------------------

fn ns_to_ms(ns: Int) -> Int { return ns / 1000000 }
fn ms_to_ns(ms: Int) -> Int { return ms * 1000000 }
fn ns_to_s(ns: Int) -> Int { return ns / 1000000000 }
fn s_to_ns(s: Int) -> Int { return s * 1000000000 }

// ---------------------------------------------------------------------------
// Approximate float comparison
// ---------------------------------------------------------------------------

fn approx_eq(a: Float, b: Float, eps: Float) -> Bool {
    let diff: Float = a - b
    if diff < 0.0 { return (0.0 - diff) < eps }
    return diff < eps
}

// ===========================================================================
// Tests
// ===========================================================================

@test
fn test_constants() {
    assert approx_eq(pi(), 3.14159265, 0.00001), "pi should be ~3.14159"
    assert approx_eq(e(), 2.71828182, 0.00001), "e should be ~2.71828"
    assert approx_eq(tau(), 6.28318530, 0.00001), "tau should be ~6.28318"
    assert approx_eq(tau(), pi() * 2.0, 0.0000001), "tau should be 2*pi"
}

@test
fn test_abs_int() {
    assert abs_int(5) == 5, "abs_int(5) == 5"
    assert abs_int(-5) == 5, "abs_int(-5) == 5"
    assert abs_int(0) == 0, "abs_int(0) == 0"
}

@test
fn test_abs_float() {
    assert approx_eq(mn_abs(3.14), 3.14, 0.001)
    assert approx_eq(mn_abs(-3.14), 3.14, 0.001)
    assert approx_eq(mn_abs(0.0), 0.0, 0.001)
}

@test
fn test_clamp() {
    assert approx_eq(clamp(5.0, 0.0, 10.0), 5.0, 0.001), "within range"
    assert approx_eq(clamp(-1.0, 0.0, 10.0), 0.0, 0.001), "below range"
    assert approx_eq(clamp(15.0, 0.0, 10.0), 10.0, 0.001), "above range"
    assert approx_eq(clamp(0.0, 0.0, 10.0), 0.0, 0.001), "at lower bound"
    assert approx_eq(clamp(10.0, 0.0, 10.0), 10.0, 0.001), "at upper bound"
}

@test
fn test_clamp_int() {
    assert clamp_int(5, 0, 10) == 5
    assert clamp_int(-1, 0, 10) == 0
    assert clamp_int(15, 0, 10) == 10
}

@test
fn test_lerp() {
    assert approx_eq(lerp(0.0, 10.0, 0.0), 0.0, 0.001), "t=0 returns a"
    assert approx_eq(lerp(0.0, 10.0, 1.0), 10.0, 0.001), "t=1 returns b"
    assert approx_eq(lerp(0.0, 10.0, 0.5), 5.0, 0.001), "t=0.5 returns midpoint"
    assert approx_eq(lerp(2.0, 8.0, 0.25), 3.5, 0.001), "lerp(2,8,0.25)=3.5"
}

@test
fn test_remap() {
    assert approx_eq(remap(5.0, 0.0, 10.0, 0.0, 100.0), 50.0, 0.001)
    assert approx_eq(remap(0.0, 0.0, 10.0, 0.0, 100.0), 0.0, 0.001)
    assert approx_eq(remap(10.0, 0.0, 10.0, 0.0, 100.0), 100.0, 0.001)
    assert approx_eq(remap(3.0, 0.0, 10.0, 100.0, 200.0), 130.0, 0.001)
}

@test
fn test_min_max_float() {
    assert approx_eq(min_float(3.0, 7.0), 3.0, 0.001)
    assert approx_eq(min_float(7.0, 3.0), 3.0, 0.001)
    assert approx_eq(max_float(3.0, 7.0), 7.0, 0.001)
    assert approx_eq(max_float(7.0, 3.0), 7.0, 0.001)
}

@test
fn test_min_max_int() {
    assert min_int(3, 7) == 3
    assert min_int(7, 3) == 3
    assert max_int(3, 7) == 7
    assert max_int(7, 3) == 7
}

@test
fn test_sign() {
    assert approx_eq(sign(5.0), 1.0, 0.001)
    assert approx_eq(sign(-3.0), -1.0, 0.001)
    assert approx_eq(sign(0.0), 0.0, 0.001)
}

@test
fn test_sign_int() {
    assert sign_int(42) == 1
    assert sign_int(-7) == -1
    assert sign_int(0) == 0
}

@test
fn test_degrees_radians() {
    assert approx_eq(degrees(pi()), 180.0, 0.001), "pi rad = 180 deg"
    assert approx_eq(radians(180.0), pi(), 0.001), "180 deg = pi rad"
    assert approx_eq(degrees(0.0), 0.0, 0.001)
    assert approx_eq(radians(0.0), 0.0, 0.001)
    assert approx_eq(radians(360.0), tau(), 0.001), "360 deg = tau rad"
}

@test
fn test_floor() {
    assert mn_floor(3.7) == 3
    assert mn_floor(3.0) == 3
    assert mn_floor(-1.5) == -2
    assert mn_floor(0.0) == 0
}

@test
fn test_ceil() {
    assert mn_ceil(3.2) == 4
    assert mn_ceil(3.0) == 3
    assert mn_ceil(-1.5) == -1
    assert mn_ceil(0.0) == 0
}

@test
fn test_round_to() {
    assert approx_eq(round_to(3.14159, 0), 3.0, 0.001)
    assert approx_eq(round_to(3.14159, 2), 3.14, 0.001)
    assert approx_eq(round_to(3.14159, 4), 3.1416, 0.00001)
    assert approx_eq(round_to(2.5, 0), 3.0, 0.001)
}

// Statistics tests disabled until List<Float> codegen is fixed:
// test_sum, test_sum_empty, test_mean, test_median_odd, test_median_even,
// test_min_max_val, test_variance

@test
fn test_duration_conversions() {
    assert ns_to_ms(1000000) == 1, "1M ns = 1 ms"
    assert ms_to_ns(1) == 1000000, "1 ms = 1M ns"
    assert ns_to_s(1000000000) == 1, "1B ns = 1 s"
    assert s_to_ns(1) == 1000000000, "1 s = 1B ns"
    assert ns_to_ms(5000000) == 5, "5M ns = 5 ms"
}
