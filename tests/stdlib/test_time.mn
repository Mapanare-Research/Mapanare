// test_time.mn — Tests for stdlib/time.mn
//
// Self-contained: structs and functions defined inline so the JIT test runner
// can compile and execute without cross-module imports.
//
// NOTE: Tests only cover pure logic (duration conversion, stopwatch state
// machine, formatting). Actual timing tests require the C runtime clock.

// ---------------------------------------------------------------------------
// Stopwatch struct (pure state machine — no extern needed for logic tests)
// ---------------------------------------------------------------------------

struct Stopwatch {
    start_ns: Int,
    elapsed_ns: Int,
    running: Bool
}

fn stopwatch_new() -> Stopwatch {
    let sw: Stopwatch = new Stopwatch { start_ns: 0, elapsed_ns: 0, running: false }
    return sw
}

fn stopwatch_start(sw: Stopwatch, now_ns: Int) -> Stopwatch {
    if sw.running { return sw }
    let result: Stopwatch = new Stopwatch { start_ns: now_ns, elapsed_ns: sw.elapsed_ns, running: true }
    return result
}

fn stopwatch_stop(sw: Stopwatch, now_ns: Int) -> Stopwatch {
    if !sw.running { return sw }
    let delta: Int = now_ns - sw.start_ns
    let total: Int = sw.elapsed_ns + delta
    let result: Stopwatch = new Stopwatch { start_ns: 0, elapsed_ns: total, running: false }
    return result
}

fn stopwatch_reset() -> Stopwatch {
    let sw: Stopwatch = new Stopwatch { start_ns: 0, elapsed_ns: 0, running: false }
    return sw
}

fn stopwatch_elapsed_ns(sw: Stopwatch, now_ns: Int) -> Int {
    if sw.running {
        return sw.elapsed_ns + (now_ns - sw.start_ns)
    }
    return sw.elapsed_ns
}

fn stopwatch_is_running(sw: Stopwatch) -> Bool {
    return sw.running
}

// ---------------------------------------------------------------------------
// Duration conversions (pure)
// ---------------------------------------------------------------------------

fn ns_to_ms(ns: Int) -> Int { return ns / 1000000 }
fn ms_to_ns(ms: Int) -> Int { return ms * 1000000 }
fn ns_to_s(ns: Int) -> Int { return ns / 1000000000 }
fn s_to_ns(s: Int) -> Int { return s * 1000000000 }
fn ms_to_s(ms: Int) -> Int { return ms / 1000 }
fn s_to_ms(s: Int) -> Int { return s * 1000 }

// ---------------------------------------------------------------------------
// Duration formatting (pure)
// ---------------------------------------------------------------------------

fn int_to_string(n: Int) -> String {
    if n == 0 { return "0" }
    let mut val: Int = n
    if val < 0 { val = 0 - val }
    let mut result: String = ""
    while val > 0 {
        let digit: Int = val % 10
        let ch: String = str(digit)
        result = ch + result
        val = val / 10
    }
    if n < 0 {
        result = "-" + result
    }
    return result
}

fn format_duration_ms(ms: Int) -> String {
    if ms < 1000 {
        return int_to_string(ms) + "ms"
    }
    if ms < 60000 {
        let secs: Int = ms / 1000
        let remainder: Int = ms % 1000
        if remainder == 0 {
            return int_to_string(secs) + "s"
        }
        let tenths: Int = remainder / 100
        return int_to_string(secs) + "." + int_to_string(tenths) + "s"
    }
    let minutes: Int = ms / 60000
    let sec_remainder: Int = (ms % 60000) / 1000
    return int_to_string(minutes) + "m " + int_to_string(sec_remainder) + "s"
}

// ===========================================================================
// Tests
// ===========================================================================

// --- Duration conversions ---

@test
fn test_ns_to_ms() {
    assert ns_to_ms(1000000) == 1
    assert ns_to_ms(5000000) == 5
    assert ns_to_ms(500000) == 0, "sub-millisecond rounds down"
    assert ns_to_ms(0) == 0
}

@test
fn test_ms_to_ns() {
    assert ms_to_ns(1) == 1000000
    assert ms_to_ns(5) == 5000000
    assert ms_to_ns(0) == 0
}

@test
fn test_ns_to_s() {
    assert ns_to_s(1000000000) == 1
    assert ns_to_s(5000000000) == 5
    assert ns_to_s(500000000) == 0
}

@test
fn test_s_to_ns() {
    assert s_to_ns(1) == 1000000000
    assert s_to_ns(3) == 3000000000
}

@test
fn test_ms_to_s() {
    assert ms_to_s(1000) == 1
    assert ms_to_s(5000) == 5
    assert ms_to_s(500) == 0
}

@test
fn test_s_to_ms() {
    assert s_to_ms(1) == 1000
    assert s_to_ms(60) == 60000
}

@test
fn test_conversion_roundtrip() {
    assert ns_to_ms(ms_to_ns(42)) == 42
    assert ns_to_s(s_to_ns(7)) == 7
    assert ms_to_s(s_to_ms(3)) == 3
}

// --- Duration formatting ---

@test
fn test_format_ms() {
    assert format_duration_ms(0) == "0ms"
    assert format_duration_ms(50) == "50ms"
    assert format_duration_ms(999) == "999ms"
}

@test
fn test_format_seconds() {
    assert format_duration_ms(1000) == "1s"
    assert format_duration_ms(5000) == "5s"
    assert format_duration_ms(1500) == "1.5s"
    assert format_duration_ms(2300) == "2.3s"
}

@test
fn test_format_minutes() {
    assert format_duration_ms(60000) == "1m 0s"
    assert format_duration_ms(90000) == "1m 30s"
    assert format_duration_ms(125000) == "2m 5s"
}

// --- Stopwatch state machine ---

@test
fn test_stopwatch_new() {
    let sw: Stopwatch = stopwatch_new()
    assert sw.start_ns == 0
    assert sw.elapsed_ns == 0
    assert sw.running == false
}

@test
fn test_stopwatch_start_stop() {
    let sw0: Stopwatch = stopwatch_new()
    // Start at t=1000
    let sw1: Stopwatch = stopwatch_start(sw0, 1000)
    assert sw1.running == true
    assert sw1.start_ns == 1000
    // Stop at t=5000 => elapsed = 4000
    let sw2: Stopwatch = stopwatch_stop(sw1, 5000)
    assert sw2.running == false
    assert sw2.elapsed_ns == 4000
}

@test
fn test_stopwatch_elapsed_while_running() {
    let sw0: Stopwatch = stopwatch_new()
    let sw1: Stopwatch = stopwatch_start(sw0, 1000)
    // Query elapsed at t=3000, still running
    let elapsed: Int = stopwatch_elapsed_ns(sw1, 3000)
    assert elapsed == 2000
}

@test
fn test_stopwatch_elapsed_stopped() {
    let sw0: Stopwatch = stopwatch_new()
    let sw1: Stopwatch = stopwatch_start(sw0, 1000)
    let sw2: Stopwatch = stopwatch_stop(sw1, 5000)
    // Elapsed should not change regardless of "now"
    let elapsed: Int = stopwatch_elapsed_ns(sw2, 99999)
    assert elapsed == 4000
}

@test
fn test_stopwatch_pause_resume() {
    let sw0: Stopwatch = stopwatch_new()
    // Run from t=0 to t=1000 (1000ns)
    let sw1: Stopwatch = stopwatch_start(sw0, 0)
    let sw2: Stopwatch = stopwatch_stop(sw1, 1000)
    assert sw2.elapsed_ns == 1000
    // Resume at t=5000, stop at t=7000 (2000ns more)
    let sw3: Stopwatch = stopwatch_start(sw2, 5000)
    let sw4: Stopwatch = stopwatch_stop(sw3, 7000)
    assert sw4.elapsed_ns == 3000, "accumulated 1000 + 2000 = 3000"
}

@test
fn test_stopwatch_reset() {
    let sw: Stopwatch = stopwatch_reset()
    assert sw.start_ns == 0
    assert sw.elapsed_ns == 0
    assert sw.running == false
}

@test
fn test_stopwatch_double_start() {
    let sw0: Stopwatch = stopwatch_new()
    let sw1: Stopwatch = stopwatch_start(sw0, 1000)
    // Starting again should be a no-op
    let sw2: Stopwatch = stopwatch_start(sw1, 9999)
    assert sw2.start_ns == 1000, "start_ns unchanged on double start"
    assert sw2.running == true
}

@test
fn test_stopwatch_double_stop() {
    let sw0: Stopwatch = stopwatch_new()
    let sw1: Stopwatch = stopwatch_start(sw0, 1000)
    let sw2: Stopwatch = stopwatch_stop(sw1, 5000)
    // Stopping again should be a no-op
    let sw3: Stopwatch = stopwatch_stop(sw2, 9999)
    assert sw3.elapsed_ns == 4000, "elapsed unchanged on double stop"
    assert sw3.running == false
}

@test
fn test_stopwatch_is_running() {
    let sw0: Stopwatch = stopwatch_new()
    assert stopwatch_is_running(sw0) == false
    let sw1: Stopwatch = stopwatch_start(sw0, 0)
    assert stopwatch_is_running(sw1) == true
    let sw2: Stopwatch = stopwatch_stop(sw1, 100)
    assert stopwatch_is_running(sw2) == false
}
